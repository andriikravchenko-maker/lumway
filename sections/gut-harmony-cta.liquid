{% style %}
  .section-{{ section.id }} {
    --ghc-font-heading: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghc-font-body: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghc-bg: {{ background_color }};
    --ghc-title-color: {{ title_color }};
    --ghc-text-color: {{ text_color }};
    --ghc-icon-color: {{ icon_color }};
    --ghc-button-bg: {{ button_bg }};
    --ghc-button-text: {{ button_text_color }};
    --ghc-button-hover-bg: {{ button_hover_bg }};
    --ghc-title-size: {{ section.settings.title_size }}px;
    --ghc-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --ghc-text-size: {{ section.settings.text_size }}px;
    --ghc-button-size: {{ section.settings.button_font_size }}px;
    --ghc-button-radius: {{ section.settings.button_radius }}px;
    --ghc-content-gap: {{ section.settings.content_gap }}px;
    --ghc-feature-gap: {{ section.settings.feature_gap }}px;
    --ghc-pad-top: {{ section.settings.padding_top }}px;
    --ghc-pad-bottom: {{ section.settings.padding_bottom }}px;
    --ghc-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ghc-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--ghc-bg);
    padding-top: var(--ghc-pad-top-mobile);
    padding-bottom: var(--ghc-pad-bottom-mobile);
  }

  .section-{{ section.id }} .gut-harmony-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ghc-content-gap);
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  /* theme forces [class*="title"] color !important; keep the design color. h2 keeps Oswald (not a span). */
  .section-{{ section.id }} .gut-harmony-cta__title {
    margin: 0;
    font-family: var(--ghc-font-heading);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    color: var(--ghc-title-color) !important;
    font-size: clamp(var(--ghc-title-size-mobile), 3.6vw, var(--ghc-title-size));
  }

  .section-{{ section.id }} .gut-harmony-cta__features {
    list-style: none;
    margin: 0;
    padding: 0;
    width: fit-content;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--ghc-feature-gap);
  }

  .section-{{ section.id }} .gut-harmony-cta__feature {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-{{ section.id }} .gut-harmony-cta__icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    color: var(--ghc-icon-color);
    line-height: 0;
  }

  .section-{{ section.id }} .gut-harmony-cta__icon-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* theme forces span { font-family: body !important }; keep League Spartan Medium per the design */
  .section-{{ section.id }} .gut-harmony-cta__feature-text {
    font-family: var(--ghc-font-body) !important;
    font-weight: 500 !important;
    font-size: var(--ghc-text-size);
    line-height: 1.4;
    color: var(--ghc-text-color);
  }

  .section-{{ section.id }} .gut-harmony-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    max-width: 100%;
    /* padding + font shrink on small screens; text wraps instead of spilling past the pill */
    padding: 12px clamp(24px, 6vw, 64px);
    font-family: var(--ghc-font-body) !important;
    font-weight: 500;
    font-size: clamp(16px, 4.6vw, var(--ghc-button-size));
    line-height: 1.4;
    text-align: center;
    text-transform: capitalize;
    text-decoration: none;
    color: var(--ghc-button-text);
    background-color: var(--ghc-button-bg);
    border: 0;
    border-radius: var(--ghc-button-radius);
    transition: background-color 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .gut-harmony-cta__button:hover {
    background-color: var(--ghc-button-hover-bg);
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .gut-harmony-cta__button:focus-visible {
    outline: 3px solid var(--ghc-button-bg);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .gut-harmony-cta__button {
      transition: none;
    }
    .section-{{ section.id }} .gut-harmony-cta__button:hover {
      transform: none;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: var(--ghc-pad-top);
      padding-bottom: var(--ghc-pad-bottom);
    }
  }
{% endstyle %}

<section class="gut-harmony-cta section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="gut-harmony-cta__inner">
    {%- if section.settings.title != blank -%}
      <h2 class="gut-harmony-cta__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="gut-harmony-cta__features">
        {%- for block in section.blocks -%}
          <li class="gut-harmony-cta__feature" {{ block.shopify_attributes }}>
            <span class="gut-harmony-cta__icon">{{ check_icon }}</span>
            <span class="gut-harmony-cta__feature-text">{{ block.settings.text }}</span>
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a class="gut-harmony-cta__button" href="{{ section.settings.button_url | default: '#' }}">
        {{- section.settings.button_text -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gut Harmony CTA",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false,
      "info": "Apply the global theme colors to this section instead of the ones below."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_gap",
