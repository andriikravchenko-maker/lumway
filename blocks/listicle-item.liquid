<div class="listicle-item listicle-item-{{ block.id }}{% if block.settings.enable_container %} has-container{% endif %} layout-{{ block.settings.desktop_layout }}" {{ block.shopify_attributes }}>
  <div class="listicle-item-inner">
    {%- if block.settings.image != blank -%}
      <div class="listicle-item-image">
        <img class="item-image" 
             src="{{ block.settings.image | image_url: width: 1000 }}" 
             alt="{{ block.settings.title | escape }}" 
             width="{{ block.settings.image.width }}" 
             height="{{ block.settings.image.height }}" 
             loading="lazy">
      </div>
    {%- endif -%}
    <div class="listicle-item-content">
      {%- if block.settings.title != blank -%}
        <h3 class="item-title">{{ block.settings.title }}</h3>
      {%- endif -%}
      {%- if block.settings.content != blank -%}
        {%- liquid
          assign content = block.settings.content
          if block.settings.highlight_text != blank
            capture highlight_span
              echo '<span class="text-highlight">'
              echo block.settings.highlight_text
              echo '</span>'
            endcapture
            assign content = content | replace: block.settings.highlight_text, highlight_span
          endif
        -%}
        <div class="item-content">{{ content }}</div>
      {%- endif -%}
      
      <div class="listicle-item-blocks">
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</div>

<style>
  .listicle-item-{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }
  .listicle-item-{{ block.id }}.has-container {
    padding: 20px;
    border: 1px solid #eee;
    border-radius: 8px;
  }
  .listicle-item-{{ block.id }} .listicle-item-image {
    width: 100%;
    margin-bottom: 20px;
  }
  .listicle-item-{{ block.id }} .item-image {
    display: block;
    width: 100%;
    max-width: 100%;
    border-radius: 4px;
    {% if block.settings.image_aspect_ratio == '1_1' %}
      height: 100%;
      object-fit: cover;
    {% else %}
      height: auto;
    {% endif %}
  }
  {% if block.settings.image_aspect_ratio == '1_1' %}
  .listicle-item-{{ block.id }} .listicle-item-image {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }
  {% endif %}

  @media (min-width: 769px) {
    .listicle-item-{{ block.id }} .listicle-item-inner {
      display: flex;
      align-items: {{ block.settings.desktop_vertical_alignment }};
      gap: 30px;
      {% if block.settings.desktop_layout == 'image_right' %}
        flex-direction: row-reverse;
      {% else %}
        flex-direction: row;
      {% endif %}
    }
    .listicle-item-{{ block.id }} .listicle-item-image {
      flex: 0 0 {{ block.settings.desktop_image_width }}%;
      margin-bottom: 0;
    }
    .listicle-item-{{ block.id }} .listicle-item-content {
      flex: 1;
    }
  }

  /* Highlighter Style */
  .listicle-item-{{ block.id }} .text-highlight {
    background: {{ block.settings.highlight_color }};
    padding: 0 4px;
    border-radius: 2px;
    display: inline;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }

  {% if block.settings.enable_highlight %}
    .listicle-item-{{ block.id }} .item-content strong {
      background: {{ block.settings.highlight_color }};
      padding: 0 4px;
      border-radius: 2px;
      display: inline;
      box-decoration-break: clone;
      -webkit-box-decoration-break: clone;
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "Listicle Item",
  "tag": "div",
  "class": "listicle-item-wrapper",
  "presets": [
    { "name": "Listicle Item" }
  ],
  "blocks": [
    { "type": "listicle-item-highlight" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "select",
      "id": "desktop_layout",
      "label": "Image Position (Desktop)",
      "options": [
        { "value": "image_left", "label": "Image Left" },
        { "value": "image_right", "label": "Image Right" },
        { "value": "stacked", "label": "Stacked" }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "desktop_vertical_alignment",
      "label": "Vertical Alignment (Desktop)",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "flex-start", "label": "Top" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "desktop_image_width",
      "min": 20,
      "max": 60,
      "step": 5,
      "unit": "%",
      "label": "Desktop Image Width",
      "default": 40
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural" },
        { "value": "1_1", "label": "Square (1:1)" }
      ],
      "default": "1_1"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Listicle Item Title"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Add your listicle content here.</p>"
    },
    {
      "type": "text",
      "id": "highlight_text",
      "label": "Text to Highlight",
      "info": "Any text entered here will be highlighted within the content."
    },
    {
      "type": "checkbox",
      "id": "enable_container",
      "label": "Enable Container",
      "default": false
    },
    {
      "type": "header",
      "content": "Highlighter"
    },
    {
      "type": "checkbox",
      "id": "enable_highlight",
      "label": "Highlight Bold Text",
      "default": false,
      "info": "Adds a highlighter background to ALL bold words within the content."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#fdf2f8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    }
  ]
}
{% endschema %}

