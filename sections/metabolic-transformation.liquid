{% style %}
  .section-{{ section.id }} {
    --mtr-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mtr-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mtr-bg: {{ section_bg }};
    --mtr-ink: {{ ink }};
    --mtr-accent: {{ accent }};
    --mtr-check: {{ section.settings.check_color }};
    --mtr-button-bg: {{ section.settings.button_background }};
    --mtr-button-text: {{ section.settings.button_text_color }};
    --mtr-heading-size: {{ section.settings.heading_size }}px;
    --mtr-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --mtr-body-size: {{ section.settings.body_size }}px;
    --mtr-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --mtr-image-radius: {{ section.settings.image_radius }}px;
    --mtr-col-gap: {{ section.settings.column_gap }}px;
    --mtr-gap: {{ section.settings.section_gap }}px;
    --mtr-pad-top: {{ section.settings.padding_top }}px;
    --mtr-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mtr-bg);
    padding-top: var(--mtr-pad-top);
    padding-bottom: var(--mtr-pad-bottom);
  }

  .section-{{ section.id }} .mtr__inner {
    max-width: 1640px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(24px, 3vw, var(--mtr-gap));
  }

  /* Heading — theme forces h2 font; lock to Oswald */
  .section-{{ section.id }} .mtr__heading {
    margin: 0;
    text-align: center;
    font-family: var(--mtr-fh) !important;
    font-weight: 500 !important;
    line-height: 1.2;
    color: var(--mtr-ink) !important;
    font-size: clamp(var(--mtr-heading-size-mobile), 3.4vw, var(--mtr-heading-size));
  }
  .section-{{ section.id }} .mtr__accent { font-family: inherit !important; color: var(--mtr-accent) !important; }

  /* 2-column content */
  .section-{{ section.id }} .mtr__content {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .section-{{ section.id }} .mtr__media { width: 100%; max-width: 788px; margin-inline: auto; }
  .section-{{ section.id }} .mtr__image { display: block; width: 100%; height: auto; border-radius: var(--mtr-image-radius); }
  .section-{{ section.id }} .mtr__image--placeholder { aspect-ratio: 788 / 560; background-color: #eef0f1; fill: #b9c3c9; object-fit: cover; }

  .section-{{ section.id }} .mtr__text { width: 100%; }
  .section-{{ section.id }} .mtr__lead {
    margin: 0;
    font-family: var(--mtr-fb) !important;
    font-weight: 600 !important;
    line-height: 1.35;
    color: var(--mtr-ink) !important;
    font-size: clamp(var(--mtr-body-size-mobile), 1.6vw, var(--mtr-body-size));
  }
  .section-{{ section.id }} .mtr__list {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .section-{{ section.id }} .mtr__item { display: flex; align-items: center; gap: 8px; }
  .section-{{ section.id }} .mtr__icon { flex-shrink: 0; width: 24px; height: 24px; line-height: 0; color: var(--mtr-check); }
  .section-{{ section.id }} .mtr__icon svg { display: block; width: 100%; height: 100%; }
  .section-{{ section.id }} .mtr__item-text {
    margin: 0;
    font-family: var(--mtr-fb) !important;
    font-weight: 400 !important;
    line-height: 1.35;
    color: var(--mtr-ink) !important;
    font-size: clamp(var(--mtr-body-size-mobile), 1.6vw, var(--mtr-body-size));
  }

  /* CTA */
  .section-{{ section.id }} .mtr__cta {
    display: flex;
    flex-direction: column;
    align-items: center; width: 100%;
    gap: 10px;
  }
  .section-{{ section.id }} .mtr__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--mtr-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--mtr-button-text) !important;
    background-color: var(--mtr-button-bg);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .mtr__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .mtr__button:focus-visible { outline: 3px solid var(--mtr-accent); outline-offset: 3px; }
  .section-{{ section.id }} .mtr__guarantee {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mtr-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(13px, 1.6vw, 16px);
    color: var(--mtr-ink) !important;
  }
  .section-{{ section.id }} .mtr__guarantee-icon { flex-shrink: 0; width: 16px; height: 16px; line-height: 0; color: var(--mtr-ink); }
  .section-{{ section.id }} .mtr__guarantee-icon svg { display: block; width: 100%; height: 100%; }

  @media (min-width: 900px) {
    .section-{{ section.id }} .mtr__content { flex-direction: row; align-items: center; gap: var(--mtr-col-gap); }
    .section-{{ section.id }} .mtr__media { flex: 1 1 0; min-width: 0; margin-inline: 0; }
    .section-{{ section.id }} .mtr__text { flex: 1 1 0; min-width: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .mtr__button { transition: none; }
  }
{% endstyle %}

<section class="mtr section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mtr__inner">

    {%- if section.settings.heading_before != blank or section.settings.heading_accent != blank -%}
      <h2 class="mtr__heading">
        {{- section.settings.heading_before -}}
        {%- if section.settings.heading_accent != blank %} <span class="mtr__accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      </h2>
    {%- endif -%}

    <div class="mtr__content">
      <div class="mtr__media">
        {%- if section.settings.image != blank -%}
          {%- assign img_alt = section.settings.image.alt | default: 'Metabolic Flow transformation' -%}
          {{
            section.settings.image
            | image_url: width: 788
            | image_tag:
              loading: 'lazy',
              widths: '400,600,788,1000',
              sizes: '(min-width: 900px) 50vw, 100vw',
              alt: img_alt,
              class: 'mtr__image'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'mtr__image mtr__image--placeholder' }}
        {%- endif -%}
      </div>

      <div class="mtr__text">
        {%- if section.settings.list_heading != blank -%}
          <p class="mtr__lead">{{ section.settings.list_heading }}</p>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="mtr__list">
            {%- for block in section.blocks -%}
              {%- if block.settings.text != blank -%}
                <li class="mtr__item" {{ block.shopify_attributes }}>
                  <span class="mtr__icon">{{ check_icon }}</span>
                  <span class="mtr__item-text">{{ block.settings.text }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="mtr__cta">
        <a class="mtr__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
        {%- if section.settings.guarantee_text != blank -%}
          <span class="mtr__guarantee"><span class="mtr__guarantee-icon">{{ check_icon }}</span>{{ section.settings.guarantee_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Metabolic Transformation",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before accent)",
      "default": "Say Goodbye To \"Meno Belly\" And Feel Like Yourself Again"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent text (colored)",
      "default": "with Metabolic Flow"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Transformation / before-after photo (~788 x 560)."
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Benefits list"
    },
    {
      "type": "text",
      "id": "list_heading",
      "label": "List heading",
      "default": "Women love Metabolic Flow because it helps them:"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Checkmark color",
      "default": "#202329"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "List text size",
      "min": 16,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "List text size (mobile)",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "CLAIM 20% OFF NOW 👉"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button color",
      "default": "#202329"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "60-Day Money-Back Guarantee"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "ink_color",
      "label": "Text color",
      "default": "#202329"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#5584c0"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Column gap (desktop)",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "section_gap",
      "label": "Gap between blocks",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Feel less controlled by cravings"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Metabolic Transformation",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Feel less controlled by cravings" } },
        { "type": "benefit", "settings": { "text": "Stop feeling frustrated by the scale" } },
        { "type": "benefit", "settings": { "text": "Support their metabolism after 45" } },
        { "type": "benefit", "settings": { "text": "Feel more energized throughout the day" } },
        { "type": "benefit", "settings": { "text": "Feel more confident in their favorite clothes again" } }
      ]
    }
  ]
}
{% endschema %}
