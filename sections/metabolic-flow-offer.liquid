{% comment %} Section: metabolic-flow-offer — offer card (header + image + checklist + price + CTA) and customer-results list {% endcomment %}

{%- liquid
  if section.settings.use_theme_colors
    assign section_bg = settings.global_section_background_color
    assign ink = settings.global_section_text_color
    assign blue = settings.global_section_accent_1_color
  else
    assign section_bg = section.settings.section_background
    assign ink = section.settings.ink_color
    assign blue = section.settings.accent_color
  endif

  assign image_alt = section.settings.image.alt | default: section.settings.promo_text | default: 'Special offer'
  assign features = section.blocks | where: 'type', 'offer_feature'
  assign results = section.blocks | where: 'type', 'result'
-%}

{%- capture offer_icon -%}
