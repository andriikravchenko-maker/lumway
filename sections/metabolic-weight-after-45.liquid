{% comment %} Section: metabolic-weight-after-45 — heading + composite infographic image + intro/notice-list/conclusion text block {% endcomment %}

{%- liquid
  if section.settings.use_theme_colors
    assign section_bg = settings.global_section_background_color
    assign ink = settings.global_section_text_color
    assign accent = settings.global_section_accent_1_color
  else
    assign section_bg = section.settings.section_background
    assign ink = section.settings.ink_color
    assign accent = section.settings.accent_color
  endif
-%}

{% style %}
  .section-{{ section.id }} {
    --mw-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mw-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mw-bg: {{ section_bg }};
    --mw-ink: {{ ink }};
    --mw-accent: {{ accent }};
    --mw-heading-size: {{ section.settings.heading_size }}px;
    --mw-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --mw-body-size: {{ section.settings.body_size }}px;
    --mw-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --mw-image-max: {{ section.settings.image_max_width }}px;
    --mw-image-radius: {{ section.settings.image_radius }}px;
    --mw-gap: {{ section.settings.section_gap }}px;
    --mw-pad-top: {{ section.settings.padding_top }}px;
    --mw-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mw-bg);
    padding-top: var(--mw-pad-top);
    padding-bottom: var(--mw-pad-bottom);
  }

  .section-{{ section.id }} .mw__inner {
    max-width: 1360px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(24px, 4vw, var(--mw-gap));
  }

  /* Title — theme forces h2 to its heading font; lock to Oswald */
  .section-{{ section.id }} .mw__title {
    margin: 0;
    font-family: var(--mw-fh) !important;
    font-weight: 500 !important;
    line-height: 1.2;
    color: var(--mw-ink) !important;
    text-align: center;
    font-size: clamp(var(--mw-heading-size-mobile), 3.4vw, var(--mw-heading-size));
  }
  .section-{{ section.id }} .mw__accent { font-family: inherit !important; color: var(--mw-accent) !important; }

  /* Composite infographic image */
  .section-{{ section.id }} .mw__media {
    width: 100%;
    max-width: var(--mw-image-max);
    margin-inline: auto;
  }
  .section-{{ section.id }} .mw__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--mw-image-radius);
  }
  .section-{{ section.id }} .mw__image--placeholder {
    aspect-ratio: 1290 / 673;
    background-color: #eef0f1;
    fill: #b9c3c9;
    object-fit: cover;
  }

  /* Text block */
  .section-{{ section.id }} .mw__text {
    width: 100%;
    max-width: 1127px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    font-family: var(--mw-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(var(--mw-body-size-mobile), 1.8vw, var(--mw-body-size));
    line-height: 1.35;
    color: var(--mw-ink) !important;
  }

  .section-{{ section.id }} .mw__intro,
  .section-{{ section.id }} .mw__conclusion { width: 100%; text-align: center; }
  .section-{{ section.id }} .mw__intro p,
  .section-{{ section.id }} .mw__conclusion p { margin: 0; }
  .section-{{ section.id }} .mw__intro p + p { margin-top: 0; }
  .section-{{ section.id }} .mw__intro strong { font-family: var(--mw-fb) !important; font-weight: 600 !important; }

  .section-{{ section.id }} .mw__notice { max-width: 720px; text-align: left; }
  .section-{{ section.id }} .mw__notice-lead { margin: 0 0 4px; }
  .section-{{ section.id }} .mw__notice-list { list-style: none; margin: 0; padding: 0; }
  .section-{{ section.id }} .mw__notice-list li {
    position: relative;
    padding-left: 1.3em;
    margin: 0;
  }
  .section-{{ section.id }} .mw__notice-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    top: 0;
  }
{% endstyle %}

<section class="mw section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mw__inner">

    {%- if section.settings.heading_before != blank or section.settings.heading_accent != blank or section.settings.heading_after != blank -%}
      <h2 class="mw__title">
        {{- section.settings.heading_before -}}
        {%- if section.settings.heading_accent != blank %} <span class="mw__accent">{{ section.settings.heading_accent }}</span>{% endif -%}
        {%- if section.settings.heading_after != blank %}<br>{{ section.settings.heading_after }}{% endif -%}
      </h2>
    {%- endif -%}

    <div class="mw__media">
      {%- if section.settings.image != blank -%}
        {%- assign img_alt = section.settings.image.alt | default: section.settings.heading_accent | default: 'Weight changes after 45' -%}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag:
            loading: 'lazy',
            widths: '600,800,1000,1290,1600',
            sizes: '(min-width: 1360px) 1290px, 100vw',
            alt: img_alt,
            class: 'mw__image'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'mw__image mw__image--placeholder' }}
      {%- endif -%}
    </div>

    {%- liquid
      assign has_notice = false
      if section.settings.list_lead != blank or section.blocks.size > 0
        assign has_notice = true
      endif
    -%}
    {%- if section.settings.intro_text != blank or has_notice or section.settings.conclusion_text != blank -%}
      <div class="mw__text">
        {%- if section.settings.intro_text != blank -%}
          <div class="mw__intro">{{ section.settings.intro_text }}</div>
        {%- endif -%}

        {%- if has_notice -%}
          <div class="mw__notice">
            {%- if section.settings.list_lead != blank -%}
              <p class="mw__notice-lead">{{ section.settings.list_lead }}</p>
            {%- endif -%}
            {%- if section.blocks.size > 0 -%}
              <ul class="mw__notice-list">
                {%- for block in section.blocks -%}
                  {%- if block.settings.text != blank -%}
                    <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.conclusion_text != blank -%}
          <div class="mw__conclusion">{{ section.settings.conclusion_text }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Metabolic Weight After 45",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_before",
      "label": "Heading (before accent)",
      "default": "The #1 Reason Women Struggle With"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Accent text (colored)",
      "default": "Stubborn Weight After 45"
    },
    {
      "type": "text",
      "id": "heading_after",
      "label": "Heading (second line)",
      "default": "Even When They're Eating Well And Staying Active"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 18,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "header",
      "content": "Infographic image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Export the full infographic (women + weight curve) as one image (~1290 x 673)."
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Image max width",
      "min": 800,
      "max": 1400,
      "step": 10,
      "unit": "px",
      "default": 1290
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Intro text"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro paragraph",
      "default": "<p>For many women, weight management starts feeling completely different after 45.</p><p>The same eating habits. The same workouts.</p><p>Yet the scale feels stuck, cravings become harder to ignore, and clothes start fitting differently.</p><p>It's frustrating—and incredibly common.</p><p><strong>One reason may be that metabolism naturally changes with age.</strong></p>"
    },
    {
      "type": "header",
      "content": "Notice list"
    },
    {
      "type": "text",
      "id": "list_lead",
      "label": "List lead-in",
      "default": "As these changes happen, many women notice:"
    },
    {
      "type": "header",
      "content": "Conclusion text"
    },
    {
      "type": "richtext",
      "id": "conclusion_text",
      "label": "Conclusion",
      "default": "<p>That's why more women are looking beyond restrictive diets and focusing on supporting their metabolism instead.*</p>"
    },
    {
      "type": "header",
      "content": "Body text"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body text size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body text size (mobile)",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "ink_color",
      "label": "Text color",
      "default": "#202329"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#ec3c6e"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "section_gap",
      "label": "Gap between blocks",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "list_item",
      "name": "List item",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Item text"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Metabolic Weight After 45",
      "blocks": [
        { "type": "list_item", "settings": { "text": "More frequent cravings, especially for sweets and carbohydrates" } },
        { "type": "list_item", "settings": { "text": "Lower energy throughout the day" } },
        { "type": "list_item", "settings": { "text": "Increased difficulty maintaining a healthy weight" } },
        { "type": "list_item", "settings": { "text": "Extra weight around the midsection that feels harder to manage" } }
      ]
    }
  ]
}
{% endschema %}
