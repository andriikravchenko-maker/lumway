<script>

  function addToCartSticky() {
    const variantInput = document.getElementById("sticky-variant-id");
    const cartDrawer = document.querySelector("cart-drawer");
    
    if (variantInput && cartDrawer) {
      const variantId = variantInput.value;
      if (variantId) {
        cartDrawer.addItemToCart(variantId);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    const selects = document.querySelectorAll('.sticky-variant-select');
    const hiddenInput = document.getElementById('sticky-variant-id');
    const variants = {{ product.variants | json }};

    function updateStickyVariant() {
      const selectedOptions = Array.from(selects).map(select => select.value);
      const matchedVariant = variants.find(variant =>
        variant.options.every((opt, idx) => opt === selectedOptions[idx])
      );
      if (matchedVariant) {
        hiddenInput.value = matchedVariant.id;
      }
    }
    selects.forEach(select => {
      select.addEventListener('change', updateStickyVariant);
    });
    
   
      
      


      

      
  });

  document.addEventListener('DOMContentLoaded', function() {
    // Format delivery dates with proper localization
    const deliveryDateElements = document.querySelectorAll('.delivery-date[data-timestamp]');
    
    deliveryDateElements.forEach(function(element) {
      try {
        const timestamp = parseInt(element.dataset.timestamp, 10) * 1000; // Convert Liquid seconds to JS milliseconds
        const locale = element.dataset.locale || 'en';
        const format = element.dataset.format || 'weekday_month_day';
        const jsDate = new Date(timestamp);
        
        // Define formatting options based on the selected format
        let options = {};
        switch (format) {
          case 'weekday_month_day':
            options = { weekday: 'long', month: 'long', day: 'numeric' };
            break;
          case 'month_day_weekday':
            options = { month: 'long', day: 'numeric', weekday: 'long' };
            break;
          case 'month_day':
            options = { month: 'long', day: 'numeric' };
            break;
          case 'day_month':
            options = { day: 'numeric', month: 'long' };
            break;
          default:
            options = { weekday: 'long', month: 'long', day: 'numeric' };
        }
        
        const formatter = new Intl.DateTimeFormat(locale, options);
        let formattedDate = formatter.format(jsDate);
        
        // For specific formats, adjust the order
        if (format === 'month_day_weekday') {
          // Convert "Monday, January 5" to "January 5, Monday"
          const parts = formatter.formatToParts(jsDate);
          const weekday = parts.find(part => part.type === 'weekday')?.value;
          const month = parts.find(part => part.type === 'month')?.value;
          const day = parts.find(part => part.type === 'day')?.value;
          if (weekday && month && day) {
            formattedDate = `${month} ${day}, ${weekday}`;
          }
        }
        
        element.textContent = formattedDate;
        
      } catch (error) {
        console.error('Error formatting delivery date:', error);
        // Fallback to simple format if error occurs
        const timestamp = parseInt(element.dataset.timestamp, 10) * 1000;
        const jsDate = new Date(timestamp);
        element.textContent = jsDate.toLocaleDateString();
      }
    });
  });
</script>

{% if request.design_mode %}
  <div id="sticky-section-helper-data" data-show-helper="{{ section.settings.show_section_numbers }}" style="display:none;"></div>

  <script>
    (function() {
      var badges = [];

      function shouldShowHelper() {
        var dataEl = document.getElementById('sticky-section-helper-data');
        return dataEl && dataEl.getAttribute('data-show-helper') === 'true';
      }

      function createHelper() {
        if (badges.length > 0) return;
        document.querySelectorAll('.shopify-section').forEach(function(section, index) {
          section.style.position = 'relative';
          var badge = document.createElement('div');
          badge.textContent = 'Section ' + (index + 1);
          badge.className = 'sticky-section-number-badge';
          badge.style.cssText = 'position:absolute;top:10px;left:10px;background:#000000;color:#ffffff;padding:8px 14px;font-size:14px;border-radius:4px;box-shadow:0 2px 6px rgba(0,0,0,0.3);z-index:999999;pointer-events:none;';
          badge.style.setProperty('font-weight', '700', 'important');
          section.appendChild(badge);
          badges.push({ section: section, badge: badge });
        });
      }

      function removeHelper() {
        badges.forEach(function(item) {
          if (item.badge && item.badge.parentNode) item.badge.remove();
        });
        badges = [];
      }

      function init() {
        if (shouldShowHelper()) createHelper();
        else removeHelper();
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();

      document.addEventListener('shopify:section:load', init);
      document.addEventListener('shopify:section:reorder', init);
      document.addEventListener('shopify:block:select', init);
      document.addEventListener('shopify:block:deselect', init);
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Sticky Add to Cart",
  "tag": "section",
  "class": "sticky-add-to-cart",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays a sticky bar at the bottom of the page. Can add to cart, scroll to a section, scroll to a page percentage, or link to a URL. Works on both product and non-product pages."
    },
    {
      "type": "header",
      "content": "Trigger Behavior"
    },
    {
      "type": "select",
      "id": "trigger_behavior",
      "label": "Sticky Bar Trigger",
      "options": [
        { "value": "atc_button", "label": "Show after scrolling past ATC button" },
        { "value": "always_except_atc", "label": "Always show (hide only when ATC is visible)" },
        { "value": "scroll_percentage", "label": "Show after scroll percentage reached" }
      ],
      "default": "atc_button"
    },
    {
      "type": "range",
      "id": "scroll_percentage_trigger",
      "min": 5,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Scroll Percentage to Trigger",
      "default": 25,
      "visible_if": "{{ section.settings.trigger_behavior == 'scroll_percentage' }}"
    },
    {
      "type": "header",
      "content": "Button Behavior"
    },
    {
      "type": "select",
      "id": "select_button_behavior",
      "label": "Select button behavior",
      "options": [
        { "value": "atc", "label": "Add to cart" },
        { "value": "scroll_to_section", "label": "Scroll to section" },
        { "value": "scroll_to_percentage", "label": "Scroll to page percentage" },
        { "value": "link", "label": "Go to link" }
      ],
      "default": "atc"
    },
    {
      "type": "number",
      "id": "scroll_to_section_number",
      "label": "Scroll to Section Number",
      "info": "Enter a section number (e.g., 5 for the 5th section). Use the helper below to find section numbers.",
      "visible_if": "{{ section.settings.select_button_behavior == 'scroll_to_section' }}"
    },
    {
      "type": "checkbox",
      "id": "show_section_numbers",
      "label": "Show Section Number Helper",
      "default": false,
      "info": "Shows numbered labels on each section. Find your target section's number, enter it above, then turn this off.",
      "visible_if": "{{ section.settings.select_button_behavior == 'scroll_to_section' }}"
    },
    {
      "type": "range",
      "id": "scroll_offset",
      "min": -100,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Scroll Offset (Fine Tuning)",
      "default": 0,
      "info": "Add extra spacing above the target section. Header height is handled automatically.",
      "visible_if": "{{ section.settings.select_button_behavior == 'scroll_to_section' }}"
    },
    {
      "type": "range",
      "id": "scroll_to_percentage",
      "min": 5,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Scroll to Page Percentage",
      "default": 50,
      "info": "Scroll to this percentage of the page (e.g., 50% = halfway).",
      "visible_if": "{{ section.settings.select_button_behavior == 'scroll_to_percentage' }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "info": "Enter the URL the button should go to.",
      "visible_if": "{{ section.settings.select_button_behavior == 'link' }}"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback Product Image",
      "info": "Used when this section is placed on a non-product page."
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "Fallback Product Title",
      "info": "Used when this section is placed on a non-product page."
