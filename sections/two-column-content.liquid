<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('two-column-{{ section.id }}');
    if (!section) return;

    const accordions = section.querySelectorAll('.block-accordion');
    
    accordions.forEach(function(accordion) {
      const isSingleMode = accordion.dataset.accordionMode === 'true';
      const headers = accordion.querySelectorAll('.accordion-header');
      
      headers.forEach(function(header) {
        header.addEventListener('click', function() {
          const item = this.closest('.accordion-item');
          const isOpen = item.classList.contains('is-open');
          
          // If single mode, close all other items first
          if (isSingleMode && !isOpen) {
            accordion.querySelectorAll('.accordion-item.is-open').forEach(function(openItem) {
              openItem.classList.remove('is-open');
            });
          }
          
          // Toggle the clicked item
          item.classList.toggle('is-open');
        });
      });
    });
  });
</script>

