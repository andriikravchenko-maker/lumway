        "padding_bottom": 80,
        "padding_top_mobile": 40,
        "padding_bottom_mobile": 40,
        "title_gap": 40,
        "column_gap": 24,
        "content_gap": 24,
        "background_color": "#ffffff",
        "title": "The Hidden Shift Most Women Don’t See Coming",
        "title_size": 40,
