{% comment %}
  Block: LTS Guarantee - Guarantee/fine print text for Limited Time Sale
{% endcomment %}

<p class="lts-guarantee lts-guarantee-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.icon != blank %}
    <span class="lts-guarantee-icon-{{ block.id }}">{{ block.settings.icon }}</span>
  {% endif %}
  {{ block.settings.text }}
</p>

<style>
  .lts-guarantee-{{ block.id }} {
    font-size: {{ block.settings.font_size }}px !important;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.text_align }};
    max-width: {{ block.settings.max_width }}ch;
    margin: 0 auto {{ block.settings.margin_bottom }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    font-weight: {{ block.settings.font_weight }} !important;
    line-height: {{ block.settings.line_height }};
  }

  .lts-guarantee-icon-{{ block.id }} {
    margin-right: 6px;
  }

  @media (max-width: 768px) {
    .lts-guarantee-{{ block.id }} {
      font-size: {{ block.settings.font_size_mobile }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "LTS Guarantee",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "label": "Icon (Emoji)",
      "info": "Optional icon before text"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Guarantee Text",
      "default": "90-Day Money-Back Guarantee"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 13
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" }
      ],
      "default": "400"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line Height",
      "default": 1.4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 30,
      "max": 80,
      "step": 2,
      "unit": "ch",
      "label": "Max Width",
      "default": 46
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    }
  ],
  "presets": [
    { "name": "LTS Guarantee" }
  ]
}
{% endschema %}

