{% comment %} Section: gut-harmony-cta-banner — centered header + CTA button + subheader {% endcomment %}

{%- unless settings.enable_oswald_font -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}
{%- unless settings.enable_league_spartan_font -%}
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}

{%- liquid
  if section.settings.use_theme_colors
    assign background_color = settings.global_section_background_color
    assign header_color = settings.global_section_heading_color | default: settings.global_section_text_color
    assign subheader_color = settings.global_section_text_color
    assign button_bg = settings.global_button_bg_color | default: settings.global_section_accent_1_color
    assign button_text_color = settings.global_button_text_color | default: '#ffffff'
    assign button_hover_bg = settings.global_button_hover_bg_color | default: settings.global_section_accent_1_color
  else
    assign background_color = section.settings.background_color
    assign header_color = section.settings.header_color
    assign subheader_color = section.settings.subheader_color
    assign button_bg = section.settings.button_bg
    assign button_text_color = section.settings.button_text_color
    assign button_hover_bg = section.settings.button_hover_bg
  endif
-%}

{% style %}
  .section-{{ section.id }} {
    --ghb-font-heading: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghb-font-body: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghb-bg: {{ background_color }};
    --ghb-header-color: {{ header_color }};
    --ghb-subheader-color: {{ subheader_color }};
    --ghb-button-bg: {{ button_bg }};
    --ghb-button-text: {{ button_text_color }};
    --ghb-button-hover-bg: {{ button_hover_bg }};
    --ghb-header-size: {{ section.settings.header_size }}px;
    --ghb-header-size-mobile: {{ section.settings.header_size_mobile }}px;
    --ghb-subheader-size: {{ section.settings.subheader_size }}px;
    --ghb-subheader-size-mobile: {{ section.settings.subheader_size_mobile }}px;
    --ghb-button-size: {{ section.settings.button_font_size }}px;
    --ghb-button-radius: {{ section.settings.button_radius }}px;
    --ghb-content-gap: {{ section.settings.content_gap }}px;
    --ghb-pad-top: {{ section.settings.padding_top }}px;
    --ghb-pad-bottom: {{ section.settings.padding_bottom }}px;
    --ghb-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ghb-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--ghb-bg);
    padding-top: var(--ghb-pad-top-mobile);
    padding-bottom: var(--ghb-pad-bottom-mobile);
  }

  .section-{{ section.id }} .gut-harmony-cta-banner__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--ghb-content-gap);
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    text-align: center;
  }

  /* theme forces h1-h6 color !important; keep the design color. h2 keeps Oswald (not a span). */
  .section-{{ section.id }} .gut-harmony-cta-banner__header {
    margin: 0;
    font-family: var(--ghb-font-heading);
    font-weight: 700;
    line-height: 1.2;
    color: var(--ghb-header-color) !important;
    font-size: clamp(var(--ghb-header-size-mobile), 3.6vw, var(--ghb-header-size));
  }

  .section-{{ section.id }} .gut-harmony-cta-banner__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    max-width: 100%;
    /* padding + font shrink on small screens; text wraps instead of spilling past the pill */
    padding: 12px clamp(24px, 6vw, 64px);
    font-family: var(--ghb-font-body) !important;
    font-weight: 700;
    font-size: clamp(16px, 4.6vw, var(--ghb-button-size));
    line-height: 1.4;
    text-align: center;
    text-transform: capitalize;
    text-decoration: none;
    color: var(--ghb-button-text);
    background-color: var(--ghb-button-bg);
    border: 0;
    border-radius: var(--ghb-button-radius);
    transition: background-color 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .gut-harmony-cta-banner__button:hover {
    background-color: var(--ghb-button-hover-bg);
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .gut-harmony-cta-banner__button:focus-visible {
    outline: 3px solid var(--ghb-button-bg);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .gut-harmony-cta-banner__button {
      transition: none;
    }
    .section-{{ section.id }} .gut-harmony-cta-banner__button:hover {
      transform: none;
    }
  }

  /* theme forces p { font-family: body !important }; keep League Spartan. regular weight (400) matches the theme. */
  .section-{{ section.id }} .gut-harmony-cta-banner__subheader {
    margin: 0;
    max-width: 1032px;
    font-family: var(--ghb-font-body) !important;
    font-weight: 400;
    line-height: 1.2;
    color: var(--ghb-subheader-color);
    font-size: clamp(var(--ghb-subheader-size-mobile), 2.6vw, var(--ghb-subheader-size));
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} {
      padding-top: var(--ghb-pad-top);
      padding-bottom: var(--ghb-pad-bottom);
    }
  }
{% endstyle %}

<section class="gut-harmony-cta-banner section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="gut-harmony-cta-banner__inner">
    {%- if section.settings.header != blank -%}
      <h2 class="gut-harmony-cta-banner__header">{{ section.settings.header }}</h2>
    {%- endif -%}

    {%- if section.settings.subheader != blank -%}
      <p class="gut-harmony-cta-banner__subheader">{{ section.settings.subheader }}</p>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a class="gut-harmony-cta-banner__button" href="{{ section.settings.button_url | default: '#' }}">
        {{- section.settings.button_text -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gut Harmony CTA Banner",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false,
      "info": "Apply the global theme colors to this section instead of the ones below."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between elements",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#f2f9f2"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "header",
      "label": "Header",
      "default": "Click Below to Begin Your Transformation"
    },
    {
      "type": "range",
      "id": "header_size",
      "label": "Header size",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "header_size_mobile",
      "label": "Header size (mobile)",
      "min": 16,
      "max": 44,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "color",
      "id": "header_color",
      "label": "Header color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "GET GUT HARMONY NOW →"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button color",
      "default": "#23a02a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_bg",
      "label": "Button color (hover)",
      "default": "#1d8a23"
    },
    {
      "type": "header",
      "content": "Subheader"
    },
    {
      "type": "text",
      "id": "subheader",
      "label": "Subheader",
      "default": "Your future self will thank you for finally taking control of your digestion today."
    },
    {
      "type": "range",
      "id": "subheader_size",
      "label": "Subheader size",
      "min": 12,
      "max": 44,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "subheader_size_mobile",
      "label": "Subheader size (mobile)",
      "min": 10,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheader_color",
      "label": "Subheader color",
      "default": "#333333"
    }
  ],
  "presets": [
    {
      "name": "Gut Harmony CTA Banner",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
