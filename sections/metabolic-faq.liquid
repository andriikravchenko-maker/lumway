{% comment %} Section: metabolic-faq — heading + 2-column accordion FAQ + CTA {% endcomment %}

{%- liquid
  if section.settings.use_theme_colors
    assign section_bg = settings.global_section_background_color
    assign ink = settings.global_section_text_color
    assign accent = settings.global_section_accent_1_color
  else
    assign section_bg = section.settings.section_background
    assign ink = section.settings.ink_color
    assign accent = section.settings.accent_color
  endif
  assign half = section.blocks.size | plus: 1 | divided_by: 2
-%}

