      gap: 6px;
    }


    .quantity-bundle-selector.layout-grid-2x2 .quantity-bundle-title {
      font-size: calc(var(--title-font-size) * 0.8);
    }

    .quantity-bundle-selector.layout-grid-2x2 .quantity-bundle-description {
      font-size: calc(var(--description-font-size) * 0.85);
    }

    .quantity-bundle-selector.layout-grid-2x2 .quantity-bundle-grid-per-item {
      font-size: calc(var(--description-font-size) * 0.85);
    }

    .quantity-bundle-content {
      padding: 6px;
    }

    .quantity-bundle-content.no-image-layout {
      display: flex !important;
      flex-direction: column !important;
      align-items: center;
      padding: {{ block.settings.no_image_content_padding | default: 12 | times: 0.8 }}px;
      gap: calc(var(--no-image-content-gap, {{ block.settings.no_image_content_gap | default: 12 }}px) * 0.4) !important;
      row-gap: calc(var(--no-image-content-gap, {{ block.settings.no_image_content_gap | default: 12 }}px) * 0.4) !important;
      overflow: hidden;
    }
  }

  /* Force per-item price font-weight to use parameter value - must be last to override all other rules */
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price *,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price span,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price .price-amount,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price .price-amount *,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price span.price-amount,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price .price-suffix,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price .price-suffix *,
  .quantity-bundle-selector .quantity-bundle-per-item-below .quantity-per-item-price span.price-suffix {
    font-weight: {{ block.settings.per_item_price_weight | default: '500' }} !important;
  }
</style>

<script>
  (function () {
    function resolveAmplitudeTrack() {
      var amp = window.amplitude;
      if (amp && typeof amp.track === 'function') return amp.track.bind(amp);
      if (amp && amp.default && typeof amp.default.track === 'function') return amp.default.track.bind(amp.default);
      if (amp && typeof amp.getInstance === 'function') {
        try {
          var inst = amp.getInstance();
          if (inst && typeof inst.logEvent === 'function') {
            return function (n, p) {
              inst.logEvent(n, p);
            };
          }
        } catch (e) {}
      }
      return null;
    }

    function trackAmplitudeEvent(eventName, eventProperties) {
      var track = resolveAmplitudeTrack();
      if (track) {
        try {
          track(eventName, eventProperties);
        } catch (e) {}
      }
    }

    function trackAmplitudeEventWhenReady(eventName, eventProperties) {
      var attempts = 0;
      var maxAttempts = 200;
      (function poll() {
        var track = resolveAmplitudeTrack();
        if (track) {
          try {
            track(eventName, eventProperties);
          } catch (e) {}
          return;
        }
        if (++attempts < maxAttempts) setTimeout(poll, 100);
      })();
    }

    document.addEventListener('alpine:init', () => {
      Alpine.data('quantityBundleComponent', () => ({
      moneyFormat: "{{ shop.money_format | escape }}",
      variants: {{ product.variants | json }},
      selectedVariantId: '{{ current_variant.id }}',
      cards: [],
      quantityInput: null,
      productForm: null,
      enableCustomPricing: false,
      originalPrices: {}, // Store original prices for subscription discount calculation
      init() {
        if (typeof Elixir_ProductFormExists !== 'function' || !Elixir_ProductFormExists()) return;
        this.enableCustomPricing = this.$root.dataset.customPrice === 'true';
        
        this.cards = [...this.$root.querySelectorAll('.quantity-bundle-card')].map(card => {
          const price = Number(card.dataset.price) || 0;
          return {
            el: card,
            quantity: Number(card.dataset.quantity) || 1,
            price: price,
            compare: Number(card.dataset.comparePrice) || 0,
            usesVariantPrice: card.dataset.usesVariantPrice === 'true',
            usesVariantCompare: card.dataset.usesVariantCompare === 'true',
            originalPrice: price // Store original price for subscription calculations
          };
        });

        // Store original prices
        this.cards.forEach(card => {
          this.originalPrices[card.quantity] = card.originalPrice;
        });

        this.productForm = (typeof Elixir_GetProductForm === 'function' && Elixir_GetProductForm()) || document.querySelector('.shop-add-to-cart-wrapper form[action="/cart/add"]');
        this.quantityInput = this.productForm ? this.productForm.querySelector('input[name="quantity"]') : null;
        if (!this.quantityInput) this.quantityInput = document.querySelector('input[name="quantity"]');

        this.refreshQuantityBundleDisplay();

        const initiallySelectedCard = this.cards.find(card => {
          const isSelected = card.el.getAttribute('data-selected') === 'true';
          const radio = card.el.querySelector('.quantity-bundle-radio');
          const isRadioChecked = radio && radio.checked;
          return isSelected || isRadioChecked;
        });
        if (initiallySelectedCard) {
          this.updateQuantityInput(initiallySelectedCard.quantity);
        }

        var cardForInitialAnalytics = initiallySelectedCard || this.cards[0];
        if (cardForInitialAnalytics) {
          this.emitBundleSelectedFromCard(cardForInitialAnalytics, true);
        }

        this.bindCardClicks();
        this.bindSellingPlanListeners();
        this.watchVariantChanges();
        this.bindExternalVariantEvents();
        this.bindSubscriptionContextListener();
      },
      getVariantInput() {
        return document.querySelector('.shop-add-to-cart-wrapper input[name="id"], .shop-add-to-cart-wrapper input[name="product-id"]');
      },
      updateSelectedVariantFromInput() {
        if (typeof Elixir_GetProductFormVariantId === 'function') {
          const id = Elixir_GetProductFormVariantId();
          if (id != null) this.selectedVariantId = String(id);
          return;
        }
        const variantInput = this.getVariantInput();
        if (variantInput?.value) this.selectedVariantId = variantInput.value;
      },
      getCurrentVariant() {
        return this.variants.find(v => v.id.toString() === this.selectedVariantId?.toString()) || null;
      },
      getSubscriptionPrice(basePrice) {
        const sealElement = document.querySelector('.sealsubs-target-element');
        if (!sealElement) {
          return basePrice;
        }

        try {
          const sealData = JSON.parse(sealElement.getAttribute('data-product') || '{}');
          const adjustment = sealData?.selling_plan_groups?.[0]?.selling_plans?.[0]?.price_adjustments?.[0];
          if (!adjustment) {
            return basePrice;
          }

          const { value_type: type, value } = adjustment;
          const numericValue = parseFloat(value);
          let finalPrice = basePrice;

          switch (type) {
            case 'percentage':
              finalPrice = basePrice * (1 - numericValue / 100);
              break;
            case 'fixed_amount':
              finalPrice = basePrice - numericValue;
              break;
            default:
              return basePrice;
          }

          return parseFloat(finalPrice.toFixed(2));
        } catch (error) {
          console.error('[Seal] Failed to parse Seal data:', error);
          return basePrice;
        }
      },
      /**
       * Single source for bundle card prices: uses Elixir_GetDisplayPrice so prices
       * respect subscription and stay in sync with variant/quantity. Always multiplies by quantity.
       */
      refreshQuantityBundleDisplay() {
        if (typeof Elixir_GetDisplayPrice !== 'function' || typeof Elixir_FormatMoney !== 'function') return;
        this.updateSelectedVariantFromInput();
        const variant = this.getCurrentVariant();
        const basePrice = variant && (typeof variant.price === 'number' || typeof variant.price === 'string') ? Number(variant.price) : null;
        const baseCompare = variant && (variant.compare_at_price != null) ? Number(variant.compare_at_price) || 0 : 0;

        this.cards.forEach(card => {
          let priceCents = Number(card.el.dataset.price) || 0;
          let compareCents = Number(card.el.dataset.comparePrice) || 0;
          if (card.usesVariantPrice && basePrice != null) {
            priceCents = basePrice * card.quantity;
            compareCents = baseCompare * card.quantity;
          }
          const perUnitPrice = card.quantity > 0 ? Math.round(priceCents / card.quantity) : priceCents;
          const perUnitCompare = card.quantity > 0 ? Math.round(compareCents / card.quantity) : compareCents;
          const result = Elixir_GetDisplayPrice({
            price: perUnitPrice,
            compareAtPrice: perUnitCompare,
            quantity: card.quantity,
            multiplyByQuantity: true,
            applySubscriptionDiscount: true
          });
          card.price = result.price;
          card.compare = result.compareAtPrice;
          card.el.dataset.price = result.price;
          const radio = card.el.querySelector('.quantity-bundle-radio');
          if (radio) radio.dataset.price = result.price;
          this.updateCardDisplay(card);
        });

        this.updateCheckoutPricingForSelected();
      },
      updateCardDisplay(card) {
        const formattedPrice = typeof Elixir_FormatMoney === 'function' ? Elixir_FormatMoney(card.price, this.moneyFormat) : String(card.price / 100);
        const currentPriceEls = card.el.querySelectorAll('.quantity-current-price');
        currentPriceEls.forEach(el => {
          el.textContent = formattedPrice;
        });

        const comparePriceEls = card.el.querySelectorAll('.quantity-original-price');
        comparePriceEls.forEach(comparePriceEl => {
          if (card.compare > 0 && this.$root.dataset.hideCompare !== 'true') {
            comparePriceEl.textContent = Elixir_FormatMoney(card.compare, this.moneyFormat);
            comparePriceEl.style.display = '';
          } else {
            comparePriceEl.style.display = 'none';
          }
        });

        const perItemPrice = card.quantity > 0 ? card.price / card.quantity : card.price;
        const perItemFormatted = Elixir_FormatMoney(perItemPrice, this.moneyFormat);
        const perItemAmountEls = card.el.querySelectorAll('.quantity-per-item-price .price-amount, .quantity-bundle-per-item .price-amount, .quantity-bundle-grid-per-item .price-amount');
        perItemAmountEls.forEach(el => {
          el.textContent = perItemFormatted;
        });
      },
      emitBundleSelectedFromCard(card, waitForAmplitude) {
        if (!card || !card.el) return;
        var pid = card.el.dataset.productId;
        var payload = {
          product_id: pid != null && pid !== '' ? String(pid) : undefined,
          bundle_type: (card.el.dataset.bundleType || '').trim() || String(card.quantity),
          bundle_price: typeof card.price === 'number' ? card.price : Number(card.price) || 0,
          page_title: typeof document !== 'undefined' && document.title ? document.title : '',
        };
        if (waitForAmplitude) {
          trackAmplitudeEventWhenReady('bundle_selected', payload);
        } else {
          trackAmplitudeEvent('bundle_selected', payload);
        }
      },
      bindCardClicks() {
        this.cards.forEach(card => {
          card.el.addEventListener('click', () => {
            console.log('[Quantity Bundle] Card clicked, quantity:', card.quantity);
            this.cards.forEach(c => {
              c.el.setAttribute('data-selected', 'false');
              c.el.querySelector('.quantity-bundle-radio')?.classList.remove('checked');
              const radio = c.el.querySelector('.quantity-bundle-radio');
              if (radio) radio.checked = false;
            });

            card.el.setAttribute('data-selected', 'true');
            const radio = card.el.querySelector('.quantity-bundle-radio');
            if (radio) radio.checked = true;

            this.updateQuantityInput(card.quantity);
            this.updateCheckoutPricing(card);

            this.emitBundleSelectedFromCard(card, false);
          });
        });
      },
      updateQuantityInput(quantity) {
        if (!this.quantityInput && this.productForm) {
          this.quantityInput = document.createElement('input');
          this.quantityInput.type = 'hidden';
          this.quantityInput.name = 'quantity';
          this.productForm.appendChild(this.quantityInput);
          console.log('[Quantity Bundle] Created quantity input in form');
        }

        if (this.quantityInput) {
          this.quantityInput.value = quantity;
          this.quantityInput.dispatchEvent(new Event('change', { bubbles: true }));
          document.dispatchEvent(new CustomEvent('quantity:changed', { bubbles: true, detail: { quantity: quantity } }));
          console.log('[Quantity Bundle] Set quantity to', quantity, ', dispatched quantity:changed. Input in form?', this.productForm && this.productForm.contains(this.quantityInput));
        } else {
          console.warn('[Quantity Bundle] No quantity input available, cannot set quantity', quantity);
        }
      },
      updateCheckoutPricing(card) {
        const formattedPrice = typeof Elixir_FormatMoney === 'function' ? Elixir_FormatMoney(card.price, this.moneyFormat) : (card.price / 100).toFixed(2);
        const formattedCompare = card.compare > card.price && typeof Elixir_FormatMoney === 'function' ? Elixir_FormatMoney(card.compare, this.moneyFormat) : '';
        this.updateBuyNowButtonText(card.price, formattedCompare);
      },
      updateBuyNowButtonText(priceCents, formattedCompare = '') {
        const buyNowTextButton = document.querySelector('.shop-add-to-cart-wrapper .shop-add-to-cart-button .button-text');
        if (!buyNowTextButton) return;
        const formatted = typeof Elixir_FormatMoney === 'function' ? Elixir_FormatMoney(priceCents, this.moneyFormat) : (priceCents / 100).toFixed(2);
        const baseText = `Buy Now - ${formatted}`;
        if (formattedCompare) {
          buyNowTextButton.innerHTML = `${baseText} <span class="compare-price">(${formattedCompare})</span>`;
        } else {
          buyNowTextButton.textContent = baseText;
        }
      },
      bindSellingPlanListeners() {
        const bindClick = container => {
          container.addEventListener('click', () => {
            const selectedCard = this.cards.find(c => c.el.getAttribute('data-selected') === 'true');
            if (selectedCard) {
              this.updateBuyNowButtonText(selectedCard.price);
            }
          });
        };

        document.querySelectorAll('.sls-option-container').forEach(bindClick);

        const observer = new MutationObserver(mutationsList => {
          for (const mutation of mutationsList) {
            mutation.addedNodes.forEach(node => {
              if (!(node instanceof HTMLElement)) return;
              if (node.matches && node.matches('.sls-option-container')) {
                bindClick(node);
              } else {
                node.querySelectorAll?.('.sls-option-container').forEach(bindClick);
              }
            });
          }
        });

        observer.observe(document.body, { childList: true, subtree: true });
      },
      watchVariantChanges() {
        const variantInput = this.getVariantInput();
        if (!variantInput) return;
        const handleVariantChange = () => {
          this.updateSelectedVariantFromInput();
          this.refreshQuantityBundleDisplay();
        };
        variantInput.addEventListener('change', handleVariantChange);
        new MutationObserver(handleVariantChange).observe(variantInput, { attributes: true, attributeFilter: ['value'] });
      },
      bindExternalVariantEvents() {
        if (this.externalVariantHandler) {
          document.removeEventListener('simple-variant-picker:variantChange', this.externalVariantHandler);
          document.removeEventListener('quantity:changed', this.externalVariantHandler);
          document.removeEventListener('quantity_break:changed', this.externalVariantHandler);
        }
        this.externalVariantHandler = () => {
          this.refreshQuantityBundleDisplay();
        };
        document.addEventListener('simple-variant-picker:variantChange', this.externalVariantHandler);
        document.addEventListener('quantity:changed', this.externalVariantHandler);
        document.addEventListener('quantity_break:changed', this.externalVariantHandler);
      },
      updateCheckoutPricingForSelected() {
        const selected = this.cards.find(card => card.el.getAttribute('data-selected') === 'true');
        if (selected) {
          this.updateCheckoutPricing(selected);
        }
      },
      bindSubscriptionContextListener() {
        document.addEventListener('subscriptionContext:updated', () => {
          this.refreshQuantityBundleDisplay();
        });
        setTimeout(() => this.refreshQuantityBundleDisplay(), 100);
      }
    }));
    });
  })();
</script>