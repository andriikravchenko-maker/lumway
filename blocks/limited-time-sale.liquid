    {
      "type": "color",
      "id": "chip_bg_color",
      "label": "Chip Background",
      "default": "#25282A"
    },
    {
      "type": "color",
      "id": "chip_text_color",
      "label": "Chip Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "chip_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Chip Font Size",
      "default": 14
    },
    {
      "type": "range",
      "id": "chip_font_size_mobile",
      "min": 8,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Chip Font Size (Mobile)",
      "default": 12
    },
    {
      "type": "select",
      "id": "chip_font_weight",
      "label": "Chip Font Weight",
      "options": [
