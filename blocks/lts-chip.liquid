{% comment %}
  Block: LTS Chip - Top banner chip for Limited Time Sale
{% endcomment %}

<div class="lts-chip lts-chip-{{ block.id }}" {{ block.shopify_attributes }}>
  {{ block.settings.text }}
</div>

<style>
  .lts-chip-{{ block.id }} {
    position: absolute;
    left: 50%;
    transform: translate(-50%, -50%);
    top: 0;
    background: {{ block.settings.bg_color }};
    color: {{ block.settings.text_color }};
    font-weight: {{ block.settings.font_weight }} !important;
    font-size: {{ block.settings.font_size }}px;
    padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    border-radius: {{ block.settings.border_radius }}px;
    white-space: nowrap;
    text-align: center;
  }

  @media (max-width: 768px) {
    .lts-chip-{{ block.id }} {
      font-size: {{ block.settings.font_size_mobile }}px;
      padding: {{ block.settings.padding_y_mobile }}px {{ block.settings.padding_x_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "LTS Chip",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Chip Text",
      "default": "FREE $40 PREMIUM SERUM WITH YOUR ORDER"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#25282A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Padding Vertical (Desktop)",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Horizontal (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_y_mobile",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Padding Vertical (Mobile)",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Padding Horizontal (Mobile)",
      "default": 14
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Border Radius",
      "default": 14
    }
  ],
  "presets": [
    { "name": "LTS Chip" }
  ]
}
{% endschema %}

