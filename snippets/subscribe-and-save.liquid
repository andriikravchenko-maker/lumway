    .subscribe-save-wrapper-dynamic .subscribe-save-container:has(.subscribe-toggle-dynamic:checked) .gift-price-lock {
      transform: translateX(100%);
      opacity: 0;
      transition-delay: calc(var(--gift-index) * 0.15s);
    }
    .subscribe-save-wrapper-dynamic .subscribe-save-container:has(input:checked) .gift-price,
    .subscribe-save-wrapper-dynamic .subscribe-save-container:has(.subscribe-toggle-dynamic:checked) .gift-price {
