{% comment %}
  Block: CS Amazon Reviews
  Parent container for Amazon-styled reviews in Content Sidebar section.
  Renders at full width below the main content/sidebar grid.
{% endcomment %}

{%- assign this = block.settings -%}

<style>
  #cs-amazon-reviews-{{ block.id }} {
    grid-column: 1 / -1;
    padding-top: {{ this.padding_top }}px;
    padding-bottom: {{ this.padding_bottom }}px;
    background-color: {{ this.background_color }};
    letter-spacing: var(--cs-body-letter-spacing, 0);
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-reviews-container {
    max-width: {{ this.max_width }}px;
    margin: 0 auto;
    padding: 0 {{ this.horizontal_padding }}px;
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-reviews-header {
    text-align: {{ this.header_alignment }};
    margin-bottom: {{ this.header_spacing }}px;
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-reviews-heading {
    font-size: {{ this.heading_size }}px;
    color: {{ this.heading_color }};
    font-weight: {{ this.heading_weight }};
    margin-bottom: {{ this.heading_margin }}px;
    letter-spacing: var(--cs-heading-letter-spacing, -0.3px);
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-reviews-subheading {
    font-size: {{ this.subheading_size }}px;
    color: {{ this.subheading_color }};
    font-weight: {{ this.subheading_weight }};
    margin-top: 0;
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-review-item {
    background-color: {{ this.review_background }};
    border: {{ this.review_border_width }}px solid {{ this.review_border_color }};
    border-radius: {{ this.review_border_radius }}px;
    padding: {{ this.review_padding }}px;
    margin-bottom: {{ this.review_spacing }}px;
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-review-item:last-child {
    margin-bottom: 0;
  }

  #cs-amazon-reviews-{{ block.id }} .review-header {
    display: flex;
    align-items: center;
    margin-bottom: 6px;
  }

  #cs-amazon-reviews-{{ block.id }} .reviewer-avatar {
    width: {{ this.avatar_size }}px;
    height: {{ this.avatar_size }}px;
    border-radius: 50%;
    margin-right: 12px;
    object-fit: cover;
  }

  #cs-amazon-reviews-{{ block.id }} .reviewer-avatar-placeholder {
    background-color: {{ this.avatar_placeholder_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #cs-amazon-reviews-{{ block.id }} .reviewer-avatar-placeholder span {
    font-size: {{ this.avatar_size | divided_by: 2 }}px;
    color: {{ this.avatar_placeholder_text }};
    font-weight: 600;
  }

  #cs-amazon-reviews-{{ block.id }} .reviewer-info {
    flex: 1;
  }

  #cs-amazon-reviews-{{ block.id }} .reviewer-name {
    font-size: {{ this.name_size }}px;
    color: {{ this.name_color }};
    font-weight: 700 !important;
    display: inline;
  }

  #cs-amazon-reviews-{{ block.id }} .review-title {
    font-size: {{ this.title_size }}px;
    color: {{ this.title_color }};
    font-weight: {{ this.title_weight }};
    margin: 0;
  }

  #cs-amazon-reviews-{{ block.id }} .review-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 0;
    flex-wrap: wrap;
  }

  #cs-amazon-reviews-{{ block.id }} .review-stars {
    display: flex;
    gap: -2px;
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-review-star {
    width: {{ this.star_size }}px;
    height: {{ this.star_size }}px;
    color: {{ this.star_color }};
  }

  #cs-amazon-reviews-{{ block.id }} .amazon-review-star.empty {
    color: {{ this.star_empty_color }};
  }

  #cs-amazon-reviews-{{ block.id }} .verified-badge {
    background-color: {{ this.badge_background }};
    padding: {{ this.badge_padding }};
    border-radius: {{ this.badge_radius }}px;
    font-size: {{ this.badge_size }}px;
    font-weight: {{ this.badge_weight }};
    color: {{ this.badge_color }} !important;
  }

  #cs-amazon-reviews-{{ block.id }} .verified-badge p {
    margin: 0 !important;
    padding: 0 !important;
    display: inline !important;
  }

  #cs-amazon-reviews-{{ block.id }} .review-date {
    color: {{ this.date_color }};
    font-size: {{ this.date_size }}px;
    display: inline;
  }

  #cs-amazon-reviews-{{ block.id }} .review-content {
    font-size: {{ this.content_size }}px;
    color: {{ this.content_color }};
    line-height: {{ this.content_line_height }};
    margin-bottom: {{ this.content_margin }}px;
    margin-top: 10px;
  }

  #cs-amazon-reviews-{{ block.id }} .review-images {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  #cs-amazon-reviews-{{ block.id }} .review-image {
    width: auto;
    height: {{ this.review_image_height }}px;
    object-fit: cover;
    border-radius: {{ this.image_border_radius }}px;
    cursor: pointer;
    transition: transform 0.2s;
  }

  #cs-amazon-reviews-{{ block.id }} .review-image.aspect-ratio-square {
    aspect-ratio: 1/1;
    width: {{ this.review_image_height }}px;
    height: {{ this.review_image_height }}px;
  }

  #cs-amazon-reviews-{{ block.id }} .review-image.aspect-ratio-portrait {
    aspect-ratio: 9/16;
    width: auto;
    height: {{ this.review_image_height }}px;
  }

  #cs-amazon-reviews-{{ block.id }} .review-image:hover {
    transform: scale(1.05);
  }

  #cs-amazon-reviews-{{ block.id }} .review-helpful {
    color: {{ this.helpful_color }};
    font-size: {{ this.helpful_size }}px;
    margin-top: 10px;
    font-weight: 700 !important;
  }

  #cs-amazon-reviews-{{ block.id }} .review-actions {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #cs-amazon-reviews-{{ block.id }} .helpful-button,
  #cs-amazon-reviews-{{ block.id }} .report-button {
    background: none;
    border: none;
    color: {{ this.helpful_button_color }};
    font-size: {{ this.action_button_size }}px;
    cursor: pointer;
    padding: 4px 0;
    text-decoration: underline;
    transition: color 0.2s ease;
  }

  #cs-amazon-reviews-{{ block.id }} .helpful-button:hover {
    color: {{ this.helpful_button_hover_color }};
  }

  #cs-amazon-reviews-{{ block.id }} .action-divider {
    color: {{ this.helpful_button_color }};
    font-size: {{ this.action_button_size }}px;
  }

  @media (max-width: 768px) {
    #cs-amazon-reviews-{{ block.id }} .amazon-reviews-container {
      padding: 0 20px;
    }

    #cs-amazon-reviews-{{ block.id }} .amazon-reviews-heading {
      font-size: calc({{ this.heading_size }}px * 0.55);
      line-height: 1;
    }

    #cs-amazon-reviews-{{ block.id }} .amazon-reviews-subheading {
      font-size: calc({{ this.subheading_size }}px * 0.85);
      line-height: 1.3;
    }
  }
</style>

<div id="cs-amazon-reviews-{{ block.id }}" class="cs-amazon-reviews-wrapper" {{ block.shopify_attributes }}>
  <div class="amazon-reviews-container">
    {% if this.heading != blank or this.subheading != blank %}
      <div class="amazon-reviews-header">
        {% if this.heading != blank %}
          <h2 class="amazon-reviews-heading">{{ this.heading }}</h2>
        {% endif %}
        {% if this.subheading != blank %}
          <p class="amazon-reviews-subheading">{{ this.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="amazon-reviews-list">
      {%- if block.blocks.size == 0 -%}
        <div style="padding: 30px; text-align: center; background: #f9f9f9; border: 2px dashed #ddd; border-radius: 8px;">
          <p style="font-size: 14px; color: #666; margin: 0 0 8px 0;">No reviews yet</p>
          <p style="font-size: 12px; color: #999; margin: 0;">Click "Add block" to add review comments</p>
        </div>
      {%- endif -%}
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

