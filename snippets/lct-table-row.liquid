{% comment %}
  Snippet: LCT table row
  Params: feature, brand_display, brand_text, competitor_display, competitor_text, is_last
{% endcomment %}

{%- liquid
  assign row_brand_display = brand_display | default: 'check'
  assign row_competitor_display = competitor_display | default: 'text'
-%}

<div class="lct__row">
  <div class="lct__cell lct__cell--label">
    <span class="lct__label">{{ feature }}</span>
  </div>

  <div class="lct__cell lct__cell--brand">
    {% if row_brand_display == 'check' %}
      <span class="lct__icon lct__icon--check" aria-label="Yes">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="10" cy="10" r="10" fill="currentColor"/>
          <path d="M6 10.5L8.5 13L14 7.5" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    {% else %}
      <span class="lct__value">{{ brand_text }}</span>
    {% endif %}
  </div>

  <div class="lct__cell lct__cell--competitor">
    {% case row_competitor_display %}
      {% when 'check' %}
        <span class="lct__icon lct__icon--mark" aria-label="Yes">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3.5 8.5L6.5 11.5L12.5 4.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      {% when 'cross' %}
        <span class="lct__icon lct__icon--cross" aria-label="No">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M4.5 4.5L11.5 11.5M11.5 4.5L4.5 11.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </span>
      {% else %}
        <span class="lct__value lct__value--muted">{{ competitor_text }}</span>
    {% endcase %}
  </div>
</div>
