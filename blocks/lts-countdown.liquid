{% comment %}
  Block: LTS Countdown - Countdown timer for Limited Time Sale
{% endcomment %}

<div 
  class="lts-countdown lts-countdown-{{ block.id }}" 
  {{ block.shopify_attributes }}
  data-mode="{{ block.settings.countdown_mode }}"
  data-hours="{{ block.settings.duration_hours }}"
  data-minutes="{{ block.settings.duration_minutes }}"
  data-seconds="{{ block.settings.duration_seconds }}"
  data-deadline="{{ block.settings.deadline | escape }}"
>
  {% if block.settings.label != blank %}
    <span class="lts-countdown-label-{{ block.id }}">{{ block.settings.label }}</span>
  {% endif %}
  <span class="lts-countdown-time-{{ block.id }}" id="lts-countdown-time-{{ block.id }}">00:00:00</span>
</div>

<style>
  .lts-countdown-{{ block.id }} {
    text-align: {{ block.settings.text_align }};
    font-weight: {{ block.settings.font_weight }} !important;
    font-size: {{ block.settings.font_size }}px !important;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .lts-countdown-label-{{ block.id }} {
    color: {{ block.settings.label_color }};
    margin-right: {{ block.settings.label_gap }}px;
  }

  .lts-countdown-time-{{ block.id }} {
    color: {{ block.settings.time_color }};
    font-weight: {{ block.settings.time_font_weight }} !important;
  }

  @media (max-width: 768px) {
    .lts-countdown-{{ block.id }} {
      font-size: {{ block.settings.font_size_mobile }}px !important;
    }
  }
</style>

<script>
  (function() {
    var container = document.querySelector('.lts-countdown-{{ block.id }}');
    if (!container) return;
    
    var mode = container.getAttribute('data-mode');
    var timeEl = document.getElementById('lts-countdown-time-{{ block.id }}');
    
    function pad(n) {
      return String(n).padStart(2, '0');
    }
    
    var end;
    if (mode === 'deadline') {
      var deadline = container.getAttribute('data-deadline');
      var t = Date.parse(deadline);
      if (!isNaN(t)) end = t;
      else end = Date.now() + (2 * 60 * 60 + 33 * 60 + 53) * 1000;
    } else {
      var H = parseInt(container.getAttribute('data-hours') || '2', 10);
      var M = parseInt(container.getAttribute('data-minutes') || '33', 10);
      var S = parseInt(container.getAttribute('data-seconds') || '53', 10);
      end = Date.now() + ((H * 60 + M) * 60 + S) * 1000;
    }
    
    function tick() {
      var diff = Math.max(0, end - Date.now());
      var total = Math.floor(diff / 1000);
      var h = Math.floor(total / 3600);
      var m = Math.floor((total % 3600) / 60);
      var s = total % 60;
      timeEl.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
      if (diff <= 0) return;
      else
        window.requestAnimationFrame(function() {
          setTimeout(tick, 1000);
        });
    }
    tick();
  })();
</script>

{% schema %}
{
  "name": "LTS Countdown",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Countdown Label",
      "default": "DEAL ENDING IN:"
    },
    {
      "type": "header",
      "content": "Countdown Mode"
    },
    {
      "type": "select",
      "id": "countdown_mode",
      "label": "Mode",
      "options": [
        { "value": "duration", "label": "Duration (Hours/Minutes/Seconds)" },
        { "value": "deadline", "label": "Specific Date & Time" }
      ],
      "default": "duration"
    },
    {
      "type": "range",
      "id": "duration_hours",
      "min": 0,
      "max": 48,
      "step": 1,
      "label": "Duration Hours",
      "default": 2
    },
    {
      "type": "range",
      "id": "duration_minutes",
      "min": 0,
      "max": 59,
      "step": 1,
      "label": "Duration Minutes",
      "default": 33
    },
    {
      "type": "range",
      "id": "duration_seconds",
      "min": 0,
      "max": 59,
      "step": 1,
      "label": "Duration Seconds",
      "default": 53
    },
    {
      "type": "text",
      "id": "deadline",
      "label": "Deadline (ISO Format)",
      "default": "2025-12-31T23:59:59Z",
      "info": "Format: YYYY-MM-DDTHH:MM:SSZ"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "time_font_weight",
      "label": "Time Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "time_color",
      "label": "Time Color",
      "default": "#D22F2F"
    },
    {
      "type": "range",
      "id": "label_gap",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Gap Between Label and Time",
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 16
    }
  ],
  "presets": [
    { "name": "LTS Countdown" }
  ]
}
{% endschema %}

