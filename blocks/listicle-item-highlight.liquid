{% comment %}
  Block: Listicle Item Highlight
  A text block with a background for highlighting key points inside a listicle item.
{% endcomment %}

<div class="listicle-item-highlight listicle-item-highlight-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="highlight-content">
    {{ block.settings.text }}
  </div>
</div>

<style>
  .listicle-item-highlight-{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border-left: {{ block.settings.border_left_width }}px solid {{ block.settings.border_left_color }};
  }

  .listicle-item-highlight-{{ block.id }} .highlight-content {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    line-height: 1.4;
    letter-spacing: 0px !important;
  }

  .listicle-item-highlight-{{ block.id }} .highlight-content * {
    margin: 0;
    letter-spacing: 0px !important;
  }
</style>

{% schema %}
{
  "name": "Item Highlight Text",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "Highlight Text",
      "default": "<p>Highlight key features or benefits here.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdf2f8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "range",
      "id": "border_left_width",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "label": "Left Border Width",
      "default": 0
    },
    {
      "type": "color",
      "id": "border_left_color",
      "label": "Left Border Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Border Radius",
      "default": 4
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font Size",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Vertical Padding",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Horizontal Padding",
      "default": 16
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 12
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 12
    }
  ],
  "presets": [
    { "name": "Item Highlight Text" }
  ]
}
{% endschema %}


