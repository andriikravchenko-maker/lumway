{% style %}
  .section-{{ section.id }} {
    --mfo-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mfo-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mfo-section-bg: {{ section_bg }};
    --mfo-ink: {{ ink }};
    --mfo-blue: {{ blue }};
    --mfo-white: {{ section.settings.header_text_color }};
    --mfo-card-bg: {{ section.settings.card_background }};
    --mfo-original: {{ section.settings.original_price_color }};
    --mfo-divider: {{ section.settings.feature_divider_color }};
    --mfo-rule: {{ section.settings.results_divider_color }};
    --mfo-offer-icon: {{ section.settings.offer_icon_color }};
    --mfo-result-icon: {{ section.settings.result_icon_color }};
    --mfo-radius: {{ section.settings.card_radius }}px;
    --mfo-pad-top: {{ section.settings.padding_top }}px;
    --mfo-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mfo-section-bg);
    padding-top: var(--mfo-pad-top);
    padding-bottom: var(--mfo-pad-bottom);
  }

  .section-{{ section.id }} .mfo__inner {
    max-width: 996px;
    margin-inline: auto;
    padding-inline: 16px;
    box-sizing: border-box;
  }

  /* ---- Offer card ---- */
  .section-{{ section.id }} .mfo__card {
    max-width: 792px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
  }

  .section-{{ section.id }} .mfo__header {
    background-color: var(--mfo-ink);
    border-radius: var(--mfo-radius) var(--mfo-radius) 0 0;
    padding: 32px 16px;
    text-align: center;
  }

  .section-{{ section.id }} .mfo__promo {
    margin: 0;
    font-family: var(--mfo-fh) !important;
    font-weight: 500 !important;
    line-height: 1.25;
    color: var(--mfo-white) !important;
    font-size: clamp(22px, 4vw, 32px);
  }

  .section-{{ section.id }} .mfo__body {
    background-color: var(--mfo-card-bg);
    border: 2px solid var(--mfo-blue);
    border-top: 0;
    border-radius: 0 0 var(--mfo-radius) var(--mfo-radius);
    padding: clamp(20px, 4vw, 32px);
    display: flex;
    flex-direction: column;
    gap: 26px;
    align-items: center;
  }

  .section-{{ section.id }} .mfo__media {
    width: 100%;
    max-width: 500px;
  }

  .section-{{ section.id }} .mfo__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .section-{{ section.id }} .mfo__image--placeholder {
    background-color: #eef0f1;
    fill: #b9c3c9;
  }

  .section-{{ section.id }} .mfo__features {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }

  .section-{{ section.id }} .mfo__feature {
    display: flex;
    align-items: center;
    gap: 8px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--mfo-divider);
  }

  .section-{{ section.id }} .mfo__feature-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    line-height: 0;
    color: var(--mfo-offer-icon);
  }

  .section-{{ section.id }} .mfo__feature-text {
    font-family: var(--mfo-fb) !important;
    font-weight: 600 !important;
    line-height: 1.33;
    color: var(--mfo-ink) !important;
    font-size: clamp(16px, 2.6vw, 24px);
  }

  .section-{{ section.id }} .mfo__feature-accent { color: var(--mfo-blue) !important; }

  .section-{{ section.id }} .mfo__price {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .section-{{ section.id }} .mfo__price-original {
    font-family: var(--mfo-fh) !important;
    font-weight: 500 !important;
    color: var(--mfo-original) !important;
    opacity: 0.7;
    text-decoration: line-through;
    font-size: clamp(18px, 3vw, 26px);
  }

  .section-{{ section.id }} .mfo__price-sale {
    font-family: var(--mfo-fh) !important;
    font-weight: 500 !important;
    color: var(--mfo-blue) !important;
    font-size: clamp(28px, 5vw, 40px);
  }

  .section-{{ section.id }} .mfo__cta {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .section-{{ section.id }} .mfo__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--mfo-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--mfo-white) !important;
    background-color: var(--mfo-ink);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .section-{{ section.id }} .mfo__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .mfo__button:focus-visible { outline: 3px solid var(--mfo-blue); outline-offset: 3px; }

  .section-{{ section.id }} button.mfo__button {
    appearance: none;
    -webkit-appearance: none;
    cursor: pointer;
  }

  .section-{{ section.id }} .mfo__button.is-loading {
    opacity: 0.6;
    pointer-events: none;
  }

  .section-{{ section.id }} .mfo__button[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  .section-{{ section.id }} .mfo__cart-error {
    margin: 0;
    font-family: var(--mfo-fb) !important;
    font-weight: 400 !important;
    font-size: 14px;
    color: #c0392b !important;
    text-align: center;
  }

  .section-{{ section.id }} .mfo__delivery {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }

  .section-{{ section.id }} .mfo__delivery span {
    font-family: var(--mfo-fb) !important;
    font-weight: 400 !important;
    color: var(--mfo-ink) !important;
    font-size: clamp(14px, 2vw, 18px);
  }

  /* ---- Results ---- */
  .section-{{ section.id }} .mfo__divider {
    border: 0;
    border-top: 1px solid var(--mfo-rule);
    margin: 40px 0;
    width: 100%;
  }

  .section-{{ section.id }} .mfo__results {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .section-{{ section.id }} .mfo__results-title {
    margin: 0;
    font-family: var(--mfo-fh) !important;
    font-weight: 500 !important;
    line-height: 1.25;
    color: var(--mfo-ink) !important;
    text-align: center;
    font-size: clamp(24px, 4vw, 32px);
  }

  .section-{{ section.id }} .mfo__results-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
  }

  .section-{{ section.id }} .mfo__result {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    max-width: 100%;
  }

  .section-{{ section.id }} .mfo__result-icon {
    flex-shrink: 0;
    width: 22px;
    margin-top: 3px;
    line-height: 0;
    color: var(--mfo-result-icon);
  }

  .section-{{ section.id }} .mfo__result-text,
  .section-{{ section.id }} .mfo__result-text * {
    font-family: var(--mfo-fb) !important;
    color: var(--mfo-ink) !important;
  }

  .section-{{ section.id }} .mfo__result-text {
    font-weight: 400 !important;
    line-height: 1.5;
    font-size: clamp(15px, 2vw, 20px);
  }

  .section-{{ section.id }} .mfo__result-text strong { font-weight: 600 !important; }

  .section-{{ section.id }} .mfo__icon-svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .section-{{ section.id }} .mfo__result-icon .mfo__icon-svg { height: auto; }
{% endstyle %}

<section class="mfo section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mfo__inner">
    <div class="mfo__card">
      {%- if section.settings.promo_text != blank -%}
        <div class="mfo__header">
          <p class="mfo__promo">{{ section.settings.promo_text }}</p>
        </div>
      {%- endif -%}

      <div class="mfo__body">
        <div class="mfo__media">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                widths: '320,500,750,1000',
                sizes: '(min-width: 824px) 500px, 90vw',
                alt: image_alt,
                class: 'mfo__image'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'mfo__image mfo__image--placeholder' }}
          {%- endif -%}
        </div>

        {%- if features.size > 0 -%}
          <ul class="mfo__features">
            {%- for block in features -%}
              <li class="mfo__feature" {{ block.shopify_attributes }}>
                <span class="mfo__feature-icon">{{ offer_icon }}</span>
                <span class="mfo__feature-text">
                  {%- if block.settings.accent != blank -%}<span class="mfo__feature-accent">{{ block.settings.accent }}</span> {% endif -%}
                  {{- block.settings.text -}}
                </span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.original_price != blank or section.settings.sale_price != blank -%}
          <div class="mfo__price">
            {%- if section.settings.original_price != blank -%}
              <span class="mfo__price-original">{{ section.settings.original_price }}</span>
            {%- endif -%}
            {%- if section.settings.sale_price != blank -%}
              <span class="mfo__price-sale">{{ section.settings.sale_price }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          {%- liquid
            assign buy_product = section.settings.product
            assign buy_variant = buy_product.selected_or_first_available_variant
          -%}
          <div class="mfo__cta">
            {%- if buy_variant != blank -%}
              <button
                type="button"
                class="mfo__button mfo__button--atc"
                data-variant-id="{{ buy_variant.id }}"
                data-quantity="{{ section.settings.quantity | default: 1 }}"
                data-behavior="{{ section.settings.cart_behavior }}"
                data-adding-text="{{ section.settings.button_adding_text | escape }}"
                data-error-text="{{ section.settings.button_error_text | escape }}"
                {% unless buy_variant.available %}disabled{% endunless %}
              >
                <span class="mfo__button-label">{{ section.settings.button_text }}</span>
              </button>
              <p class="mfo__cart-error" role="alert" hidden></p>
            {%- else -%}
              <a class="mfo__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
            {%- endif -%}
            {%- if section.settings.delivery_left != blank or section.settings.delivery_right != blank -%}
              <div class="mfo__delivery">
                {%- if section.settings.delivery_left != blank -%}<span>{{ section.settings.delivery_left }}</span>{% endif -%}
                {%- if section.settings.delivery_right != blank -%}<span>{{ section.settings.delivery_right }}</span>{% endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_results -%}
      <hr class="mfo__divider">
      <div class="mfo__results">
        {%- if section.settings.results_title != blank -%}
          <h2 class="mfo__results-title">{{ section.settings.results_title }}</h2>
        {%- endif -%}
        {%- if results.size > 0 -%}
          <ul class="mfo__results-list">
            {%- for block in results -%}
              <li class="mfo__result" {{ block.shopify_attributes }}>
                <span class="mfo__result-icon">{{ result_icon }}</span>
                <span class="mfo__result-text">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function () {
    function initMfoCart(root) {
      var button = root.querySelector('.mfo__button--atc');
      if (!button || button.dataset.mfoBound) return;
      button.dataset.mfoBound = 'true';

      var errorEl = root.querySelector('.mfo__cart-error');
      var label = button.querySelector('.mfo__button-label');
      var defaultText = label.textContent;

      function resetButton() {
        button.classList.remove('is-loading');
        label.textContent = defaultText;
      }

      button.addEventListener('click', function () {
        if (button.classList.contains('is-loading')) return;
        button.classList.add('is-loading');
        if (button.dataset.addingText) label.textContent = button.dataset.addingText;
        if (errorEl) errorEl.hidden = true;

        var routes = window.routes || {};
        var behavior = button.dataset.behavior || 'drawer';
        var formData = new FormData();
        formData.append('id', button.dataset.variantId);
        formData.append('quantity', button.dataset.quantity || 1);
        if (behavior === 'drawer') {
          formData.append('sections', 'cart-drawer,cart-icon-bubble');
          formData.append('sections_url', window.location.pathname);
        }

        fetch(routes.cart_add_url || '/cart/add', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', Accept: 'application/json' },
          body: formData
        })
          .then(function (response) { return response.json(); })
          .then(function (data) {
            if (data.status) throw new Error(data.description || '');

            if (behavior === 'checkout') {
              window.location.href = '/checkout';
              return;
            }
            if (behavior === 'cart') {
              window.location.href = routes.cart_url || '/cart';
              return;
            }

            var drawer = document.querySelector('cart-drawer');
            if (drawer && typeof drawer.renderContents === 'function') {
              drawer.renderContents(data);
            } else {
              window.location.href = routes.cart_url || '/cart';
              return;
            }

            fetch('/cart.js')
              .then(function (r) { return r.json(); })
              .then(function (cart) {
                document.querySelectorAll('.cart-count-bubble, [data-cart-count]').forEach(function (el) {
                  el.textContent = cart.item_count;
                });
              });

            resetButton();
          })
          .catch(function (err) {
            resetButton();
            if (errorEl) {
              errorEl.textContent = (err && err.message) || button.dataset.errorText || 'Unable to add to cart. Please try again.';
              errorEl.hidden = false;
            }
          });
      });
    }

    var sectionEl = document.querySelector('.section-{{ section.id }}');
    if (sectionEl) initMfoCart(sectionEl);

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        initMfoCart(event.target);
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Metabolic Flow Offer",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false,
      "info": "Apply global theme colors instead of the design colors below."
