{% comment %}
  Block: LTS Meta Box - Meta information box for Limited Time Sale
{% endcomment %}

<div class="lts-meta-box lts-meta-box-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.item_1_label != blank or block.settings.item_1_value != blank %}
    <div class="lts-meta-item-{{ block.id }}">
      {% if block.settings.item_1_label != blank %}
        <span class="lts-meta-label-{{ block.id }}">{{ block.settings.item_1_label }}</span>
      {% endif %}
      {% if block.settings.item_1_value != blank %}
        <span class="lts-meta-value-{{ block.id }}" style="color: {{ block.settings.item_1_value_color }};">{{ block.settings.item_1_value }}</span>
      {% endif %}
    </div>
  {% endif %}
  
  {% if block.settings.show_divider and block.settings.item_2_text != blank %}
    <div class="lts-meta-divider-{{ block.id }}" aria-hidden="true"></div>
  {% endif %}
  
  {% if block.settings.item_2_text != blank %}
    <div class="lts-meta-item-{{ block.id }}">
      {{ block.settings.item_2_text }}
    </div>
  {% endif %}
  
  {% if block.settings.show_divider and block.settings.item_3_text != blank %}
    <div class="lts-meta-divider-{{ block.id }}" aria-hidden="true"></div>
  {% endif %}
  
  {% if block.settings.item_3_text != blank %}
    <div class="lts-meta-item-{{ block.id }}">
      {{ block.settings.item_3_text }}
    </div>
  {% endif %}
</div>

<style>
  .lts-meta-box-{{ block.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: {{ block.settings.item_gap }}px;
    background: {{ block.settings.bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
    margin: 0 auto {{ block.settings.margin_bottom }}px;
    max-width: {{ block.settings.max_width }}px;
    
    {% if block.settings.show_border %}
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .lts-meta-item-{{ block.id }} {
    font-size: {{ block.settings.font_size }}px !important;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    font-weight: {{ block.settings.font_weight }} !important;
    color: {{ block.settings.text_color }};
  }

  .lts-meta-label-{{ block.id }} {
    color: {{ block.settings.label_color }};
    margin-right: 6px;
  }

  .lts-meta-value-{{ block.id }} {
    font-weight: {{ block.settings.value_font_weight }} !important;
  }

  .lts-meta-divider-{{ block.id }} {
    width: 1px;
    height: {{ block.settings.divider_height }}px;
    background: {{ block.settings.divider_color }};
  }

  @media (max-width: 768px) {
    .lts-meta-box-{{ block.id }} {
      padding: {{ block.settings.padding_y_mobile }}px {{ block.settings.padding_x_mobile }}px;
    }
    .lts-meta-item-{{ block.id }} {
      font-size: {{ block.settings.font_size_mobile }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "LTS Meta Box",
  "settings": [
    {
      "type": "header",
      "content": "Item 1 (Label + Value)"
    },
    {
      "type": "text",
      "id": "item_1_label",
      "label": "Item 1 Label",
      "default": "Sell-Out Risk:"
    },
    {
      "type": "text",
      "id": "item_1_value",
      "label": "Item 1 Value",
      "default": "VERY HIGH"
    },
    {
      "type": "color",
      "id": "item_1_value_color",
      "label": "Item 1 Value Color",
      "default": "#D22F2F"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Item 2 Text",
      "default": "FREE SHIPPING"
    },
    {
      "type": "header",
      "content": "Item 3"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Item 3 Text"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Desktop)",
      "default": 13
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Font Size (Mobile)",
      "default": 12
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" }
      ],
      "default": "400"
    },
    {
      "type": "select",
      "id": "value_font_weight",
      "label": "Value Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "label": "Letter Spacing",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF2E8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#6b6b6b"
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider",
      "default": true
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider Color",
      "default": "#D9CFC4"
    },
    {
      "type": "range",
      "id": "divider_height",
      "min": 10,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Divider Height",
      "default": 18
    },
    {
      "type": "header",
      "content": "Border"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "Show Border",
      "default": true
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Border Width",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#F0E2D3"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Border Radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "item_gap",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Item Gap",
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_y",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Padding Vertical (Desktop)",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_x",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Padding Horizontal (Desktop)",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_y_mobile",
      "min": 6,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Padding Vertical (Mobile)",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_x_mobile",
      "min": 8,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Padding Horizontal (Mobile)",
      "default": 12
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "label": "Max Width",
      "default": 420
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 16
    }
  ],
  "presets": [
    { "name": "LTS Meta Box" }
  ]
}
{% endschema %}

