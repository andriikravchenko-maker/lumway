{% comment %} Section: gut-harmony-cta — centered closing block: title + seal-check feature list + CTA {% endcomment %}

{%- unless settings.enable_oswald_font -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}
{%- unless settings.enable_league_spartan_font -%}
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}

{%- liquid
  if section.settings.use_theme_colors
    assign background_color = settings.global_section_background_color
    assign title_color = settings.global_section_heading_color | default: settings.global_section_text_color
    assign text_color = settings.global_section_text_color
    assign icon_color = settings.global_section_text_color
    assign button_bg = settings.global_button_bg_color | default: settings.global_section_accent_1_color
    assign button_text_color = settings.global_button_text_color | default: '#ffffff'
    assign button_hover_bg = settings.global_button_hover_bg_color | default: settings.global_section_accent_1_color
  else
    assign background_color = section.settings.background_color
    assign title_color = section.settings.title_color
    assign text_color = section.settings.text_color
    assign icon_color = section.settings.icon_color
    assign button_bg = section.settings.button_bg
    assign button_text_color = section.settings.button_text_color
    assign button_hover_bg = section.settings.button_hover_bg
  endif
-%}

