{% style %}
  .section-{{ section.id }} {
    --mt-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mt-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mt-bg: {{ section_bg }};
    --mt-ink: {{ ink }};
    --mt-blue: {{ blue }};
    --mt-card-bg: {{ section.settings.card_background }};
    --mt-card-border: {{ section.settings.card_border_color }};
    --mt-badge-bg: {{ section.settings.badge_color }};
    --mt-button-bg: {{ section.settings.button_background }};
    --mt-button-text: {{ section.settings.button_text_color }};
    --mt-heading-size: {{ section.settings.heading_size }}px;
    --mt-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --mt-card-width: {{ section.settings.card_width }}px;
    --mt-space: {{ section.settings.space_between }}px;
    --mt-pad-top: {{ section.settings.padding_top }}px;
    --mt-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mt-bg);
    padding-top: var(--mt-pad-top);
    padding-bottom: var(--mt-pad-bottom);
  }

  .section-{{ section.id }} .mt__heading {
    margin: 0 auto 32px;
    max-width: 1200px;
    padding-inline: 20px;
    font-family: var(--mt-fh) !important;
    font-weight: 500 !important;
    line-height: 1.2;
    color: var(--mt-ink) !important;
    text-align: center;
    font-size: clamp(var(--mt-heading-size-mobile), 3.4vw, var(--mt-heading-size));
  }

  .section-{{ section.id }} .mt__accent {
    font-family: inherit !important;
    color: var(--mt-blue) !important;
  }

  /* Carousel */
  .section-{{ section.id }} .mt__carousel {
    max-width: 1840px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  .section-{{ section.id }} .mt__carousel.mt__carousel--pending { opacity: 0; }
  .section-{{ section.id }} .mt__carousel { opacity: 1; transition: opacity 0.2s ease; }

  /* No-JS / pre-init fallback: native horizontal scroll */
  .section-{{ section.id }} .mt__carousel:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    gap: var(--mt-space);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 4px;
  }
  .section-{{ section.id }} .mt__carousel:not(.swiper-initialized) .swiper-wrapper::-webkit-scrollbar { display: none; }
  .section-{{ section.id }} .mt__carousel:not(.swiper-initialized) .swiper-slide { scroll-snap-align: start; flex-shrink: 0; }

  .section-{{ section.id }} .swiper-slide {
    width: var(--mt-card-width);
    max-width: 88vw;
    height: auto;
  }

  .section-{{ section.id }} .mt__card {
    height: 100%;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 24px;
    background-color: var(--mt-card-bg);
    border: 1px solid var(--mt-card-border);
    border-radius: 8px;
    box-shadow: 0 4px 5px rgba(143,143,143,0.05), 0 18px 9px rgba(143,143,143,0.05), 0 40px 12px rgba(143,143,143,0.05);
  }

  .section-{{ section.id }} .mt__media {
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
  }

  .section-{{ section.id }} .mt__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .section-{{ section.id }} .mt__image--placeholder { background-color: #eef0f1; fill: #b9c3c9; }

  .section-{{ section.id }} .mt__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
  }

  .section-{{ section.id }} .mt__badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 12px;
    border-radius: 15px;
    background-color: var(--mt-badge-bg);
    font-family: var(--mt-fb) !important;
    font-weight: 400 !important;
    font-size: 14px;
    line-height: 20px;
    color: #ffffff !important;
  }

  .section-{{ section.id }} .mt__text,
  .section-{{ section.id }} .mt__name {
    margin: 0;
    font-family: var(--mt-fb) !important;
    font-weight: 400 !important;
    font-size: 14px;
    line-height: 20px;
    color: var(--mt-ink) !important;
  }

  /* Nav buttons */
  .section-{{ section.id }} .mt__nav-row {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
  }
  .section-{{ section.id }} .mt__nav {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--mt-card-border);
    background: var(--mt-card-bg);
    color: var(--mt-ink);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }
  .section-{{ section.id }} .mt__nav:hover { background: var(--mt-bg); }
  .section-{{ section.id }} .mt__nav.nav-button-disabled { opacity: 0.35; cursor: default; }

  /* CTA */
  .section-{{ section.id }} .mt__cta {
    display: flex;
    flex-direction: column;
    align-items: center; width: 100%;
    gap: 8px;
    margin-top: 40px;
    padding-inline: 20px;
  }

  .section-{{ section.id }} .mt__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--mt-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--mt-button-text) !important;
    background-color: var(--mt-button-bg);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .mt__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .mt__button:focus-visible { outline: 3px solid var(--mt-blue); outline-offset: 3px; }

  .section-{{ section.id }} .mt__guarantee {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mt-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(14px, 2vw, 18px);
    color: var(--mt-ink) !important;
  }
  .section-{{ section.id }} .mt__guarantee-icon { flex-shrink: 0; width: 16px; height: 16px; line-height: 0; color: var(--mt-ink); }
  .section-{{ section.id }} .mt__icon-svg { display: block; width: 100%; height: 100%; }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .mt__button { transition: none; }
  }
{% endstyle %}

<section class="mt section-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.heading_before != blank or section.settings.heading_accent != blank or section.settings.heading_after != blank -%}
    <h2 class="mt__heading">
      {{- section.settings.heading_before -}}
      {%- if section.settings.heading_accent != blank %} <span class="mt__accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      {%- if section.settings.heading_after != blank %} {{ section.settings.heading_after }}{% endif -%}
    </h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="mt__carousel mt__carousel--pending swiper" id="mt-carousel-{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-delay="{{ section.settings.autoplay_delay }}" data-loop="{{ section.settings.loop }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- assign t_alt = block.settings.image.alt | default: block.settings.name | default: 'Customer testimonial' -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <article class="mt__card">
              <div class="mt__media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 720
                    | image_tag:
                      loading: 'lazy',
                      widths: '336,400,600,720',
                      sizes: '(min-width: 768px) 336px, 80vw',
                      alt: t_alt,
                      class: 'mt__image'
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'mt__image mt__image--placeholder' }}
                {%- endif -%}
              </div>
              <div class="mt__content">
                {%- if block.settings.badge_text != blank -%}
                  <span class="mt__badge">{{ block.settings.badge_text }}</span>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="mt__text">{{ block.settings.text }}</p>
                {%- endif -%}
                {%- if block.settings.name != blank -%}
                  <p class="mt__name">{{ block.settings.name }}</p>
                {%- endif -%}
              </div>
            </article>
          </div>
        {%- endfor -%}
      </div>
    </div>
    <div class="mt__nav-row">
      <button type="button" class="mt__nav nav-button prev" aria-label="Previous">&#8249;</button>
      <button type="button" class="mt__nav nav-button next" aria-label="Next">&#8250;</button>
    </div>
  {%- endif -%}

  {%- if section.settings.button_text != blank -%}
    <div class="mt__cta">
      <a class="mt__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
      {%- if section.settings.guarantee_text != blank -%}
        <span class="mt__guarantee"><span class="mt__guarantee-icon">{{ check_icon }}</span>{{ section.settings.guarantee_text }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<script>
  (function () {
    var sectionId = {{ section.id | json }};
    function init(root) {
      var container = root.querySelector('.mt__carousel');
      if (!container || container.swiper) { if (container) container.classList.remove('mt__carousel--pending'); return; }
      var prev = root.querySelector('.mt__nav.prev');
      var next = root.querySelector('.mt__nav.next');
      var reveal = function () { container.classList.remove('mt__carousel--pending'); };
      var fallback = setTimeout(reveal, 2500);
      var loader = (typeof window.swiperCheckAndLoad === 'function') ? window.swiperCheckAndLoad() : Promise.resolve();
      loader.then(function () {
        clearTimeout(fallback);
        reveal();
        if (!container || container.swiper || typeof window.Swiper === 'undefined') return;
        new window.Swiper(container, {
          slidesPerView: 'auto',
          spaceBetween: {{ section.settings.space_between }},
          loop: {{ section.settings.loop }},
          speed: 500,
          grabCursor: true,
          {% if section.settings.autoplay %}autoplay: { delay: {{ section.settings.autoplay_delay }}, disableOnInteraction: false, pauseOnMouseEnter: true },{% endif %}
          navigation: { prevEl: prev, nextEl: next, disabledClass: 'nav-button-disabled' },
          observer: true,
          observeParents: true,
          a11y: { enabled: true }
        });
      }).catch(reveal);
    }
    function run() {
      var root = document.querySelector('.section-' + sectionId);
      if (root) init(root);
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', run); } else { run(); }
    document.addEventListener('shopify:section:load', function (e) {
      if (e.detail && e.detail.sectionId === sectionId) { init(e.target); }
    });
  })();
</script>

