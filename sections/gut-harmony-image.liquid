{% comment %} Section: gut-harmony-image — single centered image (content max 1204, ~358px side margins at 1920) {% endcomment %}

{%- liquid
  if section.settings.use_theme_colors
    assign background_color = settings.global_section_background_color
  else
    assign background_color = section.settings.background_color
  endif
  assign image_alt = section.settings.image.alt | default: ''
-%}

{% style %}
  .section-{{ section.id }} {
    --ghimg-bg: {{ background_color }};
    --ghimg-max-width: {{ section.settings.max_width }}px;
    --ghimg-radius: {{ section.settings.image_border_radius }}px;
    --ghimg-pad-top: {{ section.settings.padding_top }}px;
    --ghimg-pad-bottom: {{ section.settings.padding_bottom }}px;
    --ghimg-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ghimg-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--ghimg-bg);
    padding-top: var(--ghimg-pad-top-mobile);
    padding-bottom: var(--ghimg-pad-bottom-mobile);
  }

  .section-{{ section.id }} .gut-harmony-image__inner {
    max-width: var(--ghimg-max-width);
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  .section-{{ section.id }} .gut-harmony-image__media {
    display: block;
    width: 100%;
  }

  .section-{{ section.id }} .gut-harmony-image__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--ghimg-radius);
  }

  .section-{{ section.id }} .gut-harmony-image__img--placeholder {
    aspect-ratio: 1204 / 715;
    background-color: #eef0f1;
    fill: #b9c3c9;
  }

  @media screen and (min-width: 1244px) {
    .section-{{ section.id }} {
      padding-top: var(--ghimg-pad-top);
      padding-bottom: var(--ghimg-pad-bottom);
    }

    .section-{{ section.id }} .gut-harmony-image__inner {
      padding-inline: 0;
    }
  }
{% endstyle %}

<section class="gut-harmony-image section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="gut-harmony-image__inner">
    {%- if section.settings.link != blank -%}
      <a class="gut-harmony-image__media" href="{{ section.settings.link }}">
    {%- else -%}
      <div class="gut-harmony-image__media">
    {%- endif -%}
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 2408
          | image_tag:
            loading: 'lazy',
            widths: '600,900,1204,1600,2000,2408',
            sizes: '(min-width: 1244px) 1204px, 100vw',
            alt: image_alt,
            class: 'gut-harmony-image__img'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'gut-harmony-image__img gut-harmony-image__img--placeholder' }}
      {%- endif -%}
    {%- if section.settings.link != blank -%}
      </a>
    {%- else -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gut Harmony Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended size 1204 x 715. Shown at its natural ratio."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 1000,
      "max": 1400,
      "step": 4,
      "unit": "px",
      "default": 1204
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme background color",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Gut Harmony Image",
      "category": "Custom Content"
    }
  ]
}
{% endschema %}
