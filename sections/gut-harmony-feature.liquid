      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "#1: Helps Support Digestion As You Age"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size (mobile)",
      "min": 16,
      "max": 44,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#0a430d"
    },
    {
      "type": "header",
      "content": "Graphic image"
    },
    {
      "type": "image_picker",
      "id": "image",
