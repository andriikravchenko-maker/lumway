<div class="listicle-header listicle-header-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="listicle-header-inner">
    {% if block.settings.title != blank %}
      <h1 class="listicle-title">{{ block.settings.title }}</h1>
    {% endif %}
    
    {% if block.settings.show_author_info %}
      <div class="author-info">
        {% if block.settings.author_avatar != blank %}
          <div class="author-avatar-wrap">
            <img src="{{ block.settings.author_avatar | image_url: width: 160 }}" class="author-avatar" alt="{{ block.settings.author_name }}" width="{{ block.settings.avatar_size }}" height="{{ block.settings.avatar_size }}" loading="lazy">
          </div>
        {% endif %}
        <div class="author-details">
          <p class="author-name">{{ block.settings.author_name }}</p>
          {% if block.settings.author_note != blank %}
            <p class="author-note">{{ block.settings.author_note }}</p>
          {% endif %}
          <p class="author-date">{{ block.settings.author_date }}</p>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .listicle-header-{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }
  .listicle-header-{{ block.id }} .listicle-title {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    line-height: 1.2;
    text-align: {{ block.settings.alignment }};
    margin-bottom: 20px;
  }
  .listicle-header-{{ block.id }} .author-info {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: {{ block.settings.alignment }};
  }
  .listicle-header-{{ block.id }} .author-avatar-wrap {
    width: {{ block.settings.avatar_size }}px;
    flex-shrink: 0;
    {% if block.settings.image_aspect_ratio == '1_1' %}
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 50%;
    {% endif %}
  }
  .listicle-header-{{ block.id }} .author-avatar {
    width: {{ block.settings.avatar_size }}px;
    height: {{ block.settings.avatar_size }}px;
    border-radius: 50%;
    object-fit: cover;
    {% if block.settings.image_aspect_ratio == '1_1' %}
      width: 100%;
      height: 100%;
    {% endif %}
  }
  .listicle-header-{{ block.id }} .author-name {
    margin: 0;
    font-weight: 700 !important;
    font-size: 14px;
  }
  .listicle-header-{{ block.id }} .author-note {
    margin: 0;
    font-weight: 700 !important;
    font-size: 14px;
    opacity: 0.7;
  }
  .listicle-header-{{ block.id }} .author-date {
    margin-top: 10px;
    font-size: 0.9em;
    opacity: 0.7;
  }
  @media (max-width: 768px) {
    .listicle-header-{{ block.id }} .listicle-title {
      font-size: {{ block.settings.title_size_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Listicle Header",
  "tag": "div",
  "class": "listicle-header-wrapper",
  "presets": [
    { "name": "Listicle Header" }
  ],
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Listicle Title"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Title Size (Desktop)",
      "default": 40
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Title Size (Mobile)",
      "default": 32
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "show_author_info",
      "label": "Show Author Info",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "author_avatar",
      "label": "Author Avatar"
    },
    {
      "type": "select",
      "id": "image_aspect_ratio",
      "label": "Avatar aspect ratio",
      "options": [
        { "value": "natural", "label": "Natural" },
        { "value": "1_1", "label": "Square (1:1)" }
      ],
      "default": "1_1"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author Name",
      "default": "Author Name"
    },
    {
      "type": "text",
      "id": "author_note",
      "label": "Author Note",
      "info": "Optional note under the author name (shown at 70% opacity)."
    },
    {
      "type": "text",
      "id": "author_date",
      "label": "Date",
      "default": "January 1, 2025"
    },
    {
      "type": "range",
      "id": "avatar_size",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Avatar Size",
      "default": 50
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 32
    }
  ]
}
{% endschema %}

