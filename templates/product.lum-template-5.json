          "settings": {
            "question": "How long before I notice results?",
            "answer": "<p>Many customers report feeling more balanced and consistent within the first few weeks of daily use. Individual experiences may vary.*</p>"
          }
        },
        "faq_item_gXcmep": {
          "type": "faq_item",
          "settings": {
            "question": "How do I take Metabolic Flow 45+?",
            "answer": "<p>Take 2 capsules daily with food or as directed on the label.</p>"
          }
        },
        "faq_item_tiFc8t": {
          "type": "faq_item",
          "settings": {
            "question": "Is it stimulant-free?",
            "answer": "<p>Metabolic Flow 45+ is formulated without harsh stimulants or jittery energy ingredients.</p>"
          }
        },
        "faq_item_9AD6VG": {
          "type": "faq_item",
          "settings": {
            "question": "What does the guarantee include?",
            "answer": "<p>If you’re not satisfied with your experience, contact our support team within the guarantee period for assistance.</p>"
          }
        },
        "faq_item_fmKiR8": {
          "type": "faq_item",
          "settings": {
            "question": "Can I take this with other supplements?",
            "answer": "<p>If you are pregnant, nursing, taking medication, or under medical supervision, consult your healthcare professional before use.</p>"
          }
        },
        "faq_item_4A6JDi": {
          "type": "faq_item",
          "settings": {
            "question": "Where is Metabolic Flow 45+ made?",
            "answer": "<p>Metabolic Flow 45+ is manufactured in facilities that follow quality and safety standards.</p>"
          }
        },
        "faq_item_LJzeNJ": {
          "type": "faq_item",
          "settings": {
            "question": "Is this made for women 45+?",
            "answer": "<p>Yes — the formula was designed specifically for women navigating metabolic and lifestyle changes after 45.*</p>"
          }
        },
        "faq_item_fgYMzR": {
          "type": "faq_item",
          "settings": {
            "question": "What makes this different from other supplements?",
            "answer": "<p>Metabolic Flow 45+ combines thoughtfully selected ingredients including Berberine, Chromium, Fiber, and Cinnamon Bark in one simple daily routine.*</p>"
          }
        }
      },
