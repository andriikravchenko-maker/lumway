        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "chip_letter_spacing",
      "min": 0,
      "max": 3,
      "step": 1,
      "unit": "px",
      "label": "Chip Letter Spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "chip_padding_y",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Chip Padding Vertical",
      "default": 10
    },
    {
      "type": "range",
      "id": "chip_padding_x",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Chip Padding Horizontal",
      "default": 18
