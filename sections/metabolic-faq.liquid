{% style %}
  .section-{{ section.id }} {
    --fq-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --fq-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --fq-bg: {{ section_bg }};
    --fq-ink: {{ ink }};
    --fq-accent: {{ accent }};
    --fq-muted: {{ section.settings.answer_color }};
    --fq-card-bg: {{ section.settings.card_background }};
    --fq-border: {{ section.settings.card_border_color }};
    --fq-button-bg: {{ section.settings.button_background }};
    --fq-button-text: {{ section.settings.button_text_color }};
    --fq-heading-size: {{ section.settings.heading_size }}px;
    --fq-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --fq-q-size: {{ section.settings.question_size }}px;
    --fq-a-size: {{ section.settings.answer_size }}px;
    --fq-col-gap: {{ section.settings.column_gap }}px;
    --fq-item-gap: {{ section.settings.item_gap }}px;
    --fq-gap: {{ section.settings.section_gap }}px;
    --fq-pad-top: {{ section.settings.padding_top }}px;
    --fq-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--fq-bg);
    padding-top: var(--fq-pad-top);
    padding-bottom: var(--fq-pad-bottom);
  }

  .section-{{ section.id }} .fq__inner {
    max-width: 1640px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(28px, 4vw, var(--fq-gap));
  }

  .section-{{ section.id }} .fq__heading {
    margin: 0;
    text-align: center;
    font-family: var(--fq-fh) !important;
    font-weight: 500 !important;
    line-height: 1.25;
    color: var(--fq-ink) !important;
    font-size: clamp(var(--fq-heading-size-mobile), 3.4vw, var(--fq-heading-size));
  }
  .section-{{ section.id }} .fq__accent { font-family: inherit !important; color: var(--fq-accent) !important; }

  .section-{{ section.id }} .fq__cols {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--fq-item-gap);
    align-items: start;
  }
  .section-{{ section.id }} .fq__col { display: flex; flex-direction: column; gap: var(--fq-item-gap); }

  .section-{{ section.id }} .fq__item {
    border: 1px solid var(--fq-border);
    border-radius: 8px;
    background-color: var(--fq-card-bg);
    box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .section-{{ section.id }} .fq__q {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 24px;
    margin: 0;
    font-family: var(--fq-fb) !important;
    font-weight: 600 !important;
    line-height: 1.4;
    letter-spacing: -0.2px;
    color: var(--fq-ink) !important;
    font-size: clamp(15px, 1.4vw, var(--fq-q-size));
  }
  .section-{{ section.id }} .fq__q::-webkit-details-marker { display: none; }
  .section-{{ section.id }} .fq__icon {
    flex-shrink: 0;
    position: relative;
    width: 18px;
    height: 18px;
  }
  .section-{{ section.id }} .fq__icon::before,
  .section-{{ section.id }} .fq__icon::after {
    content: '';
    position: absolute;
    background-color: var(--fq-ink);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .fq__icon::before { top: 8px; left: 0; width: 18px; height: 2px; }
  .section-{{ section.id }} .fq__icon::after { top: 0; left: 8px; width: 2px; height: 18px; }
  .section-{{ section.id }} details[open] .fq__icon::after { opacity: 0; transform: rotate(90deg); }

  .section-{{ section.id }} .fq__a {
    padding: 0 24px 18px;
    font-family: var(--fq-fb) !important;
    font-weight: 400 !important;
    line-height: 1.45;
    color: var(--fq-muted) !important;
    font-size: clamp(14px, 1.3vw, var(--fq-a-size));
  }
  .section-{{ section.id }} .fq__a > * { margin: 0; }
  .section-{{ section.id }} .fq__a > * + * { margin-top: 8px; }

  /* CTA */
  .section-{{ section.id }} .fq__cta { display: flex; flex-direction: column; align-items: center; width: 100%; gap: 10px; }
  .section-{{ section.id }} .fq__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--fq-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--fq-button-text) !important;
    background-color: var(--fq-button-bg);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .fq__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .fq__button:focus-visible { outline: 3px solid var(--fq-accent); outline-offset: 3px; }
  .section-{{ section.id }} .fq__guarantee {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--fq-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(13px, 1.6vw, 16px);
    color: var(--fq-ink) !important;
  }
  .section-{{ section.id }} .fq__guarantee-icon { flex-shrink: 0; width: 16px; height: 16px; line-height: 0; color: var(--fq-ink); }
  .section-{{ section.id }} .fq__guarantee-icon svg { display: block; width: 100%; height: 100%; }

  @media (min-width: 768px) {
    .section-{{ section.id }} .fq__cols { grid-template-columns: 1fr 1fr; column-gap: var(--fq-col-gap); }
  }
  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .fq__button { transition: none; }
  }
{% endstyle %}

<section class="fq section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="fq__inner">

    {%- if section.settings.heading_before != blank or section.settings.heading_accent != blank -%}
      <h2 class="fq__heading">
        {{- section.settings.heading_before -}}
        {%- if section.settings.heading_accent != blank %} <span class="fq__accent">{{ section.settings.heading_accent }}</span>{% endif -%}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="fq__cols">
        <div class="fq__col">
          {%- for block in section.blocks limit: half -%}
            {%- if block.settings.question != blank -%}
              <details class="fq__item" {{ block.shopify_attributes }}>
                <summary class="fq__q">{{ block.settings.question }}<span class="fq__icon" aria-hidden="true"></span></summary>
                {%- if block.settings.answer != blank -%}<div class="fq__a">{{ block.settings.answer }}</div>{%- endif -%}
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <div class="fq__col">
          {%- for block in section.blocks offset: half -%}
            {%- if block.settings.question != blank -%}
              <details class="fq__item" {{ block.shopify_attributes }}>
                <summary class="fq__q">{{ block.settings.question }}<span class="fq__icon" aria-hidden="true"></span></summary>
                {%- if block.settings.answer != blank -%}<div class="fq__a">{{ block.settings.answer }}</div>{%- endif -%}
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="fq__cta">
        <a class="fq__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
        {%- if section.settings.guarantee_text != blank -%}
          <span class="fq__guarantee"><span class="fq__guarantee-icon">{{ check_icon }}</span>{{ section.settings.guarantee_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Metabolic FAQ",
  "settings": [
    { "type": "checkbox", "id": "use_theme_colors", "label": "Use theme colors", "default": false },
    { "type": "header", "content": "Heading" },
    { "type": "text", "id": "heading_before", "label": "Heading (before accent)", "default": "Frequently Asked" },
    { "type": "text", "id": "heading_accent", "label": "Accent text (colored)", "default": "Questions" },
    { "type": "range", "id": "heading_size", "label": "Heading size", "min": 24, "max": 56, "step": 2, "unit": "px", "default": 40 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading size (mobile)", "min": 18, "max": 40, "step": 2, "unit": "px", "default": 24 },
    { "type": "header", "content": "Items" },
    { "type": "range", "id": "question_size", "label": "Question size", "min": 14, "max": 24, "step": 1, "unit": "px", "default": 18 },
    { "type": "range", "id": "answer_size", "label": "Answer size", "min": 13, "max": 20, "step": 1, "unit": "px", "default": 16 },
    { "type": "color", "id": "answer_color", "label": "Answer text color", "default": "#666666" },
    { "type": "color", "id": "card_background", "label": "Card background", "default": "#ffffff" },
    { "type": "color", "id": "card_border_color", "label": "Card border color", "default": "#ececec" },
    { "type": "header", "content": "CTA" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "CLAIM 20% OFF NOW →" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "button_background", "label": "Button color", "default": "#202329" },
    { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#ffffff" },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "60-Day Money-Back Guarantee" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "section_background", "label": "Section background", "default": "#ffffff" },
    { "type": "color", "id": "ink_color", "label": "Text color", "default": "#202329" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#5584c0" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "column_gap", "label": "Column gap (desktop)", "min": 16, "max": 64, "step": 4, "unit": "px", "default": 24 },
    { "type": "range", "id": "item_gap", "label": "Gap between items", "min": 8, "max": 40, "step": 4, "unit": "px", "default": 16 },
    { "type": "range", "id": "section_gap", "label": "Gap between blocks", "min": 16, "max": 96, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "padding_top", "label": "Padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does one bottle last?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Each bottle contains 60 capsules, a full 30-day supply at the suggested 2 capsules per day.</p>" }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Metabolic FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "How long does one bottle last?", "answer": "<p>Each bottle contains 60 capsules, a full 30-day supply at the suggested 2 capsules per day.</p>" } },
        { "type": "faq_item", "settings": { "question": "What ingredients are in Metabolic Flow?", "answer": "<p>A blend of Berberine, Chromium, Cinnamon Bark Extract, and Chicory Root Fiber. The full list is on the product page.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is Metabolic Flow right for me?", "answer": "<p>It is formulated for women 45+ who want to support healthy metabolism, balanced energy, and fewer cravings. If you have a medical condition or take medication, check with your doctor first.</p>" } },
        { "type": "faq_item", "settings": { "question": "When should I expect to notice a difference?", "answer": "<p>Everyone is different. Many women notice changes within a few weeks of daily use, with the best results over 2 to 3 months.</p>" } },
        { "type": "faq_item", "settings": { "question": "Are there any side effects?", "answer": "<p>Metabolic Flow is made from well-studied ingredients and is generally well tolerated. If you have any concerns, talk to your healthcare provider.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is a subscription worth it?", "answer": "<p>Subscribing saves money on every order and makes sure you never run out. You can pause, change, or cancel anytime.</p>" } },
        { "type": "faq_item", "settings": { "question": "How does the subscription work?", "answer": "<p>Choose a delivery frequency at checkout and we ship automatically. Manage everything from your account, with no commitment.</p>" } },
        { "type": "faq_item", "settings": { "question": "Where is Metabolic Flow made?", "answer": "<p>Metabolic Flow is made in the USA in a facility that follows strict quality standards.</p>" } },
        { "type": "faq_item", "settings": { "question": "Why is Metabolic Flow designed for women 45+?", "answer": "<p>Metabolism naturally shifts with age. Metabolic Flow was created to support women through those changes during and after menopause.</p>" } }
      ]
    }
  ]
}
{% endschema %}
