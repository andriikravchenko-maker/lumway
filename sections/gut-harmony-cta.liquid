      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 44
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Title size (mobile)",
      "min": 16,
      "max": 44,
      "step": 2,
      "unit": "px",
      "default": 26
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Feature text"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Feature text size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Feature text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Check icon color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
