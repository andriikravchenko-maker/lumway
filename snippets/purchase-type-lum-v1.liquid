{%- comment -%}
  FROZEN SNAPSHOT v1 (2026-07-02) — not rendered anywhere, do not edit.
  Purchase Type before the v2 test rework: subscribe/one-time cards + pack-aware benefits
  (Free Shipping auto-hidden for the 1-jar pack via benefit_N_multi_only).
  Restore = copy this file over snippets/purchase-type-lum.liquid. The matching schema
  (benefit_N_multi_only checkboxes) lives in sections/product-details-lum.liquid; the full
  exact pair is preserved on git branch snapshot-purchase-type-v1-freeship.
{%- endcomment -%}
{%- comment -%}
  Purchase Type (subscribe / one-time) — Lumway PDP. Figma mobile 484:7110.
  Native Shopify selling plans (Recharge is the processor). The SUBSCRIBE interval is driven by the pack
  selector: resolvePlanForVariant() picks the plan/interval per the selected variant.
    interval_mode 'mapped' (default): option index -> plan id (option < threshold -> monthly, >= threshold -> bi-monthly).
    interval_mode 'auto': read the selected variant.selling_plan_allocations (Recharge variant-level plans).
  Selecting subscribe writes name="selling_plan" (via Elixir_SetProductFormSellingPlan) + sets the price
  context (Elixir_SetSubscriptionContext) so the ATC button shows the discounted price.
  Subscribe card is rendered only when the product has selling plans (or force_show_subscribe). One-time works today.
  Usage: {% render 'purchase-type-lum', block: block, product: product %}
{%- endcomment -%}

{%- liquid
  assign uid = block.id
  assign has_plans = false
  if product.selling_plan_groups.size > 0
    assign has_plans = true
  endif
  assign show_sub = has_plans
  if block.settings.force_show_subscribe
    assign show_sub = true
  endif
  assign preselect_sub = false
  if show_sub and block.settings.preselect != 'one_time'
    assign preselect_sub = true
  endif
  assign suffix = ''
  if block.settings.show_per_pack
    assign suffix = block.settings.per_pack_suffix | default: '/pack'
  endif
-%}

{%- if product != nil and product.variants.size > 0 -%}
{% style %}
  .ptl-{{ uid }}{ --ptl-font:'Inter Tight', system-ui, sans-serif; --ptl-ink:#113b34; --ptl-card:#f4f4f2; --ptl-line:rgba(17,59,52,.1); display:flex; flex-direction:column; gap:16px; width:100%; }
  .ptl-{{ uid }} .ptl__label{ margin:0; font-family:var(--ptl-font) !important; font-weight:600 !important; font-size:16px; line-height:1.2; letter-spacing:-0.32px; color:var(--ptl-ink); }
  .ptl-{{ uid }} .ptl__list{ display:flex; flex-direction:column; gap:8px; }
  .ptl-{{ uid }} .ptl__card{ position:relative; display:flex; flex-direction:column; gap:8px; padding:12px; background:var(--ptl-card); border:1px solid var(--ptl-line); border-radius:12px; cursor:pointer; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
  .ptl-{{ uid }} .ptl__card.is-selected{ border:1.5px solid var(--ptl-ink); }
  .ptl-{{ uid }} .ptl__input{ position:absolute; inset:0; width:100%; height:100%; margin:0; opacity:0; cursor:pointer; z-index:2; -webkit-tap-highlight-color:transparent; -webkit-appearance:none; appearance:none; }
  .ptl-{{ uid }} .ptl__top{ display:flex; align-items:center; justify-content:space-between; gap:8px; }
  .ptl-{{ uid }} .ptl__main{ display:flex; align-items:center; gap:12px; min-width:0; }
  .ptl-{{ uid }} .ptl__radio{ flex:0 0 18px; width:18px; height:18px; border-radius:50%; border:1.5px solid rgba(17,59,52,.35); background:#fff; position:relative; box-sizing:border-box; }
  .ptl-{{ uid }} .ptl__card.is-selected .ptl__radio{ border-color:var(--ptl-ink); }
  .ptl-{{ uid }} .ptl__card.is-selected .ptl__radio::after{ content:""; position:absolute; inset:3px; border-radius:50%; background:var(--ptl-ink); }
  .ptl-{{ uid }} .ptl__title{ font-family:var(--ptl-font); font-weight:600; font-size:14px; line-height:1.2; letter-spacing:-0.28px; color:var(--ptl-ink); white-space:nowrap; }
  .ptl-{{ uid }} .ptl__prices{ display:flex; flex-direction:column; align-items:flex-end; gap:4px; text-align:right; }
  .ptl-{{ uid }} .ptl__card--ot .ptl__prices{ flex-direction:row; align-items:center; gap:8px; }
  .ptl-{{ uid }} .ptl__price{ font-family:var(--ptl-font); font-weight:600; font-size:14px; line-height:1.2; letter-spacing:-0.28px; color:var(--ptl-ink); white-space:nowrap; }
  .ptl-{{ uid }} .ptl__compare{ font-family:var(--ptl-font); font-weight:400; font-size:12px; line-height:1.2; letter-spacing:-0.24px; color:rgba(17,59,52,.4); text-decoration:line-through; white-space:nowrap; }
  .ptl-{{ uid }} .ptl__divider{ display:block; height:1px; width:100%; background:var(--ptl-line); }
  .ptl-{{ uid }} .ptl__benefits{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:8px; }
  .ptl-{{ uid }} .ptl__benefits li{ display:flex; align-items:center; gap:4px; }
  .ptl-{{ uid }} .ptl__check{ display:inline-flex; width:12px; height:12px; flex:0 0 12px; }
  .ptl-{{ uid }} .ptl__check svg{ display:block; width:100%; height:100%; }
  .ptl-{{ uid }} .ptl__benefits span:last-child{ font-family:var(--ptl-font); font-weight:400; font-size:12px; line-height:1.2; letter-spacing:-0.24px; color:var(--ptl-ink); }
  .ptl-{{ uid }} .ptl__badge{ position:absolute; top:-12px; right:12px; z-index:3; display:inline-flex; align-items:center; padding:4px 8px; border-radius:28px; font-family:var(--ptl-font); font-weight:500; font-size:12px; line-height:1.2; letter-spacing:-0.24px; white-space:nowrap; }
  /* Theme re-fonts these; force Inter Tight */
  .ptl-{{ uid }} .ptl__title,
  .ptl-{{ uid }} .ptl__price,
  .ptl-{{ uid }} .ptl__compare,
  .ptl-{{ uid }} .ptl__badge,
  .ptl-{{ uid }} .ptl__benefits span:last-child{ font-family:var(--ptl-font) !important; }
  .ptl-{{ uid }} .ptl__input:focus-visible ~ .ptl__top .ptl__radio{ outline:2px solid var(--ptl-ink); outline-offset:2px; }
{% endstyle %}

<div class="ptl ptl-{{ uid }}" {{ block.shopify_attributes }} data-interval-mode="{{ block.settings.interval_mode | default: 'mapped' }}">
  <script type="application/json" class="ptl-variants">{{ product.variants | json }}</script>
  <script type="application/json" class="ptl-plans">{{ product.selling_plan_groups | json }}</script>
  {%- if block.settings.heading != blank -%}<p class="ptl__label">{{ block.settings.heading | escape }}</p>{%- endif -%}
  <div class="ptl__list" role="radiogroup" aria-label="{{ block.settings.heading | default: 'Purchase type' | escape }}">

    {%- if show_sub -%}
      <label class="ptl__card ptl__card--sub{% if preselect_sub %} is-selected{% endif %}">
        <input type="radio" class="ptl__input" name="ptl-{{ uid }}" value="subscribe"{% if preselect_sub %} checked{% endif %} data-ptl-type="subscribe">
        {%- if block.settings.save_badge_show -%}<span class="ptl__badge" data-role="save-badge" style="background:{{ block.settings.save_badge_bg | default: '#fad356' }};color:{{ block.settings.save_badge_text_color | default: '#113b34' }}">{{ block.settings.save_badge_text | default: 'Save' | escape }}</span>{%- endif -%}
        <span class="ptl__top">
          <span class="ptl__main"><span class="ptl__radio" aria-hidden="true"></span><span class="ptl__title" data-role="interval">Subscribe</span></span>
          <span class="ptl__prices"><span class="ptl__price" data-role="sub-price"></span><span class="ptl__compare" data-role="sub-compare"></span></span>
        </span>
        <span class="ptl__divider"></span>
        <ul class="ptl__benefits">
          {%- for i in (1..6) -%}
            {%- assign bshow = 'benefit_' | append: i | append: '_show' -%}
            {%- assign btext = 'benefit_' | append: i | append: '_text' -%}
            {%- assign bmulti = 'benefit_' | append: i | append: '_multi_only' -%}
            {%- if block.settings[bshow] and block.settings[btext] != blank -%}
              <li{% if block.settings[bmulti] %} data-multi-only{% endif %}><span class="ptl__check">{{ 'lum-icon-tick.svg' | inline_asset_content }}</span><span>{{ block.settings[btext] | escape }}</span></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </label>
    {%- endif -%}

    <label class="ptl__card ptl__card--ot{% unless preselect_sub %} is-selected{% endunless %}">
      <input type="radio" class="ptl__input" name="ptl-{{ uid }}" value="one_time"{% unless preselect_sub %} checked{% endunless %} data-ptl-type="one_time">
      <span class="ptl__top">
        <span class="ptl__main"><span class="ptl__radio" aria-hidden="true"></span><span class="ptl__title">{{ block.settings.one_time_title | default: 'One-time Purchase' | escape }}</span></span>
        <span class="ptl__prices"><span class="ptl__price" data-role="ot-price"></span><span class="ptl__compare" data-role="ot-compare"></span></span>
      </span>
    </label>
  </div>
</div>

<script>
  (function () {
    var root = document.querySelector('.ptl-{{ uid }}');
    if (!root || root.__ptlBound) return;
    root.__ptlBound = true;

    var SUFFIX = {{ suffix | json }};
    var MODE = root.getAttribute('data-interval-mode') || 'mapped';
    var THRESHOLD = {{ block.settings.interval_threshold | default: 2 }};
    var MONTHLY_ID = {{ block.settings.monthly_plan_id | default: '' | json }};
    var BIMONTHLY_ID = {{ block.settings.bimonthly_plan_id | default: '' | json }};
    var LABEL_FMT = {{ block.settings.interval_label_format | json }} || '{n}-Month-Delivery';
    var BADGE_AUTO = {{ block.settings.save_badge_auto | default: false | json }};
    var moneyFormat = {{ shop.money_format | json }};

    var variants = [], groups = [];
    try { variants = JSON.parse(root.querySelector('.ptl-variants').textContent) || []; } catch (e) {}
    try { groups = JSON.parse(root.querySelector('.ptl-plans').textContent) || []; } catch (e) {}
    var plansById = {};
    groups.forEach(function (g) { (g.selling_plans || []).forEach(function (p) { plansById[String(p.id)] = p; }); });
    var hasPlans = Object.keys(plansById).length > 0;

    var subInput = root.querySelector('input[value="subscribe"]');
    var els = {
      interval: root.querySelector('[data-role="interval"]'),
      subPrice: root.querySelector('[data-role="sub-price"]'),
      subCompare: root.querySelector('[data-role="sub-compare"]'),
      badge: root.querySelector('[data-role="save-badge"]'),
      otPrice: root.querySelector('[data-role="ot-price"]'),
      otCompare: root.querySelector('[data-role="ot-compare"]')
    };

    function fmt(c) {
      if (typeof window.Elixir_FormatMoney === 'function') return window.Elixir_FormatMoney(c, moneyFormat);
      return String(moneyFormat).replace(/\{\{\s*amount\s*\}\}/, (Math.round(c) / 100).toFixed(2));
    }
    function setPrice(el, cents) { if (el) el.textContent = (cents || cents === 0) ? (fmt(cents) + SUFFIX) : ''; }
    function setCompare(el, cents, vs) { if (!el) return; if (cents && cents > vs) { el.textContent = fmt(cents); el.style.display = ''; } else { el.textContent = ''; el.style.display = 'none'; } }
    function variantIndex(v) { for (var i = 0; i < variants.length; i++) { if (String(variants[i].id) === String(v.id)) return i; } return 0; }
    function currentVariant() {
      var input = document.querySelector('input[name="id"]');
      var id = input && input.value;
      for (var i = 0; i < variants.length; i++) { if (String(variants[i].id) === String(id)) return variants[i]; }
      return variants[0] || null;
    }
    function intervalMonthsFromPlan(plan) {
      if (!plan) return null;
      var hay = '';
      if (plan.options) plan.options.forEach(function (o) { hay += ' ' + (o.value || '') + ' ' + (o.name || ''); });
      hay += ' ' + (plan.name || '');
      var m = hay.match(/(\d+)\s*month/i) || hay.match(/(\d+)/);
      return m ? parseInt(m[1], 10) : null;
    }
    function planForMonths(months) {
      var ids = Object.keys(plansById);
      for (var i = 0; i < ids.length; i++) { if (intervalMonthsFromPlan(plansById[ids[i]]) === months) return plansById[ids[i]]; }
      return ids.length ? plansById[ids[0]] : null;
    }
    function applyAdjustment(price, plan) {
      if (!plan || !plan.price_adjustments || !plan.price_adjustments.length) return price;
      var a = plan.price_adjustments[0];
      if (a.value_type === 'percentage') return Math.round(price * (1 - (a.value / 100)));
      if (a.value_type === 'fixed_amount') return Math.max(0, price - a.value);
      if (a.value_type === 'price') return a.value;
      return price;
    }
    function formatInterval(n) {
      if (!n) return 'Subscribe & Save';
      return String(LABEL_FMT).replace('{n}', n);
    }
    // Core dynamic-interval resolution.
    function resolvePlanForVariant(v) {
      if (!v) return null;
      if (MODE === 'auto') {
        var allocs = v.selling_plan_allocations || [];
        if (!allocs.length) return null;
        var a = allocs[0];
        var plan = plansById[String(a.selling_plan_id)];
        return { planId: a.selling_plan_id, months: plan ? intervalMonthsFromPlan(plan) : null,
                 subPrice: (typeof a.price !== 'undefined') ? a.price : v.price,
                 subCompare: a.compare_at_price || v.compare_at_price || 0 };
      }
      // mapped: pack position -> monthly / bi-monthly (auto-find plan by interval, or explicit id)
      var pos = variantIndex(v) + 1;
      var useBi = pos >= THRESHOLD;
      var months = useBi ? 2 : 1;
      var explicitId = useBi ? BIMONTHLY_ID : MONTHLY_ID;
      var plan = explicitId ? plansById[String(explicitId)] : planForMonths(months);
      return { planId: plan ? plan.id : explicitId, months: months,
               subPrice: plan ? applyAdjustment(v.price, plan) : v.price,
               subCompare: v.compare_at_price || 0 };
    }

    function isSubscribe() { return !!(subInput && subInput.checked); }
    function applySubscribe(r, v) {
      if (!r || !r.planId) return;
      if (typeof window.Elixir_SetProductFormSellingPlan === 'function') window.Elixir_SetProductFormSellingPlan(r.planId);
      var synthetic = { id: r.planId, priceAdjustments: [{ value_type: 'price', value: r.subPrice }] };
      if (typeof window.Elixir_SetSubscriptionContext === 'function') window.Elixir_SetSubscriptionContext(r.planId, v, synthetic);
    }
    function clearSubscribe() {
      if (typeof window.Elixir_SetProductFormSellingPlan === 'function') window.Elixir_SetProductFormSellingPlan('');
      if (typeof window.Elixir_SetSubscriptionContext === 'function') window.Elixir_SetSubscriptionContext();
    }

    function baseCompare() { var f = variants[0]; return (f && f.compare_at_price) || (f && f.price) || 0; }
    function packTotal(v) { if (window.__lumBundlePack && String(window.__lumBundlePack.variantId) === String(v.id)) return window.__lumBundlePack.total; return 1; }
    function emitPrice(price, compare) {
      document.dispatchEvent(new CustomEvent('lum:atc-price', { detail: { price: price, compare: compare } }));
    }
    function recompute() {
      var v = currentVariant();
      if (!v) return;
      var r = subInput ? resolvePlanForVariant(v) : null;
      // subscribe selected but no plan for this variant -> fall back to one-time
      if (subInput && subInput.checked && (!r || !r.planId || !hasPlans)) {
        var ot = root.querySelector('input[value="one_time"]');
        if (ot) { ot.checked = true; syncSelected(); }
      }
      var total = packTotal(v) || 1; // jars in the pack (paid + free)
      // benefits flagged multi-only (Free Shipping) belong to the 2+/3+ jar packs, not the single jar
      var multi = total > 1 || variantIndex(v) > 0;
      root.querySelectorAll('.ptl__benefits [data-multi-only]').forEach(function (li) { li.style.display = multi ? '' : 'none'; });
      // Purchase Type shows the PER-JAR price (pack total / jars); struck = single-jar compare-at, per jar.
      var jarStruck = baseCompare();
      var otJar = Math.round(v.price / total);
      setPrice(els.otPrice, otJar);
      setCompare(els.otCompare, jarStruck, otJar);
      if (r) {
        if (els.interval) els.interval.textContent = formatInterval(r.months);
        var subJar = Math.round(r.subPrice / total);
        setPrice(els.subPrice, subJar);
        setCompare(els.subCompare, jarStruck, subJar);
        if (els.badge && BADGE_AUTO && jarStruck > subJar) els.badge.textContent = 'Save ' + fmt(jarStruck - subJar);
      }
      var subscribing = isSubscribe() && hasPlans && r && r.planId;
      if (subscribing) applySubscribe(r, v); else clearSubscribe();
      // The ATC button keeps the PACK TOTAL price + pack-level struck (single-jar compare x jars).
      emitPrice(subscribing ? r.subPrice : v.price, baseCompare() * total);
    }

    function selectType(type) {
      var input = root.querySelector('input[value="' + type + '"]');
      if (input && !input.checked) { input.checked = true; }
      syncSelected();
      onToggle();
    }
    function syncSelected() {
      root.querySelectorAll('.ptl__card').forEach(function (c) {
        var i = c.querySelector('.ptl__input');
        c.classList.toggle('is-selected', !!(i && i.checked));
      });
    }
    function onToggle() {
      var v = currentVariant();
      if (isSubscribe() && hasPlans) {
        var r = resolvePlanForVariant(v);
        if (r && r.planId) applySubscribe(r, v); else clearSubscribe();
      } else {
        clearSubscribe();
      }
    }

    root.addEventListener('change', function (e) {
      if (!e.target.classList || !e.target.classList.contains('ptl__input')) return;
      syncSelected();
      recompute();
    });
    ['variant:change', 'simple-variant-picker:variantChange'].forEach(function (ev) {
      document.addEventListener(ev, function () { setTimeout(recompute, 0); });
    });
    document.addEventListener('change', function (e) { if (e.target && e.target.name === 'id') setTimeout(recompute, 0); });

    function init() { syncSelected(); recompute(); }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
    [200, 700, 1500].forEach(function (d) { setTimeout(recompute, d); });
    document.addEventListener('shopify:section:load', function () { setTimeout(init, 60); });
  })();
</script>
{%- endif -%}
