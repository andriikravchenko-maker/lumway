{% comment %}
  Block: CS Rating
  A star rating block for the Content Sidebar section.
{% endcomment %}

{%- assign this = block.settings -%}
{%- liquid 
  assign custom_styled = false
  if this.star_size > 0 or this.custom_size or this.text_color != blank or this.star_color != "#F1C40F" or this.empty_star_color != "#e0e0e0" or this.padding_top > 0 or this.padding_bottom > 0 or this.padding_left > 0 or this.padding_right > 0
    assign custom_styled = true
  endif
-%}

{%- if custom_styled -%}
  <style>
    #cs-rating-{{ block.id }} {
      padding: {{ this.padding_top }}px {{ this.padding_right }}px {{ this.padding_bottom }}px {{ this.padding_left }}px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    #cs-rating-{{ block.id }} .stars-wrapper {
      display: flex;
      align-items: center;
      gap: 2px;
    }
    #cs-rating-{{ block.id }} .stars-wrapper > svg {
      width: {{ this.star_size }}px;
      height: auto;
    }
    #cs-rating-{{ block.id }} .rating-block-text {
      {%- if this.custom_size -%}
        font-size: {{ this.text_size }}px;
      {%- endif -%}
      {%- if this.text_color != blank -%}
        color: {{ this.text_color }} !important;
      {%- endif -%}
      letter-spacing: var(--letter-spacing-body);
    }
    {%- if this.custom_size -%}
      @media screen and (max-width: 768px) {
        #cs-rating-{{ block.id }} .rating-block-text {
          font-size: {{ this.text_size | times: 0.9 | round }}px;
        }
      }
    {%- endif -%}
    {%- if this.star_color != "#F1C40F" -%}
      #cs-rating-{{ block.id }} .stars-wrapper svg g rect {
        fill: {{ this.star_color }};
      }
    {%- endif -%}
    {%- if this.empty_star_color != "#e0e0e0" -%}
      #cs-rating-{{ block.id }} .stars-wrapper svg path[stroke] {
        stroke: {{ this.empty_star_color }};
      }
    {%- endif -%}
  </style>
{%- endif -%}

<div 
  {% if custom_styled %}id="cs-rating-{{ block.id }}"{% endif %} 
  class="section-block rating-block" 
  {{ block.shopify_attributes }}
>
  <div class="stars-wrapper">
    {%- for i in (1..5) -%}
      {%- liquid 
        assign star_width = '100%'
        assign modulo = this.rating | modulo: 1
        assign target_index = this.rating | ceil
        
        if modulo > 0 and forloop.index == target_index
          assign star_width = modulo | split: '.' | last | times: 10 | append: '%'
        endif

        if forloop.index > target_index
          assign star_width = '0%'
        endif
      -%}
      <svg width="{{ this.star_size }}" height="{{ this.star_size }}" viewBox="0 0 1920 1920" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <mask id="cs-rating-{{ block.id }}_mask_{{ forloop.index }}" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1920">
            <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" fill="{{ this.star_color }}" fill-rule="evenodd"/>
          </mask>
        </defs>
        <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" stroke="{{ this.empty_star_color }}" stroke-width="10" fill="none" fill-rule="evenodd"/>
        <g mask="url(#cs-rating-{{ block.id }}_mask_{{ forloop.index }})">
          <rect width="1920" height="1920" fill="{{ this.star_color }}" style="width: {{ star_width }};" />
        </g>
      </svg>
    {%- endfor -%}
  </div>
  <div class="rating-block-text">
    {{ this.text }}
  </div>
</div>

{% schema %}
{
  "name": "CS Rating",
  "settings": [
    {
      "type": "range",
      "id": "rating",
      "label": "Rating",
      "default": 5,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    {
      "type": "number",
      "id": "star_size",
      "label": "Star size",
      "default": 20
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#F1C40F"
    },
    {
      "type": "color",
      "id": "empty_star_color",
      "label": "Empty star color",
      "default": "#e0e0e0"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "Text",
      "default": "3,791 Ratings"
    },
    {
      "type": "checkbox",
      "id": "custom_size",
      "label": "Custom text size",
      "default": false
    },
    {
      "type": "number",
      "id": "text_size",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_left",
      "label": "Padding left",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_right",
      "label": "Padding right",
      "default": 0
    }
  ],
  "presets": [
    { "name": "CS Rating" }
  ]
}
{% endschema %}
