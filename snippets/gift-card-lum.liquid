{%- comment -%}
  Gift / benefit card — Lumway PDP. Single card, all fields filled manually. Standalone snippet
  (snippets have no schema of their own): pass the values in from the caller's block/section settings.

  Figma reference: product image (left, rounded with tinted backing), title, description, a pill badge
  top-right (e.g. "Free"), and a struck-through compare price (e.g. "$40.00").

  Usage (from a section that owns the settings, e.g. product-details-lum):
    {%- render 'gift-card-lum',
        uid: block.id,
        image: block.settings.gc_image,
        title: block.settings.gc_title,
        text: block.settings.gc_text,
        badge: block.settings.gc_badge,
        badge_bg: block.settings.gc_badge_bg,
        badge_text_color: block.settings.gc_badge_text_color,
        compare_price: block.settings.gc_compare_price
    -%}

  All params optional. Any empty field is simply skipped (no empty nodes rendered).
{%- endcomment -%}

{%- liquid
  assign gc_uid = uid | default: 'gc'
  assign gc_badge_bg = badge_bg | default: '#fa6c56'
  assign gc_badge_fg = badge_text_color | default: '#ffffff'
-%}

{%- if title != blank or image != blank or text != blank -%}
  {%- style -%}
      .gclum-{{ gc_uid }}{
      --gclum-font:'Inter Tight', system-ui, sans-serif;
      --gclum-ink:#113b34;
      --gclum-card:#ffffff;
      --gclum-line:rgba(17,59,52,.08);
      --gclum-img-bg:#f4f4f2;
      display:flex; align-items:center; gap:16px;
      width:100%; padding:12px; box-sizing:border-box;
      background:var(--gclum-card); border:1px solid var(--gclum-line); border-radius:16px;
      box-shadow:0 1px 3px rgba(17,59,52,.05);
      }
      .gclum-{{ gc_uid }} .gclum__compare{ }
      .gclum-{{ gc_uid }} .gclum__media{ flex:0 0 72px; width:72px; height:72px; border-radius:12px; background:var(--gclum-img-bg); overflow:hidden; display:flex; align-items:center; justify-content:center; }
      .gclum-{{ gc_uid }} .gclum__media img{ display:block; width:100%; height:100%; object-fit:cover; border-radius: 8px !important;}
      .gclum-{{ gc_uid }} .gclum__body{ flex:1 1 auto; min-width:0; display:flex; flex-direction:column; gap:4px; }
      .gclum-{{ gc_uid }} .gclum__title{ margin:0; font-family:var(--gclum-font) !important; font-weight:700; font-size:18px; line-height:1.2; letter-spacing:-0.36px; color:var(--gclum-ink); }
      .gclum-{{ gc_uid }} .gclum__text{ margin:0; font-family:var(--gclum-font) !important; font-weight:400; font-size:14px; line-height:1.3; letter-spacing:-0.28px; color:rgba(17,59,52,.5); }
      .gclum-{{ gc_uid }} .gclum__aside{ flex:0 0 auto; display:flex; flex-direction:column; align-items:flex-end; justify-content:center; gap:8px; text-align:right; }
      .gclum-{{ gc_uid }} .gclum__badge{ display:inline-flex; align-items:center; padding:4px 12px; border-radius:4px; font-family:var(--gclum-font) !important; font-weight:500 !important; font-size:10px; line-height:1.2; letter-spacing:-0.28px; white-space:nowrap; background:{{ gc_badge_bg }}; color:{{ gc_badge_fg }}; }
      .gclum-purchase_type{border-radius:12px;}
      .gclum-{{ gc_uid }} .gclum__compare{ font-family:var(--gclum-font) !important; font-weight:400 !important; font-size:16px !important; line-height:1.2 !important; letter-spacing:-0.32px !important; color:rgba(17,59,52,.4) !important; text-decoration:line-through !important; white-space:nowrap !important; }
      @media (min-width:990px){
      .gclum-{{ gc_uid }} .gclum__title{ font-size:20px; letter-spacing:-0.4px; }
      }
      @media (max-width:768px){
        .gclum-{{ gc_uid }} {gap: 10px;}
      .gclum-{{ gc_uid }} .gclum__title{ font-size:14px; letter-spacing: 1.2; }
      .gclum-purchase_type{padding:4px !important; border-radius: 8px;}
      .gclum-{{ gc_uid }} .gclum__media{
        flex: 0 0 55px !important;
        width: 55px !important;
        height: 55px !important;
      }
      .gclum-{{ gc_uid }} .gclum__text{
        font-size: 12px;
    line-height: 1.2;
      }
         .gclum-{{ gc_uid }} .gclum__compare{font-size: 14px !important; }
      
      }
  {%- endstyle -%}

  <div class="gclum-{{ gc_uid }} gclum-purchase_type">
    {%- if image != blank -%}
      <div class="gclum__media">
        <img
          src="{{ image | image_url: width: 144 }}"
          alt="{{ title | default: '' | escape }}"
          width="72"
          height="72"
          loading="lazy"
        >
      </div>
    {%- endif -%}

    <div class="gclum__body">
      {%- if title != blank -%}
        <h3 class="gclum__title">{{ title | escape }}</h3>
      {%- endif -%}
      {%- if text != blank -%}
        <p class="gclum__text">{{ text | escape }}</p>
      {%- endif -%}
    </div>

    {%- if badge != blank or compare_price != blank -%}
      <div class="gclum__aside">
        {%- if badge != blank -%}
          <span class="gclum__badge">{{ badge | escape }}</span>
        {%- endif -%}
        {%- if compare_price != blank -%}
          <span class="gclum__compare">{{ compare_price | escape }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
