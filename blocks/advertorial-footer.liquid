    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link Hover Color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "link_decoration",
      "label": "Link Decoration",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "underline", "label": "Underline" }
