      }

      #shopify-section-{{ section.id }} .product-grid-wrapper .product-carousel-swiper .swiper-slide .product-card {
        height: auto;
        width: var(--mobile-carousel-width, 200px) !important;
        max-width: var(--mobile-carousel-width, 200px) !important;
        min-width: var(--mobile-carousel-width, 200px) !important;
