                            {% assign free_gift_text = option_1_free_gift_text %}
                            {% assign free_gift_icon = option_1_free_gift_icon %}
                            {% assign free_gift_icon_size = option_1_free_gift_icon_size %}
                            {% assign free_gift_font_size = option_1_free_gift_font_size %}
                            {% assign free_gift_border_radius = option_1_free_gift_border_radius %}
                            {% assign free_gift_bg_color = option_1_free_gift_bg_color %}
                            {% assign free_gift_use_gradient = option_1_free_gift_use_gradient %}
                            {% assign free_gift_gradient_start = option_1_free_gift_gradient_start %}
                            {% assign free_gift_gradient_end = option_1_free_gift_gradient_end %}
                            {% assign free_gift_text_color = option_1_free_gift_text_color %}
                            {% assign free_gift_border_color = option_1_free_gift_border_color %}
