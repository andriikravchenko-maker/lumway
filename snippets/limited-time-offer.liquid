<script>
  (function () {
    var section = document.getElementById('limited-time-offer-{{ offer_id }}');
    if (!section) return;

    var countdown = section.querySelector('[data-lto-countdown]');
    var timeEl = section.querySelector('[data-lto-countdown-time]');
    if (!countdown || !timeEl) return;

    function pad(n) {
      return String(n).padStart(2, '0');
    }

    var mode = countdown.getAttribute('data-mode');
    var end;

    if (mode === 'deadline') {
      var deadline = countdown.getAttribute('data-deadline');
      var parsed = Date.parse(deadline);
      end = !isNaN(parsed) ? parsed : Date.now() + (2 * 60 * 60 + 33 * 60 + 44) * 1000;
    } else {
      var hours = parseInt(countdown.getAttribute('data-hours') || '2', 10);
      var minutes = parseInt(countdown.getAttribute('data-minutes') || '33', 10);
      var seconds = parseInt(countdown.getAttribute('data-seconds') || '44', 10);
      end = Date.now() + ((hours * 60 + minutes) * 60 + seconds) * 1000;
    }

    function tick() {
      var diff = Math.max(0, end - Date.now());
      var total = Math.floor(diff / 1000);
      var h = Math.floor(total / 3600);
      var m = Math.floor((total % 3600) / 60);
      var s = total % 60;
      timeEl.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
      if (diff > 0) window.setTimeout(tick, 1000);
    }

    tick();
  })();
</script>
