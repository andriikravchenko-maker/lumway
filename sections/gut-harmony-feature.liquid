{% comment %} Section: gut-harmony-feature — numbered feature: title + composite graphic (left) + body & testimonial (right) {% endcomment %}

{%- unless settings.enable_oswald_font -%}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}
{%- unless settings.enable_league_spartan_font -%}
  <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@400;500;600;700&display=swap" rel="stylesheet">
{%- endunless -%}
<link href="https://fonts.googleapis.com/css2?family=Urbanist:ital,wght@1,500;1,700&display=swap" rel="stylesheet">

{%- liquid
  if section.settings.use_theme_colors
    assign background_color = settings.global_section_background_color
    assign title_color = settings.global_section_heading_color | default: settings.global_section_text_color
    assign text_color = settings.global_section_text_color
    assign testimonial_color = settings.global_section_text_color
  else
    assign background_color = section.settings.background_color
    assign title_color = section.settings.title_color
    assign text_color = section.settings.text_color
    assign testimonial_color = section.settings.testimonial_color
  endif

  assign image_alt = section.settings.image.alt | default: section.settings.title
-%}

{% style %}
  .section-{{ section.id }} {
    --ghf-font-heading: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghf-font-body: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghf-font-quote: 'Urbanist', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --ghf-bg: {{ background_color }};
    --ghf-title-color: {{ title_color }};
    --ghf-text-color: {{ text_color }};
    --ghf-testimonial-color: {{ testimonial_color }};
    --ghf-title-size: {{ section.settings.title_size }}px;
    --ghf-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --ghf-text-size: {{ section.settings.text_size }}px;
    --ghf-testimonial-size: {{ section.settings.testimonial_size }}px;
    --ghf-testimonial-gap: {{ section.settings.testimonial_paragraph_spacing }}px;
    --ghf-image-radius: {{ section.settings.image_border_radius }}px;
    --ghf-title-gap: {{ section.settings.title_gap }}px;
    --ghf-column-gap: {{ section.settings.column_gap }}px;
    --ghf-content-gap: {{ section.settings.content_gap }}px;
    --ghf-pad-top: {{ section.settings.padding_top }}px;
    --ghf-pad-bottom: {{ section.settings.padding_bottom }}px;
    --ghf-pad-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --ghf-pad-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --ghf-btn-bg: {{ section.settings.button_bg_color }};
    --ghf-btn-bg-hover: {{ section.settings.button_hover_bg_color }};
    --ghf-btn-text: {{ section.settings.button_text_color }};
    --ghf-btn-size: {{ section.settings.button_font_size }}px;
    --ghf-btn-radius: {{ section.settings.button_radius }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--ghf-bg);
    padding-top: var(--ghf-pad-top-mobile);
    padding-bottom: var(--ghf-pad-bottom-mobile);
  }

  .section-{{ section.id }} .gut-harmony-feature__inner {
    display: flex;
    flex-direction: column;
    gap: var(--ghf-title-gap);
    max-width: 1204px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
  }

  /* theme forces h1-h6 / [class*="title"] { color: ... !important }; keep the design's dark green */
  .section-{{ section.id }} .gut-harmony-feature__title {
    margin: 0;
    font-family: var(--ghf-font-heading);
    font-weight: 700;
    line-height: 1.2;
    color: var(--ghf-title-color) !important;
    font-size: clamp(var(--ghf-title-size-mobile), 3.2vw, var(--ghf-title-size));
  }

  .section-{{ section.id }} .gut-harmony-feature__row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ghf-column-gap);
  }

  .section-{{ section.id }} .gut-harmony-feature__media {
    width: 100%;
    max-width: 486px;
    flex-shrink: 0;
  }

  .section-{{ section.id }} .gut-harmony-feature__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--ghf-image-radius);
  }

  .section-{{ section.id }} .gut-harmony-feature__img--placeholder {
    background-color: #eef0f1;
    fill: #b9c3c9;
  }

  .section-{{ section.id }} .gut-harmony-feature__content {
    display: flex;
    flex-direction: column;
    gap: var(--ghf-content-gap);
    width: 100%;
  }

  /* theme forces p { font-family: body !important } and font-weight: regular !important; lock to League Spartan Medium per the design */
  .section-{{ section.id }} .gut-harmony-feature__body p {
    margin: 0 0 var(--ghf-content-gap);
    font-family: var(--ghf-font-body) !important;
    font-weight: 500 !important;
    font-size: var(--ghf-text-size);
    line-height: 1.4;
    color: var(--ghf-text-color);
  }

  .section-{{ section.id }} .gut-harmony-feature__body p:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .gut-harmony-feature__body strong {
    font-weight: 700 !important;
  }

  /* testimonial uses Urbanist italic in the design; override the theme's forced body font */
  .section-{{ section.id }} .gut-harmony-feature__testimonial p {
    margin: 0 0 var(--ghf-testimonial-gap);
    font-family: var(--ghf-font-quote) !important;
    font-weight: 500 !important;
    font-style: italic;
    font-size: var(--ghf-testimonial-size);
    line-height: 1.4;
    color: var(--ghf-testimonial-color);
  }

  .section-{{ section.id }} .gut-harmony-feature__testimonial p:last-child {
    margin-bottom: 0;
  }

  .section-{{ section.id }} .gut-harmony-feature__testimonial strong {
    font-weight: 700 !important;
    font-style: italic;
  }

  .section-{{ section.id }} .gut-harmony-feature__cta {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .section-{{ section.id }} .gut-harmony-feature__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    text-align: center;
    max-width: 100%;
    box-sizing: border-box;
    padding: 12px 64px;
    border: 0;
    border-radius: var(--ghf-btn-radius);
    background-color: var(--ghf-btn-bg);
    color: var(--ghf-btn-text) !important;
    font-family: var(--ghf-font-body) !important;
    font-weight: 500 !important;
    font-size: var(--ghf-btn-size);
    line-height: 1.4;
    text-transform: capitalize;
    white-space: nowrap;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .section-{{ section.id }} .gut-harmony-feature__button-arrow {
    display: inline-block;
    line-height: 1;
    font-weight: 500 !important;
  }

  .section-{{ section.id }} .gut-harmony-feature__button:hover {
    background-color: var(--ghf-btn-bg-hover);
  }

  .section-{{ section.id }} .gut-harmony-feature__button:focus-visible {
    outline: 3px solid var(--ghf-btn-bg-hover);
    outline-offset: 3px;
  }

  @media screen and (max-width: 600px) {
    .section-{{ section.id }} .gut-harmony-feature__button {
      width: 100%;
      padding: 14px 24px;
      white-space: normal;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .gut-harmony-feature__button { transition: none; }
  }

  @media screen and (min-width: 1240px) {
    .section-{{ section.id }} {
      padding-top: var(--ghf-pad-top);
      padding-bottom: var(--ghf-pad-bottom);
    }

    .section-{{ section.id }} .gut-harmony-feature__inner {
      padding-inline: 0;
    }

    .section-{{ section.id }} .gut-harmony-feature__row {
      flex-direction: row;
      align-items: center;
      gap: var(--ghf-column-gap);
    }

    .section-{{ section.id }} .gut-harmony-feature__media {
      flex: 0 0 486px;
    }

    .section-{{ section.id }} .gut-harmony-feature__content {
      flex: 0 0 694px;
      max-width: 694px;
    }

    /* Figma frame 133:7 is a fixed 560px-wide pill, not hug-content */
    .section-{{ section.id }} .gut-harmony-feature__button {
      min-width: 560px;
    }
  }
{% endstyle %}

<section class="gut-harmony-feature section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="gut-harmony-feature__inner">
    {%- if section.settings.title != blank -%}
      <h2 class="gut-harmony-feature__title">{{ section.settings.title }}</h2>
    {%- endif -%}

    <div class="gut-harmony-feature__row">
      <div class="gut-harmony-feature__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 972
            | image_tag:
              loading: 'lazy',
              widths: '300,400,486,600,800,972',
              sizes: '(min-width: 1240px) 486px, 100vw',
              alt: image_alt,
              class: 'gut-harmony-feature__img'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'gut-harmony-feature__img gut-harmony-feature__img--placeholder' }}
        {%- endif -%}
      </div>

      <div class="gut-harmony-feature__content">
        {%- if section.settings.body_text != blank -%}
          <div class="gut-harmony-feature__body">{{ section.settings.body_text }}</div>
        {%- endif -%}
        {%- if section.settings.testimonial_text != blank -%}
          <div class="gut-harmony-feature__testimonial">{{ section.settings.testimonial_text }}</div>
        {%- endif -%}
      </div>
    </div>
    {%- if section.settings.button_text != blank -%}
      <div class="gut-harmony-feature__cta">
        <a class="gut-harmony-feature__button" href="{{ section.settings.button_link | default: '#' }}">
          <span class="gut-harmony-feature__button-text">{{ section.settings.button_text }}</span>
          {%- if section.settings.button_show_arrow -%}
            <span class="gut-harmony-feature__button-arrow" aria-hidden="true">&rarr;</span>
          {%- endif -%}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Gut Harmony Feature",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false,
      "info": "Apply the global theme colors to this section instead of the ones below."
