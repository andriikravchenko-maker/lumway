  </style>

  <script type="application/json" id="selling-plans-data-{{ block.id }}">
    [
    {%- assign plan_index = 0 -%}
    {%- for group in product.selling_plan_groups -%}
      {%- for plan in group.selling_plans -%}
        {%- assign plan_index = plan_index | plus: 1 -%}
        {%- if plan_index > 1 -%},{%- endif -%}
        {
          "id": {{ plan.id }},
          "name": {{ plan.name | json }},
          "description": {{ plan.description | json }},
          "priceAdjustments": [
            {%- assign adj_index = 0 -%}
            {%- for adjustment in plan.price_adjustments -%}
              {%- assign adj_index = adj_index | plus: 1 -%}
              {%- if adj_index > 1 -%},{%- endif -%}
              {
                "valueType": {{ adjustment.value_type | json }},
                "value": {{ adjustment.value }}
              }
            {%- endfor -%}
          ],
          "options": [
            {%- assign opt_index = 0 -%}
            {%- for option in plan.options -%}
              {%- assign opt_index = opt_index | plus: 1 -%}
              {%- if opt_index > 1 -%},{%- endif -%}
              {
                "name": {% if option.name != blank %}{{ option.name | json }}{% elsif option.value != blank %}{{ option.value | json }}{% else %}{{ option | json }}{% endif %},
                "value": {% if option.value != blank %}{{ option.value | json }}{% elsif option.name != blank %}{{ option.name | json }}{% else %}{{ option | json }}{% endif %}
              }
            {%- endfor -%}
          ]
        }
      {%- endfor -%}
    {%- endfor -%}
    ]
  </script>

  <script>
    (function() {
      function initDynamicSubscribeSave() {
        const outerWrapper = document.querySelector('.subscribe-save-dynamic-outer[data-block-id="{{ block.id }}"]');
        if (!outerWrapper) {
          return;
        }
        const dynamicWrappers = outerWrapper.querySelectorAll('.subscribe-save-wrapper-dynamic');
        if (dynamicWrappers.length === 0) {
          return;
        }

        const form = (typeof Elixir_GetProductForm === 'function' && Elixir_GetProductForm()) || document.querySelector('form[action*="/cart/add"]');
        const toggles = document.querySelectorAll('.subscribe-save-wrapper-dynamic[data-block-id="{{ block.id }}"] .subscribe-toggle-dynamic');
        
        // Get selling plans data
        const sellingPlansDataEl = document.getElementById('selling-plans-data-{{ block.id }}');
        let sellingPlans = [];
        try {
          if (sellingPlansDataEl) {
            sellingPlans = JSON.parse(sellingPlansDataEl.textContent);
          }
        } catch (e) {
          console.error('[Subscribe & Save] Error parsing selling plans data:', e, sellingPlansDataEl?.textContent);
        }

        const productVariants = {{ product.variants | json }};
        const moneyFormat = {{ shop.money_format | json }};
        const multiplyByQuantity = outerWrapper.dataset.multiplyByQuantity !== 'false';

        /** Use global Elixir_SetSubscriptionContext (theme-loaders.js). No args = clear. */
        function ensureSingleActiveToggle(activeToggle) {
          toggles.forEach(toggle => {
            if (toggle !== activeToggle && toggle.checked) {
              toggle.checked = false;
              toggle.dispatchEvent(new Event('change'));
            }
          });
        }

        function getCurrentVariant() {
          const variantId = (typeof Elixir_GetProductFormVariantId === 'function' && Elixir_GetProductFormVariantId()) || null;
          if (!variantId) {
            return productVariants[0] || null;
          }
          const variant = productVariants.find(v => v.id.toString() === variantId.toString());
          if (!variant) {
            console.warn('[Subscribe & Save] Variant not found for ID:', variantId, 'Available variants:', productVariants.map(v => v.id));
            return productVariants[0] || null;
          }
          return variant;
        }

        function getQuantity() {
          if (!form) return 1;
          const input = form.querySelector('input[name="quantity"]');
          const qty = input ? parseInt(input.value, 10) : 1;
          return isNaN(qty) || qty < 1 ? 1 : qty;
        }

        /**
         * Calculate subscription price based on variant price and selling plan adjustments (used when wrapper plan is not the active context)
         */
        function calculateSubscriptionPrice(variant, plan) {
          if (!variant || !plan) {
            console.warn('[Subscribe & Save] calculateSubscriptionPrice: Missing variant or plan', { variant: !!variant, plan: !!plan });
            return null;
          }
          
          // define values format for price
          let basePrice = 0;
          if (typeof variant.price === 'number') {
            basePrice = variant.price;
          } else if (typeof variant.price === 'string') {
            basePrice = parseInt(variant.price) || 0;
          } else if (variant.currentPrice) {
            basePrice = typeof variant.currentPrice === 'number' ? variant.currentPrice : parseInt(variant.currentPrice) || 0;
          }
          
          let finalPrice = basePrice;
          
          if (plan.priceAdjustments && plan.priceAdjustments.length > 0) {
            const adjustment = plan.priceAdjustments[0];
            const adjustmentValue = parseFloat(adjustment.value);
            
            switch (adjustment.valueType) {
              case 'percentage':
                finalPrice = basePrice * (1 - adjustmentValue / 100);
                break;
              case 'fixed_amount':
                finalPrice = basePrice - adjustmentValue;
                break;
              case 'price':
                finalPrice = adjustmentValue;
                break;
              default:
                // No adjustment or unknown type, so we will use base price
                finalPrice = basePrice;
                break;
            }
          }
          
          let compareAtPrice = null;
          if (variant.compare_at_price) {
            compareAtPrice = typeof variant.compare_at_price === 'number' 
              ? variant.compare_at_price 
              : parseInt(variant.compare_at_price);
          } 
          else if (variant.compareAtPrice) {
            compareAtPrice = typeof variant.compareAtPrice === 'number' 
              ? variant.compareAtPrice 
              : parseInt(variant.compareAtPrice);
          }
          
          const result = {
            subscriptionPrice: Math.max(0, Math.round(finalPrice)),
            compareAtPrice: compareAtPrice
          };
          return result;
        }

        /**
         * Update price display for a specific plan (by plan id; used when we have data-plan-id on elements)
         */
        function updatePlanPrice(planId) {          
          const variant = getCurrentVariant();
          const plan = sellingPlans.find(p => p.id.toString() === planId.toString());
          
          if (!variant || !plan) {
            return;
          }
          
          const priceData = calculateSubscriptionPrice(variant, plan);
          
          if (!priceData) {
            return;
          }
          
          const priceCurrentEl = document.querySelector(`.subscribe-price-current[data-plan-id="${planId}"]`);
          const priceCompareEl = document.querySelector(`.subscribe-price-compare[data-plan-id="${planId}"]`);
          
          if (priceCurrentEl) {
            const formattedPrice = Elixir_FormatMoney(priceData.subscriptionPrice, moneyFormat);
            priceCurrentEl.textContent = formattedPrice;
          }
          
          if (priceCompareEl) {
            const basePrice = parseInt(variant.price) || 0;
            const comparePrice = priceData.compareAtPrice || basePrice;
            
            if (comparePrice > priceData.subscriptionPrice) {
              priceCompareEl.textContent = Elixir_FormatMoney(comparePrice, moneyFormat);
              priceCompareEl.style.display = '';
            } 
            else {
              priceCompareEl.style.display = 'none';
            }
          }
        }

        /**
         * Update price display for one group wrapper (dropdown selects which plan; price elements have data-group-id).
         * When this wrapper's plan is the active subscription, uses Elixir_GetDisplayPrice (theme-loaders); otherwise uses local calculateSubscriptionPrice.
         */
        function updateWrapperPrice(wrapper) {
          const dropdown = wrapper.querySelector('.subscribe-frequency-dropdown');
          const planId = dropdown && dropdown.value ? dropdown.value.trim() : null;
          if (!planId) return;
          const variant = getCurrentVariant();
          const plan = sellingPlans.find(p => p.id.toString() === planId.toString());
          if (!variant || !plan) return;
          const priceCurrentEl = wrapper.querySelector('.subscribe-price-current[data-group-id]');
          const priceCompareEl = wrapper.querySelector('.subscribe-price-compare[data-group-id]');
          const isActivePlan = window.subscriptionContext && String(window.subscriptionContext.sellingPlanId) === String(planId);
          const qty = getQuantity();
          let priceCents, compareCents;
          if (isActivePlan && typeof Elixir_GetDisplayPrice === 'function') {
            const compareAt = variant.compare_at_price != null ? variant.compare_at_price : (variant.compareAtPrice != null ? variant.compareAtPrice : 0);
            const result = Elixir_GetDisplayPrice({
              price: variant.price,
              quantity: qty,
              multiplyByQuantity: multiplyByQuantity,
              compareAtPrice: compareAt,
              applySubscriptionDiscount: true
            });
            priceCents = result.price;
            compareCents = result.compareAtPrice;
          } else {
            const priceData = calculateSubscriptionPrice(variant, plan);
            if (!priceData) return;
            priceCents = priceData.subscriptionPrice * Math.max(1, qty);
            const compareAt = priceData.compareAtPrice != null ? priceData.compareAtPrice : (parseInt(variant.compare_at_price || variant.compareAtPrice, 10) || 0);
            compareCents = compareAt * Math.max(1, qty);
          }
          if (priceCurrentEl) {
            priceCurrentEl.textContent = Elixir_FormatMoney(priceCents, moneyFormat);
          }
          if (priceCompareEl) {
            if (compareCents > priceCents) {
              priceCompareEl.textContent = Elixir_FormatMoney(compareCents, moneyFormat);
              priceCompareEl.style.display = '';
            } else {
              priceCompareEl.style.display = 'none';
            }
          }
        }

        function updateAllPlanPrices() {
          const qty = getQuantity();
          dynamicWrappers.forEach(wrapper => {
            updateWrapperPrice(wrapper);
          });
        }

        /**
         * Update price display for one group wrapper with a specific variant (same logic as updateWrapperPrice; used when variant comes from event)
         */
        function updateWrapperPriceWithVariant(wrapper, variant) {
          if (!variant) return;
          const dropdown = wrapper.querySelector('.subscribe-frequency-dropdown');
          const planId = dropdown && dropdown.value ? dropdown.value.trim() : null;
          if (!planId) return;
          const plan = sellingPlans.find(p => p.id.toString() === planId.toString());
          if (!plan) return;
          const priceCurrentEl = wrapper.querySelector('.subscribe-price-current[data-group-id]');
          const priceCompareEl = wrapper.querySelector('.subscribe-price-compare[data-group-id]');
          const isActivePlan = window.subscriptionContext && String(window.subscriptionContext.sellingPlanId) === String(planId);
          const qty = getQuantity();
          let priceCents, compareCents;
          if (isActivePlan && typeof Elixir_GetDisplayPrice === 'function') {
            const compareAt = variant.compare_at_price != null ? variant.compare_at_price : (variant.compareAtPrice != null ? variant.compareAtPrice : 0);
            const result = Elixir_GetDisplayPrice({
              price: variant.price,
              quantity: qty,
              multiplyByQuantity: multiplyByQuantity,
              compareAtPrice: compareAt,
              applySubscriptionDiscount: true
            });
            priceCents = result.price;
            compareCents = result.compareAtPrice;
          } else {
            const priceData = calculateSubscriptionPrice(variant, plan);
            if (!priceData) return;
            priceCents = priceData.subscriptionPrice * Math.max(1, qty);
            const compareAt = priceData.compareAtPrice != null ? priceData.compareAtPrice : (parseInt(variant.compare_at_price || variant.compareAtPrice, 10) || 0);
            compareCents = compareAt * Math.max(1, qty);
          }
          if (priceCurrentEl) {
            priceCurrentEl.textContent = Elixir_FormatMoney(priceCents, moneyFormat);
          }
          if (priceCompareEl) {
            if (compareCents > priceCents) {
              priceCompareEl.textContent = Elixir_FormatMoney(compareCents, moneyFormat);
              priceCompareEl.style.display = '';
            } else {
              priceCompareEl.style.display = 'none';
            }
          }
        }

        /**
         * Update all plan prices with a specific variant (used when variant comes from event)
         */
        function updateAllPlanPricesWithVariant(variant) {
          if (!variant) return;
          dynamicWrappers.forEach(wrapper => {
            updateWrapperPriceWithVariant(wrapper, variant);
          });
        }

        /**
         * Update subscription in cart form
         */
        function updateSubscription(planId, isSubscribe) {
          if (!form) return;

          if (typeof Elixir_SetProductFormSellingPlan === 'function') {
            Elixir_SetProductFormSellingPlan(isSubscribe ? planId : '');
          }

          // Update window context
          if (isSubscribe) {
            const variant = getCurrentVariant();
            const plan = sellingPlans.find(p => p.id.toString() === planId.toString());
            Elixir_SetSubscriptionContext(planId, variant, plan);
          } else {
            Elixir_SetSubscriptionContext();
          }
        }

        toggles.forEach(toggle => {
          toggle.addEventListener('change', function() {
            const wrapper = this.closest('.subscribe-save-wrapper-dynamic');
            const dropdown = wrapper ? wrapper.querySelector('.subscribe-frequency-dropdown') : null;
            const isChecked = this.checked;

            if (isChecked) {
              ensureSingleActiveToggle(this);
              // Defer so "uncheck" handlers run first and clear selling_plan; then we set the correct plan
              const planId = (dropdown && dropdown.value) ? dropdown.value.trim() : '';
              setTimeout(function() {
                updateSubscription(planId, true);
                if (wrapper) updateWrapperPrice(wrapper);
              }, 0);
            } else {
              updateSubscription('', false);
              if (wrapper) updateWrapperPrice(wrapper);
            }
          });
        });

        dynamicWrappers.forEach(wrapper => {
          const dropdown = wrapper.querySelector('.subscribe-frequency-dropdown');
          if (dropdown) {
            dropdown.addEventListener('change', function() {
              const toggle = wrapper.querySelector('.subscribe-toggle-dynamic');
              if (toggle && toggle.checked) {
                const planId = this.value ? this.value.trim() : '';
                updateSubscription(planId, true);
                updateWrapperPrice(wrapper);
              }
            });
          }
        });

        function syncContextAndUpdatePrices() {
          const variant = getCurrentVariant();
          if (window.subscriptionContext && window.subscriptionContext.sellingPlanId && variant) {
            const plan = sellingPlans.find(p => p.id.toString() === window.subscriptionContext.sellingPlanId);
            if (plan) Elixir_SetSubscriptionContext(window.subscriptionContext.sellingPlanId, variant, plan);
          }
          updateAllPlanPrices();
        }

        document.addEventListener('simple-variant-picker:variantChange', function(event) {
          const eventVariant = event.detail && event.detail.variant;
          if (eventVariant && eventVariant.id) {
            const normalizedVariant = {
              id: eventVariant.id,
              price: eventVariant.price || eventVariant.currentPrice || 0,
              compare_at_price: eventVariant.compare_at_price != null ? eventVariant.compare_at_price : (eventVariant.compareAtPrice != null ? eventVariant.compareAtPrice : null)
            };
            if (window.subscriptionContext && window.subscriptionContext.sellingPlanId) {
              const plan = sellingPlans.find(p => p.id.toString() === window.subscriptionContext.sellingPlanId);
              if (plan) Elixir_SetSubscriptionContext(window.subscriptionContext.sellingPlanId, normalizedVariant, plan);
            }
            updateAllPlanPricesWithVariant(normalizedVariant);
          } else {
            setTimeout(syncContextAndUpdatePrices, 0);
          }
        });

        document.addEventListener('quantity:changed', function(e) {
          console.log('[Subscribe & Save] quantity:changed received', e.detail);
          updateAllPlanPrices();
        });

        document.addEventListener('quantity_break:changed', updateAllPlanPrices);

        document.addEventListener('subscriptionContext:updated', updateAllPlanPrices);

        // Initialize prices and subscription state on load.
        // First frequency option is already selected in Liquid (option with {% if forloop.first %}selected{% endif %}).
        // Here we: (1) update prices for each wrapper from its dropdown value; (2) if no toggle is checked, check the first one (which uses that dropdown's first-option value); (3) if any toggle is already checked, sync selling_plan and context from each checked wrapper's dropdown value.
        setTimeout(() => {
          updateAllPlanPrices();
          const checkedToggles = Array.from(toggles).filter(t => t.checked);
          if (checkedToggles.length === 0 && toggles.length > 0) {
            const firstToggle = toggles[0];
            firstToggle.checked = true;
            firstToggle.dispatchEvent(new Event('change', { bubbles: true }));
          } else {
            checkedToggles.forEach(toggle => {
              const wrapper = toggle.closest('.subscribe-save-wrapper-dynamic');
              if (wrapper) {
                const planId = (wrapper.querySelector('.subscribe-frequency-dropdown')?.value || '').trim();
                if (planId) updateSubscription(planId, true);
                updateWrapperPrice(wrapper);
              }
            });
          }
        }, 200);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDynamicSubscribeSave);
      } else {
        initDynamicSubscribeSave();
      }
    })();
  </script>
