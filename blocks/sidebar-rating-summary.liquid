{% comment %}
  Theme block: Sidebar Rating Summary
  Shows average rating and distribution bars.
{% endcomment %}

{% assign s = block.settings %}

<style>
  #sidebar-rating-{{ block.id }} {
    {% if s.show_background %}
      background-color: {{ s.background_color }};
      padding: {{ s.padding }}px;
      border-radius: {{ s.border_radius }}px;
    {% endif %}
  }
  #sidebar-rating-{{ block.id }} h4 {
    {% if s.show_background %}
      padding-top: 0;
    {% endif %}
  }
</style>

<div id="sidebar-rating-{{ block.id }}" class="sidebar-rating" {{ block.shopify_attributes }}>
  {% if s.sidebar_title != blank %}
    <h4 class="h4">{{ s.sidebar_title }}</h4>
  {% endif %}

  <div class="ratings-by-star">
    <div class="total-rating">
      {% liquid
        assign five_star_rating = 5 | times: s.five_star_bar
        assign four_star_rating = 4 | times: s.four_star_bar
        assign three_star_rating = 3 | times: s.three_star_bar
        assign two_star_rating = 2 | times: s.two_star_bar
        assign one_star_rating = 1 | times: s.one_star_bar
        assign review_rating_total = five_star_rating | plus: four_star_rating | plus: three_star_rating | plus: two_star_rating | plus: one_star_rating

        assign average_rating = review_rating_total | times: 1.0 | divided_by: 100
        assign truncated_rating = average_rating | times: 10 | floor | divided_by: 10.0
      %}

      <div class="stars-wrapper">
        {% for i in (1..5) %}
          {% liquid
            assign star_width = '100%'
            assign modulo = average_rating | modulo: 1
            assign target_index = average_rating | ceil

            if modulo > 0 and forloop.index == target_index
              assign star_width = modulo | split: '.' | last | times: 10 | append: '%'
            endif

            if forloop.index > target_index
              assign star_width = '0%'
            endif
          %}
          <svg
            width="{{ s.rating_star_size }}"
            height="{{ s.rating_star_size }}"
            viewBox="0 0 1920 1920"
            xmlns="http://www.w3.org/2000/svg"
          >
            <defs>
              <mask id="sidebar-rating-mask-{{ block.id }}-{{ forloop.index }}" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1920">
                <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" fill="{{ s.rating_star_color }}" fill-rule="evenodd"/>
              </mask>
            </defs>
            <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" stroke="{{ s.rating_empty_star_color }}" stroke-width="10" fill="none" fill-rule="evenodd"/>
            <g mask="url(#sidebar-rating-mask-{{ block.id }}-{{ forloop.index }})">
              <rect width="1920" height="1920" fill="{{ s.rating_star_color }}" style="width: {{ star_width }};" />
            </g>
          </svg>
        {% endfor %}
      </div>
      <div class="review-rating-text">{{ truncated_rating }} out of 5</div>
    </div>

    <div class="ratings">
      {% for i in (1..5) %}
        {% liquid
          case forloop.index
            when 5
              assign index_string = 'five'
              assign bar_value = s.five_star_bar
            when 4
              assign index_string = 'four'
              assign bar_value = s.four_star_bar
            when 3
              assign index_string = 'three'
              assign bar_value = s.three_star_bar
            when 2
              assign index_string = 'two'
              assign bar_value = s.two_star_bar
            when 1
              assign index_string = 'one'
              assign bar_value = s.one_star_bar
          endcase
        %}
        <div class="star-bar {{ index_string }}-star-bar">
          <div>{{ forloop.index }} Star</div>
          <div class="rating-bar">
            <div class="rating-progress" style="--bar-progress: {{ bar_value }}%;"></div>
          </div>
          <div>{{ bar_value }}%</div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Sidebar Rating Summary",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "sidebar_title",
      "label": "Sidebar Title",
      "default": "Customer Reviews"
    },
    {
      "type": "range",
      "id": "five_star_bar",
      "label": "5 Star Bar",
      "default": 90,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "four_star_bar",
      "label": "4 Star Bar",
      "default": 7,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "three_star_bar",
      "label": "3 Star Bar",
      "default": 2,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "two_star_bar",
      "label": "2 Star Bar",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "one_star_bar",
      "label": "1 Star Bar",
      "default": 1,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "show_background",
      "label": "Show Background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "default": 20,
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "default": 8,
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "range",
      "id": "rating_star_size",
      "label": "Rating Star Size",
      "default": 15,
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "rating_star_color",
      "label": "Rating Star Color",
      "default": "#F1C40F"
    },
    {
      "type": "color",
      "id": "rating_empty_star_color",
      "label": "Rating Empty Star Color",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Progress Bars"
    },
    {
      "type": "checkbox",
      "id": "use_progress_gradient",
      "label": "Use gradient for rating progress bars",
      "default": false
    },
    {
      "type": "color",
      "id": "progress_gradient_start",
      "label": "Progress bar gradient start color",
      "default": "#1a3a5c"
    },
    {
      "type": "color",
      "id": "progress_gradient_end",
      "label": "Progress bar gradient end color",
      "default": "#0f2a45"
    }
  ],
  "presets": [{ "name": "Sidebar Rating Summary" }]
}
{% endschema %}
