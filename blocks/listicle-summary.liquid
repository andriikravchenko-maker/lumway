<div class="listicle-summary listicle-summary-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.content != blank %}
    <div class="summary-content">{{ block.settings.content }}</div>
  {% endif %}
</div>

<style>
  .listicle-summary-{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    border-bottom: 1px solid #eee;
  }
  .listicle-summary-{{ block.id }} .summary-content {
    font-size: 1.1em;
    line-height: 1.6;
  }

  /* Highlighter Style */
  {% if block.settings.enable_highlight %}
  .listicle-summary-{{ block.id }} .summary-content strong {
    background: {{ block.settings.highlight_color }};
    padding: 0 4px;
    border-radius: 2px;
    display: inline;
    box-decoration-break: clone;
    -webkit-box-decoration-break: clone;
  }
  {% endif %}
</style>

{% schema %}
{
  "name": "Listicle Summary",
  "tag": "div",
  "class": "listicle-summary-wrapper",
  "presets": [
    { "name": "Listicle Summary" }
  ],
  "settings": [
    {
      "type": "richtext",
      "id": "content",
      "label": "Summary Content",
      "default": "<p>Add a brief summary of your listicle here.</p>"
    },
    {
      "type": "header",
      "content": "Highlighter"
    },
    {
      "type": "checkbox",
      "id": "enable_highlight",
      "label": "Highlight Bold Text",
      "default": false,
      "info": "Adds a highlighter background to bold words within the content."
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Highlight Color",
      "default": "#fdf2f8"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 20
    }
  ]
}
{% endschema %}

