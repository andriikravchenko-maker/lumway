      <div class="desktop-view">
        <div class="sticky-add-to-cart__product">
          <div class="sticky-add-to-cart__image">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 60, height: 60, crop: 'center' }}"
                alt="{{ product.title }}"
                width="60"
                height="60"
                loading="lazy"
              >
            {% elsif section.settings.fallback_image %}
              <img
                src="{{ section.settings.fallback_image | image_url: width: 60, height: 60, crop: 'center' }}"
