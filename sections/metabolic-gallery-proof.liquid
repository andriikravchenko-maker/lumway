{% style %}
  .section-{{ section.id }} {
    --mg-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mg-bg: {{ section_bg }};
    --mg-ink: {{ ink }};
    --mg-accent: {{ accent }};
    --mg-button-bg: {{ section.settings.button_background }};
    --mg-button-text: {{ section.settings.button_text_color }};
    --mg-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --mg-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}px;
    --mg-heading-size: {{ section.settings.heading_size }}px;
    --mg-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --mg-body-size: {{ section.settings.body_size }}px;
    --mg-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --mg-image-max: {{ section.settings.image_max_width }}px;
    --mg-image-radius: {{ section.settings.image_radius }}px;
    --mg-gap: {{ section.settings.section_gap }}px;
    --mg-pad-top: {{ section.settings.padding_top }}px;
    --mg-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mg-bg);
    padding-top: var(--mg-pad-top);
    padding-bottom: var(--mg-pad-bottom);
  }

  .section-{{ section.id }} .mg__inner {
    max-width: 1640px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3vw, var(--mg-gap));
  }

  /* Eyebrow */
  .section-{{ section.id }} .mg__eyebrow {
    max-width: 760px;
    text-align: center;
  }
  .section-{{ section.id }} .mg__eyebrow p {
    margin: 0;
    font-family: var(--mg-fb) !important;
    font-weight: 600 !important;
    line-height: 1.3;
    color: var(--mg-accent) !important;
    font-size: clamp(var(--mg-eyebrow-size-mobile), 2vw, var(--mg-eyebrow-size));
  }

  /* Statement heading — theme forces h2 font; lock to League Spartan */
  .section-{{ section.id }} .mg__heading {
    margin: 0;
    max-width: 1460px;
    text-align: center;
    font-family: var(--mg-fb) !important;
    font-weight: 400 !important;
    line-height: 1.25;
    color: var(--mg-ink) !important;
    font-size: clamp(var(--mg-heading-size-mobile), 2.6vw, var(--mg-heading-size));
  }
  .section-{{ section.id }} .mg__heading strong,
  .section-{{ section.id }} .mg__heading b { font-family: inherit !important; font-weight: 600 !important; }

  /* Body */
  .section-{{ section.id }} .mg__body {
    max-width: 1420px;
    text-align: center;
  }
  .section-{{ section.id }} .mg__body p {
    margin: 0;
    font-family: var(--mg-fb) !important;
    font-weight: 400 !important;
    line-height: 1.35;
    color: var(--mg-ink) !important;
    font-size: clamp(var(--mg-body-size-mobile), 1.5vw, var(--mg-body-size));
  }

  /* Composite gallery + stats image */
  .section-{{ section.id }} .mg__media {
    width: 100%;
    max-width: var(--mg-image-max);
    margin-inline: auto;
  }
  .section-{{ section.id }} .mg__image {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--mg-image-radius);
  }
  .section-{{ section.id }} .mg__image--placeholder {
    aspect-ratio: 1600 / 726;
    background-color: #eef0f1;
    fill: #b9c3c9;
    object-fit: cover;
  }

  /* CTA */
  .section-{{ section.id }} .mg__cta {
    display: flex;
    flex-direction: column;
    align-items: center; width: 100%;
    gap: 10px;
    margin-top: 4px;
  }
  .section-{{ section.id }} .mg__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--mg-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--mg-button-text) !important;
    background-color: var(--mg-button-bg);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .mg__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .mg__button:focus-visible { outline: 3px solid var(--mg-accent); outline-offset: 3px; }
  .section-{{ section.id }} .mg__guarantee {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mg-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(13px, 1.6vw, 16px);
    color: var(--mg-ink) !important;
  }
  .section-{{ section.id }} .mg__guarantee-icon { flex-shrink: 0; width: 16px; height: 16px; line-height: 0; color: var(--mg-ink); }
  .section-{{ section.id }} .mg__guarantee-icon svg { display: block; width: 100%; height: 100%; }

  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .mg__button { transition: none; }
  }
{% endstyle %}

<section class="mg section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mg__inner">

    {%- if section.settings.eyebrow_text != blank -%}
      <div class="mg__eyebrow">{{ section.settings.eyebrow_text }}</div>
    {%- endif -%}

    {%- if section.settings.heading_text != blank -%}
      <h2 class="mg__heading">{{ section.settings.heading_text }}</h2>
    {%- endif -%}

    {%- if section.settings.body_text != blank -%}
      <div class="mg__body">{{ section.settings.body_text }}</div>
    {%- endif -%}

    <div class="mg__media">
      {%- if section.settings.image != blank -%}
        {%- assign img_alt = section.settings.image.alt | default: 'Customers using Metabolic Flow' -%}
        {%- if section.settings.image_mobile != blank -%}
          <picture>
            <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 600 }} 600w, {{ section.settings.image_mobile | image_url: width: 900 }} 900w, {{ section.settings.image_mobile | image_url: width: 1200 }} 1200w" sizes="100vw">
            {{
              section.settings.image
              | image_url: width: 1600
              | image_tag:
                loading: 'lazy',
                widths: '700,1000,1300,1600',
                sizes: '(min-width: 1640px) 1600px, 100vw',
                alt: img_alt,
                class: 'mg__image'
            }}
          </picture>
        {%- else -%}
          {{
            section.settings.image
            | image_url: width: 1600
            | image_tag:
              loading: 'lazy',
              widths: '700,1000,1300,1600',
              sizes: '(min-width: 1640px) 1600px, 100vw',
              alt: img_alt,
              class: 'mg__image'
          }}
        {%- endif -%}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'mg__image mg__image--placeholder' }}
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="mg__cta">
        <a class="mg__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
        {%- if section.settings.guarantee_text != blank -%}
          <span class="mg__guarantee"><span class="mg__guarantee-icon">{{ check_icon }}</span>{{ section.settings.guarantee_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Metabolic Gallery Proof",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use theme colors",
      "default": false
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "richtext",
      "id": "eyebrow_text",
      "label": "Eyebrow",
      "default": "<p>Finally, There's Good News For Women</p><p>Struggling With Menopause Weight Gain</p>"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "eyebrow_size_mobile",
      "label": "Eyebrow size (mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading_text",
      "label": "Heading",
      "info": "Bold the key phrases.",
      "default": "<strong>Metabolic Flow</strong> helps support <strong>healthy metabolism, balanced energy, and fewer cravings</strong>—without extreme diets or endless hours in the gym."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 44,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 16,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body",
      "default": "<p>Each ingredient was carefully selected to help women feel more in control of their bodies during and after menopause.</p><p>It's designed for women who are tired of battling stubborn cravings, low energy, and the frustrating changes that often come with menopause.</p><p>That's why so many women are making Metabolic Flow part of their daily routine.</p>"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size_mobile",
      "label": "Body size (mobile)",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Gallery image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Export the full gallery + statistics block as one image (~1600 x 726)."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)",
      "info": "Optional taller/cropped version for phones. Falls back to the main image."
    },
    {
      "type": "range",
      "id": "image_max_width",
      "label": "Image max width",
      "min": 800,
      "max": 1700,
      "step": 10,
      "unit": "px",
      "default": 1600
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "CLAIM 20% OFF NOW 👉"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button color",
      "default": "#202329"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "guarantee_text",
      "label": "Guarantee text",
      "default": "60-Day Money-Back Guarantee"
