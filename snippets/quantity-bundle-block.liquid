      gap: 6px;
    }

    .quantity-bundle-selector.layout-grid-2x2 .quantity-bundle-card {
      min-height: {{ block.settings.card_min_height_mobile | default: 50 | times: 0.85 }}px;
      padding: 0 6px !important;
