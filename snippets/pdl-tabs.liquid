{%- comment -%}
  Product tabs — renders inside product-details-lum's right column (block type 'product_tabs').
  Up to 3 tabs from flat block settings (tab_1_*, tab_2_*, tab_3_*); each has up to 6 rows (pill label + text).
  A tab shows when its title is set. First shown tab is active; clicking swaps the panel.
  Usage: {% render 'pdl-tabs', block: block %}
{%- endcomment -%}
{%- liquid
  assign uid = block.id
  assign tabs = ''
  for t in (1..3)
    assign tk = 'tab_' | append: t | append: '_title'
    if block.settings[tk] != blank
      assign tabs = tabs | append: t | append: ','
    endif
  endfor
  assign tab_list = tabs | split: ','
-%}
{% style %}
  .ptab-{{ uid }}{ --ptab-font:'Inter Tight', system-ui, sans-serif; --ptab-ink:#113b34; --ptab-line:rgba(17,59,52,.1); --ptab-grey:#f4f4f2; --ptab-pill:rgba(17,59,52,.12); --ptab-muted:rgba(17,59,52,.6); }
  .ptab-{{ uid }} .ptab__tabs{ display:flex; align-items:flex-end; }
  .ptab-{{ uid }} .ptab__tab{ flex:1 1 0; min-width:0; display:flex !important; align-items:center; justify-content:center; gap:8px; min-height:44px; height:auto !important; padding:10px 12px !important; margin:0 !important; background:var(--ptab-grey) !important; background-image:none !important; box-shadow:none !important; text-shadow:none !important; color:var(--ptab-ink) !important; border:1px solid var(--ptab-line) !important; border-radius:0 !important; cursor:pointer; box-sizing:border-box; text-transform:none !important; -webkit-appearance:none; appearance:none; }
  .ptab-{{ uid }} .ptab__tab::before, .ptab-{{ uid }} .ptab__tab::after{ display:none !important; }
  .ptab-{{ uid }} .ptab__tab + .ptab__tab{ margin-left:-1px !important; }
  .ptab-{{ uid }} .ptab__tab:first-child{ border-top-left-radius:12px !important; }
  .ptab-{{ uid }} .ptab__tab:last-child{ border-top-right-radius:12px !important; }
  .ptab-{{ uid }} .ptab__tab.is-active{ min-height:52px; background:#fff !important; border-bottom-color:#fff !important; border-top-left-radius:12px !important; border-top-right-radius:12px !important; position:relative; z-index:2; }
  .ptab-{{ uid }} .ptab__tab-icon{ flex:0 0 20px; width:20px; height:20px; color:var(--ptab-ink); }
  .ptab-{{ uid }} .ptab__tab-icon svg{ display:block; width:100%; height:100%; }
  .ptab-{{ uid }} .ptab__tab-label{ font-family:var(--ptab-font) !important; font-weight:600 !important; font-size:12px; line-height:1.2; letter-spacing:-0.24px; color:var(--ptab-ink); white-space:nowrap; }
  .ptab-{{ uid }} .ptab__panel-wrap{ position:relative; z-index:1; background:#fff; border:1px solid var(--ptab-line); border-top:0; border-bottom-left-radius:12px; border-bottom-right-radius:12px; padding:16px; }
  .ptab-{{ uid }} .ptab__panel{ display:none; flex-direction:column; gap:16px; }
  .ptab-{{ uid }} .ptab__panel.is-active{ display:flex; }
  .ptab-{{ uid }} .ptab__row{ display:flex; flex-direction:column; align-items:flex-start; gap:8px; }
  .ptab-{{ uid }} .ptab__pill{ display:inline-flex; align-items:center; justify-content:center; padding:4px 8px; border-radius:28px; background:var(--ptab-pill); font-family:var(--ptab-font) !important; font-weight:600 !important; font-size:12px; line-height:1.2; letter-spacing:-0.24px; color:var(--ptab-ink); }
  .ptab-{{ uid }} .ptab__text{ display:flex; flex-direction:column; gap:8px; width:100%; }
  .ptab-{{ uid }} .ptab__text p{ margin:0; font-family:var(--ptab-font) !important; font-weight:400 !important; font-size:14px; line-height:1.2; letter-spacing:-0.28px; color:var(--ptab-muted); }
{% endstyle %}

<div class="ptab ptab-{{ uid }}" {{ block.shopify_attributes }}>
  {%- if tab_list.size > 0 -%}
    <div class="ptab__tabs" role="tablist">
      {%- for t in tab_list -%}
        {%- liquid
          assign ick = 'tab_' | append: t | append: '_icon'
          assign tik = 'tab_' | append: t | append: '_title'
          assign icon = block.settings[ick]
          assign ttl = block.settings[tik] | default: 'Tab'
        -%}
        <button type="button" class="ptab__tab disable-global-button-styling{% if forloop.first %} is-active{% endif %}" data-tab="{{ forloop.index0 }}" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
          {%- if icon != blank and icon != 'none' -%}
            <span class="ptab__tab-icon">
              {%- case icon -%}
                {%- when 'star' -%}{{ 'lum-icon-star-bold.svg' | inline_asset_content }}
                {%- when 'profile' -%}{{ 'lum-icon-profile-tick.svg' | inline_asset_content }}
                {%- when 'note' -%}{{ 'lum-icon-note.svg' | inline_asset_content }}
                {%- when 'info' -%}{{ 'lum-icon-info.svg' | inline_asset_content }}
                {%- when 'tick' -%}{{ 'lum-icon-tick.svg' | inline_asset_content }}
              {%- endcase -%}
            </span>
          {%- endif -%}
          <span class="ptab__tab-label">{{ ttl | escape }}</span>
        </button>
      {%- endfor -%}
    </div>
    <div class="ptab__panel-wrap">
      {%- for t in tab_list -%}
        <div class="ptab__panel{% if forloop.first %} is-active{% endif %}" data-panel="{{ forloop.index0 }}" role="tabpanel">
          {%- for r in (1..6) -%}
            {%- liquid
              assign lk = 'tab_' | append: t | append: '_row_' | append: r | append: '_label'
              assign tk2 = 'tab_' | append: t | append: '_row_' | append: r | append: '_text'
              assign rl = block.settings[lk]
              assign rt = block.settings[tk2]
            -%}
            {%- if rl != blank or rt != blank -%}
              <div class="ptab__row">
                {%- if rl != blank -%}<span class="ptab__pill">{{ rl | escape }}</span>{%- endif -%}
                {%- if rt != blank -%}
                  <div class="ptab__text">
                    {%- assign lines = rt | newline_to_br | split: '<br />' -%}
                    {%- for line in lines -%}
                      {%- assign ln = line | strip_newlines | strip -%}
                      {%- if ln != blank -%}<p>{{ ln | escape }}</p>{%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
<script>
  (function () {
    var root = document.querySelector('.ptab-{{ uid }}');
    if (!root || root.__ptabBound) return;
    root.__ptabBound = true;
    var tabs = [].slice.call(root.querySelectorAll('.ptab__tab'));
    var panels = [].slice.call(root.querySelectorAll('.ptab__panel'));
    function activate(i) {
      tabs.forEach(function (t, k) { var on = k === i; t.classList.toggle('is-active', on); t.setAttribute('aria-selected', on ? 'true' : 'false'); });
      panels.forEach(function (p, k) { p.classList.toggle('is-active', k === i); });
    }
    tabs.forEach(function (t, i) { t.addEventListener('click', function () { activate(i); }); });
  })();
</script>
