<script>
  (function () {
    'use strict';

    const sectionInstances = new WeakMap();
    const activeSections = new Set();

    let globalResizeHandler = null;
    let resizeHandlerAttached = false;

    class FAQSection {
      constructor(rootElement) {
        this.root = rootElement;
        this.clickHandler = null;
        this.mutationObserver = null;
        this.initialized = false;
      }

      init() {
        if (this.initialized) return;

        this.setupClickHandler();
        this.setupMutationObserver();
        this.updateResponsiveFontSizes();
        this.initialized = true;
      }

      setupClickHandler() {
        if (this.clickHandler) return;

        this.clickHandler = (e) => {
          const questionEl = e.target.closest('.store-faq-question');
          if (!questionEl || !this.root.contains(questionEl)) return;

          e.preventDefault();
          e.stopPropagation();

          const item = questionEl.closest('.store-faq-item');
          if (!item) return;

          const columnContainer = questionEl.closest('.store-faq-items-container');
          if (!columnContainer) return;

          const scopeIsAccordion = columnContainer.getAttribute('data-accordion') === 'true';

          if (scopeIsAccordion && !item.classList.contains('active')) {
            const activeItems = columnContainer.querySelectorAll('.store-faq-item.active');
            activeItems.forEach((other) => {
              if (other !== item && !other.classList.contains('mobile-only-item')) {
                other.classList.remove('active');
              }
            });
          }

          item.classList.toggle('active');
        };

        this.root.addEventListener('click', this.clickHandler, true);
      }

      setupMutationObserver() {
        if (this.mutationObserver) return;

        this.mutationObserver = new MutationObserver((mutations) => {
          for (const m of mutations) {
            if (m.type === 'childList' && (m.addedNodes.length || m.removedNodes.length)) {
              this.init();
              break;
            }
          }
        });

        this.mutationObserver.observe(this.root, { childList: true, subtree: true });
      }

      updateResponsiveFontSizes() {
        if (!this.root) return;

        const isMobile = window.innerWidth < 750;
        if (isMobile) {
          document.documentElement.classList.add('faq-mobile-view');
        } else {
          document.documentElement.classList.remove('faq-mobile-view');
        }
      }

      cleanup() {
        if (this.clickHandler) {
          this.root.removeEventListener('click', this.clickHandler, true);
          this.clickHandler = null;
        }

        if (this.mutationObserver) {
          this.mutationObserver.disconnect();
          this.mutationObserver = null;
        }

        this.initialized = false;
      }
    }

    function getOrCreateFAQSection(sectionId) {
      const root = document.querySelector(`#store-faq-${sectionId}`);
      if (!root) return null;
      let instance = sectionInstances.get(root);

      if (!instance) {
        instance = new FAQSection(root);
        sectionInstances.set(root, instance);
        activeSections.add(instance);
      }

      return instance;
    }

    // Start FAQ section
    function initFAQ() {
      const instance = getOrCreateFAQSection('{{ section.id }}');
      if (!instance) {
        setTimeout(initFAQ, 100);
        return;
      }

      instance.init();
    }

    function cleanupFAQ() {
      const root = document.querySelector('#store-faq-{{ section.id }}');
      if (!root) return;

      const instance = sectionInstances.get(root);
      if (instance) {
        instance.cleanup();
        activeSections.delete(instance);
        sectionInstances.delete(root);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFAQ);
    } else {
      initFAQ();
    }

    // Shopify JS hooks
    document.addEventListener('shopify:section:load', function (evt) {
      if (!evt.detail || evt.detail.sectionId !== '{{ section.id }}') return;
      initFAQ();
    });

    document.addEventListener('shopify:section:select', function (evt) {
      if (!evt.detail || evt.detail.sectionId !== '{{ section.id }}') return;
      initFAQ();
    });

    document.addEventListener('shopify:section:reorder', function (evt) {
      if (!evt.detail || evt.detail.sectionId !== '{{ section.id }}') return;
      initFAQ();
    });

    document.addEventListener('shopify:section:unload', function (evt) {
      if (!evt.detail || evt.detail.sectionId !== '{{ section.id }}') return;
      cleanupFAQ();
    });
    // Redundancy fallback
    window.addEventListener('load', initFAQ);
  })();
</script>

<style>
  /* Critical overrides for product page conflicts */
  #store-faq-{{ section.id }} {
    position: relative;
    z-index: 1;
    pointer-events: auto !important;
  }

  #store-faq-{{ section.id }} .store-faq,
  #store-faq-{{ section.id }} .store-faq-items-container,
  #store-faq-{{ section.id }} .store-faq-item {
    pointer-events: auto !important;
  }
  #store-faq-{{ section.id }} .store-faq-question {
    cursor: pointer !important;
    pointer-events: auto !important;
  }

  #store-faq-{{ section.id }} .store-faq-answer {
    max-height: 0 !important;
    overflow: hidden !important;
    transition: max-height 0.3s ease, padding 0.3s ease !important;
  }

  #store-faq-{{ section.id }} .store-faq-item.active .store-faq-answer {
    max-height: 300px !important;
  }

  #store-faq-{{ section.id }} .store-faq-item.active .store-faq-toggle {
    transform: rotate(45deg) !important;
  }
</style>

