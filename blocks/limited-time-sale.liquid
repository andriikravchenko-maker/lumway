{% comment %}
  Block: Limited Time Sale (Parent Block)
  Uses nested theme blocks for maximum customizability
{% endcomment %}

<section class="lts-wrapper lts-wrapper-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="lts-card lts-card-{{ block.id }}">
    {% if block.settings.chip_text != blank %}
      <div class="lts-chip lts-chip-{{ block.id }}">{{ block.settings.chip_text }}</div>
    {% endif %}

    <div class="lts-grid lts-grid-{{ block.id }}">
      <!-- Left: Image Column -->
      <div class="lts-media-col lts-media-col-{{ block.id }}">
        {% if block.settings.fallback_image != blank %}
          <div class="lts-image-fallback-{{ block.id }}">
            {{ block.settings.fallback_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
          </div>
        {% else %}
          <div class="lts-image-placeholder-{{ block.id }}">Add image in settings</div>
        {% endif %}
      </div>

      <!-- Right: Content Column -->
      <div class="lts-content-col lts-content-col-{{ block.id }}">
        {% content_for 'blocks' %}
      </div>
    </div>
  </div>
</section>

<style>
  .lts-wrapper-{{ block.id }} {
    background: {{ block.settings.section_bg_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_x }}px {{ block.settings.padding_bottom }}px;
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .lts-card-{{ block.id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    background: {{ block.settings.card_bg_color }};
    position: relative;
    padding-top: {% if block.settings.chip_text != blank %}{{ block.settings.chip_offset }}px{% else %}0{% endif %};

    {% if block.settings.border_style != 'none' %}
      border: {{ block.settings.border_width }}px {{ block.settings.border_style }} {{ block.settings.border_color }};
    {% endif %}

    border-radius: {{ block.settings.border_radius }}px;
    overflow: visible;
  }

  .lts-chip-{{ block.id }} {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translate(-50%, -50%);
    z-index: 2;
    background: {{ block.settings.chip_bg_color }};
    color: {{ block.settings.chip_text_color }};
    font-weight: {{ block.settings.chip_font_weight }} !important;
    font-size: {{ block.settings.chip_font_size }}px;
    padding: {{ block.settings.chip_padding_y }}px {{ block.settings.chip_padding_x }}px;
    letter-spacing: {{ block.settings.chip_letter_spacing }}px;
    border-radius: {{ block.settings.chip_border_radius }}px;
    white-space: nowrap;
    text-align: center;
    text-transform: uppercase;
  }

  .lts-grid-{{ block.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .lts-media-col-{{ block.id }} {
    background: {{ block.settings.media_bg_color }};
    min-height: {{ block.settings.media_min_height }}px;
    position: relative;
    overflow: hidden;
  }

  .lts-image-fallback-{{ block.id }} {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .lts-image-fallback-{{ block.id }} img {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.fallback_object_fit }};
    object-position: {{ block.settings.fallback_object_position }};
    display: block;
  }

  .lts-image-placeholder-{{ block.id }} {
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f0f0f0;
    color: #999;
    font-size: 14px;
  }

  .lts-content-col-{{ block.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.content_padding_top }}px {{ block.settings.content_padding_x }}px {{ block.settings.content_padding_bottom }}px;
    text-align: {{ block.settings.content_align }};
  }

  .lts-content-col-{{ block.id }} > * {
    width: 100%;
  }

  @media (max-width: {{ block.settings.mobile_breakpoint }}px) {
    .lts-chip-{{ block.id }} {
      font-size: {{ block.settings.chip_font_size_mobile }}px;
      padding: {{ block.settings.chip_padding_y_mobile }}px {{ block.settings.chip_padding_x_mobile }}px;
      max-width: calc(100% - 24px);
      white-space: normal;
    }

    .lts-grid-{{ block.id }} {
      grid-template-columns: 1fr;
    }

    .lts-media-col-{{ block.id }} {
      {% if block.settings.mobile_image_position == 'bottom' %}
        order: 2;
      {% else %}
        order: 1;
      {% endif %}
      min-height: {{ block.settings.media_min_height_mobile }}px;
    }

    .lts-content-col-{{ block.id }} {
      {% if block.settings.mobile_image_position == 'bottom' %}
        order: 1;
      {% else %}
        order: 2;
      {% endif %}
      padding: {{ block.settings.content_padding_top_mobile }}px {{ block.settings.content_padding_x_mobile }}px {{ block.settings.content_padding_bottom_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Limited Time Sale",
  "settings": [
    {
      "type": "header",
      "content": "Top Chip"
    },
    {
      "type": "text",
      "id": "chip_text",
      "label": "Chip Text",
      "default": "FREE $40 PREMIUM SERUM WITH YOUR ORDER"
