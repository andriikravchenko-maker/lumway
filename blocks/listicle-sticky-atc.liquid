{% comment %}
  Block: Listicle Sticky Add to Cart
  Matches the image provided with a large button and discount subtext.
{% endcomment %}

<div class="listicle-sticky-atc listicle-sticky-atc-{{ block.id }} {% if block.settings.sticky %} is-sticky{% endif %} {% if block.settings.mobile_only %} mobile-only{% endif %}" {{ block.shopify_attributes }}>
  <div class="sticky-atc-container">
    <a href="{{ block.settings.button_link }}" class="sticky-atc-button">
      <span class="button-text">{{ block.settings.button_text }}</span>
      <span class="button-arrow">
        <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </span>
    </a>
    
    {% if block.settings.show_subtext %}
      <div class="sticky-atc-subtext">
        <span class="subtext-icon">
          {% if block.settings.subtext_icon_image != blank %}
            <img src="{{ block.settings.subtext_icon_image | image_url: width: 40 }}" alt="{{ block.settings.subtext_icon_image.alt | escape }}" width="20" height="20">
          {% else %}
            <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          {% endif %}
        </span>
        <span class="subtext-content">{{ block.settings.subtext }}</span>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .listicle-sticky-atc-{{ block.id }} {
    margin-top: {{ block.settings.margin_top }}px;
    margin-bottom: {{ block.settings.margin_bottom }}px;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
    letter-spacing: 0px !important;
    background-color: {{ block.settings.container_bg }} !important;
  }

  .listicle-sticky-atc-{{ block.id }} * {
    letter-spacing: 0px !important;
  }

  .listicle-sticky-atc-{{ block.id }}.is-sticky {
    position: fixed;
    bottom: 0 !important;
    left: 0 !important;
    z-index: 9999;
    width: 100vw !important;
    max-width: none !important;
    background: {{ block.settings.container_bg }} !important;
    padding: 15px 20px;
    border-radius: 0;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.1);
    transform: none !important;
    margin-bottom: 0 !important;
    transition: bottom 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .listicle-sticky-atc-{{ block.id }}.is-sticky.is-lto-hidden {
    bottom: -200px !important;
  }

  /* Desktop Hide Option */
  @media (min-width: 769px) {
    .listicle-sticky-atc-{{ block.id }}.mobile-only {
      display: none !important;
    }
  }

  .listicle-sticky-atc-{{ block.id }} .sticky-atc-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    width: 100%;
    background-color: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text_color }};
    padding: {{ block.settings.button_padding_y }}px {{ block.settings.button_padding_x }}px;
    border-radius: {{ block.settings.button_border_radius }}px;
    text-decoration: none;
    font-weight: 700 !important;
    font-size: {{ block.settings.button_font_size }}px;
    text-transform: uppercase;
    {% unless request.page_type == 'page' %}
    transition: transform 0.2s ease;
    {% endunless %}
  }

  {% if block.settings.enable_heartbeat %}
  @keyframes heartbeat-{{ block.id }} {
    0%   { transform: scale(1); }
    14%  { transform: scale(1.06); }
    28%  { transform: scale(1); }
    42%  { transform: scale(1.06); }
    70%  { transform: scale(1); }
  }
  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button {
    animation: heartbeat-{{ block.id }} 1.5s ease-in-out infinite;
    transform-origin: center;
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .listicle-sticky-atc-{{ block.id }} .sticky-atc-button {
      animation: none;
    }
  }
  {% endif %}

  {% if request.page_type == 'page' %}
  .listicle-sticky-atc-{{ block.id }}:hover,
  .listicle-sticky-atc-{{ block.id }}:focus,
  .listicle-sticky-atc-{{ block.id }}:focus-within,
  .listicle-sticky-atc-{{ block.id }}.is-sticky:hover,
  .listicle-sticky-atc-{{ block.id }}.is-sticky:focus,
  .listicle-sticky-atc-{{ block.id }}.is-sticky:focus-within {
    background-color: {{ block.settings.container_bg }} !important;
    background: {{ block.settings.container_bg }} !important;
    box-shadow: 0 -4px 15px rgba(0,0,0,0.1) !important;
    transform: none !important;
    opacity: 1 !important;
  }

  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button:hover,
  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button:focus,
  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button:active {
    background-color: {{ block.settings.button_bg }} !important;
    color: {{ block.settings.button_text_color }} !important;
    transform: none !important;
    opacity: 1 !important;
    box-shadow: none !important;
  }
  {% else %}
  .listicle-sticky-atc-{{ block.id }} .sticky-atc-button:hover {
    transform: scale(1.02);
  }
  {% endif %}

  .listicle-sticky-atc-{{ block.id }} .button-arrow {
    display: flex;
    align-items: center;
  }

  .listicle-sticky-atc-{{ block.id }} .sticky-atc-subtext {
    display: flex;
    align-items: center;
    gap: 6px;
    color: {{ block.settings.subtext_color }};
    font-size: {{ block.settings.subtext_font_size }}px;
    font-weight: 700 !important;
    text-transform: uppercase;
  }

  .listicle-sticky-atc-{{ block.id }} .subtext-icon {
    display: flex;
    align-items: center;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .listicle-sticky-atc-{{ block.id }}.is-sticky {
      bottom: 0 !important;
      width: 100vw !important;
      left: 0 !important;
      padding: 15px 20px;
    }
    .listicle-sticky-atc-{{ block.id }} .sticky-atc-button {
      padding: {{ block.settings.button_padding_y_mobile }}px {{ block.settings.button_padding_x_mobile }}px;
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
</style>

<script>
  {% if template.suffix == 'lumway3' or template.suffix contains '5-ways-for-35' %}
  /* lumway3 / 5-ways-for-35: the button must be visible from page load. Its parent section
     carries theme scroll animations (ancestor transform/opacity), which both hide the subtree
     and turn position:fixed into section-relative, so re-parent to <body>. Hidden again once
     the gut-harmony-cta section comes into view. */
  (function () {
    var stickyEl = document.querySelector('.listicle-sticky-atc-{{ block.id }}');
    if (!stickyEl) return;

    // This block lives inside a section that Dawn fades in on scroll
    // (`.scroll-trigger` sets opacity:0 while the section is offscreen). Opacity
    // on an ancestor hides its whole subtree, so the fixed button stays
    // invisible until the listicle section scrolls into view. Re-parent it to
    // <body> so it escapes the section's opacity and shows from page load.
    if (stickyEl.parentNode !== document.body) {
      document.body.appendChild(stickyEl);
    }

    // lumway3: visible from page load, hides once the gut-harmony-cta section enters the viewport.
    // 5-ways-for-35: hidden while the first content section (hero) is on screen and while the LTO
    // product cards are in view (they carry their own CTA); stays visible at the final CTA.
    var WAIT_FIRST = {% if template.suffix contains '5-ways-for-35' %}true{% else %}false{% endif %};
    var ctaInner = null;
    var firstSec = null;
    var ltoCards = null;

    function findFirstSection() {
      var secs = document.querySelectorAll('#MainContent .shopify-section');
      for (var k = 0; k < secs.length; k++) {
        if (secs[k].offsetHeight > 50) return secs[k]; // skip utility sections (font loader etc.)
      }
      return null;
    }

    function inView(el) {
      var r = el.getBoundingClientRect();
      return r.bottom > 0 && r.top < window.innerHeight;
    }

    function update() {
      if (!ctaInner) {
        ctaInner = document.querySelector('.gut-harmony-cta__inner');
      }
      var atCta = !WAIT_FIRST && ctaInner && ctaInner.getBoundingClientRect().top < window.innerHeight;
      var onFirst = false, onCards = false;
      if (WAIT_FIRST) {
        if (!firstSec) firstSec = findFirstSection();
        onFirst = firstSec ? firstSec.getBoundingClientRect().bottom > 0 : false;
        if (!ltoCards || !ltoCards.length) ltoCards = document.querySelectorAll('.lto__card');
        for (var c = 0; c < ltoCards.length; c++) {
          if (inView(ltoCards[c])) { onCards = true; break; }
        }
      }
      stickyEl.classList.toggle('is-lto-hidden', !!atCta || onFirst || onCards);
    }

    // This theme scrolls the document root with `overflow: clip`, so window
    // `scroll` events are unreliable. Drive updates with IntersectionObserver
    // (fires from the compositor regardless of the scroll mechanism) and keep
    // scroll/resize as a fallback.
    var io = ('IntersectionObserver' in window)
      ? new IntersectionObserver(update, { threshold: [0, 1] })
      : null;

    // Defer the hide logic until the page has fully loaded. Before images
    // settle into place the page is short and the CTA can momentarily sit
    // inside the viewport, which would hide the button right after it appears.
    function start() {
      ctaInner = document.querySelector('.gut-harmony-cta__inner');
      if (io && ctaInner) {
        io.observe(ctaInner);
      }
      if (WAIT_FIRST) {
        firstSec = findFirstSection();
        if (io && firstSec) io.observe(firstSec);
        ltoCards = document.querySelectorAll('.lto__card');
        if (io) { for (var c = 0; c < ltoCards.length; c++) io.observe(ltoCards[c]); }
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update);
    }

    if (document.readyState === 'complete') {
      start();
    } else {
      window.addEventListener('load', start);
    }
  })();
  {% else %}
  (function () {
    var stickyEl = document.querySelector('.listicle-sticky-atc-{{ block.id }}');
    if (!stickyEl) return;

    var ltoCards = document.querySelectorAll('.lto__card');
    if (!ltoCards.length) return;

    var visible = new Set();

    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          visible.add(entry.target);
        } else {
          visible.delete(entry.target);
        }
      });
      stickyEl.classList.toggle('is-lto-hidden', visible.size > 0);
    }, { threshold: 0 });

    ltoCards.forEach(function (card) { observer.observe(card); });
  })();
  {% endif %}
</script>

{% schema %}
{
  "name": "Sticky Add to Cart",
  "settings": [
    {
      "type": "header",
      "content": "Button Settings"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "YES, GET 58% OFF"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background Color",
      "default": "#25282a"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "enable_heartbeat",
      "label": "Heartbeat animation",
      "default": true,
      "info": "Pulsing heartbeat effect on the button to draw attention."
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 30,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size (Desktop)",
      "default": 18
    },
    {
      "type": "range",
      "id": "button_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Button Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Button Vertical Padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Button Horizontal Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Button Border Radius",
      "default": 8
    },
    {
      "type": "header",
      "content": "Subtext Settings"
    },
    {
      "type": "checkbox",
      "id": "show_subtext",
      "label": "Show Subtext",
      "default": true
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "NEW YEAR, NEW ME DISCOUNT ACTIVE"
    },
    {
      "type": "image_picker",
      "id": "subtext_icon_image",
      "label": "Custom Icon Image"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext Color",
      "default": "#25282a"
    },
    {
      "type": "range",
      "id": "subtext_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subtext Font Size",
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Enable Sticky Mode",
      "default": true,
      "info": "If enabled, the button will stick to the bottom of the screen."
    },
    {
      "type": "checkbox",
      "id": "mobile_only",
      "label": "Show on Mobile Only",
      "default": false,
      "info": "Hide this block on desktop screens."
    },
    {
      "type": "color",
      "id": "container_bg",
      "label": "Sticky Container Background",
      "default": "#ffffff",
      "info": "Only used when sticky mode is enabled."
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 300,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "label": "Max Width",
      "default": 500
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Container Border Radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 20
    }
  ],
  "presets": [
    { "name": "Sticky Add to Cart" }
  ]
}
{% endschema %}
