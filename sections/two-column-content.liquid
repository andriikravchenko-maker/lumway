


{%- style -%}
  {% if section.settings.override_global_accent %}
    {{ section.settings.accent_font_family | font_face: font_display: 'swap' }}
  {% endif %}

  #two-column-{{ section.id }} {
    {% if section.settings.use_theme_colors %}
      background-color: {{ settings.global_section_background_color }};
      color: {{ settings.global_section_text_color }};
    {% else %}
      background-color: {{ section.settings.background_color }};
      color: {{ section.settings.text_color }};
    {% endif %}
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      padding-left: {{ section.settings.padding_horizontal_desktop }}px;
      padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    }
  }

  #two-column-{{ section.id }} .two-column__container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  #two-column-{{ section.id }} .two-column__wrapper {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.column_gap_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__wrapper {
      flex-direction: {% if section.settings.column_order == 'right_first' %}row-reverse{% else %}row{% endif %};
      gap: {{ section.settings.column_gap_desktop }}px;
      align-items: {{ section.settings.vertical_alignment }};
    }
  }

  #two-column-{{ section.id }} .two-column__column {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__column--left {
      flex: 0 0 {{ section.settings.left_column_width }}%;
      max-width: {{ section.settings.left_column_width }}%;
      text-align: {{ section.settings.left_column_text_align }};
      padding: {{ section.settings.left_column_padding }}px;
      {% if section.settings.left_column_text_align == 'center' %}
        align-items: center;
      {% elsif section.settings.left_column_text_align == 'right' %}
        align-items: flex-end;
      {% else %}
        align-items: flex-start;
      {% endif %}
    }

    #two-column-{{ section.id }} .two-column__column--right {
      flex: 0 0 {{ section.settings.right_column_width }}%;
      max-width: {{ section.settings.right_column_width }}%;
      text-align: {{ section.settings.right_column_text_align }};
      padding: {{ section.settings.right_column_padding }}px;
      {% if section.settings.right_column_text_align == 'center' %}
        align-items: center;
      {% elsif section.settings.right_column_text_align == 'right' %}
        align-items: flex-end;
      {% else %}
        align-items: flex-start;
      {% endif %}
    }
  }

  /* Column Divider - Default is hidden */
  #two-column-{{ section.id }} .two-column__divider {
    display: none;
    justify-content: center;
    align-items: center;
    width: 100%;
    flex-shrink: 0;
    padding: 10px 0;
  }

  #two-column-{{ section.id }} .two-column__divider::before {
    content: '';
    display: block;
    width: {{ section.settings.divider_height }}%;
    height: {{ section.settings.divider_width }}px;
    background-color: {{ section.settings.divider_color }};
    min-height: 1px;
  }

  /* Mobile: Show horizontal divider between stacked rows */
  @media screen and (max-width: 767px) {
    {% if section.settings.show_divider_mobile %}
      #two-column-{{ section.id }} .two-column__divider {
        display: flex;
      }
    {% endif %}
  }

  /* Desktop: Show vertical divider between columns */
  @media screen and (min-width: 768px) {
    {% if section.settings.show_column_divider %}
      #two-column-{{ section.id }} .two-column__divider {
        display: flex;
        width: auto;
        align-self: stretch;
        padding: 0 10px;
      }

      #two-column-{{ section.id }} .two-column__divider::before {
        width: {{ section.settings.divider_width }}px;
        height: {{ section.settings.divider_height }}%;
        min-width: 1px;
      }
    {% endif %}
  }

  /* Block Styles */
  #two-column-{{ section.id }} .block-heading {
    font-size: var(--heading-size-mobile, 2rem);
    font-weight: var(--font-weight-bold);
    line-height: 1.2;
    letter-spacing: var(--letter-spacing-heading);
    margin: 0 0 16px 0;
    {% if section.settings.use_theme_colors %}
      color: {{ settings.global_section_text_color }};
    {% else %}
      color: {{ section.settings.heading_color }};
    {% endif %}
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .block-heading {
      font-size: var(--heading-size-desktop, 3rem);
    }
  }

  #two-column-{{ section.id }} .block-heading .accent-text {
    display: inline-block;
    padding: 2px 4px;
    margin: -2px -4px;
    margin-left: {{ section.settings.accent_text_margin_left | default: 0 }}px;
    
    {% comment %} Gradient or solid color {% endcomment %}
    {% if section.settings.use_theme_colors and settings.global_use_accent_text_gradient %}
      {% comment %} Use global gradient when theme colors enabled and global gradient is on {% endcomment %}
      background: {{ settings.global_accent_text_gradient_dark }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    {% elsif section.settings.use_accent_gradient %}
      background: {{ section.settings.accent_text_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    {% else %}
      {% if section.settings.use_theme_colors %}
        color: {{ settings.global_section_accent_1_color }};
      {% else %}
        color: {{ section.settings.accent_color }};
      {% endif %}
    {% endif %}
    
    {% comment %} Typography - global or section override {% endcomment %}
    {% if section.settings.override_global_accent %}
      {% comment %} Section-specific font styling using font_picker {% endcomment %}
      font-family: {{ section.settings.accent_font_family.family }}, {{ section.settings.accent_font_family.fallback_families }};
      
      {% if section.settings.accent_font_style != 'inherit' %}
        font-style: {{ section.settings.accent_font_style }};
      {% else %}
        font-style: {{ section.settings.accent_font_family.style }};
      {% endif %}
      
      {% if section.settings.accent_font_weight != 'inherit' %}
        font-weight: {{ section.settings.accent_font_weight }};
      {% else %}
        font-weight: {{ section.settings.accent_font_family.weight }};
      {% endif %}
    {% else %}
      {% comment %} Use global accent typography settings {% endcomment %}
      font-family: {{ settings.accent_text_font.family }}, {{ settings.accent_text_font.fallback_families }};
      font-weight: {{ settings.accent_text_weight }};
      font-style: {{ settings.accent_text_style }};
    {% endif %}
  }

  #two-column-{{ section.id }} .block-subtitle {
    font-size: 1.1rem;
    line-height: 1.5;
    letter-spacing: var(--letter-spacing-body);
    margin: 0 0 12px 0;
    opacity: 0.85;
  }

  #two-column-{{ section.id }} .block-paragraph {
    font-size: var(--paragraph-font-size-mobile, 16px);
    line-height: 1.6;
    letter-spacing: var(--letter-spacing-body);
    margin: 0 0 16px 0;
  }

  #two-column-{{ section.id }} .block-paragraph p {
    margin: 0;
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .block-paragraph {
      font-size: var(--paragraph-font-size-desktop, 16px);
    }
  }

  #two-column-{{ section.id }} .block-button {
    display: inline-block;
    padding: {{ section.settings.button_padding_vertical }}px {{ section.settings.button_padding_horizontal }}px;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-body);
    text-decoration: none;
    transition: all 0.3s ease;
    margin: 8px 0;
    {% if section.settings.use_theme_colors %}
      background-color: {{ settings.global_button_background_color | default: settings.global_section_accent_1_color }};
      color: {{ settings.global_button_text_color | default: '#ffffff' }};
    {% else %}
      background-color: {{ section.settings.button_bg_color }};
      color: {{ section.settings.button_text_color }};
    {% endif %}
  }

  #two-column-{{ section.id }} .block-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
  }

  #two-column-{{ section.id }} .block-button--secondary {
    background: transparent;
    border: 2px solid currentColor;
    {% if section.settings.use_theme_colors %}
      color: {{ settings.global_section_text_color }};
    {% else %}
      color: {{ section.settings.text_color }};
    {% endif %}
  }

  #two-column-{{ section.id }} .block-divider {
    width: 100%;
    height: 1px;
    background-color: currentColor;
    opacity: 0.2;
    margin: 16px 0;
  }

  #two-column-{{ section.id }} .block-image {
    display: block;
    border-radius: {{ section.settings.image_border_radius }}px;
    margin: 8px 0;
    /* Default: left aligned */
    margin-left: 0;
    margin-right: auto;
    /* Width uses CSS custom properties set inline on each image */
    width: var(--img-width-mobile, 100%) !important;
    max-width: 100%;
    height: auto;
  }
  
  /* Desktop width for images */
  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .block-image {
      width: var(--img-width-desktop, 100%) !important;
    }
  }
  
  /* Mobile image alignment - must come before desktop to be overridden */
  @media screen and (max-width: 767px) {
    #two-column-{{ section.id }} .two-column__column--left .block-image,
    #two-column-{{ section.id }} .two-column__column--right .block-image {
      {% if section.settings.mobile_text_align == 'center' %}
        margin-left: auto !important;
        margin-right: auto !important;
      {% elsif section.settings.mobile_text_align == 'right' %}
        margin-left: auto !important;
        margin-right: 0 !important;
      {% else %}
        margin-left: 0 !important;
        margin-right: auto !important;
      {% endif %}
    }
  }
  
  /* Desktop image alignment based on column text-align */
  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__column--left .block-image {
      {% if section.settings.left_column_text_align == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif section.settings.left_column_text_align == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% else %}
        margin-left: 0;
        margin-right: auto;
      {% endif %}
    }
    
    #two-column-{{ section.id }} .two-column__column--right .block-image {
      {% if section.settings.right_column_text_align == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif section.settings.right_column_text_align == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% else %}
        margin-left: 0;
        margin-right: auto;
      {% endif %}
    }
  }

  #two-column-{{ section.id }} .block-bullet-list {
    list-style: none;
    padding: 0;
    margin: 0 0 16px 0;
  }

  #two-column-{{ section.id }} .block-bullet-list li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 10px;
    letter-spacing: var(--letter-spacing-body);
  }

  #two-column-{{ section.id }} .block-bullet-list .bullet-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #two-column-{{ section.id }} .block-bullet-list .bullet-icon svg {
    width: 100%;
    height: 100%;
    {% if section.settings.use_theme_colors %}
      fill: {{ settings.global_section_accent_1_color }};
    {% else %}
      fill: {{ section.settings.accent_color }};
    {% endif %}
  }

  /* Accordion Styles */
  #two-column-{{ section.id }} .block-accordion {
    width: 100%;
  }

  #two-column-{{ section.id }} .accordion-item {
    border: 1px solid rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }

  #two-column-{{ section.id }} .accordion-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    cursor: pointer;
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-body);
    transition: background-color 0.2s ease;
    {% if section.settings.use_theme_colors %}
      background-color: {{ settings.global_section_background_color }};
    {% else %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
  }

  #two-column-{{ section.id }} .accordion-header:hover {
    opacity: 0.9;
  }

  #two-column-{{ section.id }} .accordion-header-icon {
    flex-shrink: 0;
    width: var(--accordion-icon-size-mobile, 32px);
    height: var(--accordion-icon-size-mobile, 32px);
    overflow: hidden;
  }

  #two-column-{{ section.id }} .accordion-header-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
  }

  #two-column-{{ section.id }} .accordion-svg-icon {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #two-column-{{ section.id }} .accordion-svg-icon svg {
    width: 100%;
    height: 100%;
  }

  #two-column-{{ section.id }} .accordion-header-text {
    flex: 1;
  }

  #two-column-{{ section.id }} .accordion-toggle {
    flex-shrink: 0;
    font-size: 24px;
    font-weight: 300;
    transition: transform 0.3s ease;
    line-height: 1;
  }

  #two-column-{{ section.id }} .accordion-item.is-open .accordion-toggle {
    transform: rotate(45deg);
  }

  #two-column-{{ section.id }} .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
    padding: 0 20px;
    {% if section.settings.use_theme_colors %}
      background-color: {{ settings.global_section_background_color }};
    {% else %}
      background-color: {{ section.settings.background_color }};
    {% endif %}
  }

  #two-column-{{ section.id }} .accordion-item.is-open .accordion-content {
    max-height: 500px;
    padding: 0 20px 20px 20px;
  }

  #two-column-{{ section.id }} .accordion-content-inner {
    padding-top: 10px;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .accordion-header-icon {
      width: var(--accordion-icon-size-desktop, 40px);
      height: var(--accordion-icon-size-desktop, 40px);
    }
  }

  /* Mobile column order */
  @media screen and (max-width: 767px) {
    #two-column-{{ section.id }} .two-column__column--left {
      {% if section.settings.show_divider_mobile %}
        order: {% if section.settings.mobile_column_order == 'right_first' %}3{% else %}0{% endif %};
      {% else %}
        order: {% if section.settings.mobile_column_order == 'right_first' %}2{% else %}1{% endif %};
      {% endif %}
      text-align: {{ section.settings.mobile_text_align }};
      {% if section.settings.mobile_text_align == 'center' %}
        align-items: center;
      {% elsif section.settings.mobile_text_align == 'right' %}
        align-items: flex-end;
      {% else %}
        align-items: flex-start;
      {% endif %}
    }
    #two-column-{{ section.id }} .two-column__column--right {
      {% if section.settings.show_divider_mobile %}
        order: {% if section.settings.mobile_column_order == 'right_first' %}0{% else %}3{% endif %};
      {% else %}
        order: {% if section.settings.mobile_column_order == 'right_first' %}1{% else %}2{% endif %};
      {% endif %}
      text-align: {{ section.settings.mobile_text_align }};
      {% if section.settings.mobile_text_align == 'center' %}
        align-items: center;
      {% elsif section.settings.mobile_text_align == 'right' %}
        align-items: flex-end;
      {% else %}
        align-items: flex-start;
      {% endif %}
    }
    #two-column-{{ section.id }} .two-column__divider {
      order: {% if section.settings.mobile_column_order == 'right_first' %}2{% else %}1{% endif %};
    }
  }

  /* Section Header (outside columns) */
  #two-column-{{ section.id }} .two-column__section-header {
    text-align: {{ section.settings.section_header_align }};
    margin-bottom: {{ section.settings.section_header_margin_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__section-header {
      margin-bottom: {{ section.settings.section_header_margin_bottom_desktop }}px;
    }
  }

  #two-column-{{ section.id }} .two-column__section-heading {
    font-size: {{ section.settings.section_heading_size_mobile }}rem;
    font-weight: var(--font-weight-bold);
    line-height: {{ section.settings.section_heading_line_height }};
    margin: 0 0 {{ section.settings.section_heading_margin_bottom }}px 0;
    {% if section.settings.use_theme_colors %}
      color: {{ settings.global_section_text_color }};
    {% else %}
      color: {{ section.settings.section_heading_color }};
    {% endif %}
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__section-heading {
      font-size: {{ section.settings.section_heading_size_desktop }}rem;
    }
  }

  #two-column-{{ section.id }} .two-column__section-heading .accent-text {
    {% if section.settings.use_theme_colors and settings.global_use_accent_text_gradient %}
      background: {{ settings.global_accent_text_gradient_dark }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    {% elsif section.settings.use_accent_gradient %}
      background: {{ section.settings.accent_text_gradient }};
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    {% else %}
      {% if section.settings.use_theme_colors %}
        color: {{ settings.global_section_accent_1_color }};
      {% else %}
        color: {{ section.settings.accent_color }};
      {% endif %}
    {% endif %}
    {% if section.settings.override_global_accent %}
      font-family: {{ section.settings.accent_font_family.family }}, {{ section.settings.accent_font_family.fallback_families }};
      {% if section.settings.accent_font_style != 'inherit' %}
        font-style: {{ section.settings.accent_font_style }};
      {% endif %}
      {% if section.settings.accent_font_weight != 'inherit' %}
        font-weight: {{ section.settings.accent_font_weight }};
      {% endif %}
    {% else %}
      font-family: {{ settings.accent_text_font.family }}, {{ settings.accent_text_font.fallback_families }};
      font-weight: {{ settings.accent_text_weight }};
      font-style: {{ settings.accent_text_style }};
    {% endif %}
  }

  #two-column-{{ section.id }} .two-column__section-subheading {
    font-size: {{ section.settings.section_subheading_size_mobile }}rem;
    line-height: 1.5;
    margin: 0;
    {% if section.settings.use_theme_colors %}
      color: {{ settings.global_section_text_color }};
      opacity: 0.85;
    {% else %}
      color: {{ section.settings.section_subheading_color }};
    {% endif %}
  }

  @media screen and (min-width: 768px) {
    #two-column-{{ section.id }} .two-column__section-subheading {
      font-size: {{ section.settings.section_subheading_size_desktop }}rem;
    }
  }
{%- endstyle -%}

<section id="two-column-{{ section.id }}" class="two-column-section {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-up{% endif %}">
  <div class="two-column__container">
    
    {%- comment -%} Section Header (outside columns) {%- endcomment -%}
    {%- if section.settings.show_section_header -%}
      <div class="two-column__section-header">
        {%- if section.settings.section_heading != blank -%}
          <{{ section.settings.section_heading_tag }} class="two-column__section-heading">
            {{ section.settings.section_heading }}
            {%- if section.settings.section_heading_accent != blank -%}
              <span class="accent-text">{{ section.settings.section_heading_accent }}</span>
            {%- endif -%}
          </{{ section.settings.section_heading_tag }}>
        {%- endif -%}
        {%- if section.settings.section_subheading != blank -%}
          <p class="two-column__section-subheading">{{ section.settings.section_subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="two-column__wrapper">
      
      {%- comment -%} Left Column {%- endcomment -%}
      <div class="two-column__column two-column__column--left">
        {%- for block in section.blocks -%}
          {%- if block.settings.column == 'left' -%}
            {%- case block.type -%}
              
              {%- when 'heading' -%}
                <{{ block.settings.heading_tag | default: 'h2' }} 
                  class="block-heading" 
                  style="--heading-size-mobile: {{ block.settings.font_size_mobile }}rem; --heading-size-desktop: {{ block.settings.font_size_desktop }}rem; line-height: {{ block.settings.line_height | default: 1.2 }}; margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;{% if block.settings.use_custom_color %} color: {{ block.settings.heading_color }};{% endif %}{% if block.settings.text_align != 'inherit' %} text-align: {{ block.settings.text_align }};{% endif %}"
                  {{ block.shopify_attributes }}>
                  {{ block.settings.heading_text }}
                  {%- if block.settings.heading_accent != blank -%}
                    <span class="accent-text{% unless section.settings.override_global_accent %} global-accent-text{% endunless %}">{{ block.settings.heading_accent }}</span>
                  {%- endif -%}
                </{{ block.settings.heading_tag | default: 'h2' }}>

              {%- when 'subtitle' -%}
                <p class="block-subtitle" 
                   style="font-size: {{ block.settings.font_size }}rem; margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px; font-weight: {{ block.settings.font_weight | default: '400' }};{% if block.settings.use_custom_color %} color: {{ block.settings.text_color }}; opacity: 1;{% endif %}"
                   {{ block.shopify_attributes }}>
                  {{ block.settings.subtitle_text }}
                </p>

              {%- when 'paragraph' -%}
                <div class="block-paragraph" 
                     style="--paragraph-font-size-mobile: {{ block.settings.font_size_mobile | default: 16 }}px; --paragraph-font-size-desktop: {{ block.settings.font_size_desktop | default: 16 }}px; margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px; line-height: {{ block.settings.line_height | default: 1.6 }};{% if block.settings.use_custom_color %} color: {{ block.settings.text_color }};{% endif %}{% if block.settings.text_align != 'inherit' %} text-align: {{ block.settings.text_align }};{% endif %}"
                     {{ block.shopify_attributes }}>
                  {{ block.settings.paragraph_text }}
                </div>

              {%- when 'button' -%}
                <div style="margin-top: {{ block.settings.margin_top }}px; margin-bottom: {{ block.settings.margin_bottom }}px;{% if block.settings.button_align != 'inherit' %} text-align: {{ block.settings.button_align }};{% endif %}" {{ block.shopify_attributes }}>
                  <a href="{{ block.settings.button_link }}" 
                     class="block-button{% if block.settings.button_style == 'secondary' %} block-button--secondary{% endif %}"
