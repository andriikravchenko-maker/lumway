{% comment %}
  Theme block: Sidebar Features List
  Renders up to four feature rows with star ratings.
{% endcomment %}

{% assign s = block.settings %}

<style>
  #sidebar-features-{{ block.id }} {
    {% if s.show_background %}
      background-color: {{ s.background_color }};
      padding: {{ s.padding }}px;
      border-radius: {{ s.border_radius }}px;
    {% endif %}
  }
</style>

<div id="sidebar-features-{{ block.id }}" class="features" {{ block.shopify_attributes }}>
  {% for feature in (1..4) %}
    {% liquid
      assign title_index = 'feature_title_' | append: forloop.index
      assign feature_rating = 'feature_rating_' | append: forloop.index
    %}
    {% if s[title_index] != blank %}
      <div class="feature feature-{{ s[title_index] | handleize }}">
        <div class="feature-title">{{ s[title_index] }}</div>
        <div class="feature-rating">
          <div class="stars-wrapper">
            {% for i in (1..5) %}
              {% liquid
                assign star_width = '100%'
                assign modulo = s[feature_rating] | modulo: 1
                assign target_index = s[feature_rating] | ceil

                if modulo > 0 and forloop.index == target_index
                  assign star_width = modulo | split: '.' | last | times: 10 | append: '%'
                endif

                if forloop.index > target_index
                  assign star_width = '0%'
                endif
              %}
              <svg
                width="{{ s.feature_star_size }}"
                height="{{ s.feature_star_size }}"
                viewBox="0 0 1920 1920"
                xmlns="http://www.w3.org/2000/svg"
              >
                <defs>
                  <mask id="feature-mask-{{ block.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="1920" height="1920">
                    <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" fill="#fff" fill-rule="evenodd"/>
                  </mask>
                </defs>
                <!-- Empty star background (always visible) -->
                <path d="M1915.918 737.475c-10.955-33.543-42.014-56.131-77.364-56.131h-612.029l-189.063-582.1v-.112C1026.394 65.588 995.335 43 959.984 43c-35.237 0-66.41 22.588-77.365 56.245L693.443 681.344H81.415c-35.35 0-66.41 22.588-77.365 56.131-10.955 33.544.79 70.137 29.478 91.03l495.247 359.831-189.177 582.212c-10.955 33.657 1.13 70.25 29.817 90.918 14.23 10.278 30.946 15.487 47.66 15.487 16.716 0 33.432-5.21 47.775-15.6l495.134-359.718 495.021 359.718c28.574 20.781 67.087 20.781 95.662.113 28.687-20.668 40.658-57.261 29.703-91.03l-189.176-582.1 495.36-359.83c28.574-20.894 40.433-57.487 29.364-91.03" fill="{{ s.feature_empty_star_color }}" fill-rule="evenodd"/>
                <!-- Filled star overlay (partial based on rating) -->
                <g mask="url(#feature-mask-{{ block.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }})">
                  <rect width="1920" height="1920" fill="{{ s.feature_star_color }}" style="width: {{ star_width }};" />
                </g>
              </svg>
            {% endfor %}
          </div>
          <div class="review-rating-text">
            {{ s[feature_rating] | times: 1.0 }}
          </div>
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Sidebar Features List",
  "settings": [
    { "type": "text", "id": "feature_title_1", "label": "Feature 1 Title", "default": "Price" },
    {
      "type": "range",
      "id": "feature_rating_1",
      "label": "Feature 1 Rating",
      "default": 5.0,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    { "type": "text", "id": "feature_title_2", "label": "Feature 2 Title", "default": "Effectiveness" },
    {
      "type": "range",
      "id": "feature_rating_2",
      "label": "Feature 2 Rating",
      "default": 5.0,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    { "type": "text", "id": "feature_title_3", "label": "Feature 3 Title", "default": "Comfort" },
    {
      "type": "range",
      "id": "feature_rating_3",
      "label": "Feature 3 Rating",
      "default": 5.0,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    { "type": "text", "id": "feature_title_4", "label": "Feature 4 Title", "default": "Quality" },
    {
      "type": "range",
      "id": "feature_rating_4",
      "label": "Feature 4 Rating",
      "default": 4.8,
      "min": 0,
      "max": 5,
      "step": 0.1
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "checkbox",
      "id": "show_background",
      "label": "Show Background",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "default": 20,
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "default": 8,
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Stars"
    },
    {
      "type": "range",
      "id": "feature_star_size",
      "label": "Feature Star Size",
      "default": 15,
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "feature_star_color",
      "label": "Feature star color",
      "default": "#F1C40F"
    },
    {
      "type": "color",
      "id": "feature_empty_star_color",
      "label": "Empty star color",
      "default": "#e0e0e0"
    }
  ],
  "presets": [{ "name": "Sidebar Features List" }]
}
{% endschema %}
