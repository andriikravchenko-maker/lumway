              .simple-variant-picker__option[data-text-orientation="horizontal"][data-image-fullwidth="true"] .simple-variant-picker__image-variant img {
                width: 100% !important;
                height: 100% !important;
                object-fit: cover !important;
              }

              .simple-variant-picker__option[data-text-orientation="horizontal"][data-image-fullwidth="true"] .simple-variant-picker__grid-text {
                position: relative;
                z-index: 3;
                padding: 0 16px;
