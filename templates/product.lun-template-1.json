    "store_faq_BMMVUF": {
      "type": "store-faq",
      "blocks": {
        "faq_item_7fCMbe": {
          "type": "faq_item",
          "settings": {
            "question": "How long before I see results?",
            "answer": "<p>Most people start noticing a difference within 28-40 days of consistent use — like feeling lighter after meals and less daily discomfort.* For best results, take 3 gummies daily as part of a simple routine. Keep in mind: results can vary depending on your body and diet.</p>"
          }
        },
        "faq_item_gXcmep": {
          "type": "faq_item",
          "settings": {
            "question": "How many gummies should I take per day?",
            "answer": "<p>Take 3 gummies daily, anytime that fits your routine — with or without food. Each jar contains 60 gummies  No strict timing, no complicated schedule.</p>"
          }
        },
        "faq_item_tiFc8t": {
          "type": "faq_item",
          "settings": {
            "question": "Is it gentle on sensitive stomachs?",
            "answer": "<p>Yes — Gut Harmony is designed to be gentle and easy to tolerate. It’s free from major allergens, gluten, and artificial fillers, and uses a balanced blend of digestive-support ingredients.* If you have a medical condition or a highly sensitive gut, it’s always best to check with your doctor first.</p>"
          }
        },
        "faq_item_9AD6VG": {
          "type": "faq_item",
          "settings": {
            "question": "What does the 60-day guarantee include?",
            "answer": "<p>If you don’t feel a difference, you’re covered. We offer a 60-day money-back guarantee — even if the jar is opened. Just reach out to our support team, and we’ll take care of the rest. No hassle. </p>"
          }
        },
        "faq_item_fmKiR8": {
          "type": "faq_item",
          "settings": {
            "question": "Can I take this if I’m pregnant or nursing?",
            "answer": "<p>We recommend speaking with your healthcare provider before using any supplement during pregnancy or while nursing. </p>"
          }
        },
        "faq_item_4A6JDi": {
          "type": "faq_item",
          "settings": {
            "question": "Where are these made?",
            "answer": "<p>Gut Harmony Gummies are made in the USA in a cGMP- and NSF-certified facility. Every batch is tested for:Microbiological safetyHeavy metals So you can feel confident about what you’re taking daily.</p>"
          }
        }
      },
