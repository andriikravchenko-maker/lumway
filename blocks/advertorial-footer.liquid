      "id": "disclaimer_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Disclaimer Font Size",
      "default": 13
    },
    {
      "type": "select",
      "id": "disclaimer_line_height",
      "label": "Disclaimer Line Height",
      "options": [
        { "value": "1", "label": "1.0" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.4", "label": "1.4" },
        { "value": "1.5", "label": "1.5" },
        { "value": "1.6", "label": "1.6" },
        { "value": "1.8", "label": "1.8" },
        { "value": "2", "label": "2.0" }
      ],
      "default": "1.5"
    },
    {
      "type": "select",
      "id": "disclaimer_alignment",
      "label": "Disclaimer Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "disclaimer_opacity",
      "min": 0.1,
      "max": 1.0,
      "step": 0.1,
      "label": "Disclaimer Opacity",
      "default": 0.9
    },
    {
      "type": "header",
      "content": "Copyright & Links"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "Â© 2025 Your Brand. All rights reserved."
    },
    {
      "type": "range",
      "id": "copyright_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Copyright Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "copyright_opacity",
      "min": 0.1,
      "max": 1.0,
      "step": 0.1,
      "label": "Copyright Opacity",
      "default": 0.8
    },
    {
      "type": "checkbox",
      "id": "show_links",
      "label": "Show Links",
      "default": true
    },
    {
      "type": "text",
      "id": "terms_text",
      "label": "Terms Text",
      "default": "Terms of Service"
    },
    {
      "type": "url",
      "id": "terms_link",
      "label": "Terms Link"
    },
    {
      "type": "text",
      "id": "privacy_text",
      "label": "Privacy Text",
      "default": "Privacy Policy"
    },
    {
      "type": "url",
      "id": "privacy_link",
      "label": "Privacy Link"
    },
    {
      "type": "range",
      "id": "link_font_size",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Link Font Size",
      "default": 12
    },
    {
      "type": "range",
      "id": "links_gap",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Links Gap",
      "default": 10
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
