{%- unless product.has_only_default_variant -%}
  <div
    class="simple-variant-picker"
    style="
      --label-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.label_color }}{% endif %};
      --label-size: {{ block.settings.label_size }}px;
      --show-labels: {% if block.settings.show_labels == false %}none{% else %}block{% endif %};
      --option-bg-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ block.settings.option_bg_color }}{% endif %};
      --option-border-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.option_border_color }}{% endif %};
      --option-text-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.option_text_color }}{% endif %};
      --option-size: {{ block.settings.option_size }}px;
      --option-border-radius: {{ block.settings.option_border_radius }}px;
      --option-padding-vertical: {{ block.settings.option_padding_vertical | default: 8 }}px;
      --option-padding-horizontal: {{ block.settings.option_padding_horizontal | default: 15 }}px;
      --option-font-size: {{ block.settings.option_font_size | default: 14 }}px;
      --option-image-size: {{ block.settings.image_variant_size | default: 30 }}px;
      --container-margin-left: {{ block.settings.container_margin_left | default: 5 }}px;
      --container-margin-right: {{ block.settings.container_margin_right | default: 0 }}px;
      --selected-bg-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ block.settings.selected_bg_color }}{% endif %};
      --selected-text-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ block.settings.selected_text_color }}{% endif %};
      --selected-border-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ block.settings.selected_border_color }}{% endif %};
      --swatch-size: {{ block.settings.swatch_size }}px;
      --swatch-bg-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_accent_2_color }}{% else %}{{ block.settings.swatch_bg_color }}{% endif %};
      --outline-color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.outline_color | default: '#e5e5e5' }}{% endif %};
      --image-variant-size: {{ block.settings.image_variant_size | default: 60 }}px;
      --variant-image-width: {% if block.settings.variant_image_size_mode == 'custom' %}{{ block.settings.variant_image_width | default: 80 }}px{% else %}{{ block.settings.image_variant_size | default: 60 }}px{% endif %};
      --variant-image-height: {% if block.settings.variant_image_size_mode == 'custom' %}{{ block.settings.variant_image_height | default: 80 }}px{% else %}{{ block.settings.image_variant_size | default: 60 }}px{% endif %};
      --variant-image-border-width: {{ block.settings.variant_image_border_width | default: 1 }}px;
      --variant-image-border-color: {{ block.settings.variant_image_border_color | default: '#e5e5e5' }};
      --variant-image-border-radius: {{ block.settings.variant_image_border_radius | default: 4 }}px;
      --variant-image-selected-border-color: {{ block.settings.variant_image_selected_border_color | default: '#007acc' }};
      --variant-image-selected-border-width: {{ block.settings.variant_image_selected_border_width | default: 2 }}px;
      --show-variant-shadows: {% if block.settings.show_variant_shadows %}1{% else %}0{% endif %};
      --grid-gap: {{ block.settings.grid_gap | default: 12 }}px;
      --grid-max-width: {{ block.settings.grid_max_width | default: 800 }}px;
      --horizontal-row-height: {{ block.settings.horizontal_row_height | default: 40 }}px;
      --size-button-height: {{ block.settings.size_button_height | default: 44 }}px;
      --size-button-height-mobile: {{ block.settings.size_button_height_mobile | default: 40 }}px;
      --size-button-font-size: {{ block.settings.size_button_font_size | default: 14 }}px;
      --size-button-font-size-mobile: {{ block.settings.size_button_font_size_mobile | default: 12 }}px;
      --size-button-border-radius: {{ block.settings.size_button_border_radius | default: 8 }}px;
      --size-button-gap: {{ block.settings.size_button_gap | default: 8 }}px;
      --size-button-bg-color: {{ block.settings.size_button_bg_color | default: '#ffffff' }};
      --size-button-text-color: {{ block.settings.size_button_text_color | default: '#1a1a1a' }};
      --size-button-border-color: {{ block.settings.size_button_border_color | default: '#e0e0e0' }};
      --size-button-border-width: {{ block.settings.size_button_border_width | default: 1 | at_least: 1 }}px;
      --size-button-border-style: {{ block.settings.size_button_border_style | default: 'solid' }};
      --size-button-selected-bg-color: {{ block.settings.size_button_selected_bg_color | default: '#1a1a1a' }};
      --size-button-selected-text-color: {{ block.settings.size_button_selected_text_color | default: '#ffffff' }};
      --size-button-selected-border-color: {{ block.settings.size_button_selected_border_color | default: '#1a1a1a' }};
      --size-button-selected-border-width: {{ block.settings.size_button_selected_border_width | default: 2 }}px;
      --option-button-height: {{ block.settings.option_button_height | default: 44 }}px;
      --option-button-padding-horizontal: {{ block.settings.option_button_padding_horizontal | default: 16 }}px;
      --option-button-font-size: {{ block.settings.option_button_font_size | default: 14 }}px;
      --option-button-border-radius: {{ block.settings.option_button_border_radius | default: 8 }}px;
      --option-button-gap: {{ block.settings.option_button_gap | default: 8 }}px;
      --option-button-border-width: {{ block.settings.option_button_border_width | default: 1 }}px;
      --option-button-border-style: {{ block.settings.option_button_border_style | default: 'solid' }};
      --option-button-bg-color: {{ block.settings.option_button_bg_color | default: '#ffffff' }};
      --option-button-text-color: {{ block.settings.option_button_text_color | default: '#1a1a1a' }};
      --option-button-border-color: {{ block.settings.option_button_border_color | default: '#e0e0e0' }};
      --option-button-selected-border-width: {{ block.settings.option_button_selected_border_width | default: 2 }}px;
      --option-button-selected-bg-color: {{ block.settings.option_button_selected_bg_color | default: '#1a1a1a' }};
      --option-button-selected-text-color: {{ block.settings.option_button_selected_text_color | default: '#ffffff' }};
      --option-button-selected-border-color: {{ block.settings.option_button_selected_border_color | default: '#1a1a1a' }};
      --fullwidth-text-size: {{ block.settings.fullwidth_text_size | default: 16 }}px;
      --fullwidth-text-color: {{ block.settings.fullwidth_text_color | default: '#ffffff' }};
      --fullwidth-text-weight: {{ block.settings.fullwidth_text_weight | default: '600' }};
      --save-badge-font-size: {{ block.settings.save_badge_font_size | default: 12 }}px;
      --save-badge-text-color: {{ block.settings.save_badge_text_color | default: '#ffffff' }};
      --save-badge-bg-color: {{ block.settings.save_badge_bg_color | default: '#22c55e' }};
      --save-badge-border-radius: {{ block.settings.save_badge_border_radius | default: 4 }}px;
      --variant-price-font-size: {{ block.settings.variant_price_font_size | default: 14 }}px;
      --variant-price-color: {{ block.settings.variant_price_color | default: '#ffffff' }};
      --variant-compare-price-color: {{ block.settings.variant_compare_price_color | default: '#999999' }};
      --list-bg-color: {{ block.settings.list_bg_color | default: '#ffffff' }};
      --list-border-color: {{ block.settings.list_border_color | default: '#e0e0e0' }};
      --list-text-color: {{ block.settings.list_text_color | default: '#1a1a1a' }};
      --list-price-color: {{ block.settings.list_price_color | default: '#1a1a1a' }};
      --list-compare-price-color: {{ block.settings.list_compare_price_color | default: '#999999' }};
      --list-savings-color: {{ block.settings.list_savings_color | default: '#16a34a' }};
      --list-savings-font-size: {{ block.settings.list_savings_font_size | default: 12 }}px;
      --list-savings-font-weight: {{ block.settings.list_savings_font_weight | default: '500' }};
      --list-selected-bg-color: {{ block.settings.list_selected_bg_color | default: '#f0f9ff' }};
      --list-selected-border-color: {{ block.settings.list_selected_border_color | default: '#007acc' }};
      --list-selected-text-color: {{ block.settings.list_selected_text_color | default: '#1a1a1a' }};
      --list-selected-price-color: {{ block.settings.list_selected_price_color | default: '#1a1a1a' }};
      --list-selected-compare-price-color: {{ block.settings.list_selected_compare_price_color | default: '#999999' }};
      --list-selected-savings-color: {{ block.settings.list_selected_savings_color | default: '#16a34a' }};
      --list-radio-color: {{ block.settings.list_radio_color | default: '#007acc' }};
      --list-show-radio: {% if block.settings.list_show_radio_button %}1{% else %}0{% endif %};
      --list-border-radius: {{ block.settings.list_border_radius | default: 8 }}px;
      --dropdown-width: {{ block.settings.dropdown_width | default: '100%' }};
      margin-top: {{ margin_top }}px;
      margin-bottom: {{ margin_bottom }}px;
    "
    data-show-variant-images="{{ block.settings.show_variant_images }}"
    data-show-images-for-all-variants="{{ block.settings.show_images_for_all_variants }}"
    data-variant-images-option-position="{{ block.settings.variant_images_option_position | default: 'auto' }}"
    data-multiply-by-quantity="{{ block.settings.multiply_price_by_quantity }}"
    data-apply-subscription-discount="{{ block.settings.apply_selected_subscription_discount }}"
    {{ block.shopify_attributes }}
  >
    {%- liquid
      assign variants_available_arr = product.variants | map: 'available'
      assign variants_option1_arr = product.variants | map: 'option1'
      assign variants_option2_arr = product.variants | map: 'option2'
      assign variants_option3_arr = product.variants | map: 'option3'
      assign color_swatch_mappings = settings.color_swatch_mappings | newline_to_br | split: '<br />'

      # Variant hiding parameters
      assign hide_option_1 = hide_option_1 | default: false
      assign hide_option_2 = hide_option_2 | default: false
      assign hide_option_3 = hide_option_3 | default: false
      assign hide_option_4 = hide_option_4 | default: false

      # Parse custom color mappings from theme settings
      assign custom_color_mappings = block.settings.custom_color_mappings | newline_to_br | split: '<br />'

      # We can't use complex hash manipulation in standard Liquid, so we'll use simpler approach
      # Create arrays of variant IDs and their images
      assign variant_ids = ''
      assign variant_images_array = ''
      for variant in product.variants
        if variant.image != blank
          assign variant_ids = variant_ids | append: variant.id | append: ','
          assign variant_images_array = variant_images_array | append: variant.image.src | append: ','
        endif
      endfor

      # Create arrays for option values and images
      assign option_keys = ''
      assign option_values = ''
      assign option_images = ''
      for variant in product.variants
        if variant.image != blank
          for option in product.options
            assign option_index = forloop.index
            assign option_key = option | downcase
            assign option_value = variant | json | split: '"option' | append: option_index | append: '":"' | split: '"' | last | split: '"' | first

            # Store this option data for lookup
            assign option_keys = option_keys | append: option_key | append: ','
            assign option_values = option_values | append: option_value | append: ','
            assign option_images = option_images | append: variant.image.src | append: ','
          endfor
        endif
      endfor
    -%}

    <div class="simple-variant-picker__container">
      {%- for option in product.options_with_values -%}
        {%- liquid
          # Check if this option should be hidden
          assign should_hide_option = false
          if option.position == 1 and hide_option_1
            assign should_hide_option = true
          elsif option.position == 2 and hide_option_2
            assign should_hide_option = true
          elsif option.position == 3 and hide_option_3
            assign should_hide_option = true
          elsif option.position == 4 and hide_option_4
            assign should_hide_option = true
          endif
        -%}

        {%- unless should_hide_option -%}
          {%- liquid
            # Reset option-specific variables for each loop iteration
            assign is_color_option = false
            assign is_size_option = false
            assign should_show_option_images = false
            assign use_option_dropdown = false
            assign use_option_buttons = false
            assign option_layout = 'inline'
            assign text_orientation = 'vertical'
            assign horizontal_style = 'simple'

            assign option_name_downcase = option.name | downcase
            assign option_value = ''
            assign option_index = option.position

            if block.settings.first_variant_auto_selected
              if option.position == 1
                assign option_value = product.selected_or_first_available_variant.option1
              elsif option.position == 2
                assign option_value = product.selected_or_first_available_variant.option2
              elsif option.position == 3
                assign option_value = product.selected_or_first_available_variant.option3
              elsif option.position == 4
                assign option_value = product.selected_or_first_available_variant.option4
              endif
            endif

            # Get the per-option display type setting
            assign current_display_type = 'auto'
            if option.position == 1
              assign current_display_type = block.settings.option_1_display_type | default: 'auto'
            elsif option.position == 2
              assign current_display_type = block.settings.option_2_display_type | default: 'auto'
            elsif option.position == 3
              assign current_display_type = block.settings.option_3_display_type | default: 'auto'
            elsif option.position == 4
              assign current_display_type = block.settings.option_4_display_type | default: 'auto'
            endif

            # If display type is set explicitly, use that
            assign option_layout = 'inline'
            assign text_orientation = 'vertical'

            # Get the text orientation setting for grid layouts
            assign horizontal_style = 'simple'
            assign list_inline = false
            if option.position == 1
              assign text_orientation = block.settings.option_1_text_orientation | default: 'vertical'
              assign horizontal_style = block.settings.option_1_horizontal_style | default: 'simple'
              assign list_inline = block.settings.option_1_list_inline | default: false
              assign dynamic_images = block.settings.option_1_dynamic_images_variant_change | default: false
            elsif option.position == 2
              assign text_orientation = block.settings.option_2_text_orientation | default: 'vertical'
              assign horizontal_style = block.settings.option_2_horizontal_style | default: 'simple'
              assign list_inline = block.settings.option_2_list_inline | default: false
              assign dynamic_images = block.settings.option_2_dynamic_images_variant_change | default: false
            elsif option.position == 3
              assign text_orientation = block.settings.option_3_text_orientation | default: 'vertical'
              assign horizontal_style = block.settings.option_3_horizontal_style | default: 'simple'
              assign list_inline = block.settings.option_3_list_inline | default: false
              assign dynamic_images = block.settings.option_3_dynamic_images_variant_change | default: false
            elsif option.position == 4
              assign text_orientation = block.settings.option_4_text_orientation | default: 'vertical'
              assign horizontal_style = block.settings.option_4_horizontal_style | default: 'simple'
              assign list_inline = block.settings.option_4_list_inline | default: false
              assign dynamic_images = block.settings.option_4_dynamic_images_variant_change | default: false
            endif

            if current_display_type == 'color_swatch'
              assign is_color_option = true
              assign is_size_option = false
              assign should_show_option_images = false
              assign use_option_dropdown = false
              assign use_option_buttons = false
            elsif current_display_type == 'variant_image'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = true
              assign use_option_dropdown = false
              assign use_option_buttons = false
              assign option_layout = 'inline'
            elsif current_display_type == 'variant_image_grid_2'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = true
              assign use_option_dropdown = false
              assign use_option_buttons = false
              assign option_layout = 'grid-2'
            elsif current_display_type == 'variant_image_grid_3'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = true
              assign use_option_dropdown = false
              assign use_option_buttons = false
              assign option_layout = 'grid-3'
            elsif current_display_type == 'variant_image_list'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = true
              assign use_option_dropdown = false
              assign use_option_buttons = false
              assign option_layout = 'list'
            elsif current_display_type == 'dropdown'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = false
              assign use_option_dropdown = true
              assign use_option_buttons = false
            elsif current_display_type == 'buttons'
              assign is_color_option = false
              assign is_size_option = false
              assign should_show_option_images = false
              assign use_option_dropdown = false
              assign use_option_buttons = true
            elsif current_display_type == 'size_buttons'
              assign is_color_option = false
              assign is_size_option = true
              assign should_show_option_images = false
              assign use_option_dropdown = false
              assign use_option_buttons = true
            else
              # Auto mode - detect based on option name
              assign use_option_dropdown = false
              assign use_option_buttons = false

              if option_name_downcase contains 'color' or option_name_downcase contains 'colour' or option_name_downcase contains 'couleur'
                assign is_color_option = true
              endif

              if option_name_downcase contains 'size' or option_name_downcase contains 'taille'
                assign is_size_option = true
              endif

              # Determine if this option should show variant images based on the setting
              assign variant_images_option_position = block.settings.variant_images_option_position | default: 'auto'
              assign should_show_option_images = false
              if variant_images_option_position == 'auto'
                # Auto mode: show images for color options only
                if is_color_option
                  assign should_show_option_images = true
                endif
              else
                # Specific option position selected
                assign selected_position = variant_images_option_position | plus: 0
                if option.position == selected_position
                  assign should_show_option_images = true
                endif
              endif

              # Disable color option if explicitly set to false
              unless block.settings.enable_color_swatches
                assign is_color_option = false
              endunless

              if is_size_option and block.settings.enable_size_preset == false
                assign is_size_option = false
              endif
            endif

            # Get custom label for this option
            assign custom_label = ''
            assign has_custom_label = false

            # Check for new custom label settings first
            if option.position == 1 and block.settings.custom_label_option_1 != blank
              assign custom_label = block.settings.custom_label_option_1
              assign has_custom_label = true
            elsif option.position == 2 and block.settings.custom_label_option_2 != blank
              assign custom_label = block.settings.custom_label_option_2
              assign has_custom_label = true
            elsif option.position == 3 and block.settings.custom_label_option_3 != blank
              assign custom_label = block.settings.custom_label_option_3
              assign has_custom_label = true
            elsif option.position == 4 and block.settings.custom_label_option_4 != blank
              assign custom_label = block.settings.custom_label_option_4
              assign has_custom_label = true
              # Fallback to old label settings
            elsif is_color_option and block.settings.color_option_label != blank
              assign custom_label = block.settings.color_option_label
            elsif is_size_option and block.settings.size_option_label != blank
              assign custom_label = block.settings.size_option_label
            elsif option.position == 1 and block.settings.custom_option_label_1 != blank
              assign custom_label = block.settings.custom_option_label_1
            elsif option.position == 2 and block.settings.custom_option_label_2 != blank
              assign custom_label = block.settings.custom_option_label_2
            elsif option.position == 3 and block.settings.custom_option_label_3 != blank
              assign custom_label = block.settings.custom_option_label_3
            elsif option.position == 4 and block.settings.custom_option_label_4 != blank
              assign custom_label = block.settings.custom_option_label_4
            else
              assign custom_label = option.name
            endif
          -%}

          <div class="simple-variant-picker__error" style="display: none;" role="alert" aria-live="assertive">
            <span>Please select a variant</span>
          </div>

          {% if use_dropdown or use_option_dropdown %}
            <div class="simple-variant-picker__option simple-variant-picker__dropdown-option">
              <label class="simple-variant-picker__label" for="{{ section.id }}-{{ option.position }}-select">
                {{ custom_label }}
              </label>
              <select
                class="simple-variant-picker__select"
                id="{{ section.id }}-{{ option.position }}-select"
                name="options[{{ option.name | escape }}]"
                form="{{ product_form_id }}"
                data-option-position="{{ option.position }}"
              >
                {%- for value in option.values -%}
                  {%- liquid
                    assign option_disabled = true
                    assign option_exists = false

                    # Determine if option is available - check if ANY variant with this option value is available
                    assign option_image_url = null

                    # Skip pulling variant images if this is a size option or explicit button type
                    assign is_explicit_button = false
                    if current_display_type == 'size_buttons' or current_display_type == 'buttons' or use_option_buttons or is_size_option
                      assign is_explicit_button = true
                    endif

                    for variant in product.variants
                      assign variant_has_option = false
                      case option.position
                        when 1
                          if variant.option1 == value
                            assign variant_has_option = true
                          endif
                        when 2
                          if variant.option2 == value
                            assign variant_has_option = true
                          endif
                        when 3
                          if variant.option3 == value
                            assign variant_has_option = true
                          endif
                      endcase

                      if variant_has_option
                        assign option_exists = true
                        if variant.available
                          assign option_disabled = false
                        endif

                        # Pull image only if NOT a button/size option
                        if is_explicit_button == false and variant.image != blank and option_image_url == null
                          assign option_image_url = variant.image
                        endif

                        # If we found both availability and an image (or if we don't need an image), we can stop
                        if option_disabled == false
                          if is_explicit_button or option_image_url != null
                            break
                          endif
                        endif
                      endif
                    endfor
                  -%}

                  <option
                    value="{{ value | escape }}"

                    {% if option_disabled %}
                      disabled
                    {% endif %}
                    {% if option_exists == false %}
                      data-non-existent
                    {% endif %}
                  >
                    {{ value }}
                    {% if option_disabled %} (Unavailable){% endif %}
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {% else %}
            <div
              class="simple-variant-picker__option{% if is_color_option %} option--color{% endif %}{% if is_size_option %} option--size{% endif %}{% if use_option_buttons %} option--buttons{% endif %}{% if should_show_option_images %} option--images{% endif %}"
              data-option-layout="{{ option_layout | default: 'inline' }}"
              data-text-orientation="{{ text_orientation | default: 'vertical' }}"
              data-horizontal-style="{{ horizontal_style | default: 'simple' }}"
              data-list-inline="{{ list_inline | default: false }}"
              data-dynamic-images="{{ dynamic_images | default: false }}"
              data-option-index="{{ option_index }}"
              data-image-fade="{{ block.settings.horizontal_image_fade | default: false }}"
              data-image-fullwidth="{{ block.settings.horizontal_image_fullwidth | default: false }}"
              data-hide-fullwidth-text="{{ block.settings.hide_fullwidth_text | default: false }}"
              data-show-save-badge="{{ block.settings.show_fullwidth_save_badge | default: false }}"
              data-show-text-shadow="{{ block.settings.show_variant_shadows | default: false }}"
              data-show-price="{{ block.settings.show_variant_price | default: false }}"
              data-price-position="{{ block.settings.price_display_position | default: 'inside' }}"
              data-fullwidth-text-position="{{ block.settings.fullwidth_text_position | default: 'inside' }}"
            >
              <div class="simple-variant-picker__label-header">
                {%- comment -%} Show label with optional selected variant value {%- endcomment -%}
                <div class="simple-variant-picker__label-row">
                  <label
                    class="simple-variant-picker__label"
                    id="{{ section.id }}-{{ option.position }}-label"
                    for="{{ section.id }}-{{ option.position }}-0"
                    style="color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.label_color }}{% endif %};"
                  >
                    {% if has_custom_label %}
                      {{ custom_label }}:
                    {% else %}
                      {{ option.name }}:
                    {% endif %}
                  </label>

                  {% if block.settings.show_selected_value_next_to_label %}
                    <span
                      class="simple-variant-picker__selected-value"
                      style="color: {% if block.settings.use_theme_colors %}{{ settings.global_section_text_color }}{% else %}{{ block.settings.label_color }}{% endif %};{% if block.settings.bold_selected_value %} font-weight: 700 !important;{% endif %}"
                      data-option-position="{{ option.position }}"
                    >
                      {% if block.settings.first_variant_auto_selected -%}
                        {{- option_value | default: option.values.first }}
                      {% else %}
                        {{ option_value | default: option.values.first }}
                      {% endif %}
                    </span>
                  {% endif %}
                </div>

                {%- comment -%} Check for inline size chart - only show on the selected option position {%- endcomment -%}
                {%- for section_block in section.blocks -%}
                  {%- assign inline_option_pos = section_block.settings.inline_option_position | default: '1' -%}
                  {%- assign current_option_pos = option.position | append: '' -%}
                  {%- if section_block.type == 'size_chart'
                    and section_block.settings.inline_with_variant_picker
                    and current_option_pos == inline_option_pos
                  -%}
                    <div class="simple-variant-picker__inline-size-chart">
                      {% render 'size-chart-block',
                        block: section_block,
                        remove_background_container: section_block.settings.remove_background_container,
                        underline_text: section_block.settings.underline_text,
                        trigger_bg_color: section_block.settings.trigger_bg_color,
                        trigger_text_color: section_block.settings.trigger_text_color,
                        trigger_border_width: section_block.settings.trigger_border_width,
                        trigger_border_color: section_block.settings.trigger_border_color,
                        trigger_border_radius: section_block.settings.trigger_border_radius,
                        trigger_font_size: section_block.settings.trigger_font_size,
                        trigger_font_weight: section_block.settings.trigger_font_weight,
                        trigger_letter_spacing: section_block.settings.trigger_letter_spacing,
                        trigger_text: section_block.settings.trigger_text,
                        show_icon: section_block.settings.show_icon,
                        use_custom_icon: section_block.settings.use_custom_icon,
                        custom_icon: section_block.settings.custom_icon,
                        icon_size: section_block.settings.icon_size,
                        icon_margin: section_block.settings.icon_margin,
                        popup_bg_color: section_block.settings.popup_bg_color,
                        popup_border_radius: section_block.settings.popup_border_radius,
                        popup_max_width: section_block.settings.popup_max_width,
                        popup_backdrop_color: section_block.settings.popup_backdrop_color,
                        popup_header_bg_color: section_block.settings.popup_header_bg_color,
                        popup_header_text_color: section_block.settings.popup_header_text_color,
                        popup_header_font_size: section_block.settings.popup_header_font_size,
                        popup_header_padding: section_block.settings.popup_header_padding,
                        popup_border_color: section_block.settings.popup_border_color,
                        popup_title: section_block.settings.popup_title,
                        close_button_color: section_block.settings.close_button_color,
                        close_button_hover_color: section_block.settings.close_button_hover_color,
                        close_button_hover_bg: section_block.settings.close_button_hover_bg,
                        popup_body_padding: section_block.settings.popup_body_padding,
                        popup_body_text_color: section_block.settings.popup_body_text_color,
                        popup_body_font_size: section_block.settings.popup_body_font_size,
                        popup_content_type: section_block.settings.popup_content_type,
                        content_type: section_block.settings.content_type,
                        table_header_1: section_block.settings.table_header_1,
                        table_header_2: section_block.settings.table_header_2,
                        table_header_3: section_block.settings.table_header_3,
                        table_header_4: section_block.settings.table_header_4,
                        table_header_5: section_block.settings.table_header_5,
                        table_row_1_col_1: section_block.settings.table_row_1_col_1,
                        table_row_1_col_2: section_block.settings.table_row_1_col_2,
                        table_row_1_col_3: section_block.settings.table_row_1_col_3,
                        table_row_1_col_4: section_block.settings.table_row_1_col_4,
                        table_row_1_col_5: section_block.settings.table_row_1_col_5,
                        table_row_2_col_1: section_block.settings.table_row_2_col_1,
                        table_row_2_col_2: section_block.settings.table_row_2_col_2,
                        table_row_2_col_3: section_block.settings.table_row_2_col_3,
                        table_row_2_col_4: section_block.settings.table_row_2_col_4,
                        table_row_2_col_5: section_block.settings.table_row_2_col_5,
                        table_row_3_col_1: section_block.settings.table_row_3_col_1,
                        table_row_3_col_2: section_block.settings.table_row_3_col_2,
                        table_row_3_col_3: section_block.settings.table_row_3_col_3,
                        table_row_3_col_4: section_block.settings.table_row_3_col_4,
                        table_row_3_col_5: section_block.settings.table_row_3_col_5,
                        table_row_4_col_1: section_block.settings.table_row_4_col_1,
                        table_row_4_col_2: section_block.settings.table_row_4_col_2,
                        table_row_4_col_3: section_block.settings.table_row_4_col_3,
                        table_row_4_col_4: section_block.settings.table_row_4_col_4,
                        table_row_4_col_5: section_block.settings.table_row_4_col_5,
                        table_row_5_col_1: section_block.settings.table_row_5_col_1,
                        table_row_5_col_2: section_block.settings.table_row_5_col_2,
                        table_row_5_col_3: section_block.settings.table_row_5_col_3,
                        table_row_5_col_4: section_block.settings.table_row_5_col_4,
                        table_row_5_col_5: section_block.settings.table_row_5_col_5,
                        size_chart_image: section_block.settings.size_chart_image,
                        custom_content: section_block.settings.custom_content,
                        popup_note: section_block.settings.popup_note,
                        table_border_color: section_block.settings.table_border_color,
                        table_text_color: section_block.settings.table_text_color,
                        table_header_bg: section_block.settings.table_header_bg,
                        table_header_text_color: section_block.settings.table_header_text_color,
                        table_row_hover_bg: section_block.settings.table_row_hover_bg,
                        note_bg_color: section_block.settings.note_bg_color,
                        note_border_color: section_block.settings.note_border_color,
                        note_text_color: section_block.settings.note_text_color,
                        scrollbar_track_color: section_block.settings.scrollbar_track_color,
                        scrollbar_thumb_color: section_block.settings.scrollbar_thumb_color,
                        scrollbar_thumb_hover_color: section_block.settings.scrollbar_thumb_hover_color,
                        margin_top: 0,
                        margin_bottom: 0,
                        inline_mode: true
                      %}
                    </div>
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              </div>
              {%- comment -%} Close .simple-variant-picker__label-header {%- endcomment -%}

              <div
                class="simple-variant-picker__values"
                role="radiogroup"
                aria-labelledby="{{ section.id }}-{{ option.position }}-label"
              >
                {%- for value in option.values -%}
                  {%- liquid
                    assign option_disabled = true
                    assign option_exists = false
                    assign color_hex = ''
                    assign image_url = ''
                    assign image_url_2x = ''
                    assign option_image_url = null

                    assign option_index = option.position | minus: 1
                    for variant in product.variants
                      if variant.options[option_index] == value
                        assign option_image_url = variant.image
                      endif
                    endfor

                    # Find variant image for this option if should_show_option_images is true
                    if should_show_option_images
                      for variant in product.variants
                        case option.position
                          when 1
                            if variant.option1 == value and variant.image
                              assign image_url = variant.image | image_url: width: 400
                              assign image_url_2x = variant.image | image_url: width: 800
                              break
                            endif
                          when 2
                            if variant.option2 == value and variant.image
                              assign image_url = variant.image | image_url: width: 400
                              assign image_url_2x = variant.image | image_url: width: 800
                              break
                            endif
                          when 3
                            if variant.option3 == value and variant.image
                              assign image_url = variant.image | image_url: width: 400
                              assign image_url_2x = variant.image | image_url: width: 800
                              break
                            endif
                        endcase
                      endfor
                    endif

                    if is_color_option
                      assign value_downcase = value | downcase

                      # Look for this color in the custom color mappings
                      for color in custom_color_mappings
                        assign color_line = color | strip
                        assign color_parts = color_line | split: '='

                        if color_parts.size >= 2
                          assign color_name = color_parts[0] | strip | downcase
                          assign color_hex_value = color_parts[1] | strip

                          if value_downcase == color_name
                            assign color_hex = color_hex_value
                            break
                          endif
                        endif
                      endfor

                      # Check if the value itself is a hex code
                      assign first_char = value | slice: 0, 1
                      assign value_size = value | size
                      if color_hex == '' and first_char == '#' and value_size == 7
                        assign color_hex = value
                      endif

                      # Fall back to default color if no hex color found
                      if color_hex == blank or color_hex == ''
                        # Try to get a sensible color based on the color name
                        for mapping in color_swatch_mappings
                          assign parts = mapping | split: ':'
                          assign color_name = parts[0] | strip | downcase
                          assign color_value = parts[1] | strip

                          if value_downcase == color_name
                            assign color_hex = color_value
                            break
                          endif
                        endfor
                      endif
                    endif

                    # For size options, prepare the abbreviated display value
                    assign display_value = value
                    if is_size_option
                      assign value_downcase = value | downcase
                      case value_downcase
                        when 'small', 'small size'
                          assign display_value = 'S'
                        when 'medium', 'medium size'
                          assign display_value = 'M'
                        when 'large', 'large size'
                          assign display_value = 'L'
                        when 'extra large', 'extra-large', 'xlarge', 'x-large', 'xl', 'x large', 'extra large size'
                          assign display_value = 'XL'
                        when 'extra extra large', 'extra-extra-large', 'xxlarge', 'xx-large', 'xxl', 'xx large', '2xl', '2x large', 'extra extra large size'
                          assign display_value = '2XL'
                        when 'extra extra extra large', 'extra-extra-extra-large', 'xxxlarge', 'xxx-large', 'xxxl', 'xxx large', '3xl', '3x large', 'extra extra extra large size'
                          assign display_value = '3XL'
                        when 'extra small', 'extra-small', 'xsmall', 'x-small', 'xs', 'x small', 'extra small size'
                          assign display_value = 'XS'
                        when 'petite'
                          assign display_value = 'P'
                        when 'one size', 'one size fits all', 'one-size', 'one-size-fits-all'
                          assign display_value = 'OS'
                      endcase
                    endif

                    # Determine if option is available - check if ANY variant with this option value is available
                    assign option_image_url = null

                    # Skip pulling variant images if this is a size option or explicit button type
                    assign is_explicit_button = false
                    if current_display_type == 'size_buttons' or current_display_type == 'buttons' or use_option_buttons or is_size_option
                      assign is_explicit_button = true
                    endif

                    for variant in product.variants
                      assign variant_has_option = false
                      case option.position
                        when 1
                          if variant.option1 == value
                            assign variant_has_option = true
                          endif
                        when 2
                          if variant.option2 == value
                            assign variant_has_option = true
                          endif
                        when 3
                          if variant.option3 == value
                            assign variant_has_option = true
                          endif
                      endcase

                      if variant_has_option
                        assign option_exists = true
                        if variant.available
                          assign option_disabled = false
                        endif

                        # Pull image only if NOT a button/size option
                        if is_explicit_button == false and variant.image != blank and option_image_url == null
                          assign option_image_url = variant.image
                        endif

                        # If we found both availability and an image (or if we don't need an image), we can stop
                        if option_disabled == false
                          if is_explicit_button or option_image_url != null
                            break
                          endif
                        endif
                      endif
                    endfor

                    assign option_class = ''
                    if option_exists == false
                      assign option_class = 'non-existent'
                    elsif option_disabled == true
                      assign option_class = 'unavailable'
                    endif
                  -%}

                  <div class="simple-variant-picker__value-container{% if is_color_option %} value--color{% endif %}{% if is_size_option %} value--size{% endif %}">
                    <input
                      type="radio"
                      id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                      name="options[{{ option.name | escape }}]"
                      value="{{ value | escape }}"
                      form="{{ product_form_id }}"
                      {% if block.settings.first_variant_auto_selected and option_value == value %}
                        checked
                      {% endif %}

                      {% if option_disabled %}
                        disabled
                      {% endif %}
                      data-option-position="{{ option.position }}"
                      class="simple-variant-picker__radio {{ option_class }}"
                      {% if image_url != blank %}
                        data-image-url="{{ image_url }}"
                      {% endif %}
                    >
                    {% if current_display_type == 'variant_image'
                      or current_display_type == 'variant_image_grid_2'
                      or current_display_type == 'variant_image_grid_3'
                      or current_display_type == 'variant_image_list'
                      or should_show_option_images
                    %}
                      {%- comment -%} Variant Images display mode {%- endcomment -%}

                      {% if option_layout == 'list' %}
                        {%- comment -%} List layout: image left, text right {%- endcomment -%}
                        {%- comment -%} Find the variant for this option value to get its price {%- endcomment -%}
                        {%- assign list_variant_for_value = null -%}
                        {%- for variant in product.variants -%}
                          {%- if option.position == 1 and variant.option1 == value -%}
                            {%- assign list_variant_for_value = variant -%}
                            {%- break -%}
                          {%- elsif option.position == 2 and variant.option2 == value -%}
                            {%- assign list_variant_for_value = variant -%}
                            {%- break -%}
                          {%- elsif option.position == 3 and variant.option3 == value -%}
                            {%- assign list_variant_for_value = variant -%}
                            {%- break -%}
                          {%- elsif option.position == 4 and variant.option4 == value -%}
                            {%- assign list_variant_for_value = variant -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                        <label
                          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          class="simple-variant-picker__list-item {{ option_class }}"
                          data-list-style="{{ horizontal_style | default: 'simple' }}"
                          data-show-radio="{% if block.settings.list_show_radio_button %}true{% else %}false{% endif %}"
                        >
                          {% if block.settings.list_show_radio_button and horizontal_style == 'quantity_break' %}
                            <span class="simple-variant-picker__list-radio">
                              <span class="simple-variant-picker__list-radio-inner"></span>
                            </span>
                          {% endif %}
                          {% if image_url != blank %}
                            <img
                              src="{{ image_url }}"
                              srcset="{{ image_url }} 1x, {{ image_url_2x }} 2x"
                              alt="{{ value }}"
                              loading="lazy"
                              width="80"
                              height="80"
                            >
                          {% endif %}
                          <div class="simple-variant-picker__list-text">
                            <span class="simple-variant-picker__list-title">{{ value }}</span>
                            {% if horizontal_style == 'quantity_break' and list_variant_for_value != null %}
                              {%- if list_variant_for_value.compare_at_price > list_variant_for_value.price -%}
                                {%- assign list_save_amount = list_variant_for_value.compare_at_price
                                  | minus: list_variant_for_value.price
                                -%}
                                {%- assign list_save_percent = list_save_amount
                                  | times: 100.0
                                  | divided_by: list_variant_for_value.compare_at_price
                                  | round
                                -%}
                                <span class="simple-variant-picker__list-savings">
                                  {{- block.settings.list_savings_prefix | default: 'Save' }}
                                  {{ list_save_percent }}% ({{ list_save_amount | money }})</span
                                >
                              {%- endif -%}
                            {% endif %}
                          </div>
                          {% if horizontal_style == 'quantity_break' and list_variant_for_value != null %}
                            <div
                              class="simple-variant-picker__list-price simple-variant-picker__quantity-break-price"
                              data-price="{{ list_variant_for_value.price }}"
                              data-compare-at-price="{{ list_variant_for_value.compare_at_price | default: 0 }}"
                            >
                              <span class="simple-variant-picker__list-current-price">
                                {{- list_variant_for_value.price | money -}}
                              </span>
                              {% if list_variant_for_value.compare_at_price > list_variant_for_value.price %}
                                <span class="simple-variant-picker__list-compare-price">
                                  {{- list_variant_for_value.compare_at_price | money -}}
                                </span>
                              {% endif %}
                            </div>
                          {% endif %}
                        </label>
                      {% elsif option_layout == 'grid-2' or option_layout == 'grid-3' %}
                        {%- comment -%} Grid layout: image with text below {%- endcomment -%}
                        <label
                          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          class="simple-variant-picker__image-variant {{ option_class }}"
                        >
                          {% if image_url != blank %}
                            <img
                              src="{{ image_url }}"
                              srcset="{{ image_url }} 1x, {{ image_url_2x }} 2x"
                              alt="{{ value }}"
                              loading="lazy"
                              width="200"
                              height="200"
                            >
                          {% else %}
                            <span class="simple-variant-picker__variant-text">{{ value }}</span>
                          {% endif %}
                        </label>
                        {%- comment -%} Find the variant for this option value to get its price {%- endcomment -%}
                        {%- assign variant_for_value = null -%}
                        {%- for variant in product.variants -%}
                          {%- if option.position == 1 and variant.option1 == value -%}
                            {%- assign variant_for_value = variant -%}
                            {%- break -%}
                          {%- elsif option.position == 2 and variant.option2 == value -%}
                            {%- assign variant_for_value = variant -%}
                            {%- break -%}
                          {%- elsif option.position == 3 and variant.option3 == value -%}
                            {%- assign variant_for_value = variant -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}

                        <span class="simple-variant-picker__grid-text">
                          <span class="variant-text-left">
                            <span class="variant-name">{{ value }}</span>
                            {% if horizontal_style == 'quantity_break' and variant_for_value != null %}
                              {%- if variant_for_value.compare_at_price > variant_for_value.price -%}
                                {%- assign save_amount = variant_for_value.compare_at_price
                                  | minus: variant_for_value.price
                                -%}
                                {%- assign save_percent = save_amount
                                  | times: 100.0
                                  | divided_by: variant_for_value.compare_at_price
                                  | round
                                -%}
                                <span class="horizontal-savings-text"
                                  >Save {{ save_percent }}% ({{ save_amount | money }})</span
                                >
                              {%- endif -%}
                            {% endif %}
                          </span>
                          {% if horizontal_style == 'quantity_break' and variant_for_value != null %}
                            <span
                              class="variant-price-right simple-variant-picker__quantity-break-price"
                              data-price="{{ variant_for_value.price }}"
                              data-compare-at-price="{{ variant_for_value.compare_at_price | default: 0 }}"
                            >
                              <span class="variant-price">{{ variant_for_value.price | money }}</span>
                              {% if variant_for_value.compare_at_price > variant_for_value.price %}
                                <span class="variant-compare-price">
                                  {{- variant_for_value.compare_at_price | money -}}
                                </span>
                              {% endif %}
                            </span>
                          {% else %}
                            {% if block.settings.show_fullwidth_save_badge %}
                              {%- if variant_for_value != null
                                and variant_for_value.compare_at_price > variant_for_value.price
                              -%}
                                {%- assign save_amount = variant_for_value.compare_at_price
                                  | minus: variant_for_value.price
                                -%}
                                <span class="save-badge">
                                  {{- block.settings.save_badge_prefix | default: 'Save' }}
                                  {{ save_amount | money -}}
                                </span>
                              {%- endif -%}
                            {% endif %}
                            {% if block.settings.show_variant_price
                              and block.settings.price_display_position == 'inside'
                              and variant_for_value != null
                            %}
                              <span class="variant-price-container">
                                {% if block.settings.show_compare_at_price
                                  and variant_for_value.compare_at_price > variant_for_value.price
                                %}
                                  <span class="variant-compare-price">
                                    {{- variant_for_value.compare_at_price | money -}}
                                  </span>
                                {% endif %}
                                <span class="variant-price">{{ variant_for_value.price | money }}</span>
                              </span>
                            {% endif %}
                          {% endif %}
                        </span>

                        {% if block.settings.show_variant_price
                          and block.settings.price_display_position == 'below'
                          and variant_for_value != null
                        %}
                          <span class="simple-variant-picker__price-below">
                            {% if block.settings.show_compare_at_price
                              and variant_for_value.compare_at_price > variant_for_value.price
                            %}
                              <span class="variant-compare-price">
                                {{- variant_for_value.compare_at_price | money -}}
                              </span>
                            {% endif %}
                            <span class="variant-price">{{ variant_for_value.price | money }}</span>
                          </span>
                        {% endif %}
                      {% else %}
                        {%- comment -%} Default inline layout {%- endcomment -%}
                        <label
                          for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                          class="simple-variant-picker__image-variant {{ option_class }}"
                        >
                          {% if image_url != blank %}
                            <img
                              src="{{ image_url }}"
                              srcset="{{ image_url }} 1x, {{ image_url_2x }} 2x"
                              alt="{{ value }}"
                              loading="lazy"
                              width="80"
                              height="80"
                              style="width: var(--variant-image-width); height: var(--variant-image-height); object-fit: cover; border-radius: var(--variant-image-border-radius);"
                            >
                          {% else %}
                            <span class="simple-variant-picker__variant-text">{{ value }}</span>
                          {% endif %}
                        </label>
                      {% endif %}
                    {% elsif is_color_option %}
                      {%- comment -%} Color Swatch display mode {%- endcomment -%}
                      <label
                        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                        class="simple-variant-picker__color-swatch {{ option_class }} "

                        {% if image_url != blank and block.settings.show_variant_images %}
                          style="background-image: url('{{ image_url }}'); width: var(--swatch-size); height: var(--swatch-size);"
                        {% else %}
                          style="background-color: {{ color_hex }} !important; width: var(--swatch-size) !important; height: var(--swatch-size) !important;"
                        {% endif %}
                        {% if value_downcase == 'white' %}
                          data-white-swatch
                        {% endif %}
                      >
                        <span class="visually-hidden">{{ value }}</span>
                      </label>
                    {% elsif option_image_url != blank and block.settings.show_images_for_all_variants %}
                      {%- comment -%} Show images for all variants (legacy fallback) {%- endcomment -%}
                      <label
                        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                        class="simple-variant-picker__image-variant {{ option_class }}{% if is_size_option %} size-value{% endif %}"
                      >
                        <img
                          src="{{ option_image_url | image_url: width: 200 }}"
                          srcset="{{ option_image_url | image_url: width: 200 }} 1x, {{ option_image_url | image_url: width: 400 }} 2x"
                          alt="{{ value }}"
                          loading="lazy"
                          width="80"
                          height="80"
                        >
                      </label>
                    {% elsif use_option_buttons or is_size_option %}
                      {%- comment -%} Option Buttons display mode (or Size preset) {%- endcomment -%}
                      <label
                        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                        class="simple-variant-picker__value {{ option_class }}{% if is_size_option %} size-value{% endif %} "
                      >
                        <span>
                          {% if is_size_option %}
                            {{ display_value }}
                          {% else %}
                            {{ value }}
                          {% endif %}
                        </span>
                      </label>
                    {% else %}
                      {%- comment -%} Default button style {%- endcomment -%}
                      <label
                        for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
