              /* Apply text shadow only when enabled */
              .simple-variant-picker__option[data-text-orientation="horizontal"][data-image-fullwidth="true"][data-show-text-shadow="true"] .simple-variant-picker__grid-text {
                text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
              }

              .simple-variant-picker__option[data-text-orientation="horizontal"][data-image-fullwidth="true"][data-show-text-shadow="true"] .simple-variant-picker__grid-text .variant-name {
                text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
              }

              .simple-variant-picker__option[data-text-orientation="horizontal"][data-image-fullwidth="true"] .simple-variant-picker__grid-text .variant-name {
                display: block;
              }

              /* General save-badge styling for all layouts */
              .simple-variant-picker__grid-text .save-badge {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 4px;
                background: var(--save-badge-bg-color, #22c55e);
                color: var(--save-badge-text-color, #fff);
                font-size: var(--save-badge-font-size, 12px);
                font-weight: 600;
                padding: 2px 8px;
                border-radius: var(--save-badge-border-radius, 4px);
