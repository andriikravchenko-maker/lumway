{%- comment -%}
  lum-amplitude-events — product-page analytics events per the ESGLD_61 event map.
  Scoped to the two agreed PDPs by product HANDLE (gut-harmony-gummies / gut-flow-gummies), not by
  template: the team reshuffles products across lum templates, handles stay put. Everything else
  renders nothing.
  Every event carries product_id (handle, as in the map examples) + page_title, goes to Amplitude via the
  app-injected window.amplitude AND is mirrored as a DOM CustomEvent 'lum:analytics' — the single seam for
  the planned move off Amplitude to a custom pipeline. Passive listeners only; no purchase logic touched.
  Already covered elsewhere (not duplicated here): scroll_depth (amplitude-scroll-depth.js),
  checkout_started (amplitude-cart-checkout.js).
  Usage: {% render 'lum-amplitude-events', product: product %}
{%- endcomment -%}
{%- if product != blank and template.name == 'product' -%}
{%- if product.handle == 'gut-harmony-gummies' or product.handle == 'gut-flow-gummies' -%}
<script>
  (function () {
    if (window.__lumEventsBound) return;
    window.__lumEventsBound = true;

    var PRODUCT_ID = {{ product.handle | json }};
    var PACKS = ['1_jar', '2_jars', '3_jars', '4_jars'];
    var state = { bundle_type: null, purchase_type: null };

    function h(s) { return String(s || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, ''); }

    var queue = [];
    function ampFn() {
      var amp = window.amplitude;
      if (!amp) return null;
      if (typeof amp.track === 'function') return amp.track.bind(amp);
      if (amp.default && typeof amp.default.track === 'function') return amp.default.track.bind(amp.default);
      if (typeof amp.getInstance === 'function') {
        try {
          var inst = amp.getInstance();
          if (inst && typeof inst.logEvent === 'function') return function (n, p) { inst.logEvent(n, p); };
        } catch (e) {}
      }
      return null;
    }
    function track(name, props) {
      try {
        var payload = Object.assign({ product_id: PRODUCT_ID, page_title: document.title }, props || {});
        document.dispatchEvent(new CustomEvent('lum:analytics', { detail: { event: name, properties: payload } }));
        var fn = ampFn();
        if (fn) fn(name, payload); else queue.push([name, payload]);
      } catch (e) {}
    }
    // the Amplitude app can arrive after us; flush what queued while it loaded
    var tries = 0;
    var flusher = setInterval(function () {
      var fn = ampFn();
      if (fn) { queue.splice(0).forEach(function (ev) { fn(ev[0], ev[1]); }); clearInterval(flusher); }
      else if (++tries > 40) { clearInterval(flusher); }
    }, 1000);

    // ---- page_view -------------------------------------------------------
    track('page_view', { page_type: 'product', referrer: document.referrer || '' });

    // ---- initial buy-box state (no events, just remember the preselection)
    function packIndexOf(input) {
      var card = input.closest('.bsl__card');
      if (!card) return -1;
      var cards = [].slice.call(card.closest('.bsl__grid').querySelectorAll('.bsl__card'));
      return cards.indexOf(card);
    }
    function readInitial() {
      var b = document.querySelector('.bsl__input:checked');
      if (b) { var i = packIndexOf(b); if (i > -1) state.bundle_type = PACKS[i] || null; }
      var p = document.querySelector('.ptl__input:checked');
      if (p) state.purchase_type = p.value === 'subscribe' ? 'subscription' : 'one_time';
    }
    if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', readInitial); } else { readInitial(); }

    // ---- buy box ---------------------------------------------------------
    var bslVariants = null;
    function bundlePrice(variantId) {
      try {
        if (!bslVariants) bslVariants = JSON.parse(document.querySelector('.bsl-variants').textContent) || [];
        for (var i = 0; i < bslVariants.length; i++) {
          if (String(bslVariants[i].id) === String(variantId)) return Math.round(bslVariants[i].price) / 100;
        }
      } catch (e) {}
      return null;
    }
    document.addEventListener('change', function (e) {
      var t = e.target;
      if (t.classList && t.classList.contains('bsl__input')) {
        var i = packIndexOf(t);
        if (i > -1) {
          state.bundle_type = PACKS[i] || String(i + 1);
          track('bundle_selected', { bundle_type: state.bundle_type, bundle_price: bundlePrice(t.value) });
        }
      }
      if (t.classList && t.classList.contains('ptl__input')) {
        state.purchase_type = t.value === 'subscribe' ? 'subscription' : 'one_time';
        track('purchase_type_selected', { purchase_type: state.purchase_type });
      }
    }, true);

    // ---- clicks (one delegate) -------------------------------------------
    var lastThumbClick = 0;
    document.addEventListener('click', function (e) {
      var el = e.target;

      var atc = el.closest('[data-atc-button]');
      if (atc) { track('add_to_cart', { purchase_type: state.purchase_type, bundle_type: state.bundle_type }); return; }

      var nav = el.closest('.header__inline-menu a, header-drawer nav a, header-drawer .menu-drawer__menu a');
      if (nav) { track('nav_click', { nav_item: h(nav.textContent) }); return; }

      var logo = el.closest('.header__heading-link, .header__heading-logo-wrapper');
      if (logo) { track('logo_clicked', {}); return; }

      var cartIcon = el.closest('.header__icon--cart');
      if (cartIcon) { track('cart_clicked', {}); return; }

      var tab = el.closest('.ptab [data-tab], [data-tab]');
      if (tab && el.closest('.ptab')) {
        var title = tab.querySelector('.ptab__check-title');
        track('tabs_clicked', { tab_name: h(title ? title.textContent : tab.textContent) });
        return;
      }

      var xsAdd = el.closest('.xsl__add');
      if (xsAdd) {
        var cardA = xsAdd.closest('.xsl__card') || document;
        var linkA = cardA.querySelector('a[href*="/products/"]');
        var nameA = cardA.querySelector('.xsl__title');
        track('cross_sell_add_click', {
          cross_sell_product_id: linkA ? (linkA.getAttribute('href').split('/products/')[1] || '').split('?')[0] : '',
          product_name: nameA ? nameA.textContent.trim() : ''
        });
        return;
      }
      var xsCard = el.closest('.xsl__main');
      if (xsCard) {
        var cardB = xsCard.closest('.xsl__card') || xsCard;
        var nameB = cardB.querySelector('.xsl__title');
        track('cross_sell_product_click', {
          cross_sell_product_id: (xsCard.getAttribute('href') || '').split('/products/')[1] ? (xsCard.getAttribute('href').split('/products/')[1] || '').split('?')[0] : '',
          product_name: nameB ? nameB.textContent.trim() : ''
        });
        return;
      }

      var thumb = el.closest('.lpg__item');
      if (thumb) {
        var rail = thumb.closest('[data-lpg-rail]');
        var thumbs = rail ? [].slice.call(rail.querySelectorAll('.lpg__item')) : [];
        lastThumbClick = Date.now();
        track('pp_image_thumbnail_click', {
          from_index: galleryIndex() + 1,
          to_index: thumbs.indexOf(thumb) + 1,
          total_images: totalImages()
        });
        return;
      }

      var faqQ = el.closest('.store-faq-question');
      if (faqQ) {
        var item = faqQ.closest('.store-faq-item');
        var qText = faqQ.textContent.trim().replace(/\s+/g, ' ').slice(0, 120);
        window.setTimeout(function () {
          track('faq_toggled', { question: qText, action: item && item.classList.contains('active') ? 'open' : 'close' });
        }, 0);
        return;
      }

      var rmv = el.closest('cart-remove-button');
      if (rmv) {
        var row = rmv.closest('.cart-item') || rmv.closest('tr') || document;
        var nm = row.querySelector('.cart-item__name');
        var pr = row.querySelector('.price, .cart-item__price-wrapper');
        track('cart_item_remove_click', {
          product_title: nm ? nm.textContent.trim().replace(/\s+/g, ' ') : '',
          price: pr ? pr.textContent.trim().replace(/\s+/g, ' ').slice(0, 40) : ''
        });
        return;
      }

      var qbtn = el.closest('cart-drawer button[name="plus"], cart-drawer button[name="minus"]');
      if (qbtn) {
        var qin = (qbtn.closest('quantity-input') || qbtn.parentElement).querySelector('input');
        var prev = qin ? parseInt(qin.value, 10) || 0 : 0;
        var next = qbtn.getAttribute('name') === 'plus' ? prev + 1 : Math.max(0, prev - 1);
        track('cart_quantity_change', { prev_quantity: prev, new_quantity: next });
        return;
      }
    }, true);

    // ---- gallery swipe -----------------------------------------------------
    var lpgTrack = document.querySelector('[data-lpg-track]');
    function galleryIndex() {
      if (!lpgTrack || !lpgTrack.clientWidth) return 0;
      return Math.round(lpgTrack.scrollLeft / lpgTrack.clientWidth);
    }
    function totalImages() {
      return document.querySelectorAll('[data-lpg-slide]').length;
    }
    if (lpgTrack) {
      var lastIdx = 0, swipeTimer = null;
      window.addEventListener('load', function () { lastIdx = galleryIndex(); });
      lpgTrack.addEventListener('scroll', function () {
        clearTimeout(swipeTimer);
        swipeTimer = setTimeout(function () {
          var idx = galleryIndex();
          if (idx === lastIdx) return;
          // a thumbnail click scrolls the track programmatically; that one is already tracked
          if (Date.now() - lastThumbClick > 900) {
            track('pp_image_swipe', { from_index: lastIdx + 1, to_index: idx + 1, total_images: totalImages() });
          }
          lastIdx = idx;
        }, 200);
      }, { passive: true });
    }

    // ---- reviews carousel --------------------------------------------------
    var revSection = document.querySelector('[id*="customer_reviews_carousel"]:not([style*="display: none"])');
    if (revSection) {
      var revLastClick = 0;
      revSection.addEventListener('click', function (e) {
        if (e.target.closest('button, [data-scroll-amount], .carousel-arrow, [class*="arrow"]')) revLastClick = Date.now();
      }, true);
      var revTimer = null, revLast = 0;
      revSection.addEventListener('scroll', function (e) {
        var sc = e.target;
        if (!sc || typeof sc.scrollLeft !== 'number') return;
        clearTimeout(revTimer);
        revTimer = setTimeout(function () {
          var slide = revSection.querySelector('.swiper-slide');
          var w = slide ? slide.offsetWidth : sc.clientWidth;
          if (!w) return;
          var idx = Math.round(sc.scrollLeft / w);
          if (idx === revLast) return;
          track('reviews_carousel', {
            interaction_type: (Date.now() - revLastClick < 900) ? 'click' : 'swipe',
            photo_index: idx + 1,
            direction: idx > revLast ? 'next' : 'prev'
          });
          revLast = idx;
        }, 250);
      }, true);
    }

    // ---- cart_view (drawer opens) ------------------------------------------
    var drawer = document.querySelector('cart-drawer');
    if (drawer && 'MutationObserver' in window) {
      var wasOpen = false;
      new MutationObserver(function () {
        var open = drawer.classList.contains('active') || drawer.classList.contains('animate');
        if (open && !wasOpen) track('cart_view', {});
        wasOpen = open;
      }).observe(drawer, { attributes: true, attributeFilter: ['class'] });
    }

    // ---- footer newsletter ---------------------------------------------------
    document.addEventListener('submit', function (e) {
      if (e.target && e.target.closest('#ContactFooter, .footer .newsletter-form, footer .newsletter-form')) {
        track('footer_email_subscribe', {});
      }
    }, true);
  })();
</script>
{%- endif -%}
{%- endif -%}
