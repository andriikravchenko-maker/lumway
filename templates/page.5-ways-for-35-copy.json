        "title_6k7zw7": {
          "type": "title",
          "settings": {
            "title": "For years, women have been told",
            "accent_text": "that losing desire after 45 is just “part of getting older.”"
          }
        },
        "subtitle_J6QgnC": {
          "type": "subtitle",
          "settings": {
            "subtitle": "<p>And eventually, many women begin to believe: <strong>“This is just my new normal.”</strong></p>"
          }
        },
        "subtitle_LjgwEz": {
          "type": "subtitle",
          "settings": {
            "subtitle": "<p><strong>But what if that explanation is incomplete?</strong></p><p>What if feeling less connected, less energized, and less like yourself isn’t only about hormones — but also about the systems that help your body create energy, maintain healthy circulation, and respond to daily life?</p><p>That’s where the conversation is starting to change.</p>"
          }
        }
