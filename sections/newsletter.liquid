{% comment %}
  --Fixed ID uniqueness - Removed the generic id="Subscribe" from the submit button--
  --Improved accessibility - Made semantic heading tags match visual heading size classes--
  --Enhanced internationalization - Made the newsletter tag value translatable--
  --Added footer restriction - Prevented section from appearing in footer areas--
  --Simplified CSS class naming - Used a generic class instead of section ID for padding--
  --Improved placeholder text - Made it distinct from the label text for better accessibility--
{% endcomment %}

{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'newsletter-section.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .newsletter-section-padding {
    padding-top: {{ section.settings.mobile_padding_top }}px;
    padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    padding-left: {{ section.settings.mobile_padding_horizontal }}px;
    padding-right: {{ section.settings.mobile_padding_horizontal }}px;
  }

  @media screen and (min-width: 750px) {
    .newsletter-section-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: {{ section.settings.padding_horizontal }}px;
      padding-right: {{ section.settings.padding_horizontal }}px;
    }
  }

  /* Input Label */
  .newsletter.section-{{ section.id }} .newsletter__input-label {
    display: block !important;
    font-size: {{ section.settings.input_label_font_size | default: 14 }}px !important;
    color: {{ section.settings.input_label_color | default: section.settings.text_color | default: '#666666' }} !important;
    margin-bottom: 8px !important;
    letter-spacing: var(--letter-spacing-body) !important;
    text-align: inherit;
  }

  /* Two Column Layout */
  {% if section.settings.two_column_layout %}
  .newsletter.section-{{ section.id }} .newsletter__wrapper {
    text-align: left !important;
    {% if section.settings.section_max_width > 0 %}
    max-width: {{ section.settings.section_max_width }}px !important;
    margin-left: auto !important;
    margin-right: auto !important;
    {% endif %}
  }

  @media screen and (min-width: 990px) {
    .newsletter.section-{{ section.id }} .newsletter__wrapper {
      display: flex !important;
      flex-wrap: wrap !important;
      align-items: flex-start !important;
      justify-content: space-between !important;
      gap: {{ section.settings.column_gap | default: 60 }}px !important;
    }

    .newsletter.section-{{ section.id }} .newsletter__column--left {
      flex: 1 1 0 !important;
      max-width: calc(50% - {{ section.settings.column_gap | default: 60 | divided_by: 2 }}px) !important;
    }

    .newsletter.section-{{ section.id }} .newsletter__column--right {
      flex: 1 1 0 !important;
      max-width: calc(50% - {{ section.settings.column_gap | default: 60 | divided_by: 2 }}px) !important;
    }

    .newsletter.section-{{ section.id }} .newsletter-form {
      max-width: 100% !important;
      width: 100% !important;
    }

    .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper {
      width: 100% !important;
      max-width: 100% !important;
    }

    .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field {
      width: 100% !important;
      max-width: 100% !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }

    .newsletter.section-{{ section.id }} .newsletter__column--left .inline-richtext,
    .newsletter.section-{{ section.id }} .newsletter__column--left .newsletter__subheading,
    .newsletter.section-{{ section.id }} .newsletter__column--left .newsletter__subheading.rte,
    .newsletter.section-{{ section.id }} .newsletter__column--left .newsletter__subheading p,
    .newsletter.section-{{ section.id }} .newsletter__column--left .rte {
      text-align: left !important;
    }
  }

  @media screen and (max-width: 989px) {
    .newsletter.section-{{ section.id }} .newsletter__column--left,
    .newsletter.section-{{ section.id }} .newsletter__column--right {
      width: 100% !important;
    }

    .newsletter.section-{{ section.id }} .newsletter__column--left {
      margin-bottom: 24px !important;
    }
  }

  /* Disclaimer Text */
  .newsletter.section-{{ section.id }} .newsletter__disclaimer {
    font-size: {{ section.settings.disclaimer_font_size | default: 12 }}px !important;
    color: {{ section.settings.disclaimer_color | default: '#666666' }} !important;
    margin-top: 12px !important;
    line-height: 1.5 !important;
  }

  .newsletter.section-{{ section.id }} .newsletter__disclaimer a {
    color: {{ section.settings.disclaimer_link_color | default: '#0066cc' }} !important;
    text-decoration: underline !important;
  }

  /* Button with text styling */
  {% if section.settings.show_button_text %}
  .newsletter.section-{{ section.id }} .newsletter-form__button {
    width: auto !important;
    min-width: 80px !important;
    padding: 0 16px !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button .newsletter-button-text {
    font-size: {{ section.settings.input_font_size | default: 14 }}px !important;
    font-weight: 600 !important;
    color: {{ section.settings.button_text_color | default: '#ffffff' }} !important;
    white-space: nowrap !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input {
    padding-right: 110px !important;
  }
  {% endif %}
  {% endif %}

  /* Section Background Color */
  {% if section.settings.section_background_color != blank %}
  .newsletter.section-{{ section.id }} {
    background-color: {{ section.settings.section_background_color }} !important;
  }
  .newsletter.section-{{ section.id }} .newsletter__wrapper {
    background-color: transparent !important;
  }
  {% endif %}

  /* Heading Styles */
  .newsletter.section-{{ section.id }} .h0,
  .newsletter.section-{{ section.id }} .h1,
  .newsletter.section-{{ section.id }} .h2,
  .newsletter.section-{{ section.id }} .hxl,
  .newsletter.section-{{ section.id }} .hxxl,
  .newsletter.section-{{ section.id }} h1,
  .newsletter.section-{{ section.id }} h2 {
    {% if section.settings.heading_color != blank %}
    color: {{ section.settings.heading_color }} !important;
    {% endif %}
    font-size: {{ section.settings.heading_font_size_mobile | default: 24 }}px !important;
  }

  @media screen and (min-width: 750px) {
    .newsletter.section-{{ section.id }} .h0,
    .newsletter.section-{{ section.id }} .h1,
    .newsletter.section-{{ section.id }} .h2,
    .newsletter.section-{{ section.id }} .hxl,
    .newsletter.section-{{ section.id }} .hxxl,
    .newsletter.section-{{ section.id }} h1,
    .newsletter.section-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_font_size | default: 32 }}px !important;
    }
  }

  /* Text/Paragraph Styles */
  .newsletter.section-{{ section.id }} .newsletter__subheading,
  .newsletter.section-{{ section.id }} .rte,
  .newsletter.section-{{ section.id }} p {
    {% if section.settings.text_color != blank %}
    color: {{ section.settings.text_color }} !important;
    {% endif %}
    font-size: {{ section.settings.text_font_size_mobile | default: 14 }}px !important;
  }

  @media screen and (min-width: 750px) {
    .newsletter.section-{{ section.id }} .newsletter__subheading,
    .newsletter.section-{{ section.id }} .rte,
    .newsletter.section-{{ section.id }} p {
      font-size: {{ section.settings.text_font_size | default: 16 }}px !important;
    }
  }

  /* Newsletter Input Customization */
  .newsletter.section-{{ section.id }} .newsletter-form {
    max-width: {{ section.settings.form_max_width | default: 400 }}px;
    margin-left: auto;
    margin-right: auto;
  }

  @media screen and (max-width: 749px) {
    .newsletter.section-{{ section.id }} .newsletter-form {
      max-width: 100% !important;
      width: 100% !important;
    }
    .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper {
      max-width: 100% !important;
      width: 100% !important;
    }
    .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field {
      max-width: 100% !important;
      width: 100% !important;
    }
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field {
    position: relative !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input {
    height: {{ section.settings.input_height | default: 50 }}px !important;
    min-height: {{ section.settings.input_height | default: 50 }}px !important;
    border-radius: {{ section.settings.input_border_radius | default: 8 }}px !important;
    border-width: {{ section.settings.input_border_width | default: 1 }}px !important;
    border-color: {{ section.settings.input_border_color | default: '#cccccc' }} !important;
    border-style: solid !important;
    font-size: {{ section.settings.input_font_size | default: 14 }}px !important;
    background-color: {{ section.settings.input_bg_color | default: '#ffffff' }} !important;
    color: {{ section.settings.input_text_color | default: '#000000' }} !important;
    padding: 12px 16px !important;
    /* Space for button */
    padding-right: calc({{ section.settings.input_height | default: 50 }}px - 10px + {{ section.settings.input_border_width | default: 1 }}px + 5px + 8px) !important;
    -webkit-text-fill-color: {{ section.settings.input_text_color | default: '#000000' }} !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input::placeholder {
    color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
    opacity: 1 !important;
    -webkit-text-fill-color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input::-webkit-input-placeholder {
    color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
    -webkit-text-fill-color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input::-moz-placeholder {
    color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input:-ms-input-placeholder {
    color: {{ section.settings.input_placeholder_color | default: '#999999' }} !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input:focus,
  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__input:focus-visible {
    border-radius: {{ section.settings.input_border_radius | default: 8 }}px !important;
    outline: none !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button {
    width: calc({{ section.settings.input_height | default: 50 }}px - 10px) !important;
    height: calc({{ section.settings.input_height | default: 50 }}px - 10px) !important;
    border-radius: {{ section.settings.button_border_radius | default: 6 }}px !important;
    position: absolute !important;
    top: calc({{ section.settings.input_border_width | default: 1 }}px + 5px) !important;
    right: calc({{ section.settings.input_border_width | default: 1 }}px + 5px) !important;
    z-index: 2 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: {{ section.settings.button_bg_color | default: '#000000' }} !important;
    background-color: {{ section.settings.button_bg_color | default: '#000000' }} !important;
    background-image: none !important;
    border: none !important;
    box-shadow: none !important;
    color: {{ section.settings.button_text_color | default: '#ffffff' }} !important;
    transition: opacity 0.3s ease !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button:hover {
    opacity: 0.85 !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button:before,
  .newsletter.section-{{ section.id }} .newsletter-form__button:after {
    display: none !important;
    content: none !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button svg,
  .newsletter.section-{{ section.id }} .newsletter-form__button .svg-wrapper {
    width: 16px !important;
    height: 16px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .newsletter.section-{{ section.id }} .newsletter-form__button svg {
    fill: {{ section.settings.button_text_color | default: '#ffffff' }} !important;
    stroke: {{ section.settings.button_text_color | default: '#ffffff' }} !important;
  }

  /* Hide label - using placeholder instead */
  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field__label {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Remove pseudo-element that creates duplicate input appearance */
  .newsletter.section-{{ section.id }} .newsletter-form__field-wrapper .field:after {
    display: none !important;
    content: none !important;
  }

  /* Block-level custom styles */
  {% for block in section.blocks %}
    {% if block.type == 'heading' and block.settings.use_custom_styles %}
      .newsletter.section-{{ section.id }} [data-block-id="{{ block.id }}"].inline-richtext {
        font-size: {{ block.settings.font_size_mobile }}px !important;
        line-height: {{ block.settings.line_height }} !important;
        margin-bottom: {{ block.settings.margin_bottom }}px !important;
        {% if block.settings.heading_color != blank %}
        color: {{ block.settings.heading_color }} !important;
        {% endif %}
      }

      @media screen and (min-width: 750px) {
        .newsletter.section-{{ section.id }} [data-block-id="{{ block.id }}"].inline-richtext {
          font-size: {{ block.settings.font_size_desktop }}px !important;
        }
      }
    {% endif %}

    {% if block.type == 'paragraph' and block.settings.use_custom_styles %}
      .newsletter.section-{{ section.id }} [data-block-id="{{ block.id }}"].newsletter__subheading {
        font-size: {{ block.settings.font_size_mobile }}px !important;
        line-height: {{ block.settings.line_height }} !important;
        margin-bottom: {{ block.settings.margin_bottom }}px !important;
        {% if block.settings.text_color != blank %}
        color: {{ block.settings.text_color }} !important;
        {% endif %}
      }

      @media screen and (min-width: 750px) {
        .newsletter.section-{{ section.id }} [data-block-id="{{ block.id }}"].newsletter__subheading {
          font-size: {{ block.settings.font_size_desktop }}px !important;
        }
      }
    {% endif %}

    {% if block.type == 'email_form' %}
      .newsletter.section-{{ section.id }} .newsletter__below-input,
      .newsletter.section-{{ section.id }} .newsletter__below-input.rte,
      .newsletter.section-{{ section.id }} .newsletter__below-input p,
      .newsletter.section-{{ section.id }} .newsletter__below-input span,
      .newsletter.section-{{ section.id }} .newsletter__below-input * {
        font-size: {{ block.settings.below_input_font_size | default: 13 }}px !important;
        color: {{ block.settings.below_input_color | default: '#666666' }} !important;
        -webkit-text-fill-color: {{ block.settings.below_input_color | default: '#666666' }} !important;
        line-height: 1.5 !important;
      }

      .newsletter.section-{{ section.id }} .newsletter__below-input {
        margin-top: {{ block.settings.below_input_margin_top | default: 10 }}px !important;
      }

      .newsletter.section-{{ section.id }} .newsletter__below-input a,
      .newsletter.section-{{ section.id }} .newsletter__below-input a * {
        color: {{ block.settings.below_input_link_color | default: '#0066cc' }} !important;
        -webkit-text-fill-color: {{ block.settings.below_input_link_color | default: '#0066cc' }} !important;
        text-decoration: underline !important;
      }
    {% endif %}
  {% endfor %}
{%- endstyle -%}

<div class="newsletter section-{{ section.id }} center {% if section.settings.full_width == false %}newsletter--narrow page-width{% endif %}">
  <div class="newsletter__wrapper content-container isolate{% if section.settings.full_width %} content-container--full-width{% endif %} newsletter-section-padding">
    {% if section.settings.two_column_layout %}
      <!-- Two Column Layout -->
      <div class="newsletter__column--left">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when '@app' -%}
          {% render block %}
        {%- when 'heading' -%}
          {%- assign heading_tag = 'h2' -%}
          {%- if block.settings.heading_size == 'h1'
            or block.settings.heading_size == 'h0'
            or block.settings.heading_size == 'hxl'
            or block.settings.heading_size == 'hxxl'
          -%}
            {%- assign heading_tag = 'h1' -%}
          {%- endif -%}

          <{{ heading_tag }}
            class="inline-richtext {{ block.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
                data-block-id="{{ block.id }}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
                style="{% if settings.animations_reveal_on_scroll %}--animation-order: {{ forloop.index }};{% endif %}{% if block.settings.use_custom_styles and block.settings.margin_bottom %}margin-bottom: {{ block.settings.margin_bottom }}px;{% endif %}"
          >
            {{ block.settings.heading }}
          </{{ heading_tag }}>
        {%- when 'paragraph' -%}
          <div
            class="newsletter__subheading rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {{ block.shopify_attributes }}
                data-block-id="{{ block.id }}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                {% endif %}
                style="{% if settings.animations_reveal_on_scroll %}--animation-order: {{ forloop.index }};{% endif %}{% if block.settings.use_custom_styles and block.settings.margin_bottom %}margin-bottom: {{ block.settings.margin_bottom }}px;{% endif %}"
              >
                {{ block.settings.text }}
              </div>
          {%- endcase -%}
        {%- endfor -%}
      </div>

      <div class="newsletter__column--right">
        {%- for block in section.blocks -%}
          {%- if block.type == 'email_form' -%}
            <div {{ block.shopify_attributes }}>
              {% if section.settings.show_input_label and section.settings.input_label_text != blank %}
                <label
                  class="newsletter__input-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  for="NewsletterForm--{{ section.id }}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index }};"
                  {% endif %}
                >
                  {{ section.settings.input_label_text }}
                </label>
              {% endif %}
              {% form 'customer', class: 'newsletter-form' %}
                <input
                  type="hidden"
                  name="contact[tags]"
                  value="{{ 'newsletter.tag_value' | t | default: 'newsletter' }}"
                >
                <div
                  class="newsletter-form__field-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
              style="--animation-order: {{ forloop.index }};"
            {% endif %}
                >
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="Newsletter-error--{{ section.id }}"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="Newsletter-success--{{ section.id }}"
                      {% endif %}
                      placeholder="{{ section.settings.input_placeholder_text | default: 'Enter your email' }}"
                      required
                    >
                    <label class="field__label visually-hidden" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      {% if section.settings.show_button_text and section.settings.button_text != blank %}
                        <span class="newsletter-button-text">{{ section.settings.button_text }}</span>
                      {% else %}
                        <span class="svg-wrapper">
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                        </span>
                      {% endif %}
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                      <span class="svg-wrapper">
                        {{- 'icon-error.svg' | inline_asset_content -}}
                      </span>
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="Newsletter-success--{{ section.id }}"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-success.svg' | inline_asset_content -}}
                    </span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {% endform %}
              {% if block.settings.below_input_text != blank %}
                <div
                  class="newsletter__below-input rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index | plus: 1 }};"
                  {% endif %}
                >
                  {{ block.settings.below_input_text }}
                </div>
              {% endif %}
              {% if section.settings.disclaimer_text != blank %}
                <div class="newsletter__disclaimer rte">
                  {{ section.settings.disclaimer_text }}
                </div>
              {% endif %}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {% else %}
      <!-- Single Column Layout (Default) -->
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- when 'heading' -%}
            {%- assign heading_tag = 'h2' -%}
            {%- if block.settings.heading_size == 'h1'
              or block.settings.heading_size == 'h0'
              or block.settings.heading_size == 'hxl'
              or block.settings.heading_size == 'hxxl'
            -%}
              {%- assign heading_tag = 'h1' -%}
            {%- endif -%}

            <{{ heading_tag }}
              class="inline-richtext {{ block.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              data-block-id="{{ block.id }}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
              {% endif %}
              style="{% if settings.animations_reveal_on_scroll %}--animation-order: {{ forloop.index }};{% endif %}{% if block.settings.use_custom_styles and block.settings.margin_bottom %}margin-bottom: {{ block.settings.margin_bottom }}px;{% endif %}"
            >
              {{ block.settings.heading }}
            </{{ heading_tag }}>
          {%- when 'paragraph' -%}
            <div
              class="newsletter__subheading rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              {{ block.shopify_attributes }}
              data-block-id="{{ block.id }}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
              {% endif %}
              style="{% if settings.animations_reveal_on_scroll %}--animation-order: {{ forloop.index }};{% endif %}{% if block.settings.use_custom_styles and block.settings.margin_bottom %}margin-bottom: {{ block.settings.margin_bottom }}px;{% endif %}"
          >
            {{ block.settings.text }}
          </div>
        {%- when 'email_form' -%}
          <div {{ block.shopify_attributes }}>
            {% if section.settings.show_input_label and section.settings.input_label_text != blank %}
              <label
                class="newsletter__input-label{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                for="NewsletterForm--{{ section.id }}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {{ section.settings.input_label_text }}
              </label>
            {% endif %}
            {% form 'customer', class: 'newsletter-form' %}
              <input
                type="hidden"
                name="contact[tags]"
                value="{{ 'newsletter.tag_value' | t | default: 'newsletter' }}"
              >
              <div
                class="newsletter-form__field-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                <div class="field">
                  <input
                    id="NewsletterForm--{{ section.id }}"
                    type="email"
                    name="contact[email]"
                    class="field__input"
                    value="{{ form.email }}"
                    aria-required="true"
                    autocorrect="off"
                    autocapitalize="off"
                    autocomplete="email"
                    {% if form.errors %}
                      autofocus
                      aria-invalid="true"
                      aria-describedby="Newsletter-error--{{ section.id }}"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="Newsletter-success--{{ section.id }}"
                    {% endif %}
                      placeholder="{{ section.settings.input_placeholder_text | default: 'Enter your email' }}"
                    required
                  >
                  <label class="field__label" for="NewsletterForm--{{ section.id }}">
                    {{ 'newsletter.label' | t }}
                  </label>
                  <button
                    type="submit"
                    class="newsletter-form__button field__button"
                    name="commit"
                    aria-label="{{ 'newsletter.button_label' | t }}"
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-arrow.svg' | inline_asset_content -}}
                    </span>
                  </button>
                </div>
                {%- if form.errors -%}
                  <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
                    <span class="svg-wrapper">
                      {{- 'icon-error.svg' | inline_asset_content -}}
                    </span>
                    {{- form.errors.translated_fields.email | capitalize }}
                    {{ form.errors.messages.email -}}
                  </small>
                {%- endif -%}
              </div>
              {%- if form.posted_successfully? -%}
                <h3
                  class="newsletter-form__message newsletter-form__message--success form__message"
                  id="Newsletter-success--{{ section.id }}"
                  tabindex="-1"
                  autofocus
                >
                  <span class="svg-wrapper">
                    {{- 'icon-success.svg' | inline_asset_content -}}
                  </span>
                  {{- 'newsletter.success' | t }}
                </h3>
              {%- endif -%}
            {% endform %}
              {% if block.settings.below_input_text != blank %}
                <div
                  class="newsletter__below-input rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                  {% if settings.animations_reveal_on_scroll %}
                    data-cascade
                    style="--animation-order: {{ forloop.index | plus: 1 }};"
                  {% endif %}
                >
                  {{ block.settings.below_input_text }}
                </div>
              {% endif %}
          </div>
      {%- endcase -%}
    {%- endfor -%}
    {% endif %}
  </div>
</div>

