{{ 'shop-product-details.css' | asset_url | stylesheet_tag }}
{{ 'variant-selector.css' | asset_url | stylesheet_tag }}

{% liquid
  assign show_price_in_button = section.settings.show_price_in_button
%}
{% style %}
    .shop-product-section {
        letter-spacing: var(--letter-spacing-body);
        background-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_background_color }}{% else %}{{ section.settings.section_bg_color }}{% endif %};
        color: {{ section.settings.text_color }};
        --accent-color: {{ section.settings.accent_color }};
        --dot-size: {{ section.settings.dot_size | default: 8 }}px;
        --dot-color: {{ section.settings.dot_color | default: '#cccccc' }};
        --dot-active-color: {{ section.settings.dot_active_color | default: '#000000' }};
        --desktop-arrow-bg: {{ section.settings.desktop_arrow_background | default: '#ffffff' }};
        --desktop-arrow-border: {{ section.settings.desktop_arrow_border | default: '#e0e0e0' }};
        --desktop-arrow-icon: {{ section.settings.desktop_arrow_icon | default: '#000000' }};
        --desktop-arrow-hover-bg: {{ section.settings.desktop_arrow_hover_background | default: '#f5f5f5' }};
        --desktop-arrow-hover-border: {{ section.settings.desktop_arrow_hover_border | default: '#d0d0d0' }};
        --arrow-border-radius: {{ section.settings.arrow_border_radius | default: 50 }}%;
        --arrow-opacity: {{ section.settings.arrow_opacity | default: 90 | divided_by: 100.0 }};
    }
    /* Added container class to handle the margin without affecting other sections */
    .shop-product-info {
        gap: {{ section.settings.blocks_spacing }}px;
        color: {{ section.settings.text_color }};
    }
    .shop-thumbnail {
        border: 1px solid {{ section.settings.thumbnail_border_color }};
    }
    .shop-thumbnail.active {
        border-color: {% if section.settings.use_theme_colors %}{{ settings.global_section_accent_1_color }}{% else %}{{ section.settings.thumbnail_active_border_color }}{% endif %};
    }
     .shop-thumbnail .thumb-square {
        position: relative;
    }
    .shop-thumbnail .thumbnail-video-icon {
        position: absolute;
        top: 4px;
        right: 4px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.9);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a1a1a;
        box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08);
        z-index: 3;
    }
    .shop-thumbnail .thumbnail-video-icon svg {
        width: 8px;
        height: 8px;
        display: block;
    }
    .shop-indicator-dot {
        background-color: {{ section.settings.indicator_color }};
    }

    /* Flèches mobiles - version plus spécifique */
    .shop-product-section .shop-mobile-arrows {
      display: none !important;
    }

    @media screen and (max-width: 767px) {
      .shop-product-section .shop-mobile-arrows {
        display: flex !important;
        align-items: center;
        justify-content: space-between;
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        pointer-events: none;
        z-index: 5;
      }

      .shop-product-section .shop-mobile-arrow {
        width: 40px !important;
        height: 40px !important;
        border-radius: var(--arrow-border-radius);
        background-color: var(--desktop-arrow-bg);
        border: 1px solid var(--desktop-arrow-border);
        display: flex !important;
        align-items: center;
        justify-content: center;
        opacity: var(--arrow-opacity);
        pointer-events: auto;
        cursor: pointer;
        transition: all 0.2s ease;
      }
    }

    /* Masquer sur desktop */
    @media screen and (min-width: 768px) {
      .shop-product-section .shop-mobile-arrows {
        display: none !important;
      }
    }

    /* Dynamic aspect ratio based on setting */
    {% case section.settings.image_aspect_ratio %}
      {% when '3:4' %}
        .shop-image-container.shop-square-container {
          aspect-ratio: 3/4 !important;
        }
        /* Desktop thumbnails only - not mobile */
        @media screen and (min-width: 768px) {
          .shop-thumbnail .thumb-square {
            padding-bottom: 133.33% !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail {
            height: auto;
            aspect-ratio: 3/4 !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
            height: auto;
          }
        }
      {% when '2:3' %}
        .shop-image-container.shop-square-container {
          aspect-ratio: 2/3 !important;
        }
        /* Desktop thumbnails only - not mobile */
        @media screen and (min-width: 768px) {
          .shop-thumbnail .thumb-square {
            padding-bottom: 150% !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail {
            height: auto;
            aspect-ratio: 2/3 !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
            height: auto;
          }
        }
      {% else %}
        /* Default 1:1 square aspect ratio */
        .shop-image-container.shop-square-container {
          aspect-ratio: 1;
        }

        /* Desktop thumbnails only - not mobile */
        @media screen and (min-width: 768px) {
          .shop-thumbnail .thumb-square {
            padding-bottom: 100% !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail {
            height: auto;
            aspect-ratio: 1 !important;
          }
          .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
            height: auto;
          }
        }
    {% endcase %}

    /* Make all thumbnails height auto for natural square appearance */
    .shop-thumbnail {
      height: auto;
    }

    /* Mobile 4-in-row layout for thumbnails using swiper-wrapper style */
    @media screen and (max-width: 767px) {
      /* When arrows are overlaid, add padding to avoid overlap */
      .shop-thumbnails.mobile-2x2-grid {
        box-sizing: border-box !important;
        display: flex !important;
        position: relative !important;
        transition-property: transform !important;
        width: 100% !important;
        z-index: 1 !important;
        height: auto !important;
        justify-content: flex-start !important;
        align-items: flex-start !important;
        padding: 0 40px !important;
        margin: 5px 0px 0px !important;
        gap: 0 !important;
      }

      /* When arrows are NOT overlaid (arrows off), remove padding */
      .shop-product-section[data-show-mobile-arrows="false"] .shop-thumbnails.mobile-2x2-grid {
        padding: 0 !important;
      }

      /* Full width image + 4 thumbnails specific spacing */
      .shop-product-section[data-full-width-image="true"] .shop-thumbnails.mobile-2x2-grid {
        margin: 5px 0px 0px !important;
      }

      .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
        flex: 0 0 calc(25% - 3px) !important;
        width: calc(25% - 3px) !important;
        max-width: calc(25% - 3px) !important;
        box-sizing: border-box !important;
        padding: 0 !important;
        margin: 0 !important;
        height: auto !important;
        position: relative !important;
        border-radius: 4px !important;
        overflow: hidden !important;
      }

      .shop-thumbnails.mobile-2x2-grid .shop-thumbnail:not(:last-child) {
        margin-right: 4px !important;
      }

      .shop-thumbnails.mobile-2x2-grid .thumb-square {
        width: 100%;
        height: 0;
        padding-bottom: 100%;
        position: relative;
        box-sizing: border-box;
        overflow: hidden;
        border-radius: 4px;
        background: #f8f8f8;
        z-index: 2 !important;
      }

      .shop-thumbnails.mobile-2x2-grid .thumb-square img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        border-radius: 4px;
      }
    }

    /* Thumbnail section padding option */
    {% if section.settings.thumbnails_include_section_padding %}
      .shop-thumbnails {
        padding: 5px 15px !important;
      }
    {% endif %}

    /* Hide thumbnails on mobile */
    {% if section.settings.hide_thumbnails_mobile %}
      @media screen and (max-width: 767px) {
        .shop-thumbnails-outer {
          display: none !important;
        }
      }

      /* Show mobile-only dots on mobile, hide on desktop */
      .mobile-only-dots {
        display: none;
      }

      @media screen and (max-width: 767px) {
        .mobile-only-dots {
          display: flex !important;
        }
      }

      @media screen and (min-width: 768px) {
        .mobile-only-dots {
          display: none !important;
        }
      }
    {% endif %}

    /* Left column thumbnails on desktop */
    {% if section.settings.thumbnails_left_column_desktop %}
      /* Mobile: Reset left column layout to normal behavior */
      @media screen and (max-width: 767px) {
        .shop-main-image-wrapper.shop-image-thumbnails-row {
          display: flex !important;
          flex-direction: column !important;
          gap: 10px !important;
          align-items: stretch !important;
        }

        .shop-main-image-wrapper.shop-image-thumbnails-row .shop-thumbnails-outer {
          flex: none !important;
          width: 100% !important;
          order: 2 !important;
          margin-top: 0 !important;
        }

        .shop-main-image-wrapper.shop-image-thumbnails-row .shop-image-container {
          flex: none !important;
          width: 100% !important;
          order: 1 !important;
        }

        .shop-thumbnails-wrapper.left-column-layout {
          flex-direction: row !important;
          align-items: center !important;
          justify-content: center !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails {
          display: flex !important;
          flex-direction: row !important;
          gap: 4px !important;
          width: 100% !important;
          justify-content: center !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail {
          width: auto !important;
          max-width: none !important;
          aspect-ratio: 1 !important;
          flex: 0 0 calc(25% - 3px) !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail .thumb-square {
          width: 100% !important;
          padding-bottom: 100% !important;
        }

        /* Ensure mobile 2x2 grid works properly with left column setting */
        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid {
          display: flex !important;
          flex-direction: row !important;
          gap: 0 !important;
          width: 100% !important;
          justify-content: center !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
          flex: 0 0 calc(25% - 3px) !important;
          width: calc(25% - 3px) !important;
          max-width: calc(25% - 3px) !important;
        }
      }

      /* Desktop: Apply left column layout */
      @media screen and (min-width: 768px) {
        .shop-main-image-wrapper.shop-image-thumbnails-row {
          display: flex !important;
          flex-direction: row !important;
          gap: 0px !important;
          align-items: stretch !important;
          min-height: 0 !important;
        }

        .shop-main-image-wrapper.shop-image-thumbnails-row .shop-thumbnails-outer {
          flex: 0 0 80px !important;
          width: 80px !important;
          order: -1 !important;
          height: 100% !important;
          overflow-y: auto !important;
          margin-right: 15px !important;
          margin-top: 0 !important;
          align-self: stretch !important;
        }

        .shop-main-image-wrapper.shop-image-thumbnails-row .shop-image-container {
          flex: 1 !important;
          margin-top: 0 !important;
          align-self: stretch !important;
          min-height: 0 !important;
          height: auto !important;
        }

        .shop-thumbnails-wrapper.left-column-layout {
          flex-direction: column !important;
          align-items: flex-start !important;
          width: 100% !important;
          max-width: 80px !important;
          margin-top: 0 !important;
          height: 100% !important;
          max-height: 100% !important;
          overflow-y: auto !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails {
          display: flex !important;
          flex-direction: column !important;
          gap: 6px !important;
          width: 100% !important;
          flex-wrap: nowrap !important;
          justify-content: flex-start !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail {
          width: 100% !important;
          max-width: 100% !important;
          /* Height and aspect-ratio set by dynamic CSS above */
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnail .thumb-square {
          width: 100% !important;
          height: 100% !important;
          padding-bottom: 0 !important;
          position: relative !important;
        }

        /* Constrain mobile-2x2-grid height in desktop left column to match main image (JS sets --thumb-column-height) */
        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid {
          max-height: var(--thumb-column-height, 400px) !important;
          overflow-y: auto !important;
          flex-wrap: nowrap !important;
          align-content: flex-start !important;
          flex-direction: column !important;
          width: 100% !important;
          justify-content: flex-start !important;
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail {
          width: 100% !important;
          max-width: 100% !important;
          flex: 0 0 auto !important;
          /* Height set by dynamic CSS above */
        }

        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid .shop-thumbnail .thumb-square {
          width: 100% !important;
          height: 100% !important;
          padding-bottom: 0 !important;
          position: relative !important;
        }
      }
    {% endif %}

    /* Fade to white at bottom of thumbnails (desktop only) */
    {% if section.settings.thumbnails_fade_to_white_desktop and product and product.media.size >= 7 %}
      @media screen and (min-width: 768px) {
        .shop-thumbnails-wrapper {
          position: relative;
        }
        .shop-thumbnails-wrapper::after {
          content: "";
          position: absolute;
          bottom: 0;
          left: 0;
          width: 100%;
          height: 80px;
          pointer-events: none;
          background: linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.6) 50%,
            rgba(255, 255, 255, 1) 100%
          );
        }
        /* Reserve space at bottom so the fade overlays padding, not the last thumb */
        .shop-thumbnails-wrapper.left-column-layout .shop-thumbnails.mobile-2x2-grid {
          padding-bottom: 80px !important;
        }
      }
    {% endif %}

    /* Portrait image adaptation */
    {% if section.settings.main_image_portrait_adaptation %}
      .shop-image-container.shop-square-container {
        aspect-ratio: auto !important;
        height: auto !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
      }

      .shop-main-image {
        position: static !important;
        width: 100% !important;
        height: auto !important;
        object-fit: contain !important;
        max-width: 100% !important;
        max-height: 100% !important;
        border-radius: 8px !important;
      }

      .shop-image-zoom-wrapper {
        position: static !important;
        width: 100% !important;
        height: auto !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
      }

      @media screen and (max-width: 767px) {
        .shop-image-container.shop-square-container {
          min-height: 300px !important;
          max-height: 80vh !important;
        }
      }
    {% endif %}
    .shop-indicator-dot.active {
        background-color: {{ section.settings.indicator_active_color }};
    }

    .shop-product-title {
        color: {{ section.settings.title_color }};
    }
    .shop-product-price {
        color: {{ section.settings.price_color }} !important;
    }
    .shop-compare-price {
        color: {{ section.settings.compare_price_color }} !important;
    }
    .shop-save-price {
        background-color: {{ section.settings.sale_badge_bg_color }} !important;
        color: {{ section.settings.sale_badge_text_color }} !important;
    }
    .shop-product-description {
        color: {{ section.settings.description_color }};
    }
    .shop-read-more, .shop-read-less {
        color: {{ section.settings.accent_color }};
    }
    .shop-custom-content {
        color: {{ section.settings.custom_content_color }};
    }

         /* Style for the add to cart button */
     .shop-add-to-cart-button {
         background-color: {% if section.settings.use_theme_colors %}
                              {% if settings.use_dedicated_button_colors %}
                                {% if settings.global_section_button_color != blank %}
                                  {{ settings.global_section_button_color }}
                                {% else %}
                                  {{ settings.global_section_accent_1_color }}
                                {% endif %}
                              {% else %}
                                {{ settings.global_section_accent_1_color }}
                              {% endif %}
                            {% else %}
                              {{ section.settings.button_color }}
                            {% endif %} !important;
         color: {% if section.settings.use_theme_colors %}
                  {% if settings.use_dedicated_button_colors %}
                    {% if settings.global_section_button_text_color != blank %}
                      {{ settings.global_section_button_text_color }}
                    {% else %}
                      {{ settings.global_section_background_color }}
                    {% endif %}
                  {% else %}
                    {{ settings.global_section_background_color }}
                  {% endif %}
                {% else %}
                  {{ section.settings.button_text_color }}
                {% endif %} !important;
         border: 2px solid {{ section.settings.border_color }} !important;
     }

    /* Add to cart button from blocks */
    {% for block in section.blocks %}
      {% if block.type == 'add_to_cart' %}
        .shop-product-section .shop-add-to-cart-button,
        .shop-add-to-cart-wrapper .shop-add-to-cart-button,
        form .shop-add-to-cart-button,
        .shop-product-details .shop-add-to-cart-button {
          transition: background-color 0.3s ease !important;
          {% if settings.enable_global_button_styling and block.settings.use_global_button_styling %}
            /* Use Global Button Styling */
            padding: var(--global-button-padding-y, 12px) 20px !important;
            font-size: var(--global-button-font-size, 14px) !important;
            font-weight: var(--global-button-font-weight, 700) !important;
            letter-spacing: var(--global-button-letter-spacing, 1px) !important;
            text-transform: var(--global-button-text-transform, none) !important;
            border-radius: var(--global-button-radius, 8px) !important;
            {% if settings.enable_button_gradient %}
            background: linear-gradient({{ settings.button_gradient_direction | default: 'to bottom' }}, {{ settings.button_gradient_start | default: '#EF4A65' }}, {{ settings.button_gradient_end | default: '#D63953' }}) !important;
            {% else %}
            background-color: var(--global-button-bg-color, #EF4A65) !important;
            {% endif %}
            border-color: solid var(--button-border-color) !important;
            color: var(--global-button-text-color, #FFFFFF) !important;
            border: var(--global-button-border-width, 0px) solid var(--global-button-border-color, #EF4A65) !important;
          {% else %}
            /* Use Section/Block Custom Colors and Sizing */
            padding: {{ block.settings.custom_button_padding_y | default: 12 }}px 20px !important;
            font-size: {{ block.settings.custom_button_font_size | default: 14 }}px !important;
            /* Always use global letter spacing and font weight for consistency */
            letter-spacing: var(--global-button-letter-spacing, 1px) !important;
            font-weight: var(--global-button-font-weight, 700) !important;
            border-color: {{ block.settings.button_border_color }} !important;
            {%- if block.settings.use_theme_colors -%}
            {%- if settings.use_dedicated_button_colors and settings.global_section_button_color != blank -%}
              {%- assign button_bg_color = settings.global_section_button_color -%}
              {%- assign color_source = 'Theme - Dedicated Button Color' -%}
            {%- else -%}
              {%- assign button_bg_color = settings.global_section_accent_1_color -%}
              {%- assign color_source = 'Theme - Accent Color' -%}
            {%- endif -%}
          {%- else -%}
            {%- assign button_bg_color = block.settings.buy_box_button_bg_color -%}
            {%- assign color_source = 'Custom Color' -%}
          {%- endif -%}

          {%- if block.settings.use_theme_colors -%}
            {%- if settings.use_dedicated_button_colors and settings.global_section_button_text_color != blank -%}
              {%- assign button_text_color = settings.global_section_button_text_color -%}
            {%- else -%}
              {%- assign button_text_color = settings.global_section_background_color -%}
            {%- endif -%}
          {%- else -%}
            {%- assign button_text_color = block.settings.button_text_color -%}
          {%- endif -%}

          background-color: var(--button-bg-color, {{ button_bg_color }}) !important;
          color: {{ button_text_color }} !important;
          border-radius: {{ block.settings.button_border_radius | default: 10 }}px !important;
          {% endif %}
        }

        /* Handle button-text and compare-price inside add to cart button */
        :is(.shop-product-section, .shop-add-to-cart-wrapper, form) .shop-add-to-cart-button :is(.button-text, .compare-price) {
          {% if settings.enable_global_button_styling and block.settings.use_global_button_styling %}
            /* Use Global Button Text Styling */
            font-size: var(--global-button-font-size, 14px) !important;
            font-weight: var(--global-button-font-weight, 700) !important;
            letter-spacing: var(--global-button-letter-spacing, 1px) !important;
            text-transform: var(--global-button-text-transform, none) ;
          {% else %}
            /* Use Custom Button Text Sizing */
            font-size: {{ block.settings.custom_button_font_size | default: 14 }}px !important;
            font-weight: var(--global-button-font-weight, 700) !important;
            letter-spacing: var(--global-button-letter-spacing, 1px) !important;
            text-transform: var(--global-button-text-transform, none) ;
          {% endif %}
        }

        .shop-product-section .shop-add-to-cart-button:hover,
        .shop-add-to-cart-wrapper .shop-add-to-cart-button:hover,
        form .shop-add-to-cart-button:hover,
        .shop-product-details .shop-add-to-cart-button:hover {
          {% if settings.enable_global_button_styling and block.settings.use_global_button_styling %}
            /* Global Button Hover State */
            {% if settings.enable_button_gradient %}
            background: linear-gradient({{ settings.button_gradient_direction | default: 'to bottom' }}, {{ settings.button_gradient_hover_start | default: '#D63953' }}, {{ settings.button_gradient_hover_end | default: '#B8314A' }}) !important;
            {% else %}
            background-color: var(--global-button-hover-bg-color, #D63953) !important;
            {% endif %}
            color: var(--global-button-hover-text-color, #FFFFFF) !important;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
          {% else %}
            /* Custom Section Hover State - Use CSS variable already defined in inline style */
            background-color: var(--button-hover-color, #D63953) !important;
          {% endif %}
        }

        /* Shopify Payment Button Styling */
        .shop-product-section shopify-payment-button,
        .shop-product-section .shopify-payment-button {
          margin-top: 5px !important;
        }

        .shop-product-section .shopify-payment-button__button,
        .shop-product-section .shopify-payment-button__button--unbranded {
          padding-top: var(--global-button-padding-y, 12px) !important;
          padding-bottom: var(--global-button-padding-y, 12px) !important;
        }
      {% endif %}
    {% endfor %}
    @media (min-width: 768px) {
        .shop-carousel-container {
            max-width: {{ section.settings.max_width }}%;
        }
    }

    {% comment %}
      Note: enable_full_width_image setting now only affects mobile devices
      Desktop layout remains unchanged with square aspect ratio
    {% endcomment %}

    {% if section.settings.enable_mobile_full_width_image %}
    /* Mobile full-width image styles - MOBILE AND TABLET ONLY */
    @media screen and (max-width: 799px) and (min-width: 0px) {
      .shop-product-section {
        padding: 0 !important;
      }
      .shop-product-carousel {
        padding: 0 !important;
      }
      .shop-main-image-wrapper {
        margin: 0 !important;
        border-radius: 0 !important;
      }
      .shop-image-container {
        border-radius: 0 !important;
      }
      .shop-thumbnails-outer {
        margin-top: 0 !important;
      }
      .shop-product-info {
        padding: 0px 15px 15px 15px !important;
      }
    }
    /* Flèches mobiles */
    @media screen and (max-width: 767px) {
      .shop-mobile-arrows {
        display: {% if section.settings.show_mobile_arrows %}flex{% else %}none{% endif %} !important;
      }

    {% if section.settings.mobile_arrow_placement == 'overlaid' %}
      .shop-mobile-arrow-prev,
      .shop-mobile-arrow-next {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
        background: var(--desktop-arrow-bg);
        border: 1px solid var(--desktop-arrow-border);
        border-radius: var(--arrow-border-radius);
        opacity: var(--arrow-opacity);
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .shop-mobile-arrow-prev {
        left: 10px;
      }

      .shop-mobile-arrow-next {
        right: 10px;
      }
    {% else %}
      .shop-mobile-arrows {
        justify-content: center;
        gap: 20px;
        margin-top: 10px;
      }
    {% endif %}
  }

    /* Explicitly prevent desktop changes */
    @media screen and (min-width: 800px) {
      .shop-product-section {
        padding: 10px 8px;
      }
      .shop-product-carousel {
        padding: 0 5px;
      }
    }
    {% endif %}

    /* Tablet and mobile specific styles */
    @media (max-width: 799px) {
        .shop-product-info {
            gap: {{ section.settings.blocks_spacing | plus: 2 }}px;
        }
    }
    @media (max-width: 767px) {
        .shop-product-info {
            gap: {{ section.settings.blocks_spacing | plus: 2 }}px;
        }
    }

    /* Added CSS for block-level styling */
    {% for block in section.blocks %}
      {% if block.type == 'size_chart' %}
        {% unless block.settings.inline_with_variant_picker %}
          #size-chart-block-{{ block.id }} {
            margin-top: {{ block.settings.margin_top }}px !important;
            margin-bottom: {{ block.settings.margin_bottom }}px !important;
            padding: 2px 6px !important;
          }
        {% else %}
          #size-chart-block-{{ block.id }} {
            margin: 0 !important;
            padding: 2px 6px !important;
          }
        {% endunless %}
      {% endif %}
    {% endfor %}
{% endstyle %}

{%- liquid
  assign current_product = section.settings.current_product | default: product
  assign current_variant = product.selected_or_first_available_variant

  assign price = current_variant.price
  assign product_form_id = 'product-form-' | append: section.id
  assign show_product_variants = section.settings.show_product_variants
-%}

<div
  class="shop-product-section  {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-up{% endif %}"
  {% if section.settings.enable_full_width_image %}
    data-full-width-image="true"
  {% endif -%}
  {% if section.settings.hide_thumbnails %}
    data-hide-thumbnails="true"
  {% endif %}
  data-show-mobile-arrows="{{ section.settings.show_mobile_arrows | default: false }}"
  {{ section.shopify_attributes }}
>
  <div class="shop-product-inner-container">
    {% if current_product == null %}
      <p>Select a product in the section settings</p>
    {% else %}
      <div class="shop-product-layout{% unless section.settings.show_product_gallery %} no-gallery{% endunless %}">
        {% if section.settings.show_product_gallery %}
          {% render 'product-gallery',
            product: current_product,
            show_product_variants: show_product_variants,
            current_variant: current_variant,
            enable_image_zoom: section.settings.enable_image_zoom
          %}
        {% endif %}

        <!-- Product Information Column -->
        {% if section.settings.show_product_info %}
          <div class="shop-product-info">
            {% render 'product-info', product: current_product, section: section %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% if section.settings.control_app_subscription_preselect %}
  <script>
    function applySealPreselect(widgetElement, sellingPlanId) {
      sellingPlanId = Number(sellingPlanId);
      if (sellingPlanId != null && !isNaN(sellingPlanId)) {
        var event = new CustomEvent("sealsubs:change_selected_selling_plan_id", {
          detail: { selling_plan_id: sellingPlanId }
        });
        widgetElement.dispatchEvent(event);
      }
    }

    var sellingPlanId = {{ section.settings.seal_selling_plan_id_preselect | json }};
    var start = Date.now();
    var interval = setInterval(function() {
      if (Date.now() - start > 5000) {
        clearInterval(interval);
        return;
      }
      var allWidgets = document.querySelectorAll('.sealsubs-target-element');
      if (allWidgets.length > 0) {
        allWidgets.forEach(function(widget) { applySealPreselect(widget, sellingPlanId); });
        clearInterval(interval);
      }
    }, 400);
  </script>
{% endif %}

<script>
  var parser = new DOMParser();
  var originPrice = '{{ price | money }}';
  const currency = window.Shopify?.currency?.active ?? 'USD';

  const formId = '{{ product_form_id }}';
  const form = document.getElementById(formId);

  function formatMoney(newMoney) {
    const originPriceNumber = originPrice.replace(/[^0-9.,]/g, '');
    return `${originPrice.replace(originPriceNumber, newMoney)} ${currency}`;
  }
  function formatMoneyWithoutSuffix(newMoney) {
    const originPriceNumber = originPrice.replace(/[^0-9.,]/g, '');
    return `${originPrice.replace(originPriceNumber, newMoney)}`;
  }

  if (window.innerWidth <= 767 && document.querySelector('.shop-mobile-arrows')) {
    const prevBtn = document.querySelector('.shop-mobile-arrow-prev');
    const nextBtn = document.querySelector('.shop-mobile-arrow-next');

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        // Logique pour image précédente
        navigateToImage('prev');
      });

      nextBtn.addEventListener('click', () => {
        // Logique pour image suivante
        navigateToImage('next');
      });
    }
  }

  const quantityElems = form.querySelectorAll('input[type="hidden"][name="quantity"]');
  const addQuantityElem = (quantityVal) => {
    const curForm = document.getElementById(formId);
    const quantityElem = document.createElement('input');
    quantityElem.setAttribute('type', 'hidden');
    quantityElem.setAttribute('name', 'quantity');
    quantityElem.setAttribute('value', quantityVal);
    curForm.appendChild(quantityElem);
  };
</script>
<script src="{{ 'product-info.js' | asset_url }}" defer></script>
<script src="{{ 'variant-selector.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>
<script src="{{ 'shop-product-details.js' | asset_url }}" defer></script>
<script src="{{ 'product-gallery.js' | asset_url }}" defer></script>

