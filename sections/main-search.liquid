{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-search.css' | asset_url | stylesheet_tag }}
{{ 'collection-grid-page.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}


<script src="{{ 'main-search.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'collection-grid-page.js' | asset_url }}" defer="defer"></script>

<style>
  .template-search__header {
    margin-bottom: 3rem;
    position: relative;
    z-index: 1;
  }

  .template-search__search {
    margin: 0 auto 3.5rem;
    max-width: 74.1rem;
  }

  .template-search__search .search {
    margin-top: 3rem;
  }

  .template-search--empty {
    padding-bottom: 18rem;
  }

  {% if section.settings.columns_desktop == 6 %}

    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:repeat(6, minmax(0, 1fr));
    }
  {% elsif section.settings.columns_desktop == 5 %}
    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:repeat(5, minmax(0, 1fr));
    }
  {% elsif section.settings.columns_desktop == 4 %}
    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:repeat(4, minmax(0, 1fr));
    }  
  {% elsif section.settings.columns_desktop == 3 %}
    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:repeat(3, minmax(0, 1fr));
    }
  {% elsif section.settings.columns_desktop == 2 %}
    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:repeat(2, minmax(0, 1fr));
    }
  {% else %}
    .template-search__results .product-grid {
      display:grid;
      grid-template-columns:minmax(0, 1fr);
    }
  {% endif %}

  {% if section.settings.image_ratio == "adapt" %}
    .template-search__results .product-grid .grid__item .product-image-container {
      aspect-ratio:auto;
    }
  {% elsif section.settings.image_ratio == "portrait" %}
    .template-search__results .product-grid .grid__item .product-image-container {
      aspect-ratio:3/4;
    }
    .template-search__results .product-grid .grid__item .product-image {
        object-fit: cover !important;
    }
  {% elsif section.settings.image_ratio == "square" %}
    .template-search__results .product-grid .grid__item .product-image-container {
      aspect-ratio:1;
    }
    .template-search__results .product-grid .grid__item .product-image {
        object-fit: cover !important;
    }
  {% endif %}

  .template-search__results .product-grid .grid__item .product-title  {
    font-size: {{ section.settings.product_title_size }}px;
  }

  @media screen and (max-width: 749px) {
    {% if section.settings.columns_mobile == '1' %}
      .template-search__results .product-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    {% elsif section.settings.columns_mobile == '2' %}
      .template-search__results .product-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap:15px;
      }
    {% endif %}

    .template-search__header, aside.facets-wrapper, .template-search__results {
      padding: 0px 2rem !important;
    }
    .template-search__results .product-grid .grid__item .product-title  {
      font-size: {{ section.settings.product_title_size_mobile }}px;
    }
  }

  .template-search__results .product-grid .grid__item {
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  @media screen and (min-width: 750px) {
    .template-search__header {
      margin-bottom: 5rem;
    }
  }

  .search__button .icon {
    height: 1.8rem;
  }

  /* Search Page Input Field Styling */
  .template-search__search .field {
    position: relative !important;
    display: flex !important;
    width: 100% !important;
    min-height: 4.5rem !important;
    overflow: visible !important;
  }

  /* Prevent field pseudo-elements from hiding the border */
  .template-search__search .field::before,
  .template-search__search .field::after {
    display: none !important;
    content: none !important;
    box-shadow: none !important;
  }

  .template-search__search .field:focus-within,
  .template-search__search .field:hover {
    box-shadow: none !important;
  }

  .template-search__search .field:focus-within .field__input,
  .template-search__search .field:hover .field__input {
    border: 1px solid rgba(var(--color-drawer-text), 0.5) !important;
  }

  .template-search__search .field__input,
  .template-search__search .search__input.field__input {
    width: 100% !important;
    height: 4.5rem !important;
    min-height: 4.5rem !important;
    padding: 1rem 9.8rem 1rem 1.5rem !important;
    border-radius: var(--inputs-radius, 4px) !important;
    border: 1px solid rgba(var(--color-drawer-text), 0.3) !important;
    background-color: rgb(var(--color-background)) !important;
    color: rgb(var(--color-drawer-text)) !important;
    font-size: 1.4rem !important;
    line-height: 1.5 !important;
    box-sizing: border-box !important;
    outline: none !important;
  }

  .template-search__search .field__input:focus,
  .template-search__search .field__input:focus-visible,
  .template-search__search .field__input:active,
  .template-search__search .search__input.field__input:focus,
  .template-search__search .search__input.field__input:focus-visible,
  .template-search__search .search__input.field__input:active {
    outline: none !important;
    border: 1px solid rgba(var(--color-drawer-text), 0.5) !important;
    box-shadow: 0 0 0 1px rgba(var(--color-drawer-text), 0.2) !important;
    background-color: rgb(var(--color-background)) !important;
  }

  .template-search__search .field__input:-webkit-autofill,
  .template-search__search .search__input.field__input:-webkit-autofill {
    border: 1px solid rgba(var(--color-drawer-text), 0.3) !important;
  }

  .template-search__search .field__label {
    position: absolute !important;
    left: 1.5rem !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    pointer-events: none !important;
    transition: all 0.2s ease !important;
    color: rgba(var(--color-drawer-text), 0.6) !important;
    font-size: 1.4rem !important;
  }

  .template-search__search .field__input:focus ~ .field__label,
  .template-search__search .field__input:not(:placeholder-shown) ~ .field__label {
    opacity: 0 !important;
  }

  /* Search Button Styling */
  .template-search__search .search__button.field__button {
    position: absolute !important;
    right: 1px !important;
    top: 1px !important;
    height: 4.4rem !important;
    width: 4.4rem !important;
    background: var(--gradient-base-background-1, rgb(var(--color-button))) !important;
    color: rgb(var(--color-background)) !important;
    border: none !important;
    border-radius: 0 var(--inputs-radius, 4px) var(--inputs-radius, 4px) 0 !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    cursor: pointer !important;
    transition: box-shadow var(--duration-short) ease !important;
    z-index: 2 !important;
  }

  /* Search Button Icon Color */
  .template-search__search .search__button .icon,
  .template-search__search .search__button .svg-wrapper,
  .template-search__search .search__button svg {
    color: rgb(var(--color-background)) !important;
    fill: rgb(var(--color-background)) !important;
    stroke: rgb(var(--color-background)) !important;
  }

  /* Reset Button Styling */
  .template-search__search .reset__button.field__button {
    position: absolute !important;
    right: 4.6rem !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    background: none !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    cursor: pointer !important;
    color: inherit !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    box-shadow: none !important;
    outline: none !important;
    width: 4rem !important;
    height: 4rem !important;
    z-index: 2 !important;
  }

  .template-search__search .reset__button.field__button:hover,
  .template-search__search .reset__button.field__button:focus,
  .template-search__search .reset__button.field__button:focus-visible,
  .template-search__search .reset__button.field__button:active {
    position: absolute !important;
    right: 4.6rem !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    background: none !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    .template-search__search .field {
      min-height: 4rem !important;
    }

    .template-search__search .field__input,
    .template-search__search .search__input.field__input {
      height: 4rem !important;
      min-height: 4rem !important;
      padding: 0.8rem 8rem 0.8rem 1rem !important;
      font-size: 1.6rem !important;
    }

    .template-search__search .search__button.field__button {
      width: 4rem !important;
      height: 4rem !important;
    }

    .template-search__search .reset__button.field__button {
      right: 4.2rem !important;
      width: 3.5rem !important;
      height: 3.5rem !important;
    }

    .template-search__search .reset__button.field__button:hover,
    .template-search__search .reset__button.field__button:focus,
    .template-search__search .reset__button.field__button:active {
      right: 4.2rem !important;
    }
  }
</style>

{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign terms = search.terms | escape
  assign search_url = '?q=' | append: terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{% paginate search.results by 24 %}
  <div class="template-search{% unless search.performed and search.results_count > 0 %} template-search--empty{% endunless %} section-{{ section.id }}-padding">
    <div class="template-search__header page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-up{% endif %}">
      <h1 class="h2 center">
        {%- if search.performed -%}
          {{- 'templates.search.title' | t -}}
        {%- else -%}
          {{- 'general.search.search' | t -}}
        {%- endif -%}
      </h1>
      <div class="template-search__search">
        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
        <main-search>
          <form action="{{ routes.search_url }}" method="get" role="search" class="search">
            <div class="field">
              <input
                class="search__input field__input"
                id="Search-In-Template"
                type="search"
                name="q"
                value="{{ search.terms | escape }}"
                placeholder="{{ 'general.search.search' | t }}"
                {%- if settings.predictive_search_enabled -%}
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results"
                  aria-controls="predictive-search-results"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                {%- endif -%}
              >
              <label class="field__label" for="Search-In-Template">{{ 'general.search.search' | t }}</label>
              <input name="options[prefix]" type="hidden" value="last">

              {%- if settings.predictive_search_enabled -%}
                <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                  {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                </div>

                <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
              {%- endif -%}

              <button
                type="reset"
                class="reset__button field__button no-enhanced-effects{% if search.terms == blank %} hidden{% endif %}"
                aria-label="{{ 'general.search.reset' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-reset.svg' | inline_asset_content -}}
                </span>
              </button>
              <button type="submit" class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
                <span class="svg-wrapper">
                  {{- 'icon-search.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          </form>
        </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}
      </div>
      {%- if search.performed -%}
        {%- unless section.settings.enable_filtering or section.settings.enable_sorting -%}
          {%- if search.results_count > 0 -%}
            <p role="status">
              {{ 'templates.search.results_with_count_and_term' | t: terms: search.terms, count: search.results_count }}
            </p>
          {%- endif -%}
        {%- endunless -%}
        {%- if search.results_count == 0 and search.filters == empty -%}
          <p role="status">{{ 'templates.search.no_results' | t: terms: search.terms }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>
    {%- if search.performed -%}
      {%- if section.settings.enable_sorting
        and section.settings.filter_type == 'vertical'
        and search.filters != empty
      -%}
        <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
          <form class="facets-vertical-form" id="FacetSortForm">
            <div class="facet-filters sorting caption">
              <div class="facet-filters__field">
                <h2 class="facet-filters__label caption-large text-body">
                  <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                </h2>
                <div class="select">
                  {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
                  <select
                    name="sort_by"
                    class="facet-filters__sort select__select caption-large"
                    id="SortBy"
                    aria-describedby="a11y-refresh-page-message"
                  >
                    {%- for option in search.sort_options -%}
                      <option
                        value="{{ option.value | escape }}"
                        {% if option.value == sort_by %}
                          selected="selected"
                        {% endif %}
                      >
                        {{ option.name | escape }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </div>
              </div>
            </div>

            <div class="product-count-vertical light" role="status">
              <h2 class="product-count__text text-body">
                <span id="ProductCountDesktop">
                  {%- if search.results_count -%}
                    {{ 'templates.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
                  {%- elsif search.products_count == search.all_products_count -%}
                    {{ 'products.facets.product_count_simple' | t: count: search.products_count }}
                  {%- else -%}
                    {{
                      'products.facets.product_count'
                      | t: product_count: search.products_count, count: search.all_products_count
                    }}
                  {%- endif -%}
                </span>
              </h2>
              {%- render 'loading-spinner' -%}
            </div>
          </form>
        </facet-filters-form>
      {%- endif -%}
      <div
        {% if section.settings.filter_type == 'vertical' %}
          class="facets-vertical page-width"
        {% endif %}
      >
        {%- if search.filters != empty -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="main-search-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: search,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}
        {%- endif -%}
        <div class="product-grid-container" id="ProductGridContainer">
          {%- if search.results.size == 0 and search.filters != empty -%}
            <div
              class="template-search__results collection collection--empty{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>
              <div class="title-wrapper center">
                <h2 class="title title--primary">
                  {{ 'sections.collection_template.empty' | t -}}
                  <br>
                  {{
                    'sections.collection_template.use_fewer_filters_html'
                    | t: link: search_url, class: 'underlined-link link'
                  }}
                </h2>
              </div>
            </div>
          {%- else -%}
            <div
              class="template-search__results collection collection-grid-section{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              data-component="collection-grid-page"
              data-section-id="{{ section.id }}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>
              {%- assign has_products = false -%}
              {%- assign has_articles = false -%}
              {%- assign has_pages = false -%}
              {%- for item in search.results -%}
                {%- if item.object_type == 'product' -%}{%- assign has_products = true -%}{%- endif -%}
                {%- if item.object_type == 'article' -%}{%- assign has_articles = true -%}{%- endif -%}
                {%- if item.object_type == 'page' -%}{%- assign has_pages = true -%}{%- endif -%}
              {%- endfor -%}

              {%- if has_products -%}

                <ul
                  class="grid product-grid  grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                  role="list"
                >
                  {%- assign item_index = 0 -%}
                  {%- for item in search.results -%}
                    {%- if item.object_type == 'product' -%}
                      {%- assign item_index = item_index | plus: 1 -%}
                      {% assign lazy_load = false %}
                      {%- if item_index > 2 -%}
                        {%- assign lazy_load = true -%}
                      {%- endif -%}
                      <li
                        class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                        {% endif %}
                      >
                        {% render 'product-card',
                          product: item,
                          settings: settings,
                          section_id: section.id,
                          full_card_clickable: true,
                          show_view_product: section.settings.show_view_product,
                          show_product_rating: section.settings.show_rating
                        %}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if has_articles -%}
                <h2 class="h5 template-search__sub-heading" style="margin-bottom:0;{% if has_products %} margin-top: 4rem;{% endif %}">Articles</h2>
                <ul
                  class="grid product-grid  grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                  role="list"
                >
                  {%- assign item_index = 0 -%}
                  {%- for item in search.results -%}
                    {%- if item.object_type == 'article' -%}
                      {%- assign item_index = item_index | plus: 1 -%}
                      {% assign lazy_load = false %}
                      {%- if item_index > 2 -%}
                        {%- assign lazy_load = true -%}
                      {%- endif -%}
                      <li
                        class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                        {% endif %}
                      >
                        {% render 'article-card',
                          article: item,
                          show_image: true,
                          show_date: section.settings.article_show_date,
                          show_author: section.settings.article_show_author,
                          show_badge: true,
                          media_aspect_ratio: section.settings.image_ratio,
                          lazy_load: lazy_load
                        %}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}

              {%- if has_pages -%}
                <h2 class="h5 template-search__sub-heading" style="margin-bottom:0;{% if has_products or has_articles %} margin-top: 4rem;{% endif %}">Pages</h2>
                <ul
                  class="grid product-grid  grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                  role="list"
                >
                  {%- for item in search.results -%}
                    {%- if item.object_type == 'page' -%}
                      <li
                        class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                        {% endif %}
                      >
                        <div class="article-card-wrapper card-wrapper underline-links-hover">
                          <div
                            class="card card--card card--text ratio"
                            style="--ratio-percent: 100%;"
                          >
                            <div class="card__content">
                              <div class="card__information">
                                <h3 class="card__heading">
                                  <a href="{{ item.url }}" class="full-unstyled-link">
                                    {{ item.title | truncate: 50 | escape }}
                                  </a>
                                </h3>
                              </div>
                              <div class="card__badge {{ settings.badge_position }}">
                                <span class="badge color-1">
                                  {{- 'templates.search.page' | t -}}
                                </span>
                              </div>
                            </div>
                          </div>
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
              {%- if paginate.pages > 1 -%}
                {% render 'pagination', paginate: paginate %}
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  </div>
{% endpaginate %}


<script>
  document.addEventListener('DOMContentLoaded', function() {
    const templateSearch = document.querySelector('.template-search');
    const predictiveSearchResults = document.querySelector('.predictive-search--search-template');
    
    if (templateSearch && predictiveSearchResults) {
      const observer = new ResizeObserver(function(entries) {
        for (let entry of entries) {
          const height = entry.target.offsetHeight;
          if (height > 0) {
            templateSearch.style.paddingBottom = `calc(${height}px + 5rem)`;
            templateSearch.style.transition = 'padding-bottom 0.3s ease';
          } else {
            templateSearch.style.paddingBottom = '';
          }
        }
      });
      observer.observe(predictiveSearchResults);
    }
  });
</script>

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "t:sections.main-search.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "default": "2",
      "label": "t:sections.main-search.settings.columns_mobile.label",
      "options": [
