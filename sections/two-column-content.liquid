                    {%- if item_title != blank -%}
                      <div class="accordion-item" style="border-radius: {{ block.settings.border_radius }}px; margin-bottom: {{ block.settings.item_spacing }}px;{% if block.settings.use_custom_colors %} border-color: {{ block.settings.border_color }};{% endif %}">
                        <div class="accordion-header" style="font-size: {{ block.settings.header_font_size | default: 16 }}px;{% if block.settings.use_custom_colors %} background-color: {{ block.settings.header_background }}; color: {{ block.settings.header_text_color }};{% endif %}">
