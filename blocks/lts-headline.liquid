{% comment %}
  Block: LTS Headline - Eyebrow + Headline for Limited Time Sale
{% endcomment %}

<div class="lts-headline-wrapper lts-headline-{{ block.id }}" {{ block.shopify_attributes }}>
  {% if block.settings.eyebrow_text != blank %}
    <div class="lts-eyebrow-{{ block.id }}">
      {% if block.settings.show_dots %}
        <span class="lts-dot-{{ block.id }}"></span>
      {% endif %}
      <span class="lts-eyebrow-text">{{ block.settings.eyebrow_text }}</span>
      {% if block.settings.show_dots %}
        <span class="lts-dot-{{ block.id }}"></span>
      {% endif %}
    </div>
  {% endif %}

  <{{ block.settings.heading_tag }} class="lts-headline-text-{{ block.id }}">
    {% if block.settings.headline_accent != blank %}
      <span class="lts-accent-{{ block.id }}">{{ block.settings.headline_accent }}</span>
    {% endif %}
    {% if block.settings.headline_strong != blank %}
      <br>
      <span class="lts-strong-{{ block.id }}">{{ block.settings.headline_strong }}</span>
    {% endif %}
  </{{ block.settings.heading_tag }}>
</div>

<style>
  .lts-headline-{{ block.id }} {
    text-align: {{ block.settings.text_align }};
    margin-bottom: {{ block.settings.margin_bottom }}px;
  }

  .lts-eyebrow-{{ block.id }} {
    display: flex;
    justify-content: {{ block.settings.text_align }};
    align-items: center;
    gap: 14px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    font-size: {{ block.settings.eyebrow_font_size }}px !important;
    font-weight: {{ block.settings.eyebrow_font_weight }} !important;
    text-transform: {{ block.settings.eyebrow_transform }};
    margin-bottom: {{ block.settings.eyebrow_margin_bottom }}px;
  }

  .lts-dot-{{ block.id }} {
    flex: 1;
    height: 1px;
    background: {{ block.settings.dot_color }};
    max-width: {{ block.settings.dot_max_width }}px;
  }

  .lts-headline-text-{{ block.id }} {
    margin: 0;
    font-size: {{ block.settings.headline_font_size }}px !important;
    line-height: {{ block.settings.headline_line_height }};
    color: {{ block.settings.headline_color }};
    letter-spacing: {{ block.settings.headline_letter_spacing }}px;
    font-weight: {{ block.settings.headline_font_weight }} !important;
  }

  .lts-accent-{{ block.id }} {
    color: {{ block.settings.accent_color }};
    font-weight: {{ block.settings.accent_font_weight }} !important;
  }

  .lts-strong-{{ block.id }} {
    font-weight: {{ block.settings.strong_font_weight }} !important;
  }

  @media (max-width: 768px) {
    .lts-eyebrow-{{ block.id }} {
      font-size: {{ block.settings.eyebrow_font_size_mobile }}px !important;
    }
    .lts-headline-text-{{ block.id }} {
      font-size: {{ block.settings.headline_font_size_mobile }}px !important;
    }
  }
</style>

{% schema %}
{
  "name": "LTS Headline",
  "settings": [
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "60% OFF FOR A LIMITED TIME ONLY!"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "eyebrow_font_size",
      "min": 8,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow Font Size",
      "default": 11
    },
    {
      "type": "range",
      "id": "eyebrow_font_size_mobile",
      "min": 8,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow Font Size (Mobile)",
      "default": 10
    },
    {
      "type": "select",
      "id": "eyebrow_font_weight",
      "label": "Eyebrow Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "eyebrow_letter_spacing",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Eyebrow Letter Spacing",
      "default": 1
    },
    {
      "type": "select",
      "id": "eyebrow_transform",
      "label": "Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "eyebrow_margin_bottom",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Eyebrow Margin Bottom",
      "default": 8
    },
    {
      "type": "header",
      "content": "Dots"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show Decorative Dots",
      "default": true
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Dot Color",
      "default": "#dddddd"
    },
    {
      "type": "range",
      "id": "dot_max_width",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Dot Max Width",
      "default": 40
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline_accent",
      "label": "Headline Accent (Price)",
      "default": "$79.99"
    },
    {
      "type": "text",
      "id": "headline_strong",
      "label": "Headline Strong Line",
      "default": "(was $199.99)"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading Tag",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "p", "label": "Paragraph" }
      ],
      "default": "h1"
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#FCDEF4"
    },
    {
      "type": "range",
      "id": "headline_font_size",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Headline Font Size",
      "default": 42
    },
    {
      "type": "range",
      "id": "headline_font_size_mobile",
      "min": 18,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Headline Font Size (Mobile)",
      "default": 32
    },
    {
      "type": "range",
      "id": "headline_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Headline Line Height",
      "default": 1.2
    },
    {
      "type": "select",
      "id": "headline_font_weight",
      "label": "Headline Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "headline_letter_spacing",
      "min": -2,
      "max": 5,
      "step": 1,
      "unit": "px",
      "label": "Headline Letter Spacing",
      "default": 0
    },
    {
      "type": "select",
      "id": "accent_font_weight",
      "label": "Accent Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra Bold" }
      ],
      "default": "700"
    },
    {
      "type": "select",
      "id": "strong_font_weight",
      "label": "Strong Line Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 8
    }
  ],
  "presets": [
    { "name": "LTS Headline" }
  ]
}
{% endschema %}

