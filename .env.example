# Copy this file to .env and fill in your own values.
# .env is not committed to Git — each developer has their own.

# Store domain (.myshopify.com)
SHOPIFY_STORE=fgwakj-ib.myshopify.com

# ID of YOUR personal theme (a duplicate of develop).
# Get it via: npm run theme:init  (or: npm run theme:list)
SHOPIFY_THEME_ID=123456789012
