{% style %}
  .section-{{ section.id }} {
    --mp-fh: 'Oswald', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mp-fb: 'League Spartan', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    --mp-bg: {{ section_bg }};
    --mp-ink: {{ ink }};
    --mp-accent: {{ accent }};
    --mp-button-bg: {{ section.settings.button_background }};
    --mp-button-text: {{ section.settings.button_text_color }};
    --mp-heading-size: {{ section.settings.heading_size }}px;
    --mp-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --mp-body-size: {{ section.settings.body_size }}px;
    --mp-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --mp-image-max: {{ section.settings.image_max_width }}px;
    --mp-image-radius: {{ section.settings.image_radius }}px;
    --mp-icon: {{ section.settings.icon_size }}px;
    --mp-gap-sm: {{ section.settings.gap_small }}px;
    --mp-gap-lg: {{ section.settings.gap_large }}px;
    --mp-pad-top: {{ section.settings.padding_top }}px;
    --mp-pad-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} {
    background-color: var(--mp-bg);
    padding-top: var(--mp-pad-top);
    padding-bottom: var(--mp-pad-bottom);
  }

  .section-{{ section.id }} .mp__inner {
    max-width: 1640px;
    margin-inline: auto;
    padding-inline: 20px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .section-{{ section.id }} .mp__inner > * { margin-top: var(--mp-gap-sm); width: 100%; }
  .section-{{ section.id }} .mp__inner > *:first-child { margin-top: 0; }

  /* Heading — theme forces h2 font; lock to Oswald */
  .section-{{ section.id }} .mp__heading {
    margin: 0;
    text-align: center;
    font-family: var(--mp-fh) !important;
    font-weight: 500 !important;
    line-height: 1.2;
    color: var(--mp-ink) !important;
    font-size: clamp(var(--mp-heading-size-mobile), 3.4vw, var(--mp-heading-size));
  }
  .section-{{ section.id }} .mp__accent { font-family: inherit !important; font-weight: 700 !important; color: var(--mp-accent) !important; }

  /* Body */
  .section-{{ section.id }} .mp__body { max-width: 1440px; margin-inline: auto; text-align: center; }
  .section-{{ section.id }} .mp__body-main p {
    margin: 0;
    font-family: var(--mp-fb) !important;
    font-weight: 400 !important;
    line-height: 1.35;
    color: var(--mp-ink) !important;
    font-size: clamp(var(--mp-body-size-mobile), 1.6vw, var(--mp-body-size));
  }
  .section-{{ section.id }} .mp__body-note {
    margin: 24px 0 0;
    font-family: var(--mp-fb) !important;
    font-weight: 400 !important;
    line-height: 1.35;
    color: var(--mp-ink) !important;
    font-size: clamp(var(--mp-body-size-mobile), 1.6vw, var(--mp-body-size));
  }

  /* Product image */
  .section-{{ section.id }} .mp__media { max-width: var(--mp-image-max); margin-inline: auto; }
  .section-{{ section.id }} .mp__image { display: block; width: 100%; height: auto; border-radius: var(--mp-image-radius); }
  .section-{{ section.id }} .mp__image--placeholder { aspect-ratio: 1330 / 749; background-color: #eef0f1; fill: #b9c3c9; object-fit: cover; }

  /* Ingredients grid */
  .section-{{ section.id }} .mp__ingredients {
    max-width: 1600px;
    margin-inline: auto;
    margin-top: var(--mp-gap-lg);
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 48px;
    row-gap: 24px;
  }
  .section-{{ section.id }} .mp__ing {
    display: flex;
    align-items: center;
    gap: 24px;
    min-width: 0;
  }
  .section-{{ section.id }} .mp__ing-icon {
    flex-shrink: 0;
    width: clamp(88px, 18vw, var(--mp-icon));
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    overflow: hidden;
    background-color: #f3ede9;
  }
  .section-{{ section.id }} .mp__ing-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .section-{{ section.id }} .mp__ing-img--placeholder { fill: #b9c3c9; }
  .section-{{ section.id }} .mp__ing-info { flex: 1 1 0; min-width: 0; display: flex; flex-direction: column; gap: 16px; }
  .section-{{ section.id }} .mp__ing-name {
    margin: 0;
    font-family: var(--mp-fb) !important;
    font-weight: 700 !important;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0.18px;
    color: var(--mp-ink) !important;
  }
  .section-{{ section.id }} .mp__ing-benefits { display: flex; flex-direction: column; gap: 8px; }
  .section-{{ section.id }} .mp__ing-benefit {
    margin: 0;
    font-family: var(--mp-fb) !important;
    font-weight: 500 !important;
    font-size: 18px;
    line-height: 22px;
    letter-spacing: 0.18px;
    color: var(--mp-ink) !important;
  }
  .section-{{ section.id }} .mp__ing-desc {
    margin: 0;
    font-family: var(--mp-fb) !important;
    font-weight: 400 !important;
    font-size: 14px;
    line-height: 20px;
    color: var(--mp-ink) !important;
  }

  /* CTA */
  .section-{{ section.id }} .mp__cta {
    margin-top: var(--mp-gap-lg);
    display: flex;
    flex-direction: column;
    align-items: center; width: 100%;
    gap: 10px;
  }
  .section-{{ section.id }} .mp__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    width: 553px;
    max-width: 100%;
    padding: 16px clamp(18px, 5vw, 32px);
    font-family: var(--mp-fb) !important;
    font-weight: 700 !important;
    font-size: clamp(15px, 2vw, 18px);
    line-height: 1.25;
    letter-spacing: 0.5px;
    text-align: center;
    text-decoration: none;
    color: var(--mp-button-text) !important;
    background-color: var(--mp-button-bg);
    border: 0;
    border-radius: 8px;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .section-{{ section.id }} .mp__button:hover { opacity: 0.92; transform: translateY(-1px); }
  .section-{{ section.id }} .mp__button:focus-visible { outline: 3px solid var(--mp-accent); outline-offset: 3px; }
  .section-{{ section.id }} .mp__guarantee {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--mp-fb) !important;
    font-weight: 400 !important;
    font-size: clamp(13px, 1.6vw, 16px);
    color: var(--mp-ink) !important;
  }
  .section-{{ section.id }} .mp__guarantee-icon { flex-shrink: 0; width: 16px; height: 16px; line-height: 0; color: var(--mp-ink); }
  .section-{{ section.id }} .mp__guarantee-icon svg { display: block; width: 100%; height: 100%; }

  @media (min-width: 768px) {
    .section-{{ section.id }} .mp__ingredients { grid-template-columns: repeat(2, 1fr); }
  }
  @media (prefers-reduced-motion: reduce) {
    .section-{{ section.id }} .mp__button { transition: none; }
  }
{% endstyle %}

<section class="mp section-{{ section.id }}" data-section-id="{{ section.id }}">
  <div class="mp__inner">

    {%- if section.settings.heading_before != blank or section.settings.heading_accent1 != blank or section.settings.heading_mid != blank or section.settings.heading_accent2 != blank -%}
      <h2 class="mp__heading">
        {{- section.settings.heading_before -}}
        {%- if section.settings.heading_accent1 != blank %} <span class="mp__accent">{{ section.settings.heading_accent1 }}</span>{% endif -%}
        {%- if section.settings.heading_mid != blank %} {{ section.settings.heading_mid }}{% endif -%}
        {%- if section.settings.heading_accent2 != blank %} <span class="mp__accent">{{ section.settings.heading_accent2 }}</span>{% endif -%}
      </h2>
    {%- endif -%}

    {%- if section.settings.body_main != blank or section.settings.body_note != blank -%}
      <div class="mp__body">
        {%- if section.settings.body_main != blank -%}
          <div class="mp__body-main">{{ section.settings.body_main }}</div>
        {%- endif -%}
        {%- if section.settings.body_note != blank -%}
          <p class="mp__body-note">{{ section.settings.body_note }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="mp__media">
      {%- if section.settings.image != blank -%}
        {%- assign img_alt = section.settings.image.alt | default: 'Metabolic Flow product' -%}
        {{
          section.settings.image
          | image_url: width: 1330
          | image_tag:
            loading: 'lazy',
            widths: '600,900,1100,1330',
            sizes: '(min-width: 1370px) 1330px, 100vw',
            alt: img_alt,
            class: 'mp__image'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'mp__image mp__image--placeholder' }}
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="mp__ingredients">
        {%- for block in section.blocks -%}
          <div class="mp__ing" {{ block.shopify_attributes }}>
            <div class="mp__ing-icon">
              {%- if block.settings.icon != blank -%}
                {%- assign icon_alt = block.settings.name | default: 'Ingredient' -%}
                {{
                  block.settings.icon
                  | image_url: width: 264
                  | image_tag:
                    loading: 'lazy',
                    widths: '132,200,264',
                    sizes: '132px',
                    alt: icon_alt,
                    class: 'mp__ing-img'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'mp__ing-img mp__ing-img--placeholder' }}
              {%- endif -%}
            </div>
            <div class="mp__ing-info">
              {%- if block.settings.name != blank -%}
                <p class="mp__ing-name">{{ block.settings.name }}</p>
              {%- endif -%}
              {%- if block.settings.benefit != blank or block.settings.description != blank -%}
                <div class="mp__ing-benefits">
                  {%- if block.settings.benefit != blank -%}
                    <p class="mp__ing-benefit">{{ block.settings.benefit }}</p>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="mp__ing-desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <div class="mp__cta">
        <a class="mp__button" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_text }}</a>
        {%- if section.settings.guarantee_text != blank -%}
          <span class="mp__guarantee"><span class="mp__guarantee-icon">{{ check_icon }}</span>{{ section.settings.guarantee_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>

