{% comment %}
  Block: Listicle LTO Title
  A configurable heading shown before the Limited Time Offer block.
{% endcomment %}

{%- assign this = block.settings -%}

<style>
  #listicle-lto-title-{{ block.id }} {
    text-align: {{ this.text_align }};
    margin-top: {{ this.margin_top }}px;
    margin-bottom: {{ this.margin_bottom }}px;
  }

  #listicle-lto-title-{{ block.id }} .listicle-lto-title-text {
    font-size: {{ this.font_size }}px;
    font-weight: {{ this.font_weight }};
    color: {{ this.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  #listicle-lto-title-{{ block.id }} .listicle-lto-subtitle-text {
    font-size: {{ this.subtitle_font_size }}px;
    color: {{ this.subtitle_color }};
    margin: {{ this.subtitle_margin_top }}px 0 0 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 768px) {
    #listicle-lto-title-{{ block.id }} .listicle-lto-title-text {
      font-size: {{ this.font_size_mobile }}px;
    }
    #listicle-lto-title-{{ block.id }} .listicle-lto-subtitle-text {
      font-size: {{ this.subtitle_font_size | times: 0.9 | round }}px;
    }
  }
</style>

<div id="listicle-lto-title-{{ block.id }}" class="listicle-lto-title-block" {{ block.shopify_attributes }}>
  {%- if this.title != blank -%}
    <{{ this.heading_tag }} class="listicle-lto-title-text">{{ this.title }}</{{ this.heading_tag }}>
  {%- endif -%}
  {%- if this.subtitle != blank -%}
    <p class="listicle-lto-subtitle-text">{{ this.subtitle }}</p>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Listicle LTO Title",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading Tag",
      "options": [
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" },
        { "value": "h4", "label": "H4" },
        { "value": "p", "label": "Paragraph" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Title Font Size",
      "default": 32,
      "min": 14,
      "max": 64,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "font_size_mobile",
      "label": "Title Font Size (Mobile)",
      "default": 24,
      "min": 12,
      "max": 48,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Title Font Weight",
      "options": [
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title Color",
      "default": "#111111"
    },
    {
      "type": "header",
      "content": "Subtitle"
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle Font Size",
      "default": 16,
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subtitle_margin_top",
      "label": "Subtitle Margin Top",
      "default": 8,
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin Top",
      "default": 0,
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin Bottom",
      "default": 20,
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px"
    }
  ],
  "presets": [{ "name": "Listicle LTO Title" }]
}
{% endschema %}
