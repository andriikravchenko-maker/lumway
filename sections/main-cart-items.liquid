{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Apply border radius to cart item images */
  .cart-items .cart-item__media {
    overflow: hidden !important;
  }
  .cart-items .cart-item__media img,
  .cart-items .cart-item__image,
  .cart-items .cart-item__image-container {
    border-radius: 8px !important;
  }

  /* Discount Banner Styles */
  .discount-banner {
    padding: 10px 15px;
    text-align: center;
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 400;
    width: 100%;
    box-sizing: border-box;
  }

  .celebration-icon {
    display: inline-block;
    margin-right: 5px;
  }

  .discount-banner-bold {
    font-weight: var(--font-weight-bold, 700);
  }

  @media (max-width: 749px) {
    .discount-banner {
      padding: 8px 10px;
      font-size: 13px;
    }
  }

  /* Prevent cart remove button from using global button gradient */
  cart-remove-button .button,
  cart-remove-button .button.button--tertiary {
    background: transparent !important;
    background-image: none !important;
    border: none !important;
    color: inherit !important;
  }

  cart-remove-button .button:hover {
    background: transparent !important;
    background-image: none !important;
    opacity: 0.7;
  }

  .spin-animation {
    display: block;
    position: absolute;
    height: 15px;
    width: 15px;
    border: solid;
    border-radius: calc(infinity * 1px);
    border-width: 2px;
    border-color: rgba(0, 0, 0, 0.3);
    border-top-color: #fff;
    /* animation: var(--animate-spin); */
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .cart-item__quantity .spin-animation {
    display: none;
  }

  .quantity__button .spin-animation {
    top: unset;
    left: unset;
  }

  /* Custom Color Styling for Cart Page */
  {% unless section.settings.use_theme_colors %}
    /* Title */
    .section-{{ section.id }}-padding .title-wrapper-with-link .title--primary {
      color: {{ section.settings.cart_title_color }} !important;
    }

    /* Continue Shopping Link */
    .section-{{ section.id }}-padding .title-wrapper-with-link .underlined-link {
      color: {{ section.settings.continue_shopping_link_color }} !important;
    }

    .section-{{ section.id }}-padding .title-wrapper-with-link .underlined-link:hover {
      color: {{ section.settings.continue_shopping_link_hover_color }} !important;
    }

    /* Table Headers */
    .section-{{ section.id }}-padding .cart-items thead th {
      color: {{ section.settings.table_header_text_color }} !important;
    }

    /* Product Titles */
    .section-{{ section.id }}-padding .cart-item__name {
      color: {{ section.settings.product_title_color }} !important;
    }

    .section-{{ section.id }}-padding .cart-item__name:hover {
      color: {{ section.settings.product_title_hover_color }} !important;
    }

    /* Prices */
    .section-{{ section.id }}-padding .price {
      color: {{ section.settings.price_color }} !important;
    }

    .section-{{ section.id }}-padding .price .price-item--regular,
    .section-{{ section.id }}-padding .price .price-item--sale {
      color: {{ section.settings.price_color }} !important;
    }

    /* Compare At Prices */
    .section-{{ section.id }}-padding .price .price-item--last {
      color: {{ section.settings.compare_at_price_color }} !important;
    }

    .section-{{ section.id }}-padding .price s,
    .section-{{ section.id }}-padding .price del {
      color: {{ section.settings.compare_at_price_color }} !important;
    }

    /* Product Options */
    .section-{{ section.id }}-padding .product-option,
    .section-{{ section.id }}-padding .product-option dt,
    .section-{{ section.id }}-padding .product-option dd,
    .section-{{ section.id }}-padding .cart-item__details dl .product-option {
      color: {{ section.settings.product_option_color }} !important;
    }

    /* Quantity */
    .section-{{ section.id }}-padding .cart-item__quantity,
    .section-{{ section.id }}-padding .cart-item__quantity .quantity,
    .section-{{ section.id }}-padding .cart-item__quantity .quantity__input,
    .section-{{ section.id }}-padding .cart-item__quantity .quantity-popover__info-button,
    .section-{{ section.id }}-padding .cart-item__quantity .quantity__button,
    .section-{{ section.id }}-padding .cart-item__quantity .quantity__button svg,
    .section-{{ section.id }}-padding quantity-input .quantity,
    .section-{{ section.id }}-padding quantity-input .quantity__input,
    .section-{{ section.id }}-padding quantity-input .quantity__button {
      color: {{ section.settings.quantity_color }} !important;
    }

    .section-{{ section.id }}-padding .cart-item__quantity .quantity__input,
    .section-{{ section.id }}-padding quantity-input .quantity__input {
      border-color: {{ section.settings.quantity_color | color_modify: 'alpha', 0.3 }} !important;
    }

    /* Borders */
    .section-{{ section.id }}-padding .cart-items {
      border-color: {{ section.settings.border_color }} !important;
    }

    .section-{{ section.id }}-padding .cart-items tr {
      border-color: {{ section.settings.border_color }} !important;
    }

    .section-{{ section.id }}-padding .cart-items td,
    .section-{{ section.id }}-padding .cart-items th {
      border-color: {{ section.settings.border_color }} !important;
    }

    /* Buttons */
    .section-{{ section.id }}-padding .button,
    .section-{{ section.id }}-padding .shopify-payment-button__button--unbranded {
      background-color: {{ section.settings.button_background_color }} !important;
      color: {{ section.settings.button_text_color }} !important;
      border-color: {{ section.settings.button_background_color }} !important;
    }

    .section-{{ section.id }}-padding .button:hover,
    .section-{{ section.id }}-padding .shopify-payment-button__button--unbranded:hover {
      background-color: {{ section.settings.button_hover_background_color }} !important;
      border-color: {{ section.settings.button_hover_background_color }} !important;
    }

    /* Empty Cart Text */
    .section-{{ section.id }}-padding .cart__empty-text {
      color: {{ section.settings.empty_cart_text_color }} !important;
    }

    .section-{{ section.id }}-padding .cart__login-title,
    .section-{{ section.id }}-padding .cart__login-paragraph {
      color: {{ section.settings.section_text_color }} !important;
    }

    /* Quantity Selector */
    .section-{{ section.id }}-padding .quantity__input {
      color: {{ section.settings.section_text_color }} !important;
    }

    /* Product Options/Variants */
    .section-{{ section.id }}-padding .product-option {
      color: {{ section.settings.section_text_color }} !important;
    }

    /* Remove Link */
    .section-{{ section.id }}-padding cart-remove-button .button {
      color: {{ section.settings.section_text_color }} !important;
    }
  {% endunless %}
{%- endstyle -%}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

{%- liquid
  if section.settings.empty_cart_redirect_url != blank
    assign continue_shopping_url = section.settings.empty_cart_redirect_url
  else
    assign continue_shopping_url = routes.all_products_collection_url
  endif
-%}
<cart-items class="isolate{% if cart == empty %} is-empty{% else %} section-{{ section.id }}-padding{% endif %}" style="{% if section.settings.use_theme_colors %}background-color: {{ settings.global_section_background_color }}; color: {{ settings.global_section_text_color }};{% else %}background-color: {{ section.settings.section_background_color }}; color: {{ section.settings.section_text_color }};{% endif %}">
  <div class="page-width">
    <div class="title-wrapper-with-link">
      <h1 class="title title--primary">{{ 'sections.cart.title' | t }}</h1>
      <a href="{{ continue_shopping_url }}" class="underlined-link">
        {{- 'general.continue_shopping' | t -}}
      </a>
    </div>

    {% comment %} Discount Banner - Start {% endcomment %}
    {% if settings.show_discount_banner and cart != empty %}
      {% liquid
        assign total_compare_at_price = 0
        assign discount_amount = 0

        for item in cart.items
          if item.variant.compare_at_price > item.variant.price
            assign compare_at_line_price = item.variant.compare_at_price | times: item.quantity
            assign total_compare_at_price = total_compare_at_price | plus: compare_at_line_price
          else
            assign total_compare_at_price = total_compare_at_price | plus: item.final_line_price
          endif
        endfor

        if total_compare_at_price > cart.total_price
          assign discount_amount = total_compare_at_price | minus: cart.total_price
        endif

        if settings.use_theme_colors_cart_drawer
          assign banner_bg_color = settings.global_section_accent_2_color
          assign banner_text_color = settings.global_section_accent_1_color
        else
          assign banner_bg_color = settings.discount_banner_bg_color
          assign banner_text_color = settings.discount_banner_text_color
        endif

        if settings.discount_banner_use_gradient and settings.use_theme_colors_cart_drawer == false
          assign banner_background_style = 'background: linear-gradient(' | append: settings.discount_banner_gradient_angle | append: 'deg, ' | append: settings.discount_banner_gradient_start_color | append: ', ' | append: settings.discount_banner_gradient_end_color | append: ');'
        else
          assign banner_background_style = 'background-color: ' | append: banner_bg_color | append: ';'
        endif
      %}

      {% if discount_amount > 0 %}
        <div class="discount-banner" style="{{ banner_background_style }} color: {{ banner_text_color }};">
          {% if settings.discount_banner_icon != 'none' %}
            <span class="celebration-icon">
              {% case settings.discount_banner_icon %}
                {% when 'celebration' %}
                  🎉
                {% when 'star' %}
                  ⭐
                {% when 'gift' %}
                  🎁
                {% when 'discount' %}
                  💰
              {% endcase %}
            </span>
          {% endif %}
          <span class="discount-banner-text">
            <span class="discount-banner-bold">{{ settings.discount_banner_prefix }}</span>
            {{ settings.discount_banner_middle }}
            <span class="discount-banner-bold">{{ discount_amount | money }}</span>
            {{ settings.discount_banner_suffix }}
          </span>
        </div>
      {% endif %}
    {% endif %}
    {% comment %} Discount Banner - End {% endcomment %}

    <div class="cart__warnings">
      <h1 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h1>
      <a href="{{ continue_shopping_url }}" class="button">
        {{ 'general.continue_shopping' | t }}
      </a>

      {%- if shop.customer_accounts_enabled and customer == null -%}
        <h2 class="cart__login-title">{{ 'sections.cart.login.title' | t }}</h2>
        <p class="cart__login-paragraph">
          {{ 'sections.cart.login.paragraph_html' | t: link: routes.account_login_url }}
        </p>
      {%- endif -%}
    </div>

    <form action="{{ routes.cart_url }}" class="cart__contents critical-hidden" method="post" id="cart">
      <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
        <div class="js-contents">
          {%- if cart != empty -%}
            <table class="cart-items">
              <caption class="visually-hidden">
                {{ 'sections.cart.title' | t }}
              </caption>
              <thead>
                <tr>
                  <th class="caption-with-letter-spacing" colspan="2" scope="col">
                    {{ 'sections.cart.headings.product' | t }}
                  </th>
                  <th class="medium-hide large-up-hide right caption-with-letter-spacing" colspan="1" scope="col">
                    {{ 'sections.cart.headings.total' | t }}
                  </th>
                  <th
                    class="cart-items__heading--wide cart-items__heading--quantity small-hide caption-with-letter-spacing"
                    colspan="1"
                    scope="col"
                  >
                    {{ 'sections.cart.headings.quantity' | t }}
                  </th>
                  <th class="small-hide right caption-with-letter-spacing" colspan="1" scope="col">
                    {{ 'sections.cart.headings.total' | t }}
                  </th>
                </tr>
              </thead>

              <tbody>
                {%- for item in cart.items -%}
                  <tr
                    class="cart-item"
                    id="CartItem-{{ item.index | plus: 1 }}"
                    {% if item.id == settings.product_shipping_protection.selected_or_first_available_variant.id %}
                      style="display:none;"
                    {% endif %}
                  >
                    <td class="cart-item__media">
                      {% if item.image %}
                        {% comment %} Leave empty space due to a:empty CSS display: none rule {% endcomment %}
                        <a href="{{ item.url }}" class="cart-item__link" aria-hidden="true" tabindex="-1"> </a>
                        <div class="cart-item__image-container gradient global-media-settings">
                          <img
                            src="{{ item.image | image_url: width: 300 }}"
                            class="cart-item__image"
                            alt="{{ item.image.alt | escape }}"
                            loading="lazy"
                            width="150"
                            height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}"
                          >
                        </div>
                      {% endif %}
                    </td>

                    <td class="cart-item__details">
                      {%- if settings.show_vendor -%}
                        <p class="caption-with-letter-spacing">{{ item.product.vendor }}</p>
                      {%- endif -%}

                      <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>

                      {%- if item.product.has_only_default_variant == false
                        or item.properties.size != 0
                        or item.selling_plan_allocation != null
                      -%}
                        <dl>
                          {%- if item.product.has_only_default_variant == false -%}
                            {%- for option in item.options_with_values -%}
                              <div class="product-option">
                                <dt>{{ option.name }}:</dt>
                                <dd>{{ option.value }}</dd>
                              </div>
                            {%- endfor -%}
                          {%- endif -%}

                          {%- for property in item.properties -%}
                            {%- assign property_first_char = property.first | slice: 0 -%}
                            {%- if property.last != blank and property_first_char != '_' -%}
                              <div class="product-option">
                                <dt>{{ property.first }}:</dt>
                                <dd>
                                  {%- if property.last contains '/uploads/' -%}
                                    <a href="{{ property.last }}" class="link" target="_blank">
                                      {{ property.last | split: '/' | last }}
                                    </a>
                                  {%- else -%}
                                    {{ property.last }}
                                  {%- endif -%}
                                </dd>
                              </div>
                            {%- endif -%}
                          {%- endfor -%}
                        </dl>

                        <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                      {%- endif -%}

                      {%- if item.discount_allocations.size > 0 -%}
                        <div class="cart-item__discount-allocations">
                          {%- for discount in item.discount_allocations -%}
                            <div class="discount-tag">
                              <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-tag-icon lucide-tag"
                              >
                                <path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"/><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"/>
                              </svg>
                              <span class="discount-label">{{ discount.discount_application.title }}</span>
                            </div>
                          {%- endfor -%}
                        </div>
                      {%- endif -%}
                    </td>

                    <td class="cart-item__totals right medium-hide large-up-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                       {% if item.variant.compare_at_price > item.variant.price %}
                          <div class="cart-item__discounted-prices">
                            <s class="cart-item__old-price product-option">
                              {{- item.variant.compare_at_price | times: item.quantity | money -}}
                            </s>
                            <strong class="cart-item__final-price product-option eee">
                              {{ item.final_line_price | money }}
                            </strong>
                          </div>
                          {% assign total_saving = item.variant.compare_at_price
                            | minus: item.final_price
                            | times: item.quantity
                          %}
                        {% else %}
                          <div class="product-option">
                            {% if item.original_line_price != item.final_line_price %}
                            <s class="cart-item__old-price">
                              {{- item.original_line_price | money -}}
                            </s>
                            <strong class="cart-item__final-price">
                              {% if item.final_line_price == 0 %}
                                {{ 'general.cart.free' | t }}
                              {% else %}
                                {{ item.final_line_price | money }}
                              {% endif %}
                            </strong>
                            {% else %}
                              {{ item.final_line_price | money }}
                            {% endif %}
                          </div>
                          {% assign total_saving = item.original_line_price | minus: item.final_line_price %}
                        {% endif %}
                        {% if total_saving != 0 %}
                          <div class="gb-price-drawer-saving">
                              {{ 'SAVE' | t }}
                              {{ total_saving | abs | money_without_trailing_zeros }}
                          </div>
                        {% endif %}

                        {%- if item.variant.available and item.unit_price_measurement -%}
                          <div class="unit-price caption">
                            <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                            {{ item.unit_price | money }}
                            <span aria-hidden="true">/</span>
                            <span class="visually-hidden"
                              >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                            >
                            {%- if item.unit_price_measurement.reference_value != 1 -%}
                              {{- item.unit_price_measurement.reference_value -}}
                            {%- endif -%}
                            {{ item.unit_price_measurement.reference_unit }}
                          </div>
                        {%- endif -%}
                      </div>
                    </td>
                    {%- liquid
                      assign has_qty_rules = false
                      if item.variant.quantity_rule.increment > 1 or item.variant.quantity_rule.min > 1 or item.variant.quantity_rule.max != null
                        assign has_qty_rules = true
                      endif

                      assign has_vol_pricing = false
                      if item.variant.quantity_price_breaks.size > 0
                        assign has_vol_pricing = true
                      endif
                    -%}
                    <td class="cart-item__quantity{% if has_qty_rules or has_vol_pricing %} cart-item__quantity--info{% endif %}">
                      <quantity-popover>
                        <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                          <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                            {{ 'products.product.quantity.label' | t }}
                          </label>
                          <div class="quantity-popover-container{% if has_qty_rules or has_vol_pricing %} quantity-popover-container--hover{% endif %}">
                            {%- if has_qty_rules or has_vol_pricing -%}
                              <button
                                type="button"
                                aria-expanded="false"
                                class="quantity-popover__info-button quantity-popover__info-button--icon-only button button--tertiary small-hide medium-hide"
                              >
                                {{- 'icon-info.svg' | inline_asset_content -}}
                              </button>
                            {%- endif -%}
                            <quantity-input class="quantity cart-quantity">
                              <button class="quantity__button" name="minus" type="button">
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.decrease' | t: product: item.product.title | escape -}}
                                </span>
                                <span class="svg-wrapper content">
                                  {{- 'icon-minus.svg' | inline_asset_content -}}
                                </span>
                                <div class="spin-animation">
                                  <span></span>
                                </div>
                              </button>
                              <input
                                class="quantity__input"
                                data-quantity-variant-id="{{ item.variant.id }}"
                                type="number"
                                name="updates[]"
                                value="{{ item.quantity }}"
                                {% # theme-check-disable %}
                                data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}"
                                min="1"
                                data-min="{{ item.variant.quantity_rule.min }}"
                                {% if item.variant.quantity_rule.max != null %}
                                  max="{{ item.variant.quantity_rule.max }}"
                                {% endif %}
                                step="{{ item.variant.quantity_rule.increment }}"
                                {% # theme-check-enable %}
                                aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                                id="Quantity-{{ item.index | plus: 1 }}"
                                data-index="{{ item.index | plus: 1 }}"
                              >
                              <button class="quantity__button" name="plus" type="button">
                                <span class="visually-hidden">
                                  {{- 'products.product.quantity.increase' | t: product: item.product.title | escape -}}
                                </span>
                                <span class="svg-wrapper content">
                                  {{- 'icon-plus.svg' | inline_asset_content -}}
                                </span>
                                <div class="spin-animation">
                                  <span></span>
                                </div>
                              </button>
                            </quantity-input>
                          </div>
                          <cart-remove-button
                            id="Remove-{{ item.index | plus: 1 }}"
                            data-index="{{ item.index | plus: 1 }}"
                          >
                            <a
                              href="{{ item.url_to_remove }}"
                              class="button button--tertiary cart-remove-button"
                              aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}"
                            >
                              <span class="svg-wrapper gb-cart-del-img content">
                                <svg
                                  width="15"
                                  height="15"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  xmlns="http://www.w3.org/2000/svg"
                                >
                                  <path d="M8 1.5V2.5H3C2.44772 2.5 2 2.94772 2 3.5V4.5C2 5.05228 2.44772 5.5 3 5.5H21C21.5523 5.5 22 5.05228 22 4.5V3.5C22 2.94772 21.5523 2.5 21 2.5H16V1.5C16 0.947715 15.5523 0.5 15 0.5H9C8.44772 0.5 8 0.947715 8 1.5Z" fill="currentColor"/>
                                  <path d="M3.9231 7.5H20.0767L19.1344 20.2216C19.0183 21.7882 17.7135 23 16.1426 23H7.85724C6.28636 23 4.98148 21.7882 4.86544 20.2216L3.9231 7.5Z" fill="currentColor"/>
                                </svg>
                              </span>
                              <div class="spin-animation">
                                <span></span>
                              </div>
                            </a>
                          </cart-remove-button>
                        </div>
                        {%- if has_qty_rules or has_vol_pricing -%}
                          <button
                            type="button"
                            class="quantity-popover__info-button quantity-popover__info-button--icon-with-label button button--tertiary large-up-hide"
                            aria-expanded="false"
                          >
                            {{- 'icon-info.svg' | inline_asset_content -}}
                            <span>
                              {%- if has_vol_pricing -%}
                                {{ 'products.product.volume_pricing.note' | t }}
                              {%- elsif has_qty_rules -%}
                                {{ 'products.product.quantity.note' | t }}
                              {%- endif -%}
                            </span>
                          </button>
                        {%- endif -%}
                        {%- if has_vol_pricing or has_qty_rules -%}
                          <div
                            class="cart-items__info global-settings-popup quantity-popover__info"
                            tabindex="-1"
                            hidden
                          >
                            {%- if has_qty_rules == false -%}
                              <span class="volume-pricing-label caption">
                                {{- 'products.product.volume_pricing.title' | t -}}
                              </span>
                            {%- endif -%}
                            <div class="quantity__rules caption">
                              {%- if item.variant.quantity_rule.increment > 1 -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.multiples_of'
                                    | t: quantity: item.variant.quantity_rule.increment
                                  -}}
                                </span>
                              {%- endif -%}
                              {%- if item.variant.quantity_rule.min > 1 -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.min_of'
                                    | t: quantity: item.variant.quantity_rule.min
                                  -}}
                                </span>
                              {%- endif -%}
                              {%- if item.variant.quantity_rule.max != null -%}
                                <span class="divider">
                                  {{-
                                    'products.product.quantity.max_of'
                                    | t: quantity: item.variant.quantity_rule.max
                                  -}}
                                </span>
                              {%- endif -%}
                            </div>
                            <button
                              class="button-close button button--tertiary large-up-hide"
                              type="button"
                              aria-label="{{ 'accessibility.close' | t }}"
                            >
                              <span class="svg-wrapper">
                                {{- 'icon-close.svg' | inline_asset_content -}}
                              </span>
                            </button>
                            {%- if item.variant.quantity_price_breaks.size > 0 -%}
                              <volume-pricing class="parent-display">
                                <ul class="list-unstyled">
                                  <li>
                                    <span>{{ item.variant.quantity_rule.min }}+</span>
                                    {%- assign price = item.variant.price | money_with_currency -%}
                                    <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                  </li>
                                  {%- for price_break in item.variant.quantity_price_breaks -%}
                                    <li>
                                      <span>
                                        {{- price_break.minimum_quantity -}}
                                        <span aria-hidden="true">+</span></span
                                      >
                                      {%- assign price = price_break.price | money_with_currency -%}
                                      <span> {{ 'sections.quick_order_list.each' | t: money: price }}</span>
                                    </li>
                                  {%- endfor -%}
                                </ul>
                              </volume-pricing>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                        <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                          <small class="cart-item__error-text"></small>
                          <span class="svg-wrapper">
                            {{- 'icon-error.svg' | inline_asset_content -}}
                          </span>
                        </div>
                      </quantity-popover>
                    </td>

                    <td class="cart-item__totals right small-hide">
                      {%- render 'loading-spinner' -%}
                      <div class="cart-item__price-wrapper">
                       {% if item.variant.compare_at_price > item.variant.price %}
                          <div class="cart-item__discounted-prices">
                            <s class="cart-item__old-price product-option">
                              {{- item.variant.compare_at_price | times: item.quantity | money -}}
                            </s>
                            <strong class="cart-item__final-price product-option">
                              {% if item.final_line_price == 0 %}
                                {{ 'general.cart.free' | t }}
                              {% else %}
                                {{ item.final_line_price | money }}
                              {% endif %}
                            </strong>
                          </div>
                          {% assign total_saving = item.variant.compare_at_price
                            | minus: item.final_price
                            | times: item.quantity
                          %}
                        {% else %}
                          <div class="product-option">
                            {% if item.original_line_price != item.final_line_price %}
                            <s class="cart-item__old-price">
                              {{- item.original_line_price | money -}}
                            </s>
                            <strong class="cart-item__final-price">
                              {% if item.final_line_price == 0 %}
                                {{ 'general.cart.free' | t }}
                              {% else %}
                                {{ item.final_line_price | money }}
                              {% endif %}
                            </strong>
                            {% else %}
                              {{ item.final_line_price | money }}
                            {% endif %}
                          </div>
                          {% assign total_saving = item.original_line_price | minus: item.final_line_price %}
                        {% endif %}
                        {% if total_saving != 0 %}
                          <div class="gb-price-drawer-saving">
                              {{ 'SAVE' | t }}
                              {{ total_saving | abs | money_without_trailing_zeros }}
                          </div>
                        {% endif %}

                        {%- if item.variant.available and item.unit_price_measurement -%}
                          <div class="unit-price caption">
                            <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                            {{ item.unit_price | money }}
                            <span aria-hidden="true">/</span>
                            <span class="visually-hidden"
                              >&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span
                            >
                            {%- if item.unit_price_measurement.reference_value != 1 -%}
                              {{- item.unit_price_measurement.reference_value -}}
                            {%- endif -%}
                            {{ item.unit_price_measurement.reference_unit }}
                          </div>
                        {%- endif -%}
                      </div>
                    </td>
                  </tr>
                {%- endfor -%}
              </tbody>
            </table>
          {%- endif -%}
        </div>
      </div>

      <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
      <p
        class="visually-hidden"
        id="shopping-cart-line-item-status"
        aria-live="polite"
        aria-hidden="true"
        role="status"
      >
        {{ 'accessibility.loading' | t }}
      </p>
    </form>
  </div>
</cart-items>

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_theme_colors",
      "label": "Use Theme Colors",
      "default": true,
      "info": "When enabled, uses global theme colors for section background and text"
    },
    {
      "type": "header",
      "content": "Section Colors"
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Section Background Color",
      "default": "#FFFFFF",
      "info": "Applies when theme colors are disabled"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color",
      "default": "#000000",
      "info": "Applies when theme colors are disabled"
    },
    {
      "type": "header",
      "content": "Empty Cart Settings"
    },
    {
      "type": "url",
      "id": "empty_cart_redirect_url",
      "label": "Continue Shopping Link",
      "info": "URL for the 'Continue Shopping' button when cart is empty. Leave blank to use the default All Products collection page."
    },
    {
      "type": "header",
      "content": "Title & Links"
    },
    {
      "type": "color",
      "id": "cart_title_color",
      "label": "Cart Title Color",
      "default": "#000000",
      "info": "Color for the 'Shopping Cart' heading"
    },
    {
      "type": "color",
      "id": "continue_shopping_link_color",
      "label": "Continue Shopping Link Color",
      "default": "#000000",
      "info": "Color for the 'Continue Shopping' link"
    },
    {
      "type": "color",
      "id": "continue_shopping_link_hover_color",
      "label": "Continue Shopping Link Hover Color",
      "default": "#333333",
      "info": "Hover color for the 'Continue Shopping' link"
    },
    {
      "type": "header",
      "content": "Table & Product Colors"
    },
    {
      "type": "color",
      "id": "table_header_text_color",
      "label": "Table Header Text Color",
      "default": "#000000",
      "info": "Color for 'Product', 'Quantity', 'Total' headers"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product Title Color",
      "default": "#000000",
      "info": "Color for product names in the cart"
    },
    {
      "type": "color",
      "id": "product_title_hover_color",
      "label": "Product Title Hover Color",
      "default": "#333333",
      "info": "Hover color for product names"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price Color",
      "default": "#000000",
      "info": "Color for product prices"
    },
    {
      "type": "color",
      "id": "compare_at_price_color",
      "label": "Compare At Price Color",
      "default": "#999999",
      "info": "Color for strikethrough original prices"
    },
    {
      "type": "color",
      "id": "product_option_color",
      "label": "Product Option Color",
      "default": "#666666",
      "info": "Color for product variant options (size, color, etc.)"
    },
    {
      "type": "color",
      "id": "quantity_color",
      "label": "Quantity Selector Color",
      "default": "#000000",
      "info": "Color for quantity input and buttons"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#E5E5E5",
      "info": "Color for table borders and separators"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button Background Color",
      "default": "#000000",
      "info": "Background color for cart buttons"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#FFFFFF",
      "info": "Text color for cart buttons"
    },
    {
      "type": "color",
      "id": "button_hover_background_color",
      "label": "Button Hover Background Color",
      "default": "#333333",
      "info": "Background color when hovering over buttons"
    },
    {
      "type": "header",
      "content": "Empty Cart"
    },
    {
      "type": "color",
      "id": "empty_cart_text_color",
      "label": "Empty Cart Text Color",
      "default": "#000000",
      "info": "Color for 'Your cart is empty' message"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:sections.all.padding.padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:sections.all.padding.padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 36,
      "unit": "px"
    }
  ]
}
{% endschema %}
