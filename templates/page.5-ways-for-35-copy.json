      }
    },
    "gut_harmony_feature_ncw9RV": {
      "type": "gut-harmony-feature",
      "name": "Gut Harmony Feature",
      "settings": {
        "use_theme_colors": false,
        "padding_top": 80,
        "padding_bottom": 80,
        "padding_top_mobile": 40,
        "padding_bottom_mobile": 28,
        "title_gap": 16,
        "column_gap": 24,
        "content_gap": 24,
        "background_color": "#ffffff",
        "title": "Why Circulation Matters",
        "title_size": 40,
        "title_size_mobile": 26,
        "title_color": "#3b3b3b",
        "image": "shopify://shop_images/4471183.webp",
        "image_border_radius": 0,
        "body_text": "<p><strong>Healthy circulation helps deliver oxygen and nutrients throughout the body.</strong></p><p>That includes your brain, muscles, and the tissues involved in normal physical response.</p><p>While hormones play an important role, healthy blood flow is also part of the bigger picture of women’s vitality.</p><p>When<strong> circulation, metabolism, and energy production are not supported</strong> many women may feel:</p><ul><li>Less physically responsive</li><li>More tired by the end of the day</li><li>Less motivated</li><li>Less connected to their body</li><li>Less like themselves</li></ul>",
        "text_size": 15,
        "text_color": "#3b3b3b",
        "testimonial_text": "<p><strong>❌ This doesn’t mean something is “wrong” with you.</strong></p><p><strong>✅ It may simply mean your body needs support in a new way.</strong></p>",
        "testimonial_size": 18,
        "testimonial_paragraph_spacing": 12,
        "testimonial_color": "#a9617a",
        "button_text": "",
        "button_link": "",
        "button_show_arrow": false,
        "button_font_size": 24,
