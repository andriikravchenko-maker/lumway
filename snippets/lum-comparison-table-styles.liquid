{% comment %}
  Snippet: LCT styles
  Params: table_settings, table_id
{% endcomment %}
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&display=swap"
  rel="stylesheet"
>

{%- liquid
  assign lct_section_bg = table_settings.section_bg_color | default: '#ffffff'
  assign lct_border_color = table_settings.border_color | default: '#eeede5'
  assign lct_border_width = table_settings.border_width | default: 1
  assign lct_border_radius = table_settings.border_radius | default: 12
  assign lct_highlight_bg = table_settings.highlight_bg_color | default: '#e6fbf8'
  assign lct_highlight_border = table_settings.highlight_border_color | default: '#000000'
  assign lct_highlight_border_width = table_settings.highlight_border_width | default: 2
  assign lct_highlight_inner_border = table_settings.highlight_inner_border_color | default: '#eeede5'
  assign lct_text = table_settings.text_color | default: '#202329'
  assign lct_muted = table_settings.muted_text_color | default: '#666666'
  assign lct_check_color = table_settings.check_color | default: '#23A02A'
  assign lct_max_width = table_settings.max_width | default: 792
  assign lct_padding_top = table_settings.padding_top | default: 0
  assign lct_padding_bottom = table_settings.padding_bottom | default: 0
  assign lct_padding_x = table_settings.padding_x | default: 0
  assign lct_margin_top = table_settings.margin_top | default: 0
  assign lct_margin_bottom = table_settings.margin_bottom | default: 32
  assign lct_cell_pad_x = table_settings.cell_padding_x | default: 12
  assign lct_cell_pad_y = table_settings.cell_padding_y | default: 12
  assign lct_cell_pad_x_mobile = table_settings.cell_padding_x_mobile | default: 8
  assign lct_cell_pad_y_mobile = table_settings.cell_padding_y_mobile | default: 8
  assign lct_label_size = table_settings.label_font_size | default: 13
  assign lct_value_size = table_settings.value_font_size | default: 13
  assign lct_header_size = table_settings.header_font_size | default: 14
  assign lct_label_size_mobile = table_settings.label_font_size_mobile | default: 11
  assign lct_value_size_mobile = table_settings.value_font_size_mobile | default: 11
  assign lct_header_size_mobile = table_settings.header_font_size_mobile | default: 11
  assign lct_logo_max_width = table_settings.logo_max_width | default: 72
  assign lct_logo_max_width_mobile = table_settings.logo_max_width_mobile | default: 52
  assign lct_mobile_breakpoint = table_settings.mobile_breakpoint | default: 768
-%}

{% style %}
  .lct--{{ table_id }} {
    --lct-font: 'Bricolage Grotesque', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    --lct-section-bg: {{ lct_section_bg }};
    --lct-border: {{ lct_border_color }};
    --lct-border-width: {{ lct_border_width }}px;
    --lct-radius: {{ lct_border_radius }}px;
    --lct-highlight-bg: {{ lct_highlight_bg }};
    --lct-highlight-border: {{ lct_highlight_border }};
    --lct-highlight-border-width: {{ lct_highlight_border_width }}px;
    --lct-highlight-inner-border: {{ lct_highlight_inner_border }};
    --lct-text: {{ lct_text }};
    --lct-muted: {{ lct_muted }};
    --lct-check: {{ lct_check_color }};
    --lct-max-width: {{ lct_max_width }}px;
    --lct-cell-px: {{ lct_cell_pad_x }}px;
    --lct-cell-py: {{ lct_cell_pad_y }}px;

    font-family: var(--lct-font);
    background: var(--lct-section-bg);
    padding: {{ lct_padding_top }}px {{ lct_padding_x }}px {{ lct_padding_bottom }}px;
    margin-top: {{ lct_margin_top }}px;
    margin-bottom: {{ lct_margin_bottom }}px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .lct--{{ table_id }},
  .lct--{{ table_id }} span,
  .lct--{{ table_id }} p,
  .lct--{{ table_id }} strong {
    font-family: var(--lct-font) !important;
    letter-spacing: normal !important;
  }

  .lct--{{ table_id }} .lct__wrap {
    max-width: 820px;
    margin: 0 auto;
    width: 100%;
  }

  .lct--{{ table_id }} .lct__scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }

  .lct--{{ table_id }} .lct__table {
    --lct-border: #eeede5;
    min-width: 100%;
    width: 100%;
    border: var(--lct-border-width) solid var(--lct-border);
    border-radius: var(--lct-radius);
    overflow: hidden;
    background: #ffffff;
  }

  .lct--{{ table_id }} .lct__row {
    display: grid;
    grid-template-columns: minmax(180px, 1.25fr) minmax(110px, 0.875fr) minmax(110px, 0.875fr);
    width: 100%;
  }

  .lct--{{ table_id }} .lct__cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--lct-cell-py) var(--lct-cell-px);
    box-sizing: border-box;
    border-bottom: var(--lct-border-width) solid var(--lct-border);
    min-height: 44px;
  }

  .lct--{{ table_id }} .lct__table > :last-child .lct__cell {
    border-bottom: none;
  }

  .lct--{{ table_id }} .lct__cell--label {
    justify-content: flex-start;
    text-align: left;
    {% comment %}border-right: var(--lct-border-width) solid var(--lct-border);{% endcomment %}
    color: var(--lct-text);
  }

  .lct--{{ table_id }} .lct__row.lct__row--header lct__cell--header:last-of-type{
    background-color:#f8f8f8;
  }

  .lct--{{ table_id }} .lct__cell--competitor {
    color: var(--lct-muted);
  }

  .lct--{{ table_id }} .lct__row--header .lct__cell--label {
    background: transparent;
    border-right: none;
    border-bottom: var(--lct-border-width) solid var(--lct-border);
  }

  .lct--{{ table_id }} .lct__cell--empty {
    visibility: hidden;
    min-height: 0;
    padding-top: 0;
    padding-bottom: 0;
  }

  .lct--{{ table_id }} .lct__cell--brand {
    background: var(--lct-highlight-bg) !important;
    color: var(--lct-text) !important;
    {% comment %}border-left: var(--lct-highlight-border-width) solid var(--lct-highlight-border) !important;{% endcomment %}
    {% comment %}border-right: var(--lct-highlight-border-width) solid var(--lct-highlight-border) !important;{% endcomment %}
    border-bottom: none !important;
    position: relative;
    z-index: 2;
  }

  .lct--{{ table_id }} .lct__cell--brand-first {
    {% comment %}border-top: var(--lct-highlight-border-width) solid var(--lct-highlight-border) !important;{% endcomment %}
    {% comment %}border-top-left-radius: var(--lct-radius);{% endcomment %}
    {% comment %}border-top-right-radius: var(--lct-radius);{% endcomment %}
    margin-top: calc(-1 * var(--lct-highlight-border-width));
    padding-top: calc(var(--lct-cell-py) + var(--lct-highlight-border-width));
    {% comment %}margin-top:1px;{% endcomment %}
  }

  .lct--{{ table_id }} .lct__table > :last-child .lct__cell--brand {
    {% comment %}border-bottom: var(--lct-highlight-border-width) solid var(--lct-highlight-border) !important;{% endcomment %}
    {% comment %}border-bottom-left-radius: var(--lct-radius);{% endcomment %}
    {% comment %}border-bottom-right-radius: var(--lct-radius);{% endcomment %}
  }

  .lct--{{ table_id }} .lct__header-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    text-align: center;
  }

  .lct--{{ table_id }} .lct__header-image {
    width: {{ lct_logo_max_width }}px;
    max-width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .lct--{{ table_id }} .lct__header-image--placeholder {
    width: {{ lct_logo_max_width }}px;
    height: {{ lct_logo_max_width }}px;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.06);
  }

  .lct--{{ table_id }} .lct__header-title {
    font-size: {{ lct_header_size }}px;
    font-weight: 700;
    line-height: 1.2;
    color: var(--lct-text);
  }

  .lct--{{ table_id }} .lct__header-label {
    font-size: {{ lct_header_size }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  .lct--{{ table_id }} .lct__label {
    font-size: {{ lct_label_size }}px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--lct-text);
  }

  .lct--{{ table_id }} .lct__value {
    font-size: {{ lct_value_size }}px;
    font-weight: 600;
    line-height: 1.3;
    text-align: center;
    color: inherit;
  }

  .lct--{{ table_id }} .lct__value--muted {
    color: var(--lct-muted);
    font-weight: 600;
  }

  .lct--{{ table_id }} .lct__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .lct--{{ table_id }} .lct__icon--check {
    color: var(--lct-check);
  }

  .lct--{{ table_id }} .lct__icon--mark,
  .lct--{{ table_id }} .lct__icon--cross {
    color: var(--lct-text);
  }

  @media (max-width: {{ lct_mobile_breakpoint }}px) {
    .lct--{{ table_id }} {
      --lct-cell-px: {{ lct_cell_pad_x_mobile }}px;
      --lct-cell-py: {{ lct_cell_pad_y_mobile }}px;
    }

    .lct--{{ table_id }} .lct__scroll {
      margin-left: calc(-1 * {{ lct_padding_x }}px);
      margin-right: calc(-1 * {{ lct_padding_x }}px);
      padding-left: max({{ lct_padding_x }}px, 12px);
      padding-right: max({{ lct_padding_x }}px, 12px);
    }

    /* Stacked mobile layout (matches babybjorn comparison chart): no horizontal
       scroll, products side by side on top, each feature label becomes a
       full-width centered section header with the two values beneath it. */
    .lct--{{ table_id }} .lct__scroll {
      overflow-x: visible;
    }

    .lct--{{ table_id }} .lct__table {
      min-width: 0;
    }

    .lct--{{ table_id }} .lct__row {
      grid-template-columns: 1fr 1fr;
    }

    .lct--{{ table_id }} .lct__cell--label {
      grid-column: 1 / -1;
      justify-content: center;
      text-align: center;
      background: #f8f8f8;
    }

    .lct--{{ table_id }} .lct__label {
      width: 100%;
      text-align: center;
    }

    /* Hide the empty feature-header cell so the two products sit at the very top */
    .lct--{{ table_id }} .lct__row--header .lct__cell--label.lct__cell--empty {
      display: none;
    }

    /* Drop the desktop highlight-border offset so the stacked header cells align */
    .lct--{{ table_id }} .lct__cell--brand-first {
      margin-top: 0;
      padding-top: var(--lct-cell-py);
    }

    .lct--{{ table_id }} .lct__header-image,
    .lct--{{ table_id }} .lct__header-image--placeholder {
      width: {{ lct_logo_max_width_mobile }}px;
    }

    .lct--{{ table_id }} .lct__header-image--placeholder {
      height: {{ lct_logo_max_width_mobile }}px;
    }

    .lct--{{ table_id }} .lct__header-title {
      font-size: {{ lct_header_size_mobile }}px;
    }

    .lct--{{ table_id }} .lct__label {
      font-size: {{ lct_label_size_mobile }}px;
    }

    .lct--{{ table_id }} .lct__value,
    .lct--{{ table_id }} .lct__value--muted {
      font-size: {{ lct_value_size_mobile }}px;
    }

    .lct--{{ table_id }} .lct__icon--check svg {
      width: 18px;
      height: 18px;
    }
  }

  .lct--{{ table_id }} .lct__header-title,
  .lct--{{ table_id }} .lct__header-label,
  .lct--{{ table_id }} .lct__value,
  .lct--{{ table_id }} .lct__value--muted,
  .lct--{{ table_id }} .lct__label {
    font-weight: 600 !important;
  }
{% endstyle %}
