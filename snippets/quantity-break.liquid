      function calculateCustomPrice(variantPrice, quantity, priceFormat, pricePercentage, priceAmount, bogoMultiplier) {
        if (!priceFormat || priceFormat === 'none') {
          return variantPrice * quantity;
        }
        
        switch(priceFormat) {
          case 'percentage':
            if (pricePercentage && pricePercentage !== '' && pricePercentage > 0 && pricePercentage <= 100) {
              const discountMultiplier = (100 - pricePercentage) / 100;
              return Math.round(variantPrice * quantity * discountMultiplier);
            }
            return variantPrice * quantity;
          
          case 'amount':
            if (priceAmount && priceAmount !== '') {
              const amount = parseFloat(priceAmount);
              if (!isNaN(amount)) {
                return Math.round(amount * 100);
              }
            }
            return variantPrice * quantity;
          
          case 'bogo':
            if (bogoMultiplier && bogoMultiplier !== '' && parseFloat(bogoMultiplier) > 0) {
              const multiplier = parseFloat(bogoMultiplier);
              if (!isNaN(multiplier)) {
                return Math.round(variantPrice * multiplier);
              }
            }
            return variantPrice * quantity;
          
          default:
            return variantPrice * quantity;
        }
      }
      
      function getCurrentVariant() {
        let selectedVariant = null;
        
        if (hasVariants && typeof variantOptions !== 'undefined') {
          const selectedOptions = {};
          for (let pos = 1; pos <= variantOptions.length; pos++) {
            const radio = document.querySelector(`.simple-variant-picker__radio[data-option-position="${pos}"]:checked`);
            const select = document.querySelector(`.simple-variant-picker__select[data-option-position="${pos}"]`);
            const value = radio ? radio.value : (select ? select.value : null);
            if (value) {
              selectedOptions[`option${pos}`] = value;
            }
          }
          
          if (Object.keys(selectedOptions).length > 0) {
            selectedVariant = productVariants.find(v => 
              Object.keys(selectedOptions).every(k => v[k] === selectedOptions[k])
            );
          }
        }
        
        if (!selectedVariant && typeof getSelectedVariants === 'function') {
          const [selectedVariantIds] = getSelectedVariants();
          const firstVariantId = selectedVariantIds && selectedVariantIds.length > 0 ? selectedVariantIds[0] : null;
          selectedVariant = firstVariantId ? 
            productVariants.find(v => v.id === firstVariantId) : 
            productVariants[0];
        }
        
        if (!selectedVariant) {
          selectedVariant = {{ product.selected_or_first_available_variant | json }};
        }
        
        return selectedVariant;
      }
      
      function updateCustomPrices() {
        const selectedVariant = getCurrentVariant();
        if (!selectedVariant) return;
        
        const variantPrice = selectedVariant.price;
        const variantComparePrice = selectedVariant.compare_at_price || 0;
        
        quantityInputs.forEach(input => {
          const hasCustomPricing = input.getAttribute('data-enable-custom-pricing') === 'true';
          if (!hasCustomPricing) return;
          
          const quantity = parseInt(input.getAttribute('data-option-quantity'), 10);
          const priceFormat = input.getAttribute('data-custom-price-format') || 'none';
          
          // Only use fields that match the selected format to avoid conflicts
          let pricePercentage = 0;
          let priceAmount = '';
          let bogoMultiplier = '';
          
          if (priceFormat === 'percentage') {
            pricePercentage = parseFloat(input.getAttribute('data-custom-price-percentage'), 10) || 0;
          } else if (priceFormat === 'amount') {
            priceAmount = input.getAttribute('data-custom-price-amount') || '';
          } else if (priceFormat === 'bogo') {
            bogoMultiplier = input.getAttribute('data-bogo-multiplier') || '';
          }
          
          const customCompareAtPrice = input.getAttribute('data-custom-compare-at-price') || '';
          
          const calculatedPrice = calculateCustomPrice(variantPrice, quantity, priceFormat, pricePercentage, priceAmount, bogoMultiplier);
          
          // Calculate compare price: use custom compare if provided, otherwise use variant compare × quantity
          let calculatedComparePrice = variantComparePrice * quantity;
          if (customCompareAtPrice && customCompareAtPrice !== '') {
            const compareAmount = parseFloat(customCompareAtPrice);
            if (!isNaN(compareAmount)) {
              calculatedComparePrice = Math.round(compareAmount * 100);
            }
          }
          
          input.setAttribute('data-price', calculatedPrice);
          
          const optionContainer = input.closest('.quantity-break-option-container');
          if (optionContainer) {
            const priceElement = optionContainer.querySelector('.quantity-break-price');
            const comparePriceElement = optionContainer.querySelector('.quantity-break-original-price');
            
            if (priceElement) {
              if (!priceElement.dataset.originalPrice) {
                priceElement.dataset.originalPrice = priceElement.textContent || '';
              }
              const formattedPrice = Elixir_FormatMoney(calculatedPrice);
              priceElement.textContent = formattedPrice;
            }
            
            if (comparePriceElement && calculatedComparePrice > calculatedPrice) {
              const formattedComparePrice = Elixir_FormatMoney(calculatedComparePrice);
              comparePriceElement.textContent = formattedComparePrice;
              comparePriceElement.style.visibility = 'visible';
            } else if (comparePriceElement) {
              comparePriceElement.style.visibility = 'hidden';
            }
            
            if (optionContainer.querySelector('.quantity-break-option.selected')) {
              const addToCartButton = document.querySelector('.product-form__submit .button__text')
                || document.querySelector('.shop-add-to-cart-button .button-text')
                || document.querySelector('[data-add-to-cart-text]');
              
              if (addToCartButton && priceElement) {
                const submitButton = addToCartButton.closest('button[type="submit"]') || addToCartButton.closest('.shop-add-to-cart-button');
                const hasTextOverride = submitButton && submitButton.dataset.textOverride === 'true';
                const persistentText = submitButton && submitButton.dataset.persistentText;
                
                const showPriceInButton = submitButton && submitButton.dataset.showPrice === 'true' 
                  || (typeof window.showPriceButton !== 'undefined' && window.showPriceButton);
                
                let buttonText = '';
                if (hasTextOverride && persistentText) {
                  buttonText = persistentText;
                } else {
                  buttonText = addToCartButtonText || 'Add to Cart';
                }
                
                let newButtonText = buttonText;
                // Only add price if the setting is enabled
                if (showPriceInButton && priceElement.textContent) {
                  newButtonText += ' - ' + formatMoneyWithoutSuffix(priceElement.textContent.replace(/[^0-9.,]/g, ''));
                  if (comparePriceElement && calculatedComparePrice > calculatedPrice) {
                    newButtonText += ` <span class="compare-price">(${formatMoneyWithoutSuffix(comparePriceElement.textContent.replace(/[^0-9.,]/g, ''))})</span>`;
                  }
                }
                
                addToCartButton.innerHTML = newButtonText;
              }
            }
          }
        });
      }

      /**
       * Single place for quantity break price display: uses Elixir_GetDisplayPrice so prices
       * respect subscription and stay in sync with variant/quantity. Updates all option labels
       * and the add-to-cart button for the selected option.
       */
      function refreshQuantityBreakDisplay() {
        if (typeof Elixir_GetDisplayPrice !== 'function' || typeof Elixir_FormatMoney !== 'function') return;
        var variant = getCurrentVariant();
        if (!variant) return;
        var variantPrice = variant.price;
        var variantComparePrice = variant.compare_at_price || 0;
        var selectedInput = document.querySelector('.quantity-break-option.selected input.quantity-break-input');
        document.querySelectorAll('.quantity-break-option-container').forEach(function(container) {
          var input = container.querySelector('input.quantity-break-input');
          if (!input) return;
          var qty = Math.max(1, parseInt(input.getAttribute('data-option-quantity') || input.value, 10) || 1);
          var hasCustom = input.getAttribute('data-enable-custom-pricing') === 'true';
          var priceCents, compareCents;
          if (hasCustom) {
            var priceFormat = input.getAttribute('data-custom-price-format') || 'none';
            var pricePercentage = parseFloat(input.getAttribute('data-custom-price-percentage'), 10) || 0;
            var priceAmount = input.getAttribute('data-custom-price-amount') || '';
            var bogoMultiplier = input.getAttribute('data-bogo-multiplier') || '';
            priceCents = calculateCustomPrice(variantPrice, qty, priceFormat, pricePercentage, priceAmount, bogoMultiplier);
            var customCompare = input.getAttribute('data-custom-compare-at-price') || '';
            compareCents = (customCompare && customCompare !== '') ? Math.round(parseFloat(customCompare) * 100) : (variantComparePrice * qty);
          } else {
            priceCents = parseInt(input.getAttribute('data-price'), 10) || parseInt(input.getAttribute('data-base-price'), 10) || 0;
            compareCents = parseInt(container.getAttribute('data-compare-at-price'), 10) || 0;
          }
          // Pass per-unit price and option quantity; always multiply by quantity so subscription is applied per unit then × qty
          var perUnitPrice = qty > 0 ? Math.round(priceCents / qty) : priceCents;
          var perUnitCompare = qty > 0 ? Math.round(compareCents / qty) : compareCents;
          var result = Elixir_GetDisplayPrice({
            price: perUnitPrice,
            compareAtPrice: perUnitCompare,
            quantity: qty,
            multiplyByQuantity: true,
            applySubscriptionDiscount: true
          });
          var priceEl = container.querySelector('.quantity-break-price');
          var compareEl = container.querySelector('.quantity-break-original-price');
          if (priceEl) priceEl.textContent = Elixir_FormatMoney(result.price);
          if (compareEl) {
            if (result.compareAtPrice <= result.price || result.compareAtPrice <= 0) {
              compareEl.style.visibility = 'hidden';
            } else {
              compareEl.textContent = Elixir_FormatMoney(result.compareAtPrice);
              compareEl.style.visibility = 'visible';
            }
          }
          var saveBadge = container.querySelector('.quantity-break-save-badge');
          if (saveBadge) {
            var savingsCents = Math.max(0, result.compareAtPrice - result.price);
            var compareAtCents = result.compareAtPrice;
            var badgeFormat = (container.getAttribute('data-save-badge-format') || 'dollar').toLowerCase();
            var badgeText = container.getAttribute('data-save-badge-text') || 'Save';
            if (savingsCents <= 0) {
              saveBadge.style.display = 'none';
            } else {
              saveBadge.style.display = '';
              if (badgeFormat === 'percentage' && compareAtCents > 0) {
                saveBadge.textContent = badgeText + ' ' + Math.round(savingsCents * 100 / compareAtCents) + '%';
              } else {
                saveBadge.textContent = badgeText + ' ' + Elixir_FormatMoney(savingsCents);
              }
            }
          }
          var isSelected = container.querySelector('.quantity-break-option.selected');
          if (isSelected) {
            var addToCartButton = document.querySelector('.product-form__submit .button__text') || document.querySelector('.shop-add-to-cart-button .button-text') || document.querySelector('[data-add-to-cart-text]');
            if (addToCartButton) {
              var submitButton = addToCartButton.closest('button[type="submit"]') || addToCartButton.closest('.shop-add-to-cart-button');
              var hasTextOverride = submitButton && submitButton.dataset.textOverride === 'true';
              var persistentText = submitButton && submitButton.dataset.persistentText;
              var showPriceInButton = submitButton && submitButton.dataset.showPrice === 'true' || (typeof window.showPriceButton !== 'undefined' && window.showPriceButton);
              var buttonText = (hasTextOverride && persistentText) ? persistentText : (addToCartButtonText || 'Add to Cart');
              if (showPriceInButton && priceEl) {
                buttonText += ' - ' + (typeof formatMoneyWithoutSuffix === 'function' ? formatMoneyWithoutSuffix(priceEl.textContent.replace(/[^0-9.,]/g, '')) : priceEl.textContent);
                if (compareEl && result.compareAtPrice > result.price) {
                  buttonText += ' <span class="compare-price">(' + (typeof formatMoneyWithoutSuffix === 'function' ? formatMoneyWithoutSuffix(compareEl.textContent.replace(/[^0-9.,]/g, '')) : compareEl.textContent) + ')</span>';
                }
              }
              addToCartButton.innerHTML = buttonText;
            }
          }
        });
      }
      
      // Function to update simple variant picker display
      function updateSimpleVariantPickerDisplay() {
          if (!enableVariantSelection || !hasVariants || !usesCustomSelectorsForSelectedOption()) return;
        
        // Get the selected quantity break option
        var selectedOption = document.querySelector('.quantity-break-option.selected input');
