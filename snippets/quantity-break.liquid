                            {% assign show_free_gift = option_2_show_free_gift %}
                            {% assign free_gift_count = option_2_free_gift_count %}
                            {% assign free_gift_text = option_2_free_gift_text %}
                            {% assign free_gift_icon = option_2_free_gift_icon %}
                            {% assign free_gift_icon_size = option_2_free_gift_icon_size %}
                            {% assign free_gift_font_size = option_2_free_gift_font_size %}
                            {% assign free_gift_border_radius = option_2_free_gift_border_radius %}
                            {% assign free_gift_bg_color = option_2_free_gift_bg_color %}
                            {% assign free_gift_use_gradient = option_2_free_gift_use_gradient %}
                            {% assign free_gift_gradient_start = option_2_free_gift_gradient_start %}
                            {% assign free_gift_gradient_end = option_2_free_gift_gradient_end %}
                            {% assign free_gift_text_color = option_2_free_gift_text_color %}
                            {% assign free_gift_border_color = option_2_free_gift_border_color %}
                          {% when 3 %}
                            {% assign show_free_gift = option_3_show_free_gift %}
                            {% assign free_gift_count = option_3_free_gift_count %}
                            {% assign free_gift_text = option_3_free_gift_text %}
                            {% assign free_gift_icon = option_3_free_gift_icon %}
                            {% assign free_gift_icon_size = option_3_free_gift_icon_size %}
                            {% assign free_gift_font_size = option_3_free_gift_font_size %}
                            {% assign free_gift_border_radius = option_3_free_gift_border_radius %}
                            {% assign free_gift_bg_color = option_3_free_gift_bg_color %}
                            {% assign free_gift_use_gradient = option_3_free_gift_use_gradient %}
                            {% assign free_gift_gradient_start = option_3_free_gift_gradient_start %}
                            {% assign free_gift_gradient_end = option_3_free_gift_gradient_end %}
                            {% assign free_gift_text_color = option_3_free_gift_text_color %}
                            {% assign free_gift_border_color = option_3_free_gift_border_color %}
                          {% when 4 %}
                            {% assign show_free_gift = option_4_show_free_gift %}
                            {% assign free_gift_count = option_4_free_gift_count %}
                            {% assign free_gift_text = option_4_free_gift_text %}
                            {% assign free_gift_icon = option_4_free_gift_icon %}
                            {% assign free_gift_icon_size = option_4_free_gift_icon_size %}
                            {% assign free_gift_font_size = option_4_free_gift_font_size %}
                            {% assign free_gift_border_radius = option_4_free_gift_border_radius %}
                            {% assign free_gift_bg_color = option_4_free_gift_bg_color %}
                            {% assign free_gift_use_gradient = option_4_free_gift_use_gradient %}
                            {% assign free_gift_gradient_start = option_4_free_gift_gradient_start %}
                            {% assign free_gift_gradient_end = option_4_free_gift_gradient_end %}
                            {% assign free_gift_text_color = option_4_free_gift_text_color %}
                            {% assign free_gift_border_color = option_4_free_gift_border_color %}
                        {% endcase %}

                        {% assign free_gift_start_index = qty | minus: free_gift_count | plus: 1 %}
                        {% if show_free_gift and free_gift_text != blank and i >= free_gift_start_index %}
                          {% capture free_gift_bg_style %}
                            {% if free_gift_use_gradient %}
                              background: linear-gradient(135deg, {{ free_gift_gradient_start }}, {{ free_gift_gradient_end }});
                            {% else %}
                              background-color: {{ free_gift_bg_color }};
                            {% endif %}
                          {% endcapture %}
                          <div
                            class="quantity-break-free-gift-badge"
                            style="{{ free_gift_bg_style }} color: {{ free_gift_text_color }}; border: 1px solid {{ free_gift_border_color }}; font-size: {{ free_gift_font_size }}px; border-radius: {{ free_gift_border_radius }}px;"
                          >
                            {% if free_gift_icon != blank %}
                              <img
                                src="{{ free_gift_icon | image_url: width: 80 }}"
                                alt="Free gift"
                                width="{{ free_gift_icon_size }}"
                                height="{{ free_gift_icon_size }}"
                                style="width: {{ free_gift_icon_size }}px; height: {{ free_gift_icon_size }}px;"
