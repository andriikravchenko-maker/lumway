        "summary_hpMNBU": {
          "type": "listicle-summary",
          "settings": {
            "content": "<p><strong>Summary:</strong> You can now achieve professional-grade under-eye rejuvenation right from home without expensive spa treatments, painful injections, or harsh chemicals! The Eye Glow Kit is simply the <strong>most advanced</strong> (and effective) red light therapy device ever created for under-eye care. Keep reading to discover why thousands are calling it a \"game-changer\"!</p>"
          }
